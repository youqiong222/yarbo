    <script>
      (() => {
        const initFaq = () => {
          // 1. 获取所有 FAQ 块
          const faqBlocks = document.querySelectorAll('.advc-faq-with-nav-text-item__block');

          if (faqBlocks.length === 0) return;

          // 获取元素的相关子组件
          const getElements = (block) => ({
            openBtn: block.querySelector('.advc-faq-with-nav-text-item__block-open-icon'),
            closeBtn: block.querySelector('.advc-faq-with-nav-text-item__block-close-icon'),
            desc: block.querySelector('.advc-faq-with-nav-text-item__block-desc'),
          });

          // 关闭逻辑
          const closeBlock = (block) => {
            const { openBtn, closeBtn, desc } = getElements(block);
            block.setAttribute('data-open', '0');

            // 切换图标显示（通过 class 控制，确保你的 CSS 有 advc-d-none）
            if (openBtn) openBtn.classList.remove('advc-d-none');
            if (closeBtn) closeBtn.classList.add('advc-d-none');

            // 动画处理
            if (desc) {
              desc.style.height = '0px';
              desc.style.opacity = '0';
              desc.style.marginTop = '0px';
            }
          };

          // 展开逻辑
          const openBlock = (block) => {
            const { openBtn, closeBtn, desc } = getElements(block);
            block.setAttribute('data-open', '1');

            if (openBtn) openBtn.classList.add('advc-d-none');
            if (closeBtn) closeBtn.classList.remove('advc-d-none');

            if (desc) {
              // 使用 scrollHeight 获取内容真实高度实现动态拉伸
              desc.style.height = `${desc.scrollHeight}px`;
              desc.style.opacity = '1';
              // 读取 CSS 变量 --margin-top，如果没有则默认为 10px
              const marginTop = getComputedStyle(desc).getPropertyValue('--margin-top').trim() || '10px';
              desc.style.marginTop = marginTop;
            }
          };

          // 初始化状态并绑定事件
          faqBlocks.forEach((block) => {
            // 初始状态全部收起
            closeBlock(block);

            block.addEventListener('click', (e) => {
              // 如果点击的是内容区域本身，不触发收起
              if (e.target.closest('.advc-faq-with-nav-text-item__block-desc')) return;

              const isOpen = block.getAttribute('data-open') === '1';

              if (isOpen) {
                closeBlock(block);
              } else {
                // 手风琴效果：打开当前这个之前，先关闭其他所有已打开的
                faqBlocks.forEach((otherBlock) => {
                  if (otherBlock.getAttribute('data-open') === '1') {
                    closeBlock(otherBlock);
                  }
                });
                openBlock(block);
              }
            });
          });
        };

        // 确保 DOM 加载完成后执行
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initFaq);
        } else {
          initFaq();
        }
      })();
    </script>
