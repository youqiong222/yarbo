<div
  class='group/hero relative flex h-[calc(100dvh-32px)] w-full items-center overflow-hidden {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}'
  id='hero-{{ section.id }}'
>
  <div class='swiper hero-swiper absolute inset-0 z-0 h-full w-full'>
    <div class='swiper-wrapper'>
      {%- for block in section.blocks -%}
        <div
          class='swiper-slide flex h-full w-full items-center'
          data-has-product='{% if block.settings.featured_product != blank %}true{% else %}false{% endif %}'
          {{ block.shopify_attributes }}
        >
          {% if block.settings.featured_product != blank %}
            {%- assign height_class = 'absolute inset-0 w-full sm:h-full z-0 h-[calc(100%-100px)]' -%}
          {% else %}
            {%- assign height_class = 'absolute inset-0 w-full sm:h-full z-0 h-full' -%}
          {% endif %}
          {%- assign slide_loading = 'lazy' -%}
          {%- assign slide_fetchpriority = '' -%}
          {%- if forloop.first -%}
            {%- assign slide_loading = 'eager' -%}
            {%- assign slide_fetchpriority = 'high' -%}
          {%- endif -%}
          {% render 'media-element',
            class: height_class,
            media_class: 'w-full h-full object-cover',
            media_type: block.settings.media_type,
            pc_image: block.settings.pc_image,
            h5_image: block.settings.h5_image,
            pc_video: block.settings.pc_video,
            h5_video: block.settings.h5_video,
            video_url: block.settings.video_url,
            other_url: block.settings.other_url,
            img_loading: slide_loading,
            img_fetchpriority: slide_fetchpriority
          %}
          {%- render 'sn-overlay', _settings: block.settings -%}
          <div
            class='page-container relative z-10 flex h-full w-full flex-col {%- if block.settings.h5_text_position == "bottom" %} justify-end md:justify-center pb-(--h5-pb) md:pb-0{%- elsif block.settings.h5_text_position == "top" %} justify-start pt-(--h5-tp) md:justify-center  md:pt-0{%- else %} justify-center{%- endif %}'
            style='--h5-pb: {{ block.settings.h5_bottom_padding }}px; --h5-tp: {{ block.settings.h5_top_padding }}px;'
          >
            <div>
              {% if block.settings.title != blank %}
                <h2 class='mb-16 text-[40px]/[1] tracking-tight text-white uppercase sm:mb-24 sm:text-[80px]/[1]'>
                  {{ block.settings.title | newline_to_br }}
                </h2>
              {% endif %}

              {% if block.settings.description != blank %}
                <div class='md-32 mb-32 text-[12px]/[1.3] tracking-[0] text-white drop-shadow-sm transition-all delay-100 duration-700 sm:mb-40 sm:text-[18px]/[1.4]'>
                  {{ block.settings.description }}
                </div>
              {% endif %}

              {% if block.settings.button_text != blank %}
                <div>
                  <a
                    href='{{ block.settings.button_link | default: '#' }}'
                    {% if block.settings.btn_anchor_id != blank %}
                      data-anchor-id='{{ block.settings.btn_anchor_id }}'
                    {% endif %}
                    class='inline-flex h-44 items-center justify-center self-start bg-white px-24 text-[14px]/[1.4] tracking-[0] text-[#25282A] no-underline transition-colors duration-300 hover:bg-[#FEDB1E] sm:px-32'
                  >
                    {{ block.settings.button_text }}
                  </a>
                </div>
              {% endif %}

              {% if section.settings.show_subscribe and forloop.first %}
                <div class='mt-32 max-w-520 md:mt-40'>
                  {% if section.settings.subscribe_text != blank %}
                    <p class='mb-12 text-[14px] text-white md:mb-16 md:text-[18px]'>
                      {{ section.settings.subscribe_text }}
                    </p>
                  {% endif %}
                  {% render 'sn-subscribe-klaviyo',
                    emailType: section.settings.email_type,
                    klaviyoListId: section.settings.klaviyo_list_id,
                    policy_class: 'text-white',
                    popup_to_body: true
                  %}
                </div>
              {% endif %}
            </div>

            {% assign product = block.settings.featured_product %}
            {% if product != blank %}
              <a
                href='{{ product.url }}'
                class='group pointer-events-auto  absolute right-0 bottom-0 left-0 flex h-100 items-center border-b border-[#E6E6E6] bg-white p-8 text-[#25282A] no-underline transition-transform duration-300 hover:-translate-y-1 sm:right-40 sm:bottom-40 sm:left-auto sm:w-360 sm:border-0'
              >
                <div class='flex h-92 w-92 shrink-0 items-center justify-center bg-[#f2f2f2]'>
                  <img
                    src='{{ product.featured_image | image_url: width: 184 }}'
                    alt='{{ product.title | escape }}'
                    width='auto'
                    height='auto'
                    class='h-full w-full object-contain transition-transform duration-500 group-hover:scale-105'
                  >
                </div>
                <div class='flex flex-col justify-center py-8 pl-16'>
                  {% if block.settings.product_badge != blank %}
                    <span class='mb-8 inline-flex h-22 w-max items-center justify-center bg-[#FFD700] px-12 py-2 text-[12px] font-bold'>
                      {{ block.settings.product_badge }}
                    </span>
                  {% endif %}
                  <h3 class='line-clamp-2 text-[22px]/[1.1] uppercase'>
                    {{ product.title }}
                  </h3>
                </div>
              </a>
            {% endif %}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
  {% if section.blocks.size > 1 %}
    <div class='page-container'>
      <div class='hero-nav pointer-events-none absolute bottom-16 z-20 sm:bottom-40'>
        <div class='pointer-events-auto mx-auto flex max-w-7xl flex-col items-start justify-between gap-6 sm:flex-row sm:items-end'>
          <div class='flex h-52 items-center space-x-4 rounded-full bg-[#cccccc]/40 px-20 backdrop-blur-[5px]'>
            <span class='hero-prev flex shrink-0 cursor-pointer sm:mr-32'>
              <svg
                style='scale: -1;'
                width='20'
                height='20'
                viewBox='0 0 20 20'
                fill='none'
                xmlns='http://www.w3.org/2000/svg'
              >
                <path d="M7.50004 4.16669L13.3334 10L7.50004 15.8334" stroke="white" stroke-width="2" stroke-linecap="square"/>
              </svg>
            </span>

            <div class='hero-pagination flex items-center space-x-3'></div>

            <span class='hero-next flex shrink-0 cursor-pointer sm:ml-32'>
              <svg
                width='20'
                height='20'
                viewBox='0 0 20 20'
                fill='none'
                xmlns='http://www.w3.org/2000/svg'
              >
                <path d="M7.50004 4.16669L13.3334 10L7.50004 15.8334" stroke="white" stroke-width="2" stroke-linecap="square"/>
              </svg>
            </span>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>

<script>
  (() => {
    const sectionElement = document.querySelector(
      '#shopify-section-{{ section.id }}',
    );
    if (!sectionElement) return;

    const heroSwiperElement = sectionElement.querySelector('.hero-swiper');

    const heroNavEl = sectionElement.querySelector('.hero-nav');

    function updateNavBottom(swiper) {
      if (!heroNavEl) return;
      const slides = heroSwiperElement.querySelectorAll('.swiper-slide:not(.swiper-slide-duplicate)');
      const index = swiper.realIndex;
      const hasProduct = slides[index] && slides[index].dataset.hasProduct === 'true';
      heroNavEl.classList.toggle('bottom-132', hasProduct);
      heroNavEl.classList.toggle('bottom-16', !hasProduct);
    }

    if (heroSwiperElement) {
      const heroSwiper = new Swiper(heroSwiperElement, {
        loop: {%- if section.blocks.size > 1 %}true{% else %}false{%- endif %},
        allowTouchMove: {%- if section.blocks.size > 1 %}true{% else %}false{%- endif %},
        effect: 'fade',
        fadeEffect: {
          crossFade: true,
        },
        {%- if section.settings.auto_rotate %}
        autoplay: { delay: {{ section.settings.change_slides_speed | times: 1000 }}, disableOnInteraction: false },
        {% endif -%}
        navigation: {
          nextEl: sectionElement.querySelector('.hero-next'),
          prevEl: sectionElement.querySelector('.hero-prev'),
        },
        pagination: {
          el: sectionElement.querySelector('.hero-pagination'),
          clickable: true,
          renderBullet: function (index, className) {
            const bulletClasses = `
              ${className}
              rounded-none
              w-8 h-8 bg-[#CCCCCC] transition-all duration-300 block cursor-pointer m-0
              hover:bg-white
              [&.swiper-pagination-bullet-active]:w-50 [&.swiper-pagination-bullet-active]:h-8 [&.swiper-pagination-bullet-active]:bg-[#FEDB1E]
            `;
            return `<span class="${bulletClasses.trim().replace(/\s+/g, ' ')}"></span>`;
          },
        },
        on: {
          init: updateNavBottom,
          slideChange: updateNavBottom,
        },
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Hero Slider",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    {
      "type": "header",
      "content": "Global Featured Product"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    },
    {
      "type": "header",
      "content": "Subscribe Settings"
    },
    {
      "type": "text",
      "id": "email_type",
      "label": "Email Type"
    },
    {
      "type": "text",
      "id": "klaviyo_list_id",
      "label": "Klaviyo List ID"
    },
    {
      "type": "checkbox",
      "id": "show_subscribe",
      "label": "Show Subscribe",
      "default": false
    },
    {
      "type": "text",
      "id": "subscribe_text",
      "label": "Subscribe Text",
      "default": "Be the first to know when M Series launches:"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "product",
          "id": "featured_product",
          "label": "Select Product"
        },
        {
          "type": "text",
          "id": "product_badge",
          "label": "Product Badge Text",
          "default": "For All Seasons"
        },
        {
          "type": "header",
          "content": "Media Settings"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Shopify Video"
            },
            {
              "value": "video_url",
              "label": "External Video URL"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "pc_image",
          "label": "PC Image"
        },
        {
          "type": "image_picker",
          "id": "h5_image",
          "label": "H5 Image"
        },
        {
          "type": "video",
          "id": "pc_video",
          "label": "PC Shopify Video"
        },
        {
          "type": "video",
          "id": "h5_video",
          "label": "H5 Shopify Video(Optional)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Platform Video URL (YouTube/Vimeo)",
          "accept": ["youtube", "vimeo"],
          "default": "https://www.youtube.com/watch?v=NpEaa2P7qZI"
        },
        {
          "type": "text",
          "id": "other_url",
          "label": "Other Video URL",
          "info": "ex: xxx.mp4 (If filled, this takes priority over the Platform Video URL)"
        },
        {
          "type": "header",
          "content": "Overlay Settings"
        },
        {
          "type": "checkbox",
          "id": "show_overlay",
          "label": "Show Media Overlay",
          "default": false
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay Opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 40
        },
        {
          "type": "header",
          "content": "Content Settings"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        },
        {
          "type": "text",
          "id": "btn_anchor_id",
          "label": "Button Anchor Id"
        },
        {
          "type": "select",
          "id": "h5_text_position",
          "label": "H5 Text Position",
          "default": "center",
          "options": [
            { "value": "top", "label": "Top" },
            { "value": "center", "label": "Center" },
            { "value": "bottom", "label": "Bottom" }
          ]
        },
        {
          "type": "range",
          "id": "h5_bottom_padding",
          "label": "H5 Bottom Padding (when Bottom)",
          "min": 0,
          "max": 200,
          "step": 4,
          "unit": "px",
          "default": 80
        },
        {
          "type": "range",
          "id": "h5_top_padding",
          "label": "H5 Top Padding (when Top)",
          "min": 0,
          "max": 200,
          "step": 4,
          "unit": "px",
          "default": 80
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "title": "<p>ONE YARD.<br/>MANY MODULES.<br/>ALL SEASONS.</p>",
            "description": "<p>Transform your yard year-round with Yarbo’s versatile modules. </p><p>From snow to grass, every season is effortless, smart, and </p><p>completely under your control.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
