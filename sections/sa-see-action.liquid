<style>
    @media (max-width: 999px) {
    #shopify-section-{{ section.id }} .page-container{
      padding:0;
    }
  }
</style>
{% render 'section-padding', section_id: section.id, settings: section.settings %}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}

{%- liquid
  assign s = section.settings

  assign pc_w = s.pc_aspect_ratio_w | default: 16
  assign pc_h = s.pc_aspect_ratio_h | default: 9
  assign pc_ratio = pc_w | append: '/' | append: pc_h

  assign h5_w = s.h5_aspect_ratio_w | default: 16
  assign h5_h = s.h5_aspect_ratio_h | default: 9
  assign h5_ratio = h5_w | append: '/' | append: h5_h
-%}
<div class='overflow-hidden {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}'>
  <div class='page-container'>
    <div class='mb-32 md:mb-40'>
      {% if section.settings.title != blank %}
        <h2 class='text-center text-[36px] leading-[1.1] uppercase md:text-[52px]'>
          {{ section.settings.title }}
        </h2>
      {% endif %}
    </div>
    {% if section.blocks.size > 0 %}
      <div
        style='
          --media-aspect-pc: {{ pc_ratio }};
          --media-aspect-h5: {{ h5_ratio }};
        '
        class='
          swiper
          media-swiper
          relative
        '
      >
        <div class='swiper-wrapper'>
          {% for block in section.blocks %}
            <div
              class='
                swiper-slide aspect-(--media-aspect-h5)  h-auto!
                md:aspect-(--media-aspect-pc)
              '
            >
              {% render 'media-element',
                class: 'absolute inset-0 w-full h-full',
                media_class: 'w-full h-full object-cover',
                media_type: block.settings.media_type,
                pc_image: block.settings.pc_image,
                h5_image: block.settings.h5_image,
                pc_video: block.settings.pc_video,
                h5_video: block.settings.h5_video,
                video_url: block.settings.video_url,
                other_url: block.settings.other_url
              %}
              {%- render 'sn-overlay', _settings: block.settings -%}
              <div class='absolute left-0 z-1 flex h-full w-full flex-col justify-end gap-12 px-16 py-32 text-white md:max-w-480 md:gap-16 md:p-40'>
                <h4 class='text-[32px] leading-[1.1] uppercase'>
                  {{ block.settings.title }}
                </h4>
                <div class='text-[16px] leading-[1.3] md:text-[18px]'>
                  {{ block.settings.desc }}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
        <div class='m-auto mt-24 flex w-fit items-center gap-32  rounded-[100px] bg-[#CCCCCC66] px-20 py-16 md:mt-40 md:px-24'>
          <div class='swiper-button-prev  static m-0 flex h-20 w-20 items-center justify-center rounded-full border border-none transition-colors duration-300 after:hidden [&.swiper-button-disabled]:opacity-100 [&.swiper-button-disabled_path]:stroke-[#A6A6A6]'>
            <svg
              width='20'
              height='20'
              viewBox='0 0 20 20'
              fill='none'
              xmlns='http://www.w3.org/2000/svg'
            >
              <path d="M12.5013 15.833L6.66797 9.99967L12.5013 4.16634" stroke="#25282a" stroke-width="2" stroke-linecap="square"/>
            </svg>
          </div>
          <div
            class='hero-pagination flex w-fit items-center justify-center space-x-3'
          ></div>
          <div class='swiper-button-next static m-0 flex h-20 w-20 items-center justify-center rounded-full border  border-none transition-colors duration-300 after:hidden [&.swiper-button-disabled]:opacity-100 [&.swiper-button-disabled_path]:stroke-[#A6A6A6]'>
            <svg
              width='20'
              height='20'
              viewBox='0 0 20 20'
              fill='none'
              xmlns='http://www.w3.org/2000/svg'
            >
              <path d="M7.4987 4.16699L13.332 10.0003L7.4987 15.8337" stroke="#25282A" stroke-width="2" stroke-linecap="square"/>
            </svg>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>
<script>
  (() => {
    new Swiper('#shopify-section-{{ section.id }} .swiper', {
      observer: true,
      observeParents: true,
      spaceBetween: 20,
      slidesPerView: 1,
      {% if section.settings.auto_rotate %}
      autoplay: { delay: {{ section.settings.change_slides_speed | times: 1000 }}, disableOnInteraction: false },
      {% endif %}
      navigation: {
        nextEl: '#shopify-section-{{ section.id }} .swiper-button-next',
        prevEl: '#shopify-section-{{ section.id }} .swiper-button-prev',
      },
      pagination: {
        el: '#shopify-section-{{ section.id }} .hero-pagination',
        clickable: true,
        renderBullet: function (index, className) {
          const bulletClasses = `
                ${className}
                rounded-none opacity-100
                w-8 h-8 bg-[#CCCCCC] transition-all duration-300 block cursor-pointer m-0
                hover:bg-white
                [&.swiper-pagination-bullet-active]:w-50 [&.swiper-pagination-bullet-active]:h-8 [&.swiper-pagination-bullet-active]:bg-[#25282a]
              `;
          return `<span class="${bulletClasses.trim().replace(/\s+/g, ' ')}"></span>`;
        },
      },
    });
  })();
</script>
{% schema %}
{
  "name": "See Action",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor Id"
    },
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_top",
      "label": "H5 Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_bottom",
      "label": "H5 Padding Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Media Aspect Ratio"
    },
    {
      "type": "number",
      "id": "pc_aspect_ratio_w",
      "label": "PC Ratio Width"
    },
    {
      "type": "number",
      "id": "pc_aspect_ratio_h",
      "label": "PC Ratio Height"
    },
    {
      "type": "number",
      "id": "h5_aspect_ratio_w",
      "label": "Mobile Ratio Width"
    },
    {
      "type": "number",
      "id": "h5_aspect_ratio_h",
      "label": "Mobile Ratio Height"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    }
  ],
  "blocks": [
    {
      "name": "block",
      "type": "Block",
      "settings": [
        {
          "type": "header",
          "content": "Media Settings"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Shopify Video"
            },
            {
              "value": "video_url",
              "label": "External Video URL"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "pc_image",
          "label": "PC Image"
        },
        {
          "type": "image_picker",
          "id": "h5_image",
          "label": "H5 Image"
        },
        {
          "type": "video",
          "id": "pc_video",
          "label": "PC Shopify Video"
        },
        {
          "type": "video",
          "id": "h5_video",
          "label": "H5 Shopify Video(Optional)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Platform Video URL (YouTube/Vimeo)",
          "accept": ["youtube", "vimeo"],
          "default": "https://www.youtube.com/watch?v=NpEaa2P7qZI"
        },
        {
          "type": "text",
          "id": "other_url",
          "label": "Other Video URL",
          "info": "ex: xxx.mp4 (If filled, this takes priority over the Platform Video URL)"
        },
        {
          "type": "header",
          "content": "Overlay Settings"
        },
        {
          "type": "checkbox",
          "id": "show_overlay",
          "label": "Show Media Overlay",
          "default": false
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay Opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 40
        },
        {
          "type": "header",
          "content": "Content Settings"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "desc",
          "label": "Desc"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "See Action",
      "settings": {
        "title": "<p>See It In Action</p>",
        "auto_rotate": true,
        "change_slides_speed": 5
      },
      "blocks": [
        {
          "type": "Block",
          "settings": {
            "title": "<p>Powerful Performance</p>",
            "desc": "<p>Experience next-level efficiency in every task.</p>"
          }
        },
        {
          "type": "Block",
          "settings": {
            "title": "<p>Smart Automation</p>",
            "desc": "<p>Let technology handle the heavy lifting.</p>"
          }
        },
        {
          "type": "Block",
          "settings": {
            "title": "<p>All Terrain Ready</p>",
            "desc": "<p>Designed to perform in any environment.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
