          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Flexible Payment Options",
            "desc": "Delivered in 3-7 days"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "30-Day Free Returns",
            "desc": "Delivered in 3-7 days"
          }
        },
        {
          "type": "item",
          "settings": {
            "title": "Comprehensive Warranty",
            "desc": "Delivered in 3-7 days"
          }
        },
        {
          "type": "item",
          "settings": {
