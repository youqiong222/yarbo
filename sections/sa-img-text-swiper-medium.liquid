{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
{%- liquid
  assign s = section.settings
  assign pc_w = s.pc_aspect_ratio_w | default: 16
  assign pc_h = s.pc_aspect_ratio_h | default: 9
  assign pc_ratio = pc_w | append: '/' | append: pc_h
  assign h5_w = s.h5_aspect_ratio_w | default: 16
  assign h5_h = s.h5_aspect_ratio_h | default: 9
  assign h5_ratio = h5_w | append: '/' | append: h5_h
-%}
<div
  style='
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    --h5-padding-top: {{ section.settings.h5_padding_top }}px;
    --h5-padding-bottom: {{ section.settings.h5_padding_bottom }}px;
    --bg_color: {{ section.settings.bg_color }};
  '
  class='
    bg-(--bg_color)
    pt-(--h5-padding-top)
    pb-(--h5-padding-bottom)
    md:pt-(--padding-top)
    md:pb-(--padding-bottom) {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}
  '
>
  <div class='overflow-hidden'>
    <div class='page-container'>
      <div class='mb-32 md:mb-40'>
        {% if section.settings.title != blank %}
          <h2 class='text-center text-[32px] leading-[1.1] uppercase md:text-[52px]'>
            {{ section.settings.title }}
          </h2>
        {% endif %}
      </div>
      {% if section.blocks.size > 0 %}
        <div class='mx-auto max-w-880'>
          <div
            style='
              --media-aspect-pc: {{ pc_ratio }};
              --media-aspect-h5: {{ h5_ratio }};
            '
            class='
              swiper
              [overflow:unset]
            '
          >
            <div class='swiper-wrapper'>
              {% for block in section.blocks %}
                <div class='swiper-slide h-auto!'>
                  <div
                    class='
                      relative
                      aspect-(--media-aspect-h5)
                      md:aspect-(--media-aspect-pc)
                    '
                  >
                    {% render 'media-element',
                      class: 'absolute inset-0 w-full h-full',
                      media_class: 'w-full h-full object-cover',
                      media_type: block.settings.media_type,
                      pc_image: block.settings.pc_image,
                      h5_image: block.settings.h5_image,
                      pc_video: block.settings.pc_video,
                      h5_video: block.settings.h5_video,
                      video_url: block.settings.video_url,
                      other_url: block.settings.other_url
                    %}
                    {%- render 'sn-overlay', _settings: block.settings -%}
                  </div>
                  <div class='relative z-10 mt-12 max-w-660'>
                    <h3 class='text-[13px] leading-[1.3] font-bold md:text-[14px]'>
                      {{ block.settings.title }}
                    </h3>
                    <div class='mt-2 text-[13px] font-[500] text-[#515355] md:text-[14px]'>
                      {{ block.settings.desc }}
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
  (() => {
    new Swiper('#shopify-section-{{ section.id }} .swiper', {
      slidesPerView: 1.1,
      spaceBetween: 12,
      centeredSlides: true,
      loop: true,
      breakpoints: {
        768: {
          spaceBetween: 24,
          slidesPerView: 1,
        },
      },
      {%- if section.settings.auto_rotate %}
      autoplay: { delay: {{ section.settings.change_slides_speed | times: 1000 }}, disableOnInteraction: false },
      {% endif -%}
    });
  })();
</script>
{% schema %}
{
  "name": "Img Text Swiper Medium",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor Id"
    },
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
