<div
  class='flex flex-col-reverse  bg-[#f2f2f2] md:flex-row'
>
  <div class='flex flex-1 flex-col justify-between px-16 py-24 md:pr-60 md:pl-40  lg:pl-[calc(50%-660px)]'>
    <div class='mb-24 flex items-center gap-6 text-[12px] leading-[1.3] md:text-[14px]'>
      <span>{{ 'navigation.home' | t }}</span>
      <svg
        width='5'
        height='7'
        viewBox='0 0 5 7'
        fill='none'
        xmlns='http://www.w3.org/2000/svg'
      >
        <path d="M0.919596 0.919235L3.25293 3.25257L0.919596 5.5859" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
      </svg>
      <span>{{ collection.title }}</span>
    </div>
    <div>
      <h2 class=' text-[32px]  leading-none uppercase  md:text-[44px] '>
        {{ section.settings.title }}
      </h2>
      <div class='mt-12 text-[14px] leading-[1.3] text-[#515355]'>
        {{ section.settings.text }}
      </div>
    </div>
    <div class='mt-32 flex flex-wrap gap-x-16 gap-y-8 border-t border-[#cccccc] pt-12 md:pt-16'>
      {% for block in section.blocks %}
        <div class='flex items-center gap-4'>
          {% render 'media-element', media_type: 'image', media_class: 'w-full h-full object-cover max-w-16', pc_image: block.settings.icon %}
          <div class='text-[14px] leading-[1.3] font-bold text-[#515355]'>
            {{ block.settings.text }}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <div
    class='md:w-[50%]'
  >
    {%- liquid
      assign s = section.settings
      assign pc_w = s.pc_aspect_ratio_w | default: 16
      assign pc_h = s.pc_aspect_ratio_h | default: 10
      assign pc_ratio = pc_w | append: '/' | append: pc_h
      assign h5_w = s.h5_aspect_ratio_w | default: 16
      assign h5_h = s.h5_aspect_ratio_h | default: 10
      assign h5_ratio = h5_w | append: '/' | append: h5_h
    -%}
    <div
      style='
        --media-aspect-pc: {{ pc_ratio }};
        --media-aspect-h5: {{ h5_ratio }};
      '
      class='
        relative aspect-(--media-aspect-h5) w-full
        overflow-hidden md:aspect-(--media-aspect-pc)
      '
    >
      {% render 'media-element',
        class: 'absolute inset-0 w-full h-full',
        media_class: 'w-full h-full object-cover',
        media_type: section.settings.media_type,
        pc_image: section.settings.pc_image,
        h5_image: section.settings.h5_image,
        pc_video: section.settings.pc_video,
        h5_video: section.settings.h5_video,
        video_url: section.settings.video_url,
        other_url: section.settings.other_url
      %}
      {%- render 'sn-overlay', _settings: section.settings -%}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Collection banner",

  "tag": "section",
  "class": "tailwind-layout",
  "settings": [
    {
      "type": "richtext",
      "id": "title",
      "label": "Label",
      "default": "<p>Collection</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "text"
    },
    {
      "type": "header",
      "content": "Media Settings"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media Type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Shopify Video"
        },
        {
          "value": "video_url",
          "label": "External Video URL"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "pc_image",
      "label": "PC Image"
    },
    {
      "type": "image_picker",
      "id": "h5_image",
      "label": "H5 Image"
    },
    {
      "type": "video",
      "id": "pc_video",
      "label": "PC Shopify Video"
    },
    {
      "type": "video",
      "id": "h5_video",
      "label": "H5 Shopify Video(Optional)"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "Platform Video URL (YouTube/Vimeo)",
      "accept": ["youtube", "vimeo"],
      "default": "https://www.youtube.com/watch?v=NpEaa2P7qZI"
    },
    {
      "type": "text",
      "id": "other_url",
      "label": "Other Video URL",
      "info": "ex: xxx.mp4 (If filled, this takes priority over the Platform Video URL)"
    },
    {
      "type": "header",
      "content": "Overlay Settings"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show Media Overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection banner",
      "settings": {}
    }
  ]
}
{% endschema %}
