{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}

{%- liquid
  assign s = section.settings

  assign pc_w = s.pc_aspect_ratio_w | default: 16
  assign pc_h = s.pc_aspect_ratio_h | default: 9
  assign pc_ratio = pc_w | append: '/' | append: pc_h

  assign h5_w = s.h5_aspect_ratio_w | default: 16
  assign h5_h = s.h5_aspect_ratio_h | default: 9
  assign h5_ratio = h5_w | append: '/' | append: h5_h
-%}

<div
  class='overflow-hidden {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %} bg-(--bg-color) pt-(--pt-h5) pb-(--pb-h5) md:pt-(--pt-pc) md:pb-(--pb-pc)'
  style='
    --pt-pc: {{ s.padding_top }}px;
    --pb-pc: {{ s.padding_bottom }}px;
    --pt-h5: {{ s.h5_padding_top }}px;
    --pb-h5: {{ s.h5_padding_bottom }}px;
    --bg-color: {{ s.bg_color }};
    --title-color: {{ s.title_color }};
    --text-color: {{ s.text_color }};
  '
>
  <div class='page-container'>
    <header class='flex items-end justify-between gap-16'>
      {% if s.title != blank %}
        <h2 class='text-[26px] leading-[1.1] text-(--title-color) uppercase md:text-[32px]'>
          {{ s.title }}
        </h2>
      {% endif %}

      {% if section.blocks.size > 1 %}
        <div class='hidden items-center gap-8 md:flex'>
          <div class='swiper-button-prev static m-0 flex h-48 w-48 cursor-pointer items-center justify-center rounded-full border border-[#cccccc] bg-white transition-colors duration-300 after:hidden [&.swiper-button-disabled]:bg-[#e3e3e3] [&.swiper-button-disabled]:opacity-100 [&.swiper-button-disabled_path]:stroke-[#A6A6A6] [&:hover]:bg-[#f2f2f2]'>
            <svg
              width='8'
              height='14'
              viewBox='0 0 8 14'
              fill='none'
              xmlns='http://www.w3.org/2000/svg'
            >
              <path d="M6.75325 12.5859L0.919923 6.7526L6.75325 0.91927" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
            </svg>
          </div>

          <div class='swiper-button-next static m-0 flex h-48 w-48 cursor-pointer items-center justify-center rounded-full border border-[#cccccc] bg-white transition-colors duration-300 after:hidden [&.swiper-button-disabled]:bg-[#e3e3e3] [&.swiper-button-disabled]:opacity-100 [&.swiper-button-disabled_path]:stroke-[#A6A6A6] [&:hover]:bg-[#f2f2f2]'>
            <svg
              width='8'
              height='14'
              viewBox='0 0 8 14'
              fill='none'
              xmlns='http://www.w3.org/2000/svg'
            >
              <path d="M0.91862 0.919434L6.75195 6.75277L0.91862 12.5861" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
            </svg>
          </div>
        </div>
      {% endif %}
    </header>

    <div class='mt-24 md:mt-32'>
      <div class='swiper [overflow:unset]'>
        <div class='swiper-wrapper'>
          {% for block in section.blocks %}
            {%- assign cover = block.settings.video_cover -%}
            {%- assign cover_mobile = block.settings.h5_video_cover | default: cover -%}
            {%- assign selected_product = block.settings.product -%}

            <div class='swiper-slide h-auto'>
              <article
                x-data='{ open: false }'
                class='flex h-full flex-col'
                data-block-id='{{ block.id }}'
                {{ block.shopify_attributes }}
              >
                <div
                  style='
                    --media-aspect-pc: {{ pc_ratio }};
                    --media-aspect-h5: {{ h5_ratio }};
                  '
                  class='relative aspect-(--media-aspect-h5) overflow-hidden rounded-[4px] md:aspect-(--media-aspect-pc)'
                >
                  <div class='absolute inset-0 z-10 bg-black/5'>
                    {% if cover != blank %}
                      <picture>
                        <source
                          media='(max-width: 768px)'
                          srcset='{{ cover_mobile | image_url: width: 750 }}'
                        >
                        <img
                          src='{{ cover | image_url }}'
                          alt='{{ cover.alt | escape }}'
                          width='auto'
                          height='auto'
                          class='h-full w-full object-cover'
                        >
                      </picture>
                    {% else %}
                      <div class='flex h-full w-full items-center justify-center bg-[#d9d9d9] text-[#8a8a8a]'>
                        {{ 'lifestyle-1' | placeholder_svg_tag: 'h-full w-full object-cover' }}
                      </div>
                    {% endif %}
                  </div>

                  <button
                    type='button'
                    @click="window.dispatchEvent(new CustomEvent('sa-img-swiper-videos:open', { detail: '{{ block.id }}' })); open = true"
                    class='absolute inset-0 z-20 flex cursor-pointer items-center justify-center border-0 bg-transparent p-0'
                    aria-label='Play video'
                  >
                    <span class='relative flex h-60 w-60 items-center justify-center overflow-hidden rounded-full border border-[#CCCCCC] bg-[#FFFFFF]'>
                      <svg
                        width='16'
                        height='20'
                        viewBox='0 0 16 20'
                        fill='none'
                        xmlns='http://www.w3.org/2000/svg'
                      >
                        <path d="M13.7162 8.69343C15.0583 9.43376 15.0632 10.3651 13.7162 11.2021L3.30845 18.1504C2.00073 18.8412 1.11256 18.4334 1.01933 16.9385L0.975165 2.39583C0.945723 1.0189 2.09151 0.629867 3.18332 1.29004L13.7162 8.69343Z" fill="#25282A" stroke="#25282A" stroke-width="1.95" stroke-linecap="square"/>
                      </svg>
                    </span>
                  </button>

                  {% if selected_product != blank %}
                    <a
                      href='{{ selected_product.url }}'
                      class='absolute top-12 right-12 z-30 flex h-40 w-40 items-center justify-center rounded-full bg-[#FFFFFFD9] text-[#25282A] no-underline transition-colors duration-300 hover:bg-white md:top-16 md:right-16'
                      aria-label='View product details'
                    >
                      <svg
                        width='40'
                        height='40'
                        viewBox='0 0 40 40'
                        fill='none'
                        xmlns='http://www.w3.org/2000/svg'
                      >
                        <foreignObject x="-5" y="-5" width="50" height="50"><div xmlns="http://www.w3.org/1999/xhtml" style="backdrop-filter:blur(2.5px);clip-path:url(#bgblur_0_11436_5842_clip_path);height:100%;width:100%"></div></foreignObject><g data-figma-bg-blur-radius="5">
                        <rect width="40" height="40" rx="20" fill="#CCCCCC" fill-opacity="0.4"/>
                        <path d="M22.5927 18.332V15.832C22.5927 14.4487 21.4347 13.332 20.0001 13.332C18.5656 13.332 17.4076 14.4487 17.4076 15.832V18.332M14.815 16.6654H25.1853L25.9261 26.6654H14.0742L14.815 16.6654Z" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
                        </g>
                        <defs>
                        <clipPath id="bgblur_0_11436_5842_clip_path" transform="translate(5 5)"><rect width="40" height="40" rx="20"/>
                        </clipPath></defs>
                      </svg>
                    </a>
                  {% endif %}
                </div>

                <template x-teleport='body'>
                  <div
                    class='css-reset tailwind-layout sa-img-swiper-videos-modal-{{ section.id }}'
                    x-on:sa-img-swiper-videos:open.window="if ($event.detail !== '{{ block.id }}') open = false"
                  >
                    <div
                      x-cloak
                      x-show='open'
                      x-transition.opacity.duration.300ms
                      class='fixed inset-0 z-50 flex items-center justify-center bg-[#25282A]/80'
                    >
                      <div
                        @click.outside="open = false; window.dispatchEvent(new CustomEvent('sa-img-swiper-videos:close', { detail: '{{ block.id }}' }))"
                        x-transition.scale.95.duration.300ms
                        class='relative mx-4 aspect-video w-full max-w-960 bg-black'
                      >
                        <button
                          @click="open = false; window.dispatchEvent(new CustomEvent('sa-img-swiper-videos:close', { detail: '{{ block.id }}' }))"
                          class='absolute -top-12 right-0 z-10 flex h-40 w-40 cursor-pointer items-center justify-center rounded-full border-0 bg-white text-black hover:bg-gray-100 md:-right-12'
                          aria-label='Close video'
                        >
                          <svg
                            width='12'
                            height='12'
                            viewBox='0 0 12 12'
                            fill='none'
                            xmlns='http://www.w3.org/2000/svg'
                          >
                            <path d="M10.918 0.919237L0.917969 10.9192M10.918 10.9192L0.917969 0.919235" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
                          </svg>
                        </button>

                        {% render 'media-element',
                          class: 'absolute inset-0 z-0 h-[calc(100%-100px)] w-full sm:h-full',
                          media_class: 'h-full w-full object-cover',
                          media_type: block.settings.media_type,
                          pc_video: block.settings.pc_video,
                          h5_video: block.settings.h5_video,
                          video_url: block.settings.video_url,
                          other_url: block.settings.other_url,
                          controls: true,
                          muted: false,
                          is_modal: true
                        %}
                      </div>
                    </div>
                  </div>
                </template>
              </article>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const sectionElement = document.querySelector(
      '#shopify-section-{{ section.id }}',
    );
    if (!sectionElement) return;

    const swiperElement = sectionElement.querySelector('.swiper');

    if (!swiperElement) return;

    const swiper = new Swiper(swiperElement, {
      observer: true,
      observeParents: true,
      spaceBetween: 12,
      slidesPerView: 1.15,
      breakpoints: {
        768: {
          spaceBetween: 24,
          slidesPerView: 2.2,
        },
        {% if section.blocks.size == 2 %}
          1000: {
            spaceBetween: 24,
            slidesPerView: 2,
          },
        {% elsif section.blocks.size == 3 %}
          1000: {
            spaceBetween: 24,
            slidesPerView: 3,
          },
        {% elsif section.blocks.size > 3 %}
          1000: {
            spaceBetween: 24,
            slidesPerView: 3.3,
          },
        {% endif %}
      },
      navigation: {
        nextEl: '#shopify-section-{{ section.id }} .swiper-button-next',
        prevEl: '#shopify-section-{{ section.id }} .swiper-button-prev',
      },
      on: {
        slideChangeTransitionStart() {
          pauseAllModalMedia();
        },
      },
    });
  })();
</script>

{% schema %}
{
  "name": "Img Swiper Videos",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor Id"
    },
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 80
    },
    {
      "type": "number",
      "id": "h5_padding_top",
      "label": "H5 Padding Top",
      "default": 56
    },
    {
      "type": "number",
      "id": "h5_padding_bottom",
      "label": "H5 Padding Bottom",
      "default": 56
    },
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "WATCH OUR KOLS"
    },
    {
      "type": "header",
      "content": "Color Settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fff"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#25282A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#515355"
    },
    {
      "type": "header",
      "content": "Media Aspect Ratio"
    },
    {
      "type": "number",
      "id": "pc_aspect_ratio_w",
      "label": "PC Ratio Width",
      "default": 16
    },
    {
      "type": "number",
      "id": "pc_aspect_ratio_h",
      "label": "PC Ratio Height",
      "default": 9
    },
    {
      "type": "number",
      "id": "h5_aspect_ratio_w",
      "label": "Mobile Ratio Width",
      "default": 16
    },
    {
      "type": "number",
      "id": "h5_aspect_ratio_h",
      "label": "Mobile Ratio Height",
      "default": 9
    }
  ],
  "blocks": [
    {
      "name": "Video",
      "type": "video",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "header",
          "content": "Cover Settings"
        },
        {
          "type": "image_picker",
          "id": "video_cover",
          "label": "Video Cover"
        },
        {
          "type": "image_picker",
          "id": "h5_video_cover",
          "label": "Mobile Video Cover"
        },
        {
          "type": "header",
          "content": "Video Settings"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type",
          "options": [
            {
              "value": "video",
              "label": "Shopify Video"
            },
            {
              "value": "video_url",
              "label": "External Video URL"
            }
          ],
          "default": "video"
        },
        {
          "type": "video",
          "id": "pc_video",
          "label": "PC Shopify Video"
        },
        {
          "type": "video",
          "id": "h5_video",
          "label": "H5 Shopify Video(Optional)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Platform Video URL (YouTube/Vimeo)",
          "accept": ["youtube", "vimeo"],
          "default": "https://www.youtube.com/watch?v=NpEaa2P7qZI"
        },
        {
          "type": "text",
          "id": "other_url",
          "label": "Other Video URL",
          "info": "ex: xxx.mp4 (If filled, this takes priority over the Platform Video URL)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Img Swiper Videos",
      "blocks": [
        {
          "type": "video"
        },
        {
          "type": "video"
        },
        {
          "type": "video"
        }
      ]
    }
  ]
}
{% endschema %}
