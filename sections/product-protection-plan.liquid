<style>
  #shopify-section-{{ section.id }} .yarbo-detailed-text-display-main-box {
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .yarbo-detailed-text-list {
    display: flex;
    width: 100%;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 24px;
  }
  #shopify-section-{{ section.id }} p {
    margin: 16px 0;
  }
  #shopify-section-{{ section.id }} h4 {
    margin: 24px 0 16px;
    font-size: 24px;
  }
  #shopify-section-{{ section.id }} li {
    margin: 8px 0;
  }
  #shopify-section-{{ section.id }} h4:first-child {
    margin-top: 0;
  }
  #shopify-section-{{ section.id }} .yarbo-detailed-text-one {
    width: 100%;
  }

  /* 375-679px */
  @media (max-width: 679px) {
    #shopify-section-{{ section.id }} .yarbo-detailed-text-display-main-box {
      max-width: calc(100% - 2 * 16px);
      margin-top: 32px;
    }
  #shopify-section-{{ section.id }} h4 {
    margin: 16px 0 8px;
    font-size: 16px;
  }
    #shopify-section-{{ section.id }} .yarbo-detailed-text-one {
      padding: 24px 16px;
      border-radius: 16px;
      overflow: hidden;
    }

    #shopify-section-{{ section.id }} .yarbo-detailed-text {
      font-size: 14px;
      font-weight: 400;
    }
  }

  /* 680-959px */
  @media (min-width: 680px) and (max-width: 959px) {
    #shopify-section-{{ section.id }} .yarbo-detailed-text-display-main-box {
      max-width: calc(100% - 2 * 24px);
      margin-top: 48px;
    }

    #shopify-section-{{ section.id }} .yarbo-detailed-text-one {
      padding: 32px;
      border-radius: 16px;
    }

    #shopify-section-{{ section.id }} .yarbo-detailed-text {
      font-size: 14px;
      font-weight: 400;
    }
  }

  /* 960-1439px */
  @media (min-width: 960px) and (max-width: 1439px) {
    #shopify-section-{{ section.id }} .yarbo-detailed-text-display-main-box {
      max-width: 900px;
      margin-top: 48px;
    }

    #shopify-section-{{ section.id }} .yarbo-detailed-text-one {
      padding: 40px;
      border-radius: 16px;
    }

    #shopify-section-{{ section.id }} .yarbo-detailed-text {
      font-size: 16px;
      font-weight: 400;
    }
  }

  /* 1440-1919px */
  @media (min-width: 1440px) and (max-width: 1919px) {
    #shopify-section-{{ section.id }} .yarbo-detailed-text-display-main-box {
      max-width: 1320px;
      margin-top: 56px;
    }

    #shopify-section-{{ section.id }} .yarbo-detailed-text-one {
      padding: 56px;
      border-radius: 16px;
    }

    #shopify-section-{{ section.id }} .yarbo-detailed-text {
      font-size: 16px;
      font-weight: 400;
    }
  }

  /* 1920px+ default*/
  @media (min-width: 1920px) {
    #shopify-section-{{ section.id }} .yarbo-detailed-text-display-main-box {
      max-width: 1320px;
      margin-top: 64px;
    }

    #shopify-section-{{ section.id }} .yarbo-detailed-text-one {
      padding: 100px;
      border-radius: 24px;
    }

    #shopify-section-{{ section.id }} .yarbo-detailed-text {
      font-size: 16px;
      font-weight: 400;
    }
  }
</style>
<link
  href='https://cdn.shopify.com/s/files/1/0604/5394/5441/files/yb-section-common.css'
  media='all'
  rel='stylesheet'
  type='text/css'
>
<div>
  <style>
    #shopify-section-{{ section.id }} {
      background-color: #ffffff;
    }

    /* 375-679px */
    @media (max-width: 679px) {
      #shopify-section-{{ section.id }} {
        padding-top: 48px;
        padding-bottom: 48px;
      }
    }

    /* 680-959px */
    @media (min-width: 680px) and (max-width: 959px) {
      #shopify-section-{{ section.id }} {
        padding-top: 64px;
        padding-bottom: 64px;
      }
    }

    /* 960-1439px */
    @media (min-width: 960px) and (max-width: 1439px) {
      #shopify-section-{{ section.id }} {
        padding-top: 64px;
        padding-bottom: 64px;
      }
    }

    /* 1440-1919px */
    @media (min-width: 1440px) and (max-width: 1919px) {
      #shopify-section-{{ section.id }} {
        padding-top: 100px;
        padding-bottom: 100px;
      }
    }

    /* 1920px+ */
    @media (min-width: 1920px) {
      #shopify-section-{{ section.id }} {
        padding-top: 120px;
        padding-bottom: 120px;
      }
    }
  </style>
  <div class='yb-section-common'>
    <div class='yb-section-common-title'>
      {{ section.settings.title }}
    </div>
  </div>
  <div class='yarbo-detailed-text-display-main-box'>
    <div class='yarbo-detailed-text-list'>
      <div
        class='yarbo-detailed-text-one'
        style='background-color: #f5f5f5;'
      >
        <div class='yarbo-detailed-text'>
          <main
            class='content-for-layout policy-product-protection-plan'
            id='MainContent'
            tabindex='-1'
          >
            {{ section.settings.content }}
          </main>
        </div>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Product Protection Plan",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    }
  ],
  "presets": [
    {
      "name": "Product Protection Plan"
    }
  ]
}
{% endschema %}
