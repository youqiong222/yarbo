{% render 'section-padding', section_id: section.id, settings: section.settings %}
{%- liquid
  assign s = section.settings
  assign desktop_image = s.desktop_image
  assign mobile_image = s.mobile_image
  assign desktop_image_url = s.desktop_image_url | strip
  assign mobile_image_url = s.mobile_image_url | strip
  assign button_link = s.button_link | default: '#'
-%}

{%- style -%}
  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner {
  	position: relative;
  	overflow: hidden;
  	background: {{ s.background_color }};
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__media {
  	position: relative;
  	min-height: {{ s.desktop_height }}px;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__picture,
  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__picture img,
  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__image-url {
  	display: block;
  	width: 100%;
  	height: 100%;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__picture,
  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__image-url {
  	position: absolute;
  	inset: 0;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__picture img,
  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__image-url {
  	object-fit: cover;
  	object-position: center;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__image-url {
  	background-repeat: no-repeat;
  	background-position: center;
  	background-size: cover;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__desktop,
  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__mobile {
  	display: none;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__desktop {
  	display: block;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__overlay {
  	position: absolute;
  	inset: 0;
  	background: rgba(0, 0, 0, {{ s.overlay_opacity | times: 0.01 }});
  	pointer-events: none;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__inner {
  	position: relative;
  	z-index: 1;
  	display: flex;
  	min-height: {{ s.desktop_height }}px;
  	width: 100%;
  	max-width: {{ s.content_max_width }}px;
  	margin: 0 auto;
  	padding: {{ s.desktop_padding_top }}px {{ s.desktop_padding_horizontal }}px {{ s.desktop_padding_bottom }}px;
  	align-items: {{ s.desktop_vertical_alignment }};
  	justify-content: {{ s.desktop_horizontal_alignment }};
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__content {
  	display: flex;
  	width: 100%;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__content--left {
  	justify-content: flex-start;
  	text-align: left;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__content--center {
  	justify-content: center;
  	text-align: center;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__content--right {
  	justify-content: flex-end;
  	text-align: right;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__actions {
  	display: flex;
  	width: 50%;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__button {
  	display: inline-flex;
  	align-items: center;
  	justify-content: center;
  	min-height: 56px;
    line-height: 56px;
  	padding: 8px 36px;
  	border: {{ s.button_border_width }}px solid {{ s.button_border_color }};
  	border-radius: {{ s.button_radius }}px;
  	background: {{ s.button_background }};
  	color: {{ s.button_text_color }};
  	font-size: {{ s.button_font_size }}px;
  	font-weight: 500;
  	line-height: 1.2;
  	text-decoration: none;
  	transition: background-color 0.25s ease, color 0.25s ease, border-color 0.25s ease, transform 0.25s ease;
  }

  #shopify-section-{{ section.id }} .sa-spoga-gafa-banner__button:hover {
  	background: {{ s.button_hover_background }};
  	color: {{ s.button_hover_text_color }};
  	border-color: {{ s.button_hover_border_color }};
  	transform: translateY(-1px);
  }

  @media screen and (max-width: 767px) {
  	#shopify-section-{{ section.id }} .sa-spoga-gafa-banner__media,
  	#shopify-section-{{ section.id }} .sa-spoga-gafa-banner__inner {
  		min-height: {{ s.mobile_height }}px;
  	}

  	#shopify-section-{{ section.id }} .sa-spoga-gafa-banner__desktop {
  		display: none;
  	}

  	#shopify-section-{{ section.id }} .sa-spoga-gafa-banner__mobile {
  		display: block;
  	}

  	#shopify-section-{{ section.id }} .sa-spoga-gafa-banner__inner {
  		max-width: 100%;
  		padding: {{ s.mobile_padding_top }}px {{ s.mobile_padding_horizontal }}px {{ s.mobile_padding_bottom }}px;
  		align-items: {{ s.mobile_vertical_alignment }};
  		justify-content: {{ s.mobile_horizontal_alignment }};
  	}

  	#shopify-section-{{ section.id }} .sa-spoga-gafa-banner__content,
  	#shopify-section-{{ section.id }} .sa-spoga-gafa-banner__actions {
  		justify-content: center;
  		text-align: center;
  	}

  	#shopify-section-{{ section.id }} .sa-spoga-gafa-banner__button {
  		min-height: 44px;
  		padding: 8px 28px;
      line-height: 44px;
  		font-size: {{ s.button_font_size_mobile }}px;
  	}
  }
{%- endstyle -%}

<section class='sa-spoga-gafa-banner'>
  <div class='sa-spoga-gafa-banner__media'>
    {%- if desktop_image != blank or desktop_image_url != blank -%}
      <div class='sa-spoga-gafa-banner__desktop'>
        {%- if desktop_image != blank -%}
          <picture class='sa-spoga-gafa-banner__picture'>
            {{
              desktop_image
              | image_url: width: 3840
              | image_tag: widths: '750, 1100, 1500, 2000, 2400, 3000, 3840', loading: 'lazy', alt: s.image_alt, class: 'sa-spoga-gafa-banner__img'
            }}
          </picture>
        {%- else -%}
          <div
            class='sa-spoga-gafa-banner__image-url'
            style='background-image: url("{{ desktop_image_url }}");'
            aria-hidden='true'
          ></div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if mobile_image != blank or mobile_image_url != blank -%}
      <div class='sa-spoga-gafa-banner__mobile'>
        {%- if mobile_image != blank -%}
          <picture class='sa-spoga-gafa-banner__picture'>
            {{
              mobile_image
              | image_url: width: 2000
              | image_tag: widths: '375, 550, 750, 900, 1200, 1500, 2000', loading: 'lazy', alt: s.image_alt, class: 'sa-spoga-gafa-banner__img'
            }}
          </picture>
        {%- else -%}
          <div
            class='sa-spoga-gafa-banner__image-url'
            style='background-image: url("{{ mobile_image_url }}");'
            aria-hidden='true'
          ></div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class='sa-spoga-gafa-banner__overlay'></div>

    <div class='sa-spoga-gafa-banner__inner'>
      <div class='sa-spoga-gafa-banner__content sa-spoga-gafa-banner__content--{{ s.content_alignment }}'>
        {%- if s.button_text != blank -%}
          <div class='sa-spoga-gafa-banner__actions'>
            <a
              href='{{ button_link }}'
              class='sa-spoga-gafa-banner__button'
              {% if s.open_new_tab %}
                target='_blank' rel='noopener noreferrer'
              {% endif %}
            >
              {{ s.button_text }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
