{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}

<div
  style='
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
    --h5-padding-top: {{ section.settings.h5_padding_top }}px;
    --h5-padding-bottom: {{ section.settings.h5_padding_bottom }}px;
  '
  class='
    yb-product-collection
    pt-(--h5-padding-top) pb-(--h5-padding-bottom)
    md:pt-(--padding-top) md:pb-(--padding-bottom)
    {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}
  '
>
  <div class='page-container'>
    {% if section.settings.title != blank %}
      <h2 class='mb-24 text-center text-[28px] leading-[1.1] font-bold uppercase md:mb-40 md:text-[44px]'>
        {{ section.settings.title }}
      </h2>
    {% endif %}

    <div class='yb-product-collection-container'>
      <div class='swiper-wrapper'>
        {% for block in section.blocks %}
          {%- liquid
            assign p = block.settings.product
            if p != blank
              assign card_url = p.url
              assign card_title = block.settings.title | default: p.title
              assign card_image = block.settings.product_image | default: p.featured_image
            else
              assign card_url = '#'
              assign card_title = block.settings.title
              assign card_image = block.settings.product_image
            endif
          -%}
          <a
            href='{{ card_url }}'
            class='yb-product-collection-card yb-product-collection-card-style2 swiper-slide no-underline'
            {{ block.shopify_attributes }}
          >
            {% if card_title != blank %}
              <div class='title empty-score'>{{ card_title }}</div>
            {% endif %}

            {% if block.settings.icon_image != blank %}
              <img
                src='{{ block.settings.icon_image | image_url: width: 240 }}'
                alt=''
                width='240'
                height='240'
                loading='lazy'
                class='icon'
              >
            {% endif %}

            {% if card_image != blank %}
              <img
                src='{{ card_image | image_url: width: 568 }}'
                alt=''
                width='284'
                height='284'
                loading='lazy'
                class='product-img'
              >
            {% endif %}

            <div class='price-container'>
              {% if p != blank %}
                <div class='price-row'>
                  {% render 'price', product: p, show_compare_at_price: true %}
                </div>
              {% endif %}

              <span class='yb-product-collection-btn'>
                {{ block.settings.button_text | default: 'Shop Now' }}
              </span>
            </div>
          </a>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    var swiperInstance = null;
    var section = document.querySelector('#shopify-section-{{ section.id }} .yb-product-collection-container');
    if (!section) return;

    function init() {
      var width = window.innerWidth || document.documentElement.clientWidth;
      if (width < 960) {
        if (!swiperInstance) {
          swiperInstance = new Swiper(section, {
            slidesPerView: 'auto',
            slidesPerGroup: 1,
            spaceBetween: 16,
          });
        }
      } else if (swiperInstance) {
        swiperInstance.destroy(true, true);
        swiperInstance = null;
      }
    }

    document.addEventListener('DOMContentLoaded', init);
    if (document.readyState !== 'loading') init();
    window.addEventListener('resize', init);
  })();
</script>

{% schema %}
{
  "name": "Flash Hover",
  "class": "css-reset tailwind-layout",
  "settings": [
    { "type": "text", "id": "anchor_id", "label": "Anchor Id" },
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    { "type": "richtext", "id": "title", "label": "Title", "default": "<p>Upgrade in a Flash</p>" },
    { "type": "header", "content": "Spacing Settings" },
    { "type": "number", "id": "padding_top", "label": "Padding Top", "default": 96 },
    { "type": "number", "id": "padding_bottom", "label": "Padding Bottom", "default": 100 },
    { "type": "number", "id": "h5_padding_top", "label": "H5 Padding Top", "default": 48 },
    { "type": "number", "id": "h5_padding_bottom", "label": "H5 Padding Bottom", "default": 48 }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Block",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "header", "content": "Content" },
        { "type": "text", "id": "title", "label": "Title (override, default: product title)" },
        { "type": "text", "id": "button_text", "label": "Button Text", "default": "Shop Now" },
        { "type": "header", "content": "Images" },
        { "type": "image_picker", "id": "icon_image", "label": "Icon (top-right)" },
        { "type": "image_picker", "id": "product_image", "label": "Product Image (override product featured image)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Flash Hover",
      "blocks": [
        { "type": "block", "settings": { "title": "Lawn Mower Pro Module" } },
        { "type": "block", "settings": { "title": "Lawn Mower Module" } },
        { "type": "block", "settings": { "title": "Snow Blower Module" } },
        { "type": "block", "settings": { "title": "Blower Module" } }
      ]
    }
  ]
}
{% endschema %}
