      document.addEventListener('DOMContentLoaded', function () {
        const list = document.getElementById('splide01-list');
        if (list) list.style.transform = '';
        const clones = document.querySelectorAll('.splide__slide--clone');
        clones.forEach((clone) => clone.remove());
        const slides = document.querySelectorAll('.splide__slide');
        slides.forEach((slide) => {
          slide.style.marginRight = '';
          slide.style.width = '';
        });
        const track = document.getElementById('splide01-track');
        if (track) track.style.overflow = 'hidden';
        if (typeof Swiper !== 'undefined') {
          new Swiper('#splide01-track', {
            wrapperClass: 'splide__list',
            slideClass: 'splide__slide',
            loop: true,
            spaceBetween: 22,
            autoplay: { delay: 3000, disableOnInteraction: false },
            navigation: {
              nextEl: document.querySelector('.splide__arrow--next'),
              prevEl: document.querySelector('.splide__arrow--prev'),
            },
            breakpoints: {
              0: { slidesPerView: 1.5, centeredSlides: true },
              750: { slidesPerView: 3, centeredSlides: false },
            },
          });
        }
      });
