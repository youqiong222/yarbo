{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
{%- style -%}
  /* Pre-size the container to match the scroll distance ScrollTrigger will add,
     preventing layout overlap before GSAP initializes. */
  .scrolljack-outer-{{ section.id }} {
    min-height: calc(100dvh + 1200px);
  }
  @media (min-width: 1024px) {
    .scrolljack-outer-{{ section.id }} {
      min-height: calc(100dvh + 3000px);
    }
  }
{%- endstyle -%}
<div class='scrolljack-outer-{{ section.id }} bg-[#0d0d0d] text-white {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}'>
  <div
    id='{{ section.settings.anchor_id }}'
    class='pin-section-{{ section.id }} relative flex h-dvh w-full touch-pan-y flex-col justify-center overflow-hidden py-40 md:py-0'
  >
    {% if section.settings.title != blank %}
      <div class='page-container'>
        <h2 class='mb-32 shrink-0 text-center text-[32px] tracking-wide uppercase md:mb-64 md:text-[44px]'>
          {{ section.settings.title }}
        </h2>
      </div>
    {% endif %}

    <div
      class='
        page-container mx-auto flex w-full flex-1 items-center justify-center gap-32 md:h-auto md:flex-none {% if section.settings.mobile_layout == 'image_top' %}
          flex-col
        {% else %}
          flex-col-reverse
        {% endif %}
        {% if section.settings.pc_layout == 'image_left' %}
          md:flex-row
        {% else %}
          md:flex-row-reverse
        {% endif %} lg:gap-40
      '
    >
      <div class='relative flex h-[45dvh] w-full shrink-0 translate-z-0 transform-gpu items-center justify-center md:aspect-4/3 md:h-auto md:w-1/2'>
        {% for block in section.blocks %}
          <div
            class='media-wrapper invisible absolute inset-0 flex items-center justify-center pr-24 md:pr-0'
            {{ block.shopify_attributes }}
            data-index='{{ forloop.index0 }}'
          >
            {% render 'media-element',
              class: 'w-full h-full relative z-0',
              media_class: 'w-full h-full object-contain md:object-cover rounded-12 transform-gpu',
              media_type: block.settings.media_type,
              pc_image: block.settings.pc_image,
              h5_image: block.settings.h5_image,
              pc_video: block.settings.pc_video,
              h5_video: block.settings.h5_video,
              video_url: block.settings.video_url,
              other_url: block.settings.other_url
            %}

            {%- render 'sn-overlay', _settings: section.settings -%}
          </div>
        {% endfor %}

        <div class='absolute top-0 right-0 h-full w-4 translate-z-0 transform-gpu overflow-hidden rounded-full bg-gray-800 md:hidden'>
          <div
            class='progress-bar-fill absolute top-0 left-0 block! w-full rounded-full bg-yellow-400'
          ></div>
        </div>
      </div>

      <div class='flex h-[25dvh] w-full items-stretch md:h-auto md:w-1/2'>
        <div class='text-container relative flex h-full w-full flex-1 flex-col justify-start md:h-auto md:justify-center md:pr-60'>
          {% for block in section.blocks %}
            <div
              class='text-item invisible absolute top-0 left-0 w-full translate-z-0 transform-gpu cursor-pointer border-gray-800 py-16 backface-hidden md:visible md:static md:border-b md:py-32'
              data-index='{{ forloop.index0 }}'
            >
              <div class='mb-8 flex items-center gap-12 md:gap-16'>
                <span class='h-20 w-20 shrink-0 text-white md:h-24 md:w-24'>
                  {{ block.settings.icon }}
                </span>
                <h3 class='text-[18px]/[1.1] uppercase md:text-[20px]/[1.1]'>
                  {{ block.settings.title | strip_html }}
                </h3>
              </div>

              <div class='desc translate-z-0 transform-gpu overflow-hidden pl-32 text-[14px]/[1.3] leading-relaxed text-[#e6e6e6] backface-hidden md:h-0 md:pl-40'>
                {{ block.settings.desc }}
              </div>
            </div>
          {% endfor %}
        </div>

        <div class='relative hidden w-4 shrink-0 translate-z-0 transform-gpu overflow-hidden bg-gray-800 md:block'>
          <div
            class='progress-bar-fill absolute top-0 left-0 block! w-full rounded-full bg-yellow-400'
          ></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script
  src='https://cdn.shopify.com/s/files/1/0604/5394/5441/files/gsap.min.js?v=1776244928'
  defer
></script>
<script
  src='https://cdn.shopify.com/s/files/1/0604/5394/5441/files/scrollTrigger.min.js?v=1776244928'
  defer
></script>
<script>
  // GSAP 逻辑保持不变，因为高度动画 'auto' 不受 Tailwind spacing 影响
  const initFn = () => {
    const sectionContainer = document.querySelector('.pin-section-{{ section.id }}');
    if (!sectionContainer) return;

    const mediaWrappers = sectionContainer.querySelectorAll('.media-wrapper');
    const texts = sectionContainer.querySelectorAll('.text-item');
    const descs = sectionContainer.querySelectorAll('.desc');
    const progressBars = sectionContainer.querySelectorAll('.progress-bar-fill');
    const total = texts.length;

    if (total === 0) return;

    let activeIndex = 0;
    const mm = gsap.matchMedia();

    mm.add(
      {
        isDesktop: '(min-width: 1024px)',
        isMobile: '(max-width: 1023px)',
      },
      (context) => {
        const { isDesktop } = context.conditions;
        const scrollEndDistance = isDesktop ? '+=3000' : '+=1200';
        const scrubConfig = isDesktop ? 0.5 : 0.1;

        gsap.set(mediaWrappers, { autoAlpha: 0 });
        gsap.set(mediaWrappers[0], { autoAlpha: 1, visibility: 'inherit' });
        gsap.set(progressBars, { height: `${(1 / total) * 100}%` });

        if (isDesktop) {
          gsap.set(texts, {
            opacity: 0.5,
            autoAlpha: 1,
            visibility: 'inherit',
          });
          gsap.set(texts[0], { opacity: 1 });
          gsap.set(descs, { height: 0, opacity: 0 });
          gsap.set(descs[0], { height: 'auto', opacity: 1 });
        } else {
          gsap.set(texts, { autoAlpha: 0, opacity: 1 });
          gsap.set(texts[0], { autoAlpha: 1, visibility: 'inherit' });
          gsap.set(descs, { height: 'auto', opacity: 1 });
        }

        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: sectionContainer,
            start: 'top top',
            end: scrollEndDistance,
            pin: true,
            scrub: scrubConfig,
            snap: {
              snapTo: 'labels',
              duration: { min: 0.2, max: 0.4 },
              delay: 0.05,
              ease: 'power1.out',
            },
            onUpdate: (self) => {
              const newIndex = Math.round(self.progress * (total - 1));
              if (newIndex !== activeIndex) {
                const oldVideo = mediaWrappers[activeIndex].querySelector('video');
                if (oldVideo) oldVideo.pause();

                const newVideo = mediaWrappers[newIndex].querySelector('video');
                if (newVideo) {
                  newVideo.currentTime = 0;
                  newVideo.play().catch(() => {});
                }
                activeIndex = newIndex;
              }
            },
          },
        });

        const holdDuration = 1;
        const transDuration = 0.3;
        let currentTime = 0;

        tl.addLabel('step0', currentTime + holdDuration / 2);
        tl.to({}, { duration: holdDuration });
        currentTime += holdDuration;

        texts.forEach((text, i) => {
          if (i === 0) return;

          tl.to(mediaWrappers[i - 1], { autoAlpha: 0, duration: transDuration, ease: 'power1.inOut' }, currentTime)
            .to(
              mediaWrappers[i],
              {
                autoAlpha: 1,
                visibility: 'inherit',
                duration: transDuration,
                ease: 'power1.inOut',
              },
              currentTime,
            )
            .to(
              progressBars,
              {
                height: `${((i + 1) / total) * 100}%`,
                duration: transDuration,
                ease: 'power1.inOut',
              },
              currentTime,
            );

          if (isDesktop) {
            tl.to(
              descs[i - 1],
              {
                height: 0,
                opacity: 0,
                duration: transDuration,
                ease: 'power1.inOut',
              },
              currentTime,
            )
              .to(texts[i - 1], { opacity: 0.5, duration: transDuration, ease: 'power1.inOut' }, currentTime)
              .to(
                descs[i],
                {
                  height: 'auto',
                  opacity: 1,
                  duration: transDuration,
                  ease: 'power1.inOut',
                },
                currentTime,
              )
              .to(texts[i], { opacity: 1, duration: transDuration, ease: 'power1.inOut' }, currentTime);
          } else {
            tl.to(texts[i - 1], { autoAlpha: 0, duration: transDuration, ease: 'power1.inOut' }, currentTime).to(
              texts[i],
              {
                autoAlpha: 1,
                visibility: 'inherit',
                duration: transDuration,
                ease: 'power1.inOut',
              },
              currentTime,
            );
          }

          currentTime += transDuration;
          tl.addLabel(`step${i}`, currentTime + holdDuration / 2);
          tl.to({}, { duration: holdDuration });
          currentTime += holdDuration;
        });

        const goToStep = (i) => {
          const st = tl.scrollTrigger;
          if (st) {
            const timeAtItem = i * (holdDuration + transDuration) + holdDuration / 2;
            const progress = timeAtItem / tl.duration();
            const scrollPos = st.start + (st.end - st.start) * progress;
            window.scrollTo({ top: scrollPos, behavior: 'smooth' });
          }
        };

        texts.forEach((text, i) => {
          text.addEventListener('click', () => goToStep(i));
        });

        document.addEventListener('shopify:block:select', (event) => {
          const targetIndex = event.target.dataset.index;
          if (targetIndex !== undefined) goToStep(parseInt(targetIndex));
        });
      },
    );
  };
  document.addEventListener('DOMContentLoaded', initFn);
</script>

{% schema %}
{
  "name": "Index Scrolljacking",
  "tag": "section",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor Id"
    },
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Section Title",
      "default": "<p>Reliability, built into every Yarbo.</p>"
    },
    {
      "type": "select",
      "id": "pc_layout",
      "label": "PC Layout",
      "default": "image_left",
      "options": [
        { "value": "image_right", "label": "Text Left, Image Right" },
        { "value": "image_left", "label": "Image Left, Text Right" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile Layout",
      "default": "image_top",
      "options": [
        { "value": "text_top", "label": " Text Top, Image Bottom" },
        { "value": "image_top", "label": "Image Top, Text Bottom" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Text Block",
      "settings": [
        {
          "type": "html",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Block Title",
          "default": "<p>Feature Title</p>"
        },
        {
          "type": "richtext",
          "id": "desc",
          "label": "Block Description",
          "default": "<p>Description text here.</p>"
        },
        {
          "type": "header",
          "content": "Media Settings"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Shopify Video"
            },
            {
              "value": "video_url",
              "label": "External Video URL"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "pc_image",
          "label": "PC Image"
        },
        {
          "type": "image_picker",
          "id": "h5_image",
          "label": "H5 Image"
        },
        {
          "type": "video",
          "id": "pc_video",
          "label": "PC Shopify Video"
        },
        {
          "type": "video",
          "id": "h5_video",
          "label": "H5 Shopify Video(Optional)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Platform Video URL (YouTube/Vimeo)",
          "accept": ["youtube", "vimeo"],
          "default": "https://www.youtube.com/watch?v=NpEaa2P7qZI"
        },
        {
          "type": "text",
          "id": "other_url",
          "label": "Other Video URL",
          "info": "ex: xxx.mp4 (If filled, this takes priority over the Platform Video URL)"
        },
        {
          "type": "header",
          "content": "Overlay Settings"
        },
        {
          "type": "checkbox",
          "id": "show_overlay",
          "label": "Show Media Overlay",
          "default": false
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay Opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 40
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Index Scrolljacking",
      "blocks": [{ "type": "item" }, { "type": "item" }, { "type": "item" }]
    }
  ]
}
{% endschema %}
