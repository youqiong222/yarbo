<link
  rel='stylesheet'
  href='{{ 'component-list-menu.css' | asset_url }}'
  media='print'
  onload="this.media='all'"
>
<link
  rel='stylesheet'
  href='{{ 'component-menu-drawer.css' | asset_url }}'
>

{%- if settings.predictive_search_enabled -%}
  <link
    rel='stylesheet'
    href='{{ 'component-price.css' | asset_url }}'
    media='print'
    onload="this.media='all'"
  >
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link
    rel='stylesheet'
    href='{{ 'component-mega-menu.css' | asset_url }}'
    media='print'
    onload="this.media='all'"
  >
{%- endif -%}
{% assign transparent_pages = section.settings.transparent_pages | split: ',' %}
{% assign disable_sticky_pages = section.settings.disable_sticky_pages | split: ',' %}
{%- assign pageName = template.suffix | downcase -%}
{%- assign sticky_active = section.settings.enable_sticky_header -%}
{%- if sticky_active and section.settings.disable_sticky_pages != blank -%}
  {%- for path in disable_sticky_pages -%}
    {%- assign trimmed = path | strip -%}
    {%- if trimmed != blank and request.path contains trimmed -%}
      {%- assign sticky_active = false -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}
<style>
  header-drawer {
    justify-self: start;
  }



  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 990px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
    flex-wrap: wrap;
  }
  .header-icon path {
    transition: stroke 0.3s ease;
  }
  .header--transparent .header-icon path {
    stroke: #fff;
  }
  summary.list-menu__item {
    padding-right: 2.7rem;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    line-height: calc(1 + 0.3 / var(--font-body-scale));
  }

  .list-menu__item--link {
    text-decoration: none;
    padding-bottom: 1rem;
    padding-top: 1rem;
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }
  #shopify-section-{{ section.id }}{
    overflow: visible;
  }
  @media screen and (min-width: 750px) {
    .list-menu__item--link {
      padding-bottom: 0.5rem;
      padding-top: 0.5rem;
    }
  }


  @media (min-width: 1200px) {

    .header__logo {
      width: 100%;
      display: flex;
      align-items: center;
      padding-top: 6px;
        padding-bottom: 6px;
    }

    .header_linklist_item {
      font-size: 14px;
    }

  }
</style>
<style>
    :root {
      --enable-sticky-header: {% if sticky_active %}1{% else %}0{% endif %};
      --enable-transparent-header: {% if request.page_type == 'index' and section.settings.enable_transparent_header %}1{% else %}0{% endif %};
      --loading-bar-background: {{ section.settings.header_text_color.red }}, {{ section.settings.header_text_color.green }}, {{ section.settings.header_text_color.blue }}; /* Prevent the loading bar to be invisible */
    }

    #shopify-section-{{ section.id }} {
      {%- assign header_border_color = settings.header_background | color_mix: settings.header_text_color, 85 -%}
  {% if section.settings.header_background != blank %}
    --header-background: {{ section.settings.header_background.red }}, {{ section.settings.header_background.green }}, {{ section.settings.header_background.blue }};
  {% else %}
    --header-background: 255, 255, 255;
  {% endif %}
      --header-text-color: {{ section.settings.header_text_color.red }}, {{ section.settings.header_text_color.green }}, {{ section.settings.header_text_color.blue }};
      --header-border-color: {{ header_border_color.red }}, {{ header_border_color.green }}, {{ header_border_color.blue }};
      --reduce-header-padding: {% if section.settings.reduce_desktop_padding %}1{% else %}0{% endif %};

      {%- if sticky_active -%}
        position: -webkit-sticky;
        position: sticky;
        background: {{ header_border_color }};
      {%- else -%}
        position: relative;
      {%- endif -%}
    top: {% if sticky_active %}calc(var(--enable-sticky-announcement-bar, 0) * var(--announcement-bar-height, 0px)){% else %}0{% endif %};
      z-index: 9999;
    }

    {%- if section.settings.enable_transparent_header -%}
      {% if request.page_type == 'index' or transparent_pages contains pageName %}
      #shopify-section-{{ section.id }} {
        margin-bottom: calc(-1 * (var(--header-height, 0px) + 0 * var(--announcement-bar-height, 0px)));
      }

      #shopify-section-{{ section.id }} .header--transparent {
        {%- if section.settings.header_text_color == section.settings.transparent_header_text_color -%}
          {%- assign header_bubble_text_color = section.settings.header_background -%}
        {%- else -%}
          {%- assign header_bubble_text_color = section.settings.header_text_color -%}
        {%- endif -%}

        --header-background: transparent;
        --header-text-color: {{ section.settings.transparent_header_text_color.red }}, {{ section.settings.transparent_header_text_color.green }}, {{ section.settings.transparent_header_text_color.blue }};
        --header-border-color: {{ section.settings.transparent_header_text_color.red }}, {{ section.settings.transparent_header_text_color.green }}, {{ section.settings.transparent_header_text_color.blue }}, 0.15;
        --header-transparent-bubble-text-color: {{ header_bubble_text_color.red }}, {{ header_bubble_text_color.green }}, {{ header_bubble_text_color.blue }};
      }
      {% endif %}
    {%- endif -%}

    #shopify-section-{{ section.id }} .header__logo-image {
      width: max-content;
      height: auto;
    }

    @media screen and (min-width: 741px) {
      #shopify-section-{{ section.id }} .header__logo-image {
        max-width: {{ section.settings.logo_max_width }}px;
      }
    }

    @media screen and (min-width: 1200px) {
      {%- if section.settings.header_layout == 'logo_left_navigation_inline' -%}
        /* For this navigation we have to move the logo at the first and add a margin */
        [dir="rtl"] .header__logo {
          margin-left: 40px;
        }

        [dir="ltr"] .header__logo {
          margin-right: 40px;
        }

        .header__logo {
          order: -1;
        }

        @media screen and (min-width: 741px) {
          .header__secondary-links {
            max-width: max-content;
            margin-inline-start: 48px;
          }
        }
      {%- endif -%}

      {%- if section.settings.header_layout == 'logo_left_navigation_center' -%}
        /* For this navigation we have to move the logo and make sure the navigation takes the whole width */
        .header__logo {
          order: -1;
          flex: 1 1 0;
        }

        .header__inline-navigation {
          flex: 1 1 auto;
          justify-content: center;
          max-width: max-content;
          margin-inline: 48px;
        }
      {%- endif -%}
    }

    {%- if request.page_type == '404' -%}
      .shopify-section--404 {
        /* For the 404 page, we re-use the same colors as the header for design reason */
        --background: {{ settings.header_background.red }}, {{ settings.header_background.green }}, {{ settings.header_background.blue }};
        --heading-color: {{ settings.header_text_color.red }}, {{ settings.header_text_color.green }}, {{ settings.header_text_color.blue }};
        --text-color: {{ settings.header_text_color.red }}, {{ settings.header_text_color.green }}, {{ settings.header_text_color.blue }};
        --primary-button-background: {{ settings.header_text_color.red }}, {{ settings.header_text_color.green }}, {{ settings.header_text_color.blue }};
        --primary-button-text-color: {{ settings.header_background.red }}, {{ settings.header_background.green }}, {{ settings.header_background.blue }};
      }
    {%- endif -%}
</style>
<script
  src='{{ 'cart-notification.js' | asset_url }}'
  defer='defer'
></script>

<store-header
  {% if sticky_active %}
    sticky
  {% endif %}
  {% if section.settings.enable_transparent_header %}
    {% if request.page_type == 'index' or transparent_pages contains pageName %}
      transparent
    {% endif %}
  {% endif %}
  class='
    header-wrapper header h-48 sm:h-56 {% if settings.background == settings.header_background %}header--bordered{% endif %} {% if section.settings.enable_transparent_header %} {% if request.page_type == 'index' or transparent_pages contains pageName %}

    header--transparent {% endif %} {% endif %}
  '
  role='banner'
>
  {%- liquid
    assign social_links = false
    assign localization_forms = false

    if settings.social_twitter_link != blank or settings.social_facebook_link != blank or settings.social_pinterest_link != blank or settings.social_instagram_link != blank or settings.social_youtube_link != blank or settings.social_vimeo_link != blank or settings.social_tiktok_link != blank or settings.social_tumblr_link != blank or settings.social_snapchat_link != blank
      assign social_links = true
    endif
  -%}

  <header
    class='page-container h-full {% if section.settings.menu_type_desktop == 'drawer' %} drawer-menu{% endif %}{% if section.settings.menu != blank %} header--has-menu{% endif %}{% if has_app_block %} header--has-app{% endif %}{% if social_links %} header--has-social{% endif %}{% if shop.customer_accounts_enabled %} header--has-account{% endif %}{% if localization_forms %} header--has-localizations{% endif %}'
  >
    <div class='header__wrapper flex h-full flex-wrap items-center justify-center'>
      <!-- LOGO PART -->

      <div class='header_navBottom flex h-full w-full items-center justify-between'>
        <div>
          {%- capture logo -%}
            <a class="header__logo-link header__logo-link_new " href="{{ routes.root_url }}">
              {%- if section.settings.logo != blank -%}

                <span class="visually-hidden">{{ shop.name }}</span>

                  <div class="header__logo-image pad_pc flex max-w-120 md:max-w-140">
                  <img src="{{ section.settings.logo |  image_url: width: '140x' }}"  class="w-full" alt="{{ section.settings.logo.alt }}" width="auto" height="auto" loading="eager"/>
                  </div>
                {% if section.settings.logo_mobile !=blank %}
                    <div class="header__logo-image pad_mobile flex max-w-120 md:max-w-140">
                      <img src="{{ section.settings.logo_mobile |  image_url: width: '140x' }}"  class="w-full" alt="{{ section.settings.logo_mobile.alt }}" width="auto" height="auto" loading="eager"/>
                    </div>
                {% else %}
                  <div class="header__logo-image pad_mobile max-w-120 md:max-w-140">
                      <img src="{{ section.settings.logo |  image_url: width: '140x' }}"  class="w-full"/>
                    </div>
                {% endif %}
              {% if section.settings.enable_transparent_header and section.settings.transparent_logo != blank %}
                  {% if request.page_type == 'index'
                    or transparent_pages contains pageName
                  %}
                  <div class="header__logo-image header__logo-image--transparent flex max-w-120 md:max-w-140">
                  <img src="{{ section.settings.transparent_logo |  image_url: width: '140x' }}" class="w-full" alt="{{ section.settings.transparent_logo.alt }}" width="auto" height="auto" loading="eager"/>
                </div>
                  {% endif %}
                {% endif %}

              {%- else -%}
                <span class="header__logo-text heading h5">{{ shop.name }}</span>
              {%- endif -%}
            </a>
            {%- endcapture -%}

          {%- if request.page_type == 'index' -%}
            <h1 class='header__logo flex items-center py-6 text-[12px]'>
              {{ logo }}
            </h1>
          {%- else -%}
            <span class='header__logo'>{{ logo }}</span>
          {%- endif -%}
        </div>
        {%- liquid
          if section.settings.menu != blank
            if section.settings.menu_type_desktop == 'dropdown'
              render 'sn-header-dropdown-menu'
            elsif section.settings.menu_type_desktop != 'drawer'
              render 'header-mega-menu'
            endif
          endif
        %}

        <div class='header__icons flex items-center gap-12 pr-0'>
          <div class='country_nationalFlag hidden-phone flex cursor-pointer'>
            <svg
              width='24'
              height='24'
              viewBox='0 0 24 24'
              fill='none'
              xmlns='http://www.w3.org/2000/svg'
            >
              <path d="M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12ZM21 12C20.3067 11.6403 19.5379 11.312 18.7569 11.3077H15.8077C15.1651 11.3077 14.5487 11.563 14.0943 12.0174C13.6399 12.4718 13.3846 13.0881 13.3846 13.7308C13.3846 14.3734 13.6399 14.9897 14.0943 15.4441C14.5487 15.8986 15.1651 16.1538 15.8077 16.1538C16.2667 16.1538 16.7069 16.3362 17.0315 16.6608C17.3561 16.9854 17.5385 17.4256 17.5385 17.8846V19.0892M3.69231 15.4615H6.11538C6.75802 15.4615 7.37434 15.2063 7.82876 14.7518C8.28317 14.2974 8.53846 13.6811 8.53846 13.0385V10.9615C8.53846 10.3189 8.79375 9.70259 9.24816 9.24817C9.70258 8.79376 10.3189 8.53847 10.9615 8.53847C11.6042 8.53847 12.2205 8.28318 12.6749 7.82877C13.1293 7.37435 13.3846 6.75803 13.3846 6.11539V3.09693" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
            </svg>
          </div>
          <div>
            {%- render 'sn-search-modal' -%}
          </div>

          {%- if shop.customer_accounts_enabled -%}
            <a
              href='{%- if customer -%}{{ routes.account_url }}{%- else -%}/customer_authentication/login?return_to={{ "/pages/orders" | url_encode }}{%- endif -%}'
              class='header__icon header__icon--account link focus-inset{% if section.settings.menu != blank %} small-hide{% endif %}'
              rel='nofollow'
            >
              {%- if section.settings.enable_customer_avatar -%}
                <account-icon>
                  {%- if customer and customer.has_avatar? -%}
                    {{ customer | avatar }}
                  {%- else -%}
                    <span class='svg-wrapper'>
                      <svg
                        width='24'
                        height='24'
                        viewBox='0 0 24 24'
                        fill='none'
                        xmlns='http://www.w3.org/2000/svg'
                      >
                        <path d="M4 19.0937C4 15.9474 6.62857 13.3968 12 13.3968C17.3714 13.3968 20 15.9474 20 19.0937C20 19.5942 19.6348 20 19.1843 20H4.81569C4.3652 20 4 19.5942 4 19.0937Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
                        <path d="M15 7C15 8.65685 13.6569 10 12 10C10.3431 10 9 8.65685 9 7C9 5.34315 10.3431 4 12 4C13.6569 4 15 5.34315 15 7Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
                      </svg>
                    </span>
                  {%- endif -%}
                </account-icon>
              {%- else -%}
                <span class='svg-wrapper'>
                  <svg
                    width='24'
                    height='24'
                    viewBox='0 0 24 24'
                    fill='none'
                    xmlns='http://www.w3.org/2000/svg'
                  >
                    <path d="M4 19.0937C4 15.9474 6.62857 13.3968 12 13.3968C17.3714 13.3968 20 15.9474 20 19.0937C20 19.5942 19.6348 20 19.1843 20H4.81569C4.3652 20 4 19.5942 4 19.0937Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
                    <path d="M15 7C15 8.65685 13.6569 10 12 10C10.3431 10 9 8.65685 9 7C9 5.34315 10.3431 4 12 4C13.6569 4 15 5.34315 15 7Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
                  </svg>
                </span>
              {%- endif -%}
              <span class='visually-hidden'>
                {%- liquid
                  if customer
                    echo 'customer.account_fallback' | t
                  else
                    echo 'customer.log_in' | t
                  endif
                -%}
              </span>
            </a>
          {%- endif -%}

          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
            {%- endcase -%}
          {%- endfor -%}

          <a
            href='{{ routes.cart_url }}'
            class='header__icon header__icon--cart link focus-inset'
            id='cart-icon-bubble'
          >
            {% if cart == empty %}
              <span class='svg-wrapper'>
                <svg
                  width='24'
                  class='icon icon--header-cart'
                  height='24'
                  viewBox='0 0 24 24'
                  fill='none'
                  xmlns='http://www.w3.org/2000/svg'
                >
                  <path d="M7.5 15.4286H19.875L21 7.42857H6.375L7.5 15.4286ZM7.5 15.4286L5.89125 4H3M18.75 18.5714C18.75 19.3604 18.1204 20 17.3438 20C16.5671 20 15.9375 19.3604 15.9375 18.5714C15.9375 17.7825 16.5671 17.1429 17.3438 17.1429C18.1204 17.1429 18.75 17.7825 18.75 18.5714ZM11.4375 18.5714C11.4375 19.3604 10.8079 20 10.0312 20C9.2546 20 8.625 19.3604 8.625 18.5714C8.625 17.7825 9.2546 17.1429 10.0312 17.1429C10.8079 17.1429 11.4375 17.7825 11.4375 18.5714Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
                </svg>
              </span>
            {% else %}
              <span class='svg-wrapper'>
                <svg
                  width='24'
                  class='icon icon--header-cart'
                  height='24'
                  viewBox='0 0 24 24'
                  fill='none'
                  xmlns='http://www.w3.org/2000/svg'
                >
                  <path d="M7.5 15.4286H19.875L21 7.42857H6.375L7.5 15.4286ZM7.5 15.4286L5.89125 4H3M18.75 18.5714C18.75 19.3604 18.1204 20 17.3438 20C16.5671 20 15.9375 19.3604 15.9375 18.5714C15.9375 17.7825 16.5671 17.1429 17.3438 17.1429C18.1204 17.1429 18.75 17.7825 18.75 18.5714ZM11.4375 18.5714C11.4375 19.3604 10.8079 20 10.0312 20C9.2546 20 8.625 19.3604 8.625 18.5714C8.625 17.7825 9.2546 17.1429 10.0312 17.1429C10.8079 17.1429 11.4375 17.7825 11.4375 18.5714Z" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
                </svg>
              </span>
            {% endif %}
            <span class='visually-hidden'>{{ 'templates.cart.cart' | t }}</span>
            {%- if cart != empty -%}
              <div class='cart-count-bubble text-[16px] leading-[1.3] font-bold'>
                {%- if cart.item_count < 100 -%}
                  <span aria-hidden='true'>{{ cart.item_count }}</span>
                {%- endif -%}
                <span class='visually-hidden'>
                  {{- 'sections.header.cart_count' | t: count: cart.item_count -}}
                </span>
              </div>
            {%- endif -%}
          </a>
          {%- assign menu = section.settings.sidebar_navigation_menu | default: section.settings.menu -%}
          {%- liquid
            if section.settings.menu != blank
              render 'sn-header-drawer', menu: menu
            endif
          -%}
        </div>
      </div>
    </div>
  </header>
</store-header>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification', color_scheme: section.settings.color_scheme, desktop_menu_type: section.settings.menu_type_desktop -%}
{%- endif -%}

<script>
  const sectionHeader = document.querySelector('.section-header');
  if (sectionHeader) {
    const updateHeaderZIndex = () => {
      const menuOpen = sectionHeader.classList.contains('menu-open');
      const searchPanel = document.querySelector('[data-modal-panel]');
      const searchOpen = searchPanel && !searchPanel.classList.contains('hidden');
      sectionHeader.style.zIndex = menuOpen || searchOpen ? '9999999999' : '1';
    };
    updateHeaderZIndex();
    new MutationObserver(updateHeaderZIndex).observe(sectionHeader, { attributeFilter: ['class'] });
    const searchPanel = document.querySelector('[data-modal-panel]');
    if (searchPanel) {
      new MutationObserver(updateHeaderZIndex).observe(searchPanel, { attributeFilter: ['class'] });
    }
  }
</script>

<script type='application/ld+json'>
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if section.settings.logo %}
      {% assign image_size = section.settings.logo.width | append: 'x' %}
      "logo": {{ section.settings.logo | img_url: image_size | prepend: 'https:' | json }},
    {% endif %}
    "url": {{ shop.url | append: page.url | json }}
  }
</script>

{% schema %}
{
  "name": "t:sections.header.name",
  "class": "section-header shopify-section--header header_all css-reset tailwind-layout",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_sticky_header",
      "label": "Enable sticky header",
      "default": false
    },
    {
      "type": "text",
      "id": "transparent_pages",
      "label": "Transparent Pages (comma separated)",
      "default": "/pages/about-new,/pages/sustainability"
    },
    {
      "type": "text",
      "id": "disable_sticky_pages",
      "label": "Disable sticky on pages (comma separated paths)",
      "info": "Match against request path. e.g. /products/,/pages/yarbo-live disables sticky on all product pages.",
      "default": "/products/"
    },
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "logo"
    },
    {
      "type": "image_picker",
      "id": "logo_mobile",
      "label": "logo Mobile"
    },
    {
      "type": "link_list",
      "id": "menu",
      "default": "main-menu",
      "label": "t:sections.header.settings.menu.label"
    },
    {
      "type": "link_list",
      "id": "sidebar_navigation_menu",
      "label": "Mobile menu",
      "info": "Select a different menu for mobile sidebar. If none is set the main menu is used."
    },
    {
      "type": "select",
      "id": "menu_type_desktop",
      "options": [
        {
          "value": "dropdown",
          "label": "t:sections.header.settings.menu_type_desktop.options__1.label"
        },
        {
          "value": "mega",
          "label": "t:sections.header.settings.menu_type_desktop.options__2.label"
        },
        {
          "value": "drawer",
          "label": "t:sections.header.settings.menu_type_desktop.options__3.label"
        }
      ],
      "default": "dropdown",
      "label": "t:sections.header.settings.menu_type_desktop.label"
    },
    {
      "type": "checkbox",
      "id": "show_live",
      "label": "Show live Icon",
      "default": true
    },
    {
      "type": "text",
      "id": "live_nav",
      "label": "Live Nav"
    },
    {
      "type": "url",
      "id": "live_link",
      "label": "Live Link"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__utilities.content"
    },
    {
      "type": "checkbox",
      "id": "enable_customer_avatar",
      "default": true,
      "label": "t:sections.header.settings.enable_customer_avatar.label",
      "info": "t:sections.header.settings.enable_customer_avatar.info"
    },
    {
      "type": "header",
      "content": "Transparent header",
      "info": "Home page only. For best results, use an image section such as slideshow."
    },
    {
      "type": "checkbox",
      "id": "enable_transparent_header",
      "label": "Enable",
      "default": false
    },
    {
