{% render 'section-padding', section_id: section.id, settings: section.settings %}

<div class='overflow-hidden {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}'>
  <div class='page-container'>
    <header class='flex items-center justify-between gap-40'>
      <h2 class=' text-[32px] leading-none md:text-[44px] '>
        {{ section.settings.title }}
      </h2>
      <div class='hidden gap-8 md:flex'>
        <div class='swiper-button-prev  static m-0 flex h-48 w-48 items-center justify-center rounded-full border border-[#cccccc] bg-white backdrop-blur-[5px] transition-colors duration-300 after:hidden [&.swiper-button-disabled]:bg-[#ccc] [&.swiper-button-disabled]:opacity-100 [&.swiper-button-disabled_path]:stroke-[#A6A6A6] [&:hover]:bg-[#ccc]'>
          <svg
            width='8'
            height='14'
            viewBox='0 0 8 14'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d="M6.75325 12.5859L0.919923 6.7526L6.75325 0.91927" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
          </svg>
        </div>

        <div class='swiper-button-next static m-0 flex h-48 w-48 items-center justify-center rounded-full border border-[#cccccc] bg-white backdrop-blur-[5px] transition-colors duration-300 after:hidden [&.swiper-button-disabled]:bg-[#ccc] [&.swiper-button-disabled]:opacity-100 [&.swiper-button-disabled_path]:stroke-[#A6A6A6] [&:hover]:bg-[#ccc]'>
          <svg
            width='8'
            height='14'
            viewBox='0 0 8 14'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d="M0.91862 0.919434L6.75195 6.75277L0.91862 12.5861" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
          </svg>
        </div>
      </div>
    </header>
    <div class='swiper mt-32 md:mt-40 md:[overflow:unset]'>
      <div class='swiper-wrapper'>
        {%- for block in section.blocks -%}
          <div class='swiper-slide flex h-auto! w-full flex-col items-center overflow-hidden md:flex-row'>
            <div class='h-full w-full md:w-[46%]'>
              <div class='relative aspect-343/229 h-full md:aspect-auto'>
                {% render 'media-element',
                  class: 'w-full h-full',
                  media_class: 'w-full h-full object-cover',
                  media_type: 'image',
                  pc_image: block.settings.larger_image,
                  h5_image: block.settings.h5_larger_image
                %}
                {%- render 'sn-overlay', _settings: block.settings -%}
              </div>
            </div>
            <div class='flex h-full flex-1 flex-col items-center justify-between bg-[#f2f2f2] p-24 md:p-40'>
              <div>
                <h4 class='text-[26px] leading-[1.1] uppercase md:text-[32px]'>
                  {{ block.settings.title }}
                </h4>
                <div class='mt-12 text-[14px] text-[#515355] md:text-[15px]'>
                  {{ block.settings.text }}
                </div>
                {% if block.settings.button_text != blank and block.settings.link != blank %}
                  <a
                    href='{{ block.settings.link }}'
                    class='mt-20 flex items-center gap-7 text-[14px] md:mt-24 md:text-[15px]'
                  >
                    {{ block.settings.button_text }}
                    <svg
                      width='9'
                      height='9'
                      viewBox='0 0 9 9'
                      fill='none'
                      xmlns='http://www.w3.org/2000/svg'
                    >
                      <path d="M1.77014 0.657715L7.51885 0.725021M7.51885 0.725021L7.58528 6.39198M7.51885 0.725021L0.919189 7.32468" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"></path>
                    </svg>
                  </a>
                {% endif %}
              </div>
              {% if block.settings.image != blank %}
                {% render 'media-element',
                  class: 'w-full h-60 md:mt-24 mt-28',
                  media_class: 'w-auto h-full',
                  media_type: 'image',
                  pc_image: block.settings.image
                %}
              {% endif %}
            </div>
          </div>
        {%- endfor -%}
      </div>
      <div
        class='real-pagination mt-32 flex w-full items-center justify-center space-x-3 md:hidden'
      ></div>
    </div>
  </div>
</div>
<script>
  (() => {
    new Swiper('#shopify-section-{{ section.id }} .swiper', {
      observer: true,
      observeParents: true,
      spaceBetween: 24,
      slidesPerView: 1,
      {% if section.settings.auto_rotate %}
      autoplay: { delay: {{ section.settings.change_slides_speed | times: 1000 }}, disableOnInteraction: false },
      {% endif %}
      breakpoints: {
        768: {
          spaceBetween: 12,
          slidesPerView: 1.4,
        },
      },
      navigation: {
        nextEl: '#shopify-section-{{ section.id }} .swiper-button-next',
        prevEl: '#shopify-section-{{ section.id }} .swiper-button-prev',
      },
      pagination: {
        el: '#shopify-section-{{ section.id }} .real-pagination',
        clickable: true,
        renderBullet: function (index, className) {
          const bulletClasses = `
                ${className}
                rounded-none opacity-100
                w-8 h-8 bg-[#CCCCCC] transition-all duration-300 block cursor-pointer m-0
                hover:bg-white
                [&.swiper-pagination-bullet-active]:w-50 [&.swiper-pagination-bullet-active]:h-8 [&.swiper-pagination-bullet-active]:bg-[#25282a]
              `;
          return `<span class="${bulletClasses.trim().replace(/\s+/g, ' ')}"></span>`;
        },
      },
    });
  })();
</script>
{% schema %}
{
  "name": "Real Deal or Not",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_top",
      "label": "H5 Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_bottom",
      "label": "H5 Padding Bottom",
      "default": 0
    },
    {
      "type": "image_picker",
      "id": "pc_image",
      "label": "PC Image"
    },
    {
      "type": "image_picker",
      "id": "h5_image",
      "label": "Mobile Image (Optional)"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show Media Overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    }
  ],
  "blocks": [
    {
      "name": "block",
      "type": "Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "larger_image",
          "label": "Larger Image"
        },
        {
          "type": "image_picker",
          "id": "h5_larger_image",
          "label": "H5 Larger Image"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Real Deal or Not"
    }
  ]
}
{% endschema %}
