{% render 'section-padding', section_id: section.id, settings: section.settings %}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}

<div
  style='--content-max-width: {{ section.settings.content_width_pc }}px;'
>
  <div class='page-container {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}'>
    <div class='mx-auto max-w-(--content-max-width)'>
      <div
        x-data='{ expanded: false }'
        class='flex w-full flex-col items-center'
      >
        {% if section.settings.title != blank %}
          <h2 class='mb-12 text-center text-[13px] md:text-[14px]'>
            {{ section.settings.title }}
          </h2>
        {% endif %}

        <div class='mb-16 w-full text-center text-[13px] leading-[1.3] text-[#515355] md:text-[14px]'>
          <div
            :class="expanded ? '' : 'line-clamp-4 overflow-hidden'"
            class='w-full'
          >
            {{ section.settings.content }}
          </div>
        </div>

        <button
          @click='expanded = !expanded'
          class='flex cursor-pointer items-center gap-4 border-0 bg-transparent text-[13px] leading-none transition-colors hover:underline md:text-[14px]'
        >
          <span x-text="expanded ? 'Show Less' : 'Show More'"></span>
          <span>
            <svg
              x-show='expanded'
              width='20'
              height='20'
              viewBox='0 0 20 20'
              fill='none'
              xmlns='http://www.w3.org/2000/svg'
            >
              <path d="M16.6668 10L3.3335 10" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
            </svg>

            <svg
              x-show='!expanded'
              width='14'
              height='14'
              viewBox='0 0 14 14'
              fill='none'
              xmlns='http://www.w3.org/2000/svg'
            >
              <path d="M7.00016 2.33203L7.00016 11.6654M11.6668 6.9987L2.3335 6.9987" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
            </svg>
          </span>
        </button>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Load More Text",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor Id"
    },
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_top",
      "label": "H5 Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_bottom",
      "label": "H5 Padding Bottom",
      "default": 0
    },
    {
      "type": "range",
      "id": "content_width_pc",
      "label": "Content Width (PC)",
      "default": 1320,
      "min": 400,
      "max": 1320,
      "step": 10,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Terms & Conditions"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>1. Contest Overview<br>The \"Your Yarbo Journey Wanted\" Contest (“Contest”) invites Yarbo owners to submit original video content showcasing their Yarbo units in real-world scenarios. The Contest is conducted on an ongoing, weekly basis starting from August 4, 2025.</p>"
    }
  ],
  "presets": [
    {
      "name": "Load More Text"
    }
  ]
}
{% endschema %}
