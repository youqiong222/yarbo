      <script>
        (function () {
          const id = '17427972064164abb214';
          const templateCustomSwiperSlide = (slide) => {
            return `<div class="swiper-slide">
    <div class="product-card-custom__swiper-slide-content">
      <div class="product-card-custom__swiper-left">
      ${
        slide.video
          ? `<video loop="" muted="muted" playsinline="playsinline" autoplay="" class="product-card-custom__swiper-video" src="${slide.url}"></video>`
          : `<img style="position: absolute; height: 100%; width: 100%; inset: 0px; color: transparent; touch-action: pan-y;" loading="lazy" decoding="async" data-nimg="fill" class="object-cover" sizes="100vw" srcset="${
              slide.srcset || slide.url
            }" src="${slide.url}" />`
      }
      </div>
      <div class="product-card-custom__swiper-right">
        <div class="product-card-custom__swiper-close">
          <svg width="20" height="20" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <line x1="4" y1="4" x2="20" y2="20" stroke="black" stroke-width="2" stroke-linecap="round"></line>
            <line x1="20" y1="4" x2="4" y2="20" stroke="black" stroke-width="2" stroke-linecap="round"></line>
          </svg>
        </div>
        <h4 class="product-card-custom__swiper-title">${slide.title}</h4>
        <div class="product-card-custom__swiper-content">
        ${slide.content.map((v) => `<p>${v}</p>`).join('')}
        </div>
      </div>
    </div>
    </div>`;
          };
          document.querySelectorAll(`[data-custom-launch-swiper]`).forEach((launch) => {
            launch.addEventListener('click', () => {
              try {
                const swiperData = JSON.parse(launch.dataset.customLaunchSwiper);
                const swiperSlides = swiperData.map((slide) => {
                  return templateCustomSwiperSlide(slide);
                });
                document.querySelector(`#product-card-custom__swiper-container-${id} .swiper-wrapper`).innerHTML =
                  swiperSlides.join('');
                setTimeout(() => {
                  var swiper = new Swiper(`#product-card-custom__swiper-container-${id} .swiper`, {
                    navigation: {
                      nextEl: `#product-card-custom__swiper-container-${id} .swiper-button-next`,
                      prevEl: `#product-card-custom__swiper-container-${id} .swiper-button-prev`,
                    },
                    slidesPerView: 'auto',
                    spaceBetween: 30,
                    pagination: {
                      el: `#product-card-custom__swiper-container-${id} .swiper-pagination`,
                      clickable: true,
                    },
                    centeredSlides: true,
                  });
                  document
                    .querySelectorAll(`#product-card-custom__swiper-container-${id} .product-card-custom__swiper-close`)
                    .forEach((close) => {
                      close.addEventListener('click', () => {
                        document
                          .querySelector(`#product-card-custom__swiper-container-${id}`)
                          .classList.remove('opacity-1');
                        setTimeout(() => {
                          document
                            .querySelector(`#product-card-custom__swiper-container-${id}`)
                            .classList.add('display-none');
                          swiper.pagination.destroy();
                          swiper.destroy();
                        }, 200);
                      });
                    });
                  document
                    .querySelector(`#product-card-custom__swiper-container-${id}`)
                    .classList.remove('display-none');
                  setTimeout(() => {
                    document.querySelector(`#product-card-custom__swiper-container-${id}`).classList.add('opacity-1');
                  }, 100);
                });
              } catch (e) {
                console.log(e, 'error');
              }
            });
          });
        })();
      </script>
    </div>
