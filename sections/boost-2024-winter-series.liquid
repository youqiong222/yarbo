        //   disableOnInteraction: true, // 用户操作后停止自动播放
        // },
      });
      // 获取缩略图元素
      const swiperItems = this.querySelectorAll('.swiper-slide');

      function onVideoEnded(){
        swiper.slideNext();
      }

      swiper.on('slideChangeTransitionEnd', () => {
        const activeIndex = swiper.realIndex; // 使用realIndex以兼容loop模式
        swiperItems.forEach((item, index) => {
          const media = item.querySelector('deferred-media1.deferred-media')
          media.pauseVideo();
          media.rePlay();
          const mediaDom = media.querySelector('video');
          if (mediaDom) {
            // 移除之前的ended事件监听器
            mediaDom.removeEventListener('ended', onVideoEnded);
          }
        });

        if (swiperItems[activeIndex]) {
          const media = this.querySelector('.swiper-slide-active deferred-media1.deferred-media');
          setTimeout(() => {
            media.loadContent();
            const mediaDom = media.querySelector('video');
            mediaDom.addEventListener('ended', onVideoEnded);
            media.playVideo();
            // 确保视频已加载完成后再播放
          }, 0)
        }
      });
    }

    connectedCallback () {
      this.checkDeferredMedia.call(this)
    }

    disconnectedCallback () {
    }

    checkDeferredMedia () {
      const medias = this.container.querySelectorAll('deferred-media1.deferred-media');
      medias.forEach((el) => {
        el.loadContent(false);
      });
    }
  };
  window.customElements.define('custom-video-swiper', CustomVideoSwiper);
  });
</script>
