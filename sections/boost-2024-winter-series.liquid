  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.video-data video').forEach((video) => {
      video.muted = true;
      setTimeout(() => {
        video.play();
      }, 100);
    });

    const btn = document.querySelector('.watch-video-button');
    const popup = document.querySelector('.watch-video-player-wrapper');
    const popupVideo = document.querySelector('.watch-video-player');
    const closeBtn = document.querySelector('.watch-video-close');

    if (!btn || !popup || !popupVideo) return;

    // 点击播放按钮
    btn.addEventListener('click', function () {
      popup.style.display = 'block';
      popupVideo.currentTime = 0;
      popupVideo.play();
    });

    // 点击关闭
    closeBtn.addEventListener('click', function () {
      popup.style.display = 'none';
      popupVideo.pause();
    });
  });
</script>

