    <script>
      const faqCollapses = document.querySelectorAll('.faq-collapse');
      const faqsTag = document.querySelector('.faqs-tag');

      faqCollapses.forEach((faqCollapse) => {
        const header = faqCollapse.querySelector('.faq-collapse-header');
        const arrow = faqCollapse.querySelector('.faq-collapse-desc-arrow');
        const desc = faqCollapse.querySelector('.faq-collapse-desc');

        header.addEventListener('click', function () {
          faqCollapses.forEach((otherFaqCollapse) => {
            const otherDesc = otherFaqCollapse.querySelector('.faq-collapse-desc');
            const otherArrow = otherFaqCollapse.querySelector('.faq-collapse-desc-arrow');
            if (otherDesc !== desc) {
              otherDesc.classList.remove('active');
              otherDesc.style.maxHeight = '0px';
              otherArrow.classList.remove('active');
            }
          });

          if (desc.classList.contains('active')) {
            desc.classList.remove('active');
            desc.style.maxHeight = '0px';
            arrow.classList.remove('active');
          } else {
            desc.classList.add('active');
            desc.style.maxHeight = desc.scrollHeight + 'px';
            arrow.classList.add('active');
          }
        });
      });
      window.addEventListener('resize', function () {
        faqCollapses.forEach((faqCollapse) => {
          const desc = faqCollapse.querySelector('.faq-collapse-desc');
          if (desc.classList.contains('active')) {
            desc.style.maxHeight = desc.scrollHeight + 'px';
          }
        });
      });
    </script>
