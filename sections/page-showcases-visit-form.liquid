<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
  flatpickr("#start_time", {
      dateFormat: "Y-m-d",
      allowInput: true,
      disableMobile: "true",
      onReady: function () {
          const input = document.querySelector('#start_time');
          input.classList.add('date-input');
      }
  });
  flatpickr("#end_time", {
      dateFormat: "Y-m-d",
      allowInput: true,
      disableMobile: "true",
      onReady: function () {
          const input = document.querySelector('#end_time');
          input.classList.add('date-input');
      }
  });
  const selectedProducts = new Set();
  function toggleDropdown() {
      const dropdown = document.getElementById('product-dropdown');
      dropdown.style.display = dropdown.style.display === 'flex' ? 'none' : 'flex';
  }
  function selectProduct(product, element) {
      if (selectedProducts.has(product)) {
          selectedProducts.delete(product);
          element.classList.remove('selected-option');
      } else {
          selectedProducts.add(product);
          element.classList.add('selected-option');
      }
      updateSelectedProductsDisplay();
      toggleDropdown();
  }
  function updateSelectedProductsDisplay() {
      const selectedContainer = document.getElementById('selected-products');
      selectedContainer.innerHTML = '';

      if (selectedProducts.size === 0) {
          selectedContainer.innerHTML = '<div class="no-select">Select an option</div>';
      } else {
          selectedProducts.forEach(product => {
              const item = document.createElement('div');
              item.className = 'ant-select-selection-overflow-item';
              item.innerHTML = `${product} <span class="ant-select-selection-item-remove" onclick="removeProduct(event, '${product}')">×</span>`;
              selectedContainer.appendChild(item);
          });
      }
  }
  function removeProduct(event, product) {
      event.stopPropagation();
      selectedProducts.delete(product);
      updateSelectedProductsDisplay();
      const dropdownItems = document.querySelectorAll('.ant-select-item-option');
      dropdownItems.forEach(item => {
          if (item.textContent.trim() === product) {
              item.classList.remove('selected-option');
          }
      });
  }
  document.addEventListener('click', function (event) {
      const dropdown = document.getElementById('product-dropdown');
      if (!dropdown.contains(event.target) && !document.querySelector('.ant-select-selector').contains(event.target)) {
          dropdown.style.display = 'none';
      }
  });
  function getUrlParam(param) {
      const urlParams = new URLSearchParams(window.location.search);
      return urlParams.get(param);
  }
  const startTimeInput = document.getElementById('start_time');
  const endTimeInput = document.getElementById('end_time');
  startTimeInput.addEventListener('change', validateTimes);
  endTimeInput.addEventListener('change', validateTimes);

  function validateTimes() {
      const startTime = new Date(startTimeInput.value);
      const endTime = new Date(endTimeInput.value);

      if (endTime < startTime) {
          alert('结束时间不能早于开始时间');
          endTimeInput.value = '';
      }
  }
  let isSubmitting = false;
  document.getElementById('visit-form').addEventListener('submit', async function (event) {
      event.preventDefault();
      if (isSubmitting) {
          return;
      }

      isSubmitting = true;
      const submitButton = document.querySelector('button[type="submit"]');
      if (submitButton) {
          submitButton.disabled = true;
          submitButton.textContent = 'Submitting...';
          submitButton.style.opacity = '0.7';
          submitButton.style.cursor = 'not-allowed';
      }

      const ambassadorId = getUrlParam('id');
      let startTime = document.getElementById('start_time').value;
      let endTime = document.getElementById('end_time').value;
      const startTimeIso = convertToISO(startTime);
      const endTimeIso = convertToISO(endTime);

      const formData = {
          first_name: document.getElementById('first_name').value,
          last_name: document.getElementById('last_name').value,
          phone_number: document.getElementById('phone').value,
          end_time: endTimeIso,
          start_time: startTimeIso,
          interest_yarbo_products: Array.from(selectedProducts),
          why_yarbo_product: document.getElementById('descAll').value,
          email: document.getElementById('email').value,
          ambassador_email: ambassadorId
      };
      try {
          const response = await fetch('https://dev.yarbo.ai/backend/ambassador/visit/face', {
              method: 'POST',
              headers: {
                  'Content-Type': 'application/json',
              },
              body: JSON.stringify(formData),
          });
          if (!response.ok) {
              throw new Error('request failed');
          }
          const responseData = await response.json();
          const ambassadorName = responseData.data.ambassador_name;
          const confirmationUrl = `/showcases/confirmation?name=${encodeURIComponent(formData.first_name + ' ' + formData.last_name)}&email=${encodeURIComponent(formData.email)}&phone=${encodeURIComponent(formData.phone_number)}&type=On-site Showcase&products=${encodeURIComponent(Array.from(selectedProducts).join(','))}&start_time=${encodeURIComponent(startTime)}&end_time=${encodeURIComponent(endTime)}&ambassador_name=${encodeURIComponent(ambassadorName)}`;
          window.location.href = confirmationUrl;
      } catch (error) {
          console.error('request error:', error);
          isSubmitting = false;
          if (submitButton) {
              submitButton.disabled = false;
              submitButton.textContent = 'Submit Request';
              submitButton.style.opacity = '1';
          }
      }
  });
  function convertToISO(dateString) {
      const date = new Date(dateString);
      date.setUTCHours(16, 0, 0, 0);
      return date.toISOString();
  }
</script>

