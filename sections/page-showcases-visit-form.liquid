<div class="w-full px-6 pb-[98px] md:bg-[linear-gradient(to_right,_white_50%,_#F5F5F5_50%)] mobile:pb-[63px]">
    <div class="mx-auto grid w-full max-w-[1600px] grid-cols-2 mobile:grid-cols-1">
        <div class="pr-[51px] pt-[131px] mobile:bg-white mobile:px-4 mobile:py-12">
            <h1 class="text-[56px]/[67px] text-[#02060B] mobile:text-2xl/[29px] >3xl:text-[56px]/[67px]">Visit a
                Neighbor Product Demo Program</h1>
            <p
                class="mt-5 text-[28px]/[39px] font-semibold text-[#676A6D] mobile:mt-[14px] mobile:text-[18px]/[25px] >3xl:mt-[20px] >3xl:text-[28px]/[39px]">
                Discover Yarbo products up close by visiting a Neighbor Product Demo Program near you! Submit your request,
                and our team will connect you with a Yarbo ambassadors who will guide you through the Product Demo Program
                and answer your questions.</p>
            <div class="mt-[65px] flex flex-col gap-[26px] mobile:mt-[30px] mobile:gap-[14px] >3xl:mt-[65px]">
                <h3 class="text-2xl/7 font-medium text-[#676A6D] mobile:text-base/[19px] >3xl:text-2xl/[28px]">
                    Benefits of visiting a Yarbo Neighbor Product Demo Program include:</h3>
                <ul class="list-outside list-disc pl-6 mobile:pl-4">
                    <li
                        class=">3xltext-text-2xl/[28px] text-2xl/7 font-medium text-[#676A6D] mobile:text-base/[19px]">
                        Hands-on experience with Yarbo products in real-world settings before making a purchase.
                    </li>
                    <li
                        class=">3xltext-text-2xl/[28px] text-2xl/7 font-medium text-[#676A6D] mobile:text-base/[19px]">
                        Honest conversations with actual Yarbo owners about their experiences and how Yarbo fits
                        into their lives.</li>
                    <li
                        class=">3xltext-text-2xl/[28px] text-2xl/7 font-medium text-[#676A6D] mobile:text-base/[19px]">
                        Opportunity to see the performance, quality, and design of Yarbo products in action.
                    </li>
                    <li
                        class=">3xltext-text-2xl/[28px] text-2xl/7 font-medium text-[#676A6D] mobile:text-base/[19px]">
                        A relaxed, pressure-free environment with no obligation to buy.</li>
                </ul>
            </div>
        </div>
        <div class="pl-20 pt-[151px] mobile:px-4 mobile:pt-[34px]">
            <h2 class="text-[30px]/none text-[#02060B] mobile:text-2xl/none">Request to Visit</h2>
            <p class="mb-14 mt-4 text-xl/none text-[#02060B] mobile:mb-[35px] mobile:text-sm/none">* Required
            </p>
            <form id="visit-form">
                <div class="form-item">
                    <label for="first_name"><span style="color: red;">*</span>First Name</label>
                    <input type="text" id="first_name" name="first_name" required>
                </div>

                <div class="form-item">
                    <label for="last_name"><span style="color: red;">*</span>Last Name</label>
                    <input type="text" id="last_name" name="last_name" required>
                </div>

                <div class="form-item">
                    <label for="email"><span style="color: red;">*</span>Email</label>
                    <input type="email" id="email" name="email" required>
                </div>

                <div class="form-item">
                    <label for="phone"><span style="color: red;">*</span>Phone Number</label>
                    <input type="tel" id="phone" name="phone" required>
                </div>
                <div class="form-item">
                    <label for="timeframe"><span style="color: red;">*</span>When would you prefer to visit the
                        Neighbor Product Demo Program?</label>
                    <div class="input-time-box">
                        <input type="text" id="start_time" placeholder="Start date" required>
                        <div class="ant-picker-range-separator"><span aria-label="to"
                                class="ant-picker-separator"><span role="img" aria-label="swap-right"
                                    class="anticon anticon-swap-right"><svg viewBox="0 0 1024 1024"
                                        focusable="false" data-icon="swap-right" width="1em" height="1em"
                                        fill="currentColor" aria-hidden="true">
                                        <path
                                            d="M873.1 596.2l-164-208A32 32 0 00684 376h-64.8c-6.7 0-10.4 7.7-6.3 13l144.3 183H152c-4.4 0-8 3.6-8 8v60c0 4.4 3.6 8 8 8h695.9c26.8 0 41.7-30.8 25.2-51.8z">
                                        </path>
                                    </svg></span></span></div>
                        <input type="text" id="end_time" placeholder="End date" required>
                    </div>
                </div>

                <div class="form-item">
                    <label for="first_name"><span style="color: red;">*</span>What Yarbo products are you
                        interested in?</label>
                    <div class="select-container">
                        <div class="ant-select-selector" onclick="toggleDropdown()">
                            <div class="ant-select-selection-overflow" id="selected-products">
                                <div class="no-select">Select an option</div>
                            </div>
                        </div>
                        <div class="ant-select-dropdown" id="product-dropdown">
                            <div class="ant-select-item ant-select-item-option"
                                onclick="selectProduct('Yarbo Core 2024',this)">
                                <div class="ant-select-item-option-content">Yarbo Core 2024</div>
                            </div>
                            <div class="ant-select-item ant-select-item-option"
                                onclick="selectProduct('Yarbo Core 2023',this)">
                                <div class="ant-select-item-option-content">Yarbo Core 2023</div>
                            </div>
                            <div class="ant-select-item ant-select-item-option"
                                onclick="selectProduct('Lawn Mower',this)">
                                <div class="ant-select-item-option-content">Lawn Mower</div>
                            </div>
                            <div class="ant-select-item ant-select-item-option"
                                onclick="selectProduct('Snow Blower',this)">
                                <div class="ant-select-item-option-content">Snow Blower</div>
                            </div>
                            <div class="ant-select-item ant-select-item-option"
                                onclick="selectProduct('Blower',this)">
                                <div class="ant-select-item-option-content">Blower</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-item">
                    <label for="timeframe"><span style="color: red;">*</span>Is there anything specific you
                        would like to learn about or see during your visit?</label>
                    <textarea id="descAll" name="descAll" rows="4" required></textarea>
                </div>

                <button type="submit" class="btn">Submit Request</button>
            </form>

            <p class="mt-[30px] text-xl/6 text-[#777777] mobile:mt-5 mobile:text-xs/[14px]">By submitting this
                form, you agree to Yarbo's <a class="underline" target="_blank"
                    href="/legal/terms-of-service">Terms of Use</a> and <a href="/legal/privacy-policy"
                    class="underline" target="_blank">Privacy Policy</a>.<br><br>Note: You may receive updates,
                calls, or texts from Yarbo’s team regarding your application process.</p>
        </div>
    </div>
</div>
<style>
