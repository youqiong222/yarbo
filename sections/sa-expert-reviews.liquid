{% render 'section-padding', section_id: section.id, settings: section.settings %}
<div class="overflow-hidden {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
  <div class="hidden-lap-and-up w-full">
    <div class="relative aspect-375/250 md:aspect-490/566">
      {% render 'media-element',
        class: 'w-full h-full',
        media_class: 'w-full h-full object-cover',
        media_type: 'image',
        pc_image: section.settings.pc_image,
        h5_image: section.settings.h5_image
      %}
      {%- render 'sn-overlay', _settings: section.settings -%}
    </div>
  </div>
  <div class="page-container">
    <div class="mt-40 flex flex-col items-center md:mt-0 md:flex-row">
      <div class=" hidden-pocket md:w-[34%]">
        <div class="relative aspect-375/250 md:aspect-490/566">
          {% render 'media-element',
            class: 'w-full h-full',
            media_class: 'w-full h-full object-cover',
            media_type: 'image',
            pc_image: section.settings.pc_image,
            h5_image: section.settings.h5_image
          %}
          {%- render 'sn-overlay', _settings: section.settings -%}
        </div>
      </div>
      <div class="w-full flex-1 md:w-[66%] md:pl-60">
        <header class="flex items-end justify-between gap-40">
          <div class="flex flex-col gap-24 md:gap-32">
            <h2 class=" text-[32px] leading-none md:text-[44px] ">
              {{ section.settings.title }}
            </h2>
            {% if section.settings.button != blank %}
              <div class="yb-savings-calculator-btn w-fit cursor-pointer bg-[#FEDB1E] px-32 py-10 text-[15px] leading-[1.3] hover:bg-[#25282a] hover:text-white">
                {{ section.settings.button }}
              </div>
            {% endif %}
          </div>
          <div class="hidden gap-8 md:flex">
            <div class="swiper-button-prev  static m-0 flex h-48 w-48 items-center justify-center rounded-full border border-[#cccccc] bg-white backdrop-blur-[5px] transition-colors duration-300 after:hidden [&.swiper-button-disabled]:bg-[#ccc] [&.swiper-button-disabled]:opacity-100 [&.swiper-button-disabled_path]:stroke-[#A6A6A6] [&:hover]:bg-[#ccc]">
              <svg
                width="8"
                height="14"
                viewBox="0 0 8 14"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M6.75325 12.5859L0.919923 6.7526L6.75325 0.91927" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
              </svg>
            </div>

            <div class="swiper-button-next static m-0 flex h-48 w-48 items-center justify-center rounded-full border border-[#cccccc] bg-white backdrop-blur-[5px] transition-colors duration-300 after:hidden [&.swiper-button-disabled]:bg-[#ccc] [&.swiper-button-disabled]:opacity-100 [&.swiper-button-disabled_path]:stroke-[#A6A6A6] [&:hover]:bg-[#ccc]">
              <svg
                width="8"
                height="14"
                viewBox="0 0 8 14"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M0.91862 0.919434L6.75195 6.75277L0.91862 12.5861" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
              </svg>
            </div>
          </div>
        </header>
        <main class="mt-32 md:mt-40">
          <div class="swiper ">
            <div class="swiper-wrapper">
              {%- for block in section.blocks -%}
                <div class="swiper-slide h-auto!">
                  <div class="flex h-full flex-col bg-[#F2F2F2] p-20 md:p-24">
                    <span class="md:h-44">
                      <svg
                        width="16"
                        height="10"
                        viewBox="0 0 16 10"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path d="M0.52792 9.94478C0.35192 9.94478 0.21992 9.90078 0.13192 9.81278C0.0439199 9.69545 0.0292533 9.53411 0.0879199 9.32878L3.21192 0.440779C3.29992 0.147446 3.49059 0.000779152 3.78392 0.000779152H7.47992C7.86125 0.000779152 8.00792 0.191446 7.91992 0.57278L5.98392 9.46078C5.92525 9.78345 5.73459 9.94478 5.41192 9.94478H0.52792ZM8.09592 9.94478C7.91992 9.94478 7.78792 9.90078 7.69992 9.81278C7.64125 9.69545 7.64125 9.53411 7.69992 9.32878L10.7359 0.440779C10.8239 0.147446 11.0146 0.000779152 11.3079 0.000779152H15.0479C15.4293 0.000779152 15.5759 0.191446 15.4879 0.57278L13.5959 9.46078C13.5373 9.78345 13.3466 9.94478 13.0239 9.94478H8.09592Z" fill="#25282A"/>
                      </svg>
                    </span>
                    <div class="mt-20 mb-auto text-[14px] leading-[1.3] text-[#515355] md:min-h-76 md:text-[15px]">
                      {{ block.settings.content }}
                    </div>

                    <div class="mt-24 flex items-center gap-12 md:mt-32">
                      {% if block.settings.avatar != blank %}
                        <div class="h-50 w-50 overflow-hidden">
                          <img
                            src="{{ block.settings.avatar | image_url: width: 80 }}"
                            alt="{{ block.settings.name }}"
                            width="auto"
                            height="auto"
                            class="h-full w-full object-cover"
                          >
                        </div>
                      {% endif %}

                      <div>
                        <p class="text-[14px] font-bold md:text-[15px]">
                          {{ block.settings.name }}
                        </p>

                        <div class="mt-4 flex gap-2">
                          {% for i in (1..5) %}
                            <svg
                              width="16"
                              height="16"
                              viewBox="0 0 20 20"
                              fill="{% if i <= block.settings.rating %}#FFC107{% else %}#E5E7EB{% endif %}"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path d="M10 15L4.5 18L5.5 12L1 8.5L7 7.5L10 2L13 7.5L19 8.5L14.5 12L15.5 18L10 15Z"/>
                            </svg>
                          {% endfor %}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              {%- endfor -%}
            </div>
          </div>
        </main>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    new Swiper('#shopify-section-{{ section.id }} .swiper', {
      observer: true,
      observeParents: true,
      spaceBetween: 12,
      slidesPerView: 1.15,
      {% if section.settings.auto_rotate %}
      autoplay: { delay: {{ section.settings.change_slides_speed | times: 1000 }}, disableOnInteraction: false },
      {% endif %}
      breakpoints: {
        768: {
          spaceBetween: 12,
          slidesPerView: 2.5,
        },
      },
      navigation: {
        nextEl: '#shopify-section-{{ section.id }} .swiper-button-next',
        prevEl: '#shopify-section-{{ section.id }} .swiper-button-prev',
      },
    });
  })();
</script>
{% schema %}
{
  "name": "Expert Say",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "text",
      "id": "button",
      "label": "Button text"
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_top",
      "label": "H5 Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_bottom",
      "label": "H5 Padding Bottom",
      "default": 0
    },
    {
      "type": "image_picker",
      "id": "pc_image",
      "label": "PC Image"
    },
    {
      "type": "image_picker",
      "id": "h5_image",
      "label": "Mobile Image (Optional)"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show Media Overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    }
  ],
  "blocks": [
    {
      "name": "block",
      "type": "Block",
      "settings": [
        {
          "type": "richtext",
          "id": "content",
          "label": "Content"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Megan"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Expert Say"
    }
  ]
}
{% endschema %}
