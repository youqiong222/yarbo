{%- if recommendations.performed and recommendations.products_count > 0 -%}
  <div class='flex items-center justify-between py-12'>
    <h3 class='text-[13px] leading-[1.1] uppercase md:text-[22px]'>
      {{ 'sections.cart.recommended_products' | t }}
    </h3>
    <div class='flex items-center justify-end gap-8 max-sm:hidden'>
      <div class='swiper-button-prev relative left-0 mt-0 flex h-40 w-40 items-center justify-center rounded-[50%] border border-[#cccccc] after:hidden hover:bg-[#ccc] [&.swiper-button-disabled]:bg-[#ccc]'>
        <svg
          width='8'
          height='14'
          viewBox='0 0 8 14'
          fill='none'
          xmlns='http://www.w3.org/2000/svg'
        >
          <path d="M6.75325 12.5859L0.919923 6.7526L6.75325 0.91927" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
        </svg>
      </div>

      <div class='swiper-button-next relative right-0 mt-0 flex h-40 w-40 items-center justify-center rounded-[50%] border border-[#cccccc] after:hidden hover:bg-[#ccc] [&.swiper-button-disabled]:bg-[#ccc]'>
        <svg
          width='8'
          height='14'
          viewBox='0 0 8 14'
          fill='none'
          xmlns='http://www.w3.org/2000/svg'
        >
          <path d="M0.91862 0.919434L6.75195 6.75277L0.91862 12.5861" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
        </svg>
      </div>
    </div>
  </div>
  <div class='swiper cart-recs__swiper [overflow:unset]'>
    <div class='swiper-wrapper'>
      {%- for recommendation in recommendations.products -%}
        <div class='swiper-slide h-auto!'>
          <a
            href='{{ recommendation.url }}'
            class='group flex h-full items-center bg-[#F2F2F2] p-8 text-[#25282A] no-underline transition-transform duration-300'
          >
            <div class='flex h-60 w-60 shrink-0 items-center justify-center overflow-hidden bg-[#f2f2f2] md:h-92 md:w-92'>
              {%- if recommendation.featured_image != blank -%}
                <img
                  src='{{ recommendation.featured_image | image_url: width: 184 }}'
                  alt='{{ recommendation.featured_image.alt | escape }}'
                  loading='lazy'
                  width='92'
                  height='92'
                  class='h-full w-full object-contain transition-transform duration-500 group-hover:scale-105'
                >
              {%- endif -%}
            </div>
            <div class='flex min-w-0 flex-1 flex-col justify-center py-8 pl-16'>
              <h3 class='text-[14px] leading-[1.2] font-medium uppercase'>
                {{ recommendation.title | escape }}
              </h3>
              <div class='mt-4 text-[14px] text-[#25282A] md:text-[15px]'>
                {{ recommendation.price | money }}
              </div>
            </div>

            {%- assign product_form_id = 'cart-recs-' | append: section.id | append: '-' | append: recommendation.id -%}
            <div class='ml-8'>
              {%- assign add_text = 'products.product.add' | t -%}
              {%- render 'sn-buy-buttons-new',
                add_text: add_text,
                btn_class: 'h-32 min-h-32 px-16 text-[12px]',
                product: recommendation,
                product_form_id: product_form_id,
                section_id: section.id
              -%}
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Cart Recommendations",
  "settings": []
}
{% endschema %}
