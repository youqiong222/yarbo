{% render 'yb-section-style', section: section %}

<div class='custom_tri_column_outter'>
  <div class='yb-section-container'>
    {% if section.settings.heading != blank
      or section.settings.text != blank
      or section.settings.button_text != blank
    %}
      <div class='zj5-section_header'>
        <div class='headerTitle'>
          <h3 class='zj5-section-title yb-section-title'>{{ section.settings.heading }}</h3>
          <div class='zj5-section-des'>{{ section.settings.text }}</div>
        </div>
        {% if section.settings.button_text != blank %}
          {% render 'yb-button',
            type: section.settings.button_type,
            class: 'yb-single-video-btn',
            tag: 'button',
            config: section.settings
          %}
        {% endif %}
      </div>
    {% endif %}

    <div class='lcf-custom_multicolumn'>
      <div class='multicolumn-swiper-slide'>
        <div class='swiper-wrapper'>
          {% for block in section.blocks %}
            <div class='lcf_custom_multicolumn-card swiper-slide' {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                <div class='lcf_custom_tri_column_image_wrapper' style='position: relative;'>
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag: style: 'width:100%;height:100%', loading: 'lazy'
                  }}
                  <div class='column-arrow-separator pc-hidden'>
                    <svg
                      t='1746363969915'
                      class='icon'
                      viewBox='213.33 128 591.36 762.15'
                      version='1.1'
                      xmlns='http://www.w3.org/2000/svg'
                      p-id='1553'
                      width='200'
                      height='200'
                    >
                      <defs>
                        <linearGradient id="myGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                          <stop offset="0%" stop-color="rgba(254, 219, 30, 0)"></stop>
                          <stop offset="100%" stop-color="rgba(254, 219, 30, 1)"></stop>
                        </linearGradient>
                      </defs>
                      <path d="M541.866667 128l262.826666 381.098667h-328.533333L213.333333 128h328.533334zM541.866667 890.154667H213.333333l262.826667-381.056h328.533333l-262.826666 381.056z" fill="url(#myGradient)" p-id="1554"></path>
                    </svg>
                  </div>
                </div>
              {% endif %}
              {% if block.settings.info_text != blank %}
                <div
                  class='lcf-steps lcf_yb-tri-col-body'
                  style='color: {{ block.settings.text_color }}; background: {{ block.settings.bg_color }};'
                >
                  {{ block.settings.info_text }}
                </div>
              {% endif %}
              {% if block.settings.heading != blank %}
                <h4 class='lcf_bz-head-4'>{{ block.settings.heading }}</h4>
              {% endif %}
              {% if block.settings.text != blank %}
                <div class='lcf_yb-multi-col-body'>{{ block.settings.text }}</div>
              {% endif %}
              <div class='column-arrow-separator mobile-hidden'>
                <svg viewBox='213.33 128 591.36 762.15' class='icon' xmlns='http://www.w3.org/2000/svg'>
                  <defs>
                    <linearGradient id="goldenGradient" x1="0%" y1="0%" x2="100%" y2="0%">
                      <stop offset="0%" stop-color="#FEDB1E" stop-opacity="0"/>
                      <stop offset="100%" stop-color="#FEDB1E" stop-opacity="1"/>
                    </linearGradient>
                  </defs>
                  <path d="M541.866667 128l262.826666 381.098667h-328.533333L213.333333 128h328.533334zM541.866667 890.154667H213.333333l262.826667-381.056h328.533333l-262.826666 381.056z"
                        fill="url(#goldenGradient)" />
                </svg>
              </div>
            </div>
          {% endfor %}
        </div>
        <div class='multicolumn-swiper-button-prev'></div>
        <div class='multicolumn-swiper-button-next'></div>
      </div>
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} .column-arrow-separator svg {
      width: 100%;
      height: 100%;
  }
  #shopify-section-{{ section.id }} .swiper-wrapper > .swiper-slide:last-of-type .column-arrow-separator {
      display: none !important;
  }
  {% unless section.blocks.size > 4 %}
      #shopify-section-{{ section.id }} .swiper-backface-hidden .swiper-slide:last-child{
          margin-right: 0px !important;
      }
      #shopify-section-{{ section.id }} .swiper-wrapper {
          justify-content: center;
      }
  {% endunless %}
  #shopify-section-{{ section.id }} .multicolumn-swiper-slide {
      overflow: hidden;
  }
  #shopify-section-{{ section.id }} .lcf-custom_multicolumn{
      position: relative;
  }
  #shopify-section-{{ section.id }} .multicolumn-swiper-button-prev {
      display: flex;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      left: 8px;
      width: 56px;
      height: 56px;
      box-shadow: 0px 4px 12px 0px #00000014;
      background-color: #ffffff;
      border-radius: 50%;
      z-index: 1;
      cursor: pointer;
  }
  #shopify-section-{{ section.id }} .multicolumn-swiper-button-next {
      display: flex;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      right: 8px;
      width: 56px;
      height: 56px;
      box-shadow: 0px 4px 12px 0px #00000014;
      background-color: #ffffff;
      border-radius: 50%;
      z-index: 1;
      cursor: pointer;
  }
  #shopify-section-{{ section.id }} .multicolumn-swiper-button-next::after {
      content: "next";
      transform: translateX(0);
      transition: transform 0.3s ease;
  }

  #shopify-section-{{ section.id }} .multicolumn-swiper-button-next:hover::after {
      transform: translateX(4px);
  }

  #shopify-section-{{ section.id }} .multicolumn-swiper-button-prev::after {
      transform: translateX(0);
      transition: transform 0.3s ease;
      content: "prev";
  }

  #shopify-section-{{ section.id }} .multicolumn-swiper-button-prev:hover::after {
