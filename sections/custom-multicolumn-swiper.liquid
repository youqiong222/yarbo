<script>
  document.addEventListener('DOMContentLoaded', function() {
      let multiColumnSwiper_{{ section.id | replace: '-', '_' }};

      function initMultiColumnSwiper_{{ section.id | replace: '-', '_' }}() {
          const multiColumnScreenWidth = window.innerWidth;
          const swiperElement = document.querySelector("#shopify-section-{{ section.id }} .multicolumn-swiper-slide");

          if (!swiperElement) {
              return;
          }

          if (typeof Swiper === 'undefined') {
              return;
          }

          if (multiColumnSwiper_{{ section.id | replace: '-', '_' }}) {
              multiColumnSwiper_{{ section.id | replace: '-', '_' }}.destroy(true, true);
              multiColumnSwiper_{{ section.id | replace: '-', '_' }} = undefined;
          }

          if (multiColumnScreenWidth > 959) {
              try {
                  multiColumnSwiper_{{ section.id | replace: '-', '_' }} = new Swiper("#shopify-section-{{ section.id }} .multicolumn-swiper-slide", {
                      loop: false,
                      slidesPerView: 4,
                      spaceBetween: 20,
                      speed: 1000,
                      allowTouchMove: true,
                      grabCursor: true,
                      navigation: {
                          nextEl: '#shopify-section-{{ section.id }} .multicolumn-swiper-button-next',
                          prevEl: '#shopify-section-{{ section.id }} .multicolumn-swiper-button-prev',
                      },
                      breakpoints: {
                          1200: {
                              slidesPerView: 4,
                              spaceBetween: 20,
                          },
                          1024: {
                              slidesPerView: 3,
                              spaceBetween: 15,
                          },
                          960: {
                              slidesPerView: 2,
                              spaceBetween: 10,
                          }
                      },
                      on: {
                          init: function() {
                              updateNavigationButtons_{{ section.id | replace: '-', '_' }}();
                          },
                          slideChange: function() {
                              updateNavigationButtons_{{ section.id | replace: '-', '_' }}();
                          },
                          resize: function() {
                              updateNavigationButtons_{{ section.id | replace: '-', '_' }}();
                          }
                      }
                  });
              } catch (error) {
                  console.error(error);
              }
          }
      }

      setTimeout(initMultiColumnSwiper_{{ section.id | replace: '-', '_' }}, 100);

      window.addEventListener('load', function() {
          if (!multiColumnSwiper_{{ section.id | replace: '-', '_' }}) {
              initMultiColumnSwiper_{{ section.id | replace: '-', '_' }}();
          }
      });

      let resizeTimer_{{ section.id | replace: '-', '_' }};
      window.addEventListener('resize', function() {
          clearTimeout(resizeTimer_{{ section.id | replace: '-', '_' }});
          resizeTimer_{{ section.id | replace: '-', '_' }} = setTimeout(initMultiColumnSwiper_{{ section.id | replace: '-', '_' }}, 250);
      });

      function updateNavigationButtons_{{ section.id | replace: '-', '_' }}() {
          const swiper = multiColumnSwiper_{{ section.id | replace: '-', '_' }};
          if (!swiper) return;

          const prevButton = document.querySelector('#shopify-section-{{ section.id }} .multicolumn-swiper-button-prev');
          const nextButton = document.querySelector('#shopify-section-{{ section.id }} .multicolumn-swiper-button-next');

          if (!prevButton || !nextButton) return;

          const canGoPrev = swiper.allowSlidePrev;
          const canGoNext = swiper.allowSlideNext;
          const isBeginning = swiper.isBeginning;
          const isEnd = swiper.isEnd;

          if (isBeginning || !canGoPrev) {
              prevButton.style.opacity = '0.3';
              prevButton.style.pointerEvents = 'none';
              prevButton.style.cursor = 'not-allowed';
          } else {
              prevButton.style.opacity = '1';
              prevButton.style.pointerEvents = 'auto';
              prevButton.style.cursor = 'pointer';
          }

          if (isEnd || !canGoNext) {
              nextButton.style.opacity = '0.3';
              nextButton.style.pointerEvents = 'none';
              nextButton.style.cursor = 'not-allowed';
          } else {
              nextButton.style.opacity = '1';
              nextButton.style.pointerEvents = 'auto';
              nextButton.style.cursor = 'pointer';
          }
      }
  });
</script>

