{% render 'yb-section-style', section: section %}
{% render 'yb-section-common', section: section %}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
{% assign is_only_two = false %}
{% if section.blocks.size == 2 %}
  {% assign is_only_two = true %}
{% endif %}

<div class='comments-main-box swiper'>
  <div class='swiper-wrapper comments-list {% if is_only_two %}comments-list-only-two{% endif %}'>
    {% for block in section.blocks %}
      <div
        class='swiper-slide comments-once {% if is_only_two %}comments-once-only-two{% endif %}'
        {{ block.shopify_attributes }}
      >
        {% render 'yb-snippet-modal-comments',
          class: 'picture-main-box',
          picture: block.settings.picture_image,
          picture_url: block.settings.picture_url,
          video-youtube-url: block.settings.picture_youtube_video_url,
          video-firework-url: block.settings.picture_firework_video_url,
          video: block.settings.picture_video,
          muted: muted
        %}

        {% if block.settings.comments_title != blank or block.settings.people_image != blank or block.settings.comments_small_title != blank %}
          <div class='people-message-main-box'>
            {% if block.settings.people_url != blank %}
              {% assign media_people_url = 'a' %}
            {% else %}
              {% assign media_people_url = 'div' %}
            {% endif %}

            {% if block.settings.people_image != blank %}
              <{{ media_people_url }}
                class='people-picture-box'
                {% if block.settings.people_url != blank %}
                  href='{{ block.settings.people_url }}'
                {% endif %}
                {% unless block.settings.people_image != blank %}
                  style='background:#D9D9D9;'
                {% endunless %}
              >
                {{ block.settings.people_image | image_url: width: 200 | image_tag: class: 'people-picture-img', loading: 'lazy' }}
              </{{ media_people_url }}>
            {% endif %}

            <div class='people-picture-message-box'>
              {% if block.settings.comments_title != blank %}
                <div class='comments_title'>{{ block.settings.comments_title }}</div>
              {% endif %}
              {% if block.settings.comments_small_title != blank %}
                <div class='comments_small_title'>{{ block.settings.comments_small_title }}</div>
              {% endif %}
            </div>
          </div>
        {% endif %}

        {% if block.settings.comments_text != blank %}
          <div class='people-comments-box'>{{ block.settings.comments_text }}</div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
  <div class='comments_swiper-pagination'></div>
  <div class='comments-left-button transform-button {% if is_only_two %}comments-list-only-button{% endif %}'>
    <svg
      xmlns='http://www.w3.org/2000/svg'
      viewBox='0 0 320 512'
    >
      <path d="M41.4 233.4c-12.5 12.5-12.5 32.8 0 45.3l160 160c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L109.3 256 246.6 118.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0l-160 160z"></path>
    </svg>
  </div>
  <div class='comments-right-button transform-button {% if is_only_two %}comments-list-only-button{% endif %}'>
    <svg
      xmlns='http://www.w3.org/2000/svg'
      viewBox='0 0 320 512'
    >
      <path d="M278.6 233.4c12.5 12.5 12.5 32.8 0 45.3l-160 160c-12.5 12.5-32.8 12.5-45.3 0s-12.5-32.8 0-45.3L210.7 256 73.4 118.6c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l160 160z"></path>
    </svg>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
      let commentsSwiper_{{ section.id | replace: '-', '_' }} = null;
      const m_sliderAllowed_{{ section.id | replace: '-', '_' }} = {{ section.settings.M-swiper-show | default: 'false' }};

      function initCommentsSwiper_{{ section.id | replace: '-', '_' }}() {
          destroyCommentsSwiper_{{ section.id | replace: '-', '_' }}();

          const commentsisMobile_{{ section.id | replace: '-', '_' }} = window.innerWidth <= 679;
          const comments_list_number_{{ section.id | replace: '-', '_' }} = {{ section.blocks.size }} === 2;
          const container_{{ section.id | replace: '-', '_' }} = document.querySelector('#shopify-section-{{ section.id }} .comments-main-box');
          const containerList_{{ section.id | replace: '-', '_' }} = document.querySelector('#shopify-section-{{ section.id }} .comments-list');

          if(!container_{{ section.id | replace: '-', '_' }}) return;

          if(commentsisMobile_{{ section.id | replace: '-', '_' }} && m_sliderAllowed_{{ section.id | replace: '-', '_' }}) {
              containerList_{{ section.id | replace: '-', '_' }}.classList.remove("m-no-swiper");
              commentsSwiper_{{ section.id | replace: '-', '_' }} = new Swiper(container_{{ section.id | replace: '-', '_' }}, {
                  slidesPerView: 'auto',
                  spaceBetween: 16,
                  pagination: {
                      el: "#shopify-section-{{ section.id }} .comments_swiper-pagination",
                      clickable: true
                  },
                  resistanceRatio: 0.6,
              });
              return;
          }

          if(commentsisMobile_{{ section.id | replace: '-', '_' }} && !m_sliderAllowed_{{ section.id | replace: '-', '_' }}) {
              containerList_{{ section.id | replace: '-', '_' }}.classList.add("m-no-swiper");
          }

          if(!commentsisMobile_{{ section.id | replace: '-', '_' }} && !comments_list_number_{{ section.id | replace: '-', '_' }}) {
              containerList_{{ section.id | replace: '-', '_' }}.classList.remove("m-no-swiper");
              commentsSwiper_{{ section.id | replace: '-', '_' }} = new Swiper(container_{{ section.id | replace: '-', '_' }}, {
                  slidesPerView: 'auto',
                  spaceBetween: 0,
                  resistanceRatio: 0,
                  speed: 600,
                  watchOverflow: true,
                  navigation: {
                      nextEl: '#shopify-section-{{ section.id }} .comments-right-button',
                      prevEl: '#shopify-section-{{ section.id }} .comments-left-button',
                  },
                  breakpoints: {
                      680: { spaceBetween: 8 },
                      960: { spaceBetween: 16 },
                      1440: { spaceBetween: 16 }
                  },
                  on: {
                      init: function(swiper) { updateSlides_{{ section.id | replace: '-', '_' }}(swiper) },
                      resize: function(swiper) { updateSlides_{{ section.id | replace: '-', '_' }}(swiper) }
                  }
              });
          }
      }

      function destroyCommentsSwiper_{{ section.id | replace: '-', '_' }}() {
          if(commentsSwiper_{{ section.id | replace: '-', '_' }}) {
              commentsSwiper_{{ section.id | replace: '-', '_' }}.destroy(true, true);
              commentsSwiper_{{ section.id | replace: '-', '_' }} = null;
          }
      }

      function updateSlides_{{ section.id | replace: '-', '_' }}(swiper) {
          const width_{{ section.id | replace: '-', '_' }} = window.innerWidth;
          let slidesPerGroup_{{ section.id | replace: '-', '_' }} = 1;

          if (width_{{ section.id | replace: '-', '_' }} >= 1440) slidesPerGroup_{{ section.id | replace: '-', '_' }} = 3;
          else if (width_{{ section.id | replace: '-', '_' }} >= 960) slidesPerGroup_{{ section.id | replace: '-', '_' }} = 2;
          else if (width_{{ section.id | replace: '-', '_' }} >= 680) slidesPerGroup_{{ section.id | replace: '-', '_' }} = 1;

          swiper.params.slidesPerGroup = slidesPerGroup_{{ section.id | replace: '-', '_' }};
          swiper.update();
      }

      initCommentsSwiper_{{ section.id | replace: '-', '_' }}();

      let resizeTimer_{{ section.id | replace: '-', '_' }};
      window.addEventListener('resize', () => {
          clearTimeout(resizeTimer_{{ section.id | replace: '-', '_' }});
          resizeTimer_{{ section.id | replace: '-', '_' }} = setTimeout(() => {
              initCommentsSwiper_{{ section.id | replace: '-', '_' }}();
          }, 300);
      });

      if (Shopify.designMode) {
          document.addEventListener('shopify:section:load', function(event) {
              if (event.detail.sectionId === '{{ section.id }}') {
                  initCommentsSwiper_{{ section.id | replace: '-', '_' }}();
              }
          });
      }
  });
</script>

