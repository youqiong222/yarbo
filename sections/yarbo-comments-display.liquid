{% schema %}
{
  "name": "Yarbo Comments display",
  "class": "migrated-page",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor Id"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景颜色",
      "default": "#e6e6e7"
    },
    {
      "id": "common_title",
      "type": "richtext",
      "label": "标题",
      "default": "<p>Influencer Insights</p>"
    },
    {
      "id": "common_content",
      "type": "richtext",
      "label": "内容",
      "default": "<p>Section Content</p>"
    },
    {
      "type": "text",
      "id": "common_button_text",
      "label": "按钮文字"
    },
    {
      "type": "checkbox",
      "id": "M-swiper-show",
      "label": "移动端滑动展示",
      "default": false,
      "info": "关闭则平铺,只针对680以下"
    },
    {
      "type": "select",
      "id": "common_button_type",
      "label": "按钮类型",
      "default": "link",
      "options": [
        { "value": "link", "label": "链接" },
        { "value": "anchor", "label": "锚点" },
        {
          "value": "modal",
          "label": "弹窗"
        }
      ]
    },
    {
      "type": "text",
      "id": "common_button_link",
      "label": "按钮链接"
    },
    {
      "type": "text",
      "id": "common_button_anchor",
      "label": "按钮锚点ID"
    },
    {
