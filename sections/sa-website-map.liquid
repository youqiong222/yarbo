<style>
  .website_map.active {
    opacity: 1;
    pointer-events: auto;
  }

  .website_map::before {
    content: '';
    position: fixed;
    inset: 0;
    background: #24272980;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .website_map.active::before {
    opacity: 1;
  }
</style>

<div
  x-data='{ open: false }'
  class='website_map pointer-events-none fixed top-0 left-0 z-1000 flex h-full w-full flex-col items-center justify-center overflow-hidden opacity-0 transition-opacity duration-300'
>
  <div class='website_map_desc relative flex h-[70%] w-[90%] flex-col gap-32 overflow-auto bg-white px-16 py-32 md:w-[70%] md:gap-40 md:px-40 md:py-60'>
    <div class='absolute top-16 right-16 cursor-pointer md:top-24 md:right-24'>
      <svg
        width='48'
        height='48'
        viewBox='0 0 48 48'
        fill='none'
        xmlns='http://www.w3.org/2000/svg'
      >
        <foreignObject x="-5" y="-5" width="58" height="58"><div xmlns="http://www.w3.org/1999/xhtml" style="backdrop-filter:blur(2.5px);clip-path:url(#bgblur_0_9445_255184_clip_path);height:100%;width:100%"></div></foreignObject><g data-figma-bg-blur-radius="5">
        <rect width="48" height="48" rx="24" fill="#CCCCCC" fill-opacity="0.4"/>
        <path d="M29 19L19 29M29 29L19 19" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
        </g>
        <defs>
        <clipPath id="bgblur_0_9445_255184_clip_path" transform="translate(5 5)"><rect width="48" height="48" rx="24"/>
        </clipPath></defs>
      </svg>
    </div>
    <h2 class='theme-title pr-[24%] text-[26px] uppercase md:pr-0 md:text-[32px]'>
      {{ section.settings.title }}
    </h2>
    <div class='hidden-phone'>
      <div class=' flex flex-col gap-16 md:gap-32 '>
        {% for block in section.blocks %}
          {% if block.type == 'country' %}
            <div class=' flex flex-col gap-16'>
              <h5 class=' text-[17px] leading-[1.1] uppercase md:text-[20px]'>
                {{ block.settings.country_title }}
              </h5>
              {% assign country_code = localization.country.iso_code
                | downcase
              %}

              {% assign lang_code = localization.language.iso_code | downcase %}
              <div class=' grid grid-cols-1 gap-8 md:grid-cols-3 md:gap-12 '>
                {% for nationalFlag in section.blocks %}
                  {% if nationalFlag.type == 'national-flag'
                    and nationalFlag.settings.id == block.settings.id
                  %}
                    {% assign target_code = nationalFlag.settings.abbreviation
                      | downcase
                    %}
                    <a
                      class='
                        mo-underline flex items-center  justify-between gap-10 border  p-16 text-[13px]  md:text-[14px] {% if country_code == target_code %}
                            border-[#25282a]  bg-[#fcfaf2] {% else %} border-[#cccccc]
                        {% endif %}
                      '
                      href='{{nationalFlag.settings.link}}'
                    >
                      <div class='leading-[1.3]'>
                        {{ nationalFlag.settings.title }}
                      </div>
                      <div class='leading-[1.3] text-[#515355]'>
                        {{ nationalFlag.settings.content }}
                      </div>
                    </a>
                  {% endif %}
                {% endfor %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div class='hidden-lap-and-up'>
      <div class='flex flex-col gap-16 md:gap-32'>
        {% for block in section.blocks %}
          {% if block.type == 'country' %}
            <div
              class='flex flex-col gap-16 border-b border-[#ccc]'
              x-data='{ active: false }'
            >
              <!-- 标题（点击触发） -->
              <h5
                class='flex cursor-pointer items-center justify-between text-[17px] leading-[1.1] uppercase md:text-[20px]'
                @click='active = !active'
              >
                <span>{{ block.settings.country_title }}</span>

                <div
                  class='flex items-center'
                  :class="{ 'rotate-180': active }"
                >
                  <svg
                    width='20'
                    height='20'
                    viewBox='0 0 20 20'
                    fill='none'
                    xmlns='http://www.w3.org/2000/svg'
                  >
                    <path d="M4.1665 7.5L10.0008 13.3333L15.8332 7.5" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
                  </svg>
                </div>
              </h5>

              {% assign country_code = localization.country.iso_code
                | downcase
              %}
              {% assign lang_code = localization.language.iso_code | downcase %}

              <!-- 折叠内容 -->
              <div
                class='grid transition-all duration-300 ease-in-out'
                :class="active ? 'grid-rows-[1fr] opacity-100' : 'grid-rows-[0fr] opacity-0'"
              >
                <div class='overflow-hidden'>
                  <div class='mb-16 grid grid-cols-1 gap-8 md:grid-cols-3 md:gap-12'>
                    {% for nationalFlag in section.blocks %}
                      {% if nationalFlag.type == 'national-flag'
                        and nationalFlag.settings.id == block.settings.id
                      %}
                        {% assign target_code = nationalFlag.settings.abbreviation
                          | downcase
                        %}

                        <a
                          class='
                            mo-underline flex items-center justify-between gap-10 border p-16 text-[13px] md:text-[14px]
                            {% if country_code == target_code %}
                              border-[#25282a] bg-[#fcfaf2]
                            {% else %}
                              border-[#cccccc]
                            {% endif %}
                          '
                          href='{{ nationalFlag.settings.link }}'
                        >
                          <div class='leading-[1.3]'>
                            <span>{{ nationalFlag.settings.title }}</span>
                          </div>

                          <div class='leading-[1.3] text-[#515355]'>
                            {{ nationalFlag.settings.content }}
                          </div>
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const websiteMap = document.querySelector('.website_map');
    const triggers = document.querySelectorAll('.country_nationalFlag');
    const closeBtn = document.querySelector('.website_map svg');
    const header = document.querySelector('.shopify-section--header');
    if (!websiteMap) return;

    let scrollY = 0;

    // 👉 打开
    function openMap() {
      websiteMap.classList.add('active');

      // 锁定滚动（更稳写法）
      document.body.style.position = 'fixed';
      document.body.style.top = `-${scrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
    }

    // 👉 关闭
    function closeMap() {
      websiteMap.classList.remove('active');

      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
    }

    // 👉 toggle
    function toggleMap() {
      if (websiteMap.classList.contains('active')) {
        closeMap();
      } else {
        openMap();
      }
    }

    // ===== 事件绑定 =====

    // 触发按钮（支持多个）
    triggers.forEach((btn) => {
      btn.addEventListener('click', toggleMap);
    });

    // 关闭按钮
    if (closeBtn) {
      closeBtn.addEventListener('click', closeMap);
    }

    // 点击遮罩关闭（利用 before 伪元素）
    websiteMap.addEventListener('click', function (e) {
      // 点在空白区域才关闭
      if (e.target === websiteMap) {
        closeMap();
      }
    });

    // ESC 关闭
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') {
        closeMap();
      }
    });
  });
</script>
{% schema %}
{
  "name": "Website Map",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "title"
    }
  ],
  "blocks": [
    {
      "name": "country",
      "type": "country",
      "settings": [
        {
          "type": "text",
          "id": "id",
          "label": "id"
        },
        {
          "type": "text",
          "id": "country_title",
          "label": "country title"
        }
      ]
    },
    {
      "name": "national flag",
      "type": "national-flag",
      "settings": [
        {
          "type": "text",
          "id": "id",
          "label": "id"
        },
        {
          "type": "text",
          "id": "title",
          "label": "title"
        },
        {
          "type": "text",
          "id": "content",
          "label": "Language Type"
        },
        {
          "type": "url",
          "id": "link",
          "label": "link"
        },
        {
          "type": "text",
          "id": "abbreviation",
          "label": "Abbreviation"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Website Map"
    }
  ]
}
{% endschema %}
