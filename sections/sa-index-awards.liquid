            "text": "Red Dot Design Award"
          }
        },
        {
          "type": "block",
          "settings": {
            "text": "Red Dot Design Award"
          }
        },
        {
          "type": "block",
          "settings": {
            "text": "Red Dot Design Award"
          }
        },
        {
          "type": "block",
          "settings": {
            "text": "Red Dot Design Award"
          }
        }
      ]
    }
  ]
}
{% endschema %}
