{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
{%- liquid
  assign s = section.settings
  assign pc_w = s.pc_aspect_ratio_w | default: 4
  assign pc_h = s.pc_aspect_ratio_h | default: 3
  assign pc_ratio = pc_w | append: '/' | append: pc_h
  assign h5_w = s.h5_aspect_ratio_w | default: 4
  assign h5_h = s.h5_aspect_ratio_h | default: 3
  assign h5_ratio = h5_w | append: '/' | append: h5_h
-%}

<div
  style='
      --padding-top: {{ s.padding_top }}px;
    --padding-bottom: {{ s.padding_bottom }}px;
    --h5-padding-top: {{ s.h5_padding_top }}px;
    --h5-padding-bottom: {{ s.h5_padding_bottom }}px;
    --bg_color: {{ s.bg_color }};
  '
  class='
    bg-(--bg_color)
    pt-(--h5-padding-top)
    pb-(--h5-padding-bottom)
    md:pt-(--padding-top)
    md:pb-(--padding-bottom)
    {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}
  '
>
  <div class='page-container'>
    {% if section.settings.title != blank %}
      <h2 class='theme-title mb-24 text-center text-[28px] leading-[1.1] font-bold uppercase md:mb-40 md:text-[44px]'>
        {{ section.settings.title }}
      </h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class='relative'>
        <div
          style='
            --media-aspect-pc: {{ pc_ratio }};
            --media-aspect-h5: {{ h5_ratio }};
          '
          class='swiper max-md:[overflow:unset]'
        >
          <div class='swiper-wrapper'>
            {% for block in section.blocks %}
              {%- liquid
                assign p = block.settings.product
                if p != blank
                  assign card_url = p.url
                  assign card_title = block.settings.title | default: p.title
                  assign card_image = block.settings.pc_image | default: p.featured_image
                else
                  assign card_url = '#'
                  assign card_title = block.settings.title
                  assign card_image = block.settings.pc_image
                endif
              -%}
              <div class='swiper-slide h-auto!'>
                <div
                  class='flex h-full flex-col rounded-[8px] bg-white p-20 md:p-32'
                  {{ block.shopify_attributes }}
                >
                  <a
                    href='{{ card_url }}'
                    class='relative block aspect-(--media-aspect-h5) overflow-hidden no-underline md:aspect-(--media-aspect-pc)'
                  >
                    {% if card_image != blank %}
                      {% render 'media-element',
                        class: 'absolute inset-0 w-full h-full',
                        media_class: 'w-full h-full object-contain transition-transform duration-500 hover:scale-105',
                        media_type: 'image',
                        pc_image: card_image,
                        h5_image: block.settings.h5_image
                      %}
                    {% endif %}
                  </a>

                  <div class='mt-16 flex flex-1 flex-col items-center text-center md:mt-24'>
                    {% if card_title != blank %}
                      <h3 class='text-[16px] leading-[1.3] font-bold text-[#25282A] md:text-[18px]'>
                        <a
                          href='{{ card_url }}'
                          class='no-underline hover:underline'
                        >
                          {{ card_title }}
                        </a>
                      </h3>
                    {% endif %}

                    {% if p != blank %}
                      <div class='mt-8'>
                        {% render 'sn-main-price', product: p, use_variant: true %}
                      </div>
                    {% endif %}

                    <a
                      href='{{ card_url }}'
                      class='mt-16 inline-flex h-44 w-fit min-w-200 items-center justify-center rounded-full bg-[#FCE300] px-32 text-[14px] text-[#25282A] no-underline transition-colors duration-300 hover:bg-[#25282A] hover:text-white md:mt-24'
                    >
                      {{ block.settings.button_text | default: 'Shop Now' }}
                    </a>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>

        <div class='swiper-button-prev absolute top-1/2 left-12 z-10 m-0 hidden h-40 w-40 -translate-y-1/2 cursor-pointer items-center justify-center rounded-full border border-[#cccccc] bg-white shadow-md transition-colors duration-300 after:hidden hover:bg-[#f2f2f2] md:left-24 md:flex md:h-48 md:w-48 [&.swiper-button-disabled]:opacity-50'>
          <svg
            width='8'
            height='14'
            viewBox='0 0 8 14'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d='M6.75325 12.5859L0.919923 6.7526L6.75325 0.91927' stroke='#25282A' stroke-width='1.3' stroke-linecap='square'/>
          </svg>
        </div>
        <div class='swiper-button-next absolute top-1/2 right-12 z-10 m-0 hidden h-40 w-40 -translate-y-1/2 cursor-pointer items-center justify-center rounded-full border border-[#cccccc] bg-white shadow-md transition-colors duration-300 after:hidden hover:bg-[#f2f2f2] md:right-24 md:flex md:h-48 md:w-48 [&.swiper-button-disabled]:opacity-50'>
          <svg
            width='8'
            height='14'
            viewBox='0 0 8 14'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d='M0.91862 0.919434L6.75195 6.75277L0.91862 12.5861' stroke='#25282A' stroke-width='1.3' stroke-linecap='square'/>
          </svg>
        </div>
      </div>

      <div class='swiper-pagination relative top-auto mt-24 flex justify-center gap-8 md:mt-32'></div>
    {% endif %}
  </div>
</div>

<script>
  (() => {
    const sectionElement = document.querySelector('#shopify-section-{{ section.id }}');
    if (!sectionElement) return;

    const swiperElement = sectionElement.querySelector('.swiper');
    if (!swiperElement) return;

    new Swiper(swiperElement, {
      observer: true,
      observeParents: true,
      spaceBetween: 12,
      slidesPerView: 1.1,
      centeredSlides: false,
      breakpoints: {
        768: {
          spaceBetween: 24,
          slidesPerView: 2,
          centeredSlides: false,
        },
      },
      {%- if section.settings.auto_rotate %}
      autoplay: { delay: {{ section.settings.change_slides_speed | times: 1000 }}, disableOnInteraction: false },
      {% endif -%}
      navigation: {
        nextEl: sectionElement.querySelector('.swiper-button-next'),
        prevEl: sectionElement.querySelector('.swiper-button-prev'),
      },
      pagination: {
        el: sectionElement.querySelector('.swiper-pagination'),
        clickable: true,
        renderBullet: function (index, className) {
          const bulletClasses = `
            ${className}
            rounded-none
            h-[3px] w-32 bg-[#cccccc] cursor-pointer transition-colors duration-300 block m-0
            [&.swiper-pagination-bullet-active]:bg-[#25282A]
          `;
          return `<span class="${bulletClasses.trim().replace(/\s+/g, ' ')}"></span>`;
        },
      },
    });
  })();
</script>

{% schema %}
{
  "name": "Flash Product Swiper",
  "class": "css-reset tailwind-layout",
  "settings": [
    { "type": "text", "id": "anchor_id", "label": "Anchor Id" },
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    { "type": "richtext", "id": "title", "label": "Title" },
    { "type": "header", "content": "Color Settings" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#F2F2F2" },
    { "type": "header", "content": "Spacing Settings" },
    { "type": "number", "id": "padding_top", "label": "Padding Top", "default": 60 },
    { "type": "number", "id": "padding_bottom", "label": "Padding Bottom", "default": 60 },
    { "type": "number", "id": "h5_padding_top", "label": "H5 Padding Top", "default": 40 },
    { "type": "number", "id": "h5_padding_bottom", "label": "H5 Padding Bottom", "default": 40 },
    { "type": "header", "content": "Image Aspect Ratio" },
    { "type": "number", "id": "pc_aspect_ratio_w", "label": "PC Ratio Width", "default": 4 },
    { "type": "number", "id": "pc_aspect_ratio_h", "label": "PC Ratio Height", "default": 3 },
    { "type": "number", "id": "h5_aspect_ratio_w", "label": "Mobile Ratio Width", "default": 4 },
    { "type": "number", "id": "h5_aspect_ratio_h", "label": "Mobile Ratio Height", "default": 3 },
    { "type": "header", "content": "Autoplay" },
    { "type": "checkbox", "id": "auto_rotate", "label": "Auto-rotate slides", "default": false },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Block",
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "header", "content": "Content" },
        { "type": "text", "id": "title", "label": "Title (override, default: product title)" },
        { "type": "text", "id": "button_text", "label": "Button Text", "default": "Shop Now" },
        { "type": "header", "content": "Image (override product image)" },
        { "type": "image_picker", "id": "pc_image", "label": "PC Image" },
        { "type": "image_picker", "id": "h5_image", "label": "H5 Image" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Flash Product Swiper",
      "settings": { "title": "<p>Bundle Up, Save More</p>" },
      "blocks": [{ "type": "block" }, { "type": "block" }, { "type": "block" }, { "type": "block" }]
    }
  ]
}
{% endschema %}
