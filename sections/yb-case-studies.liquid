  .yb-case-studies-card-content-avatar-content-title {
    font-weight: 700;
    font-size: 16px;
    line-height: 140%;
    letter-spacing: 0px;
  }

  .yb-case-studies-card-content-avatar-content-text {
    font-weight: 400;
    font-size: 12px;
    line-height: 140%;
    letter-spacing: 0px;
  }

  .yb-case-studies-card-content-link {
    position: absolute;
    cursor: pointer;
    right: 50px;
    bottom: 64px;
    font-weight: 400;
    font-size: 16px;
    line-height: 140%;
    letter-spacing: 0px;
  }

  .yb-case-studies-card-media {
    width: 480px;
    height: 480px;
    border-radius: 24px;
    background-color: #d9d9d9;
    -webkit-border-radius: 24px;
    -moz-border-radius: 24px;
    -ms-border-radius: 24px;
    -o-border-radius: 24px;
  }

  .yb-case-studies-card-media img,
  .yb-case-studies-card-media video,
  .yb-case-studies-card-media iframe {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    border-radius: 24px;
  }

  .yb-case-studies-content-box .yb-case-studies-swiper-button-next {
    display: flex;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    right: -28px;
    width: 56px;
    height: 56px;
    box-shadow: 0px 4px 12px 0px #00000014;
    background-color: #ffffff;
    border-radius: 50%;
    z-index: 1;
    cursor: pointer;
  }

  .yb-case-studies-content-box .yb-case-studies-swiper-button-prev {
    display: flex;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    left: -28px;
    width: 56px;
    height: 56px;
    box-shadow: 0px 4px 12px 0px #00000014;
    background-color: #ffffff;
    border-radius: 50%;
    z-index: 1;
    cursor: pointer;
  }

  .yb-case-studies-swiper-button-next::after {
    content: 'next';
    transform: translateX(0);
    transition: transform 0.3s ease;
  }

  .yb-case-studies-swiper-button-next:hover::after {
    transform: translateX(4px);
  }

  .yb-case-studies-swiper-button-prev::after {
    transform: translateX(0);
    transition: transform 0.3s ease;
    content: 'prev';
  }

  .yb-case-studies-swiper-button-prev:hover::after {
    transform: translateX(-4px);
  }

  .yb-case-studies-swiper-button-next::after,
  .yb-case-studies-swiper-button-prev::after {
    font-family: swiper-icons;
    font-size: var(--swiper-navigation-size);
    text-transform: none !important;
    letter-spacing: 0;
    font-variant: initial;
    line-height: 1;
    font-size: 18px;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #000000;
    height: 100%;
    width: 100%;
    margin: 0;
  }

