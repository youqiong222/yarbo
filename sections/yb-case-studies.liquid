{% render 'yb-section-style', section: section %}
<style>
  .yb-case-studies-container {
    display: flex;
    flex-flow: column;
    align-items: center;
    gap: 64px;
  }

  .yb-case-studies-content-box {
    width: 1400px;
    display: flex;
    position: relative;
    flex-flow: column;
    padding-bottom: 44px;
  }

  .yb-case-studies-swiper {
    width: 100%;
    height: 480px;
    position: relative;
    overflow: clip;
  }

  .yb-case-studies-swiper .swiper-wrapper {
    align-items: stretch;
  }

  .yb-case-studies-swiper .swiper-slide {
    height: auto;
    display: flex;
  }

  .yb-case-studies-swiper .yb-case-studies-card {
    width: 100%;
    height: 480px;
    border-radius: 24px;
    display: flex;
    gap: 0;
    background-color: #f5f5f5;
  }

  .yb-case-studies-swiper .yb-case-studies-card-with-media {
    height: 480px;
  }

  .yb-case-studies-card-content {
    display: flex;
    position: relative;
    flex-flow: column;
    width: 100%;
    gap: 24px;
  }

  .yb-case-studies-card-with-media .yb-case-studies-card-content {
    width: calc(100% - 480px);
  }

  .yb-case-studies-card-content-title {
    font-weight: 700;
    font-size: 32px;
    line-height: 120%;
    letter-spacing: 0px;
    margin: 0 48px;
    margin-right: 190px;
    margin-top: 64px;
  }

  .yb-case-studies-card-content-text {
    font-weight: 400;
    font-size: 18px;
    line-height: 140%;
    letter-spacing: 0px;
    color: #6e6e73;
    margin: 0 48px;
    margin-right: 190px;
  }

  .yb-case-studies-card-with-media .yb-case-studies-card-content-title,
  .yb-case-studies-card-with-media .yb-case-studies-card-content-text {
    margin-right: 48px;
  }

  .yb-case-studies-card-content-avatar {
    position: absolute;
    left: 48px;
    bottom: 64px;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .yb-case-studies-card-content-avatar-image {
    min-width: 56px;
    width: 56px;
    height: 56px;
    background-color: #d9d9d9;
    border-radius: 50%;
  }

  .yb-case-studies-card-content-avatar-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    border-radius: 50%;
  }

  .yb-case-studies-card-content-avatar-content {
    max-width: 400px;
    display: flex;
    justify-content: center;
    flex-flow: column;
    gap: 6px;
    height: 56px;
