{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
<div class='yb-case-studies-container'>
  {% render 'yb-section-common', section: section %}
  <div class='yb-case-studies-content-box'>
    <div class='yb-case-studies-swiper'>
      <div class='swiper-wrapper'>
        {% for block in section.blocks %}
          <div
            id='yb-case-studies-{{ block.settings.css_style }}'
            class='swiper-slide yb-case-studies-card {% if block.settings.media_image != blank or block.settings.media_local_video != blank or block.settings.media_external_youtube_video != blank or block.settings.media_external_video != blank %}yb-case-studies-card-with-media{% endif %}'
          >
            <div class='yb-case-studies-card-content'>
              <div class='yb-case-studies-card-content-title'>
                {{ block.settings.title }}
              </div>
              <div class='yb-case-studies-card-content-text'>
                {{ block.settings.content }}
              </div>
              {% if block.settings.avatar_image != blank or block.settings.avatar_title != blank or block.settings.avatar_content != blank %}
                <div class='yb-case-studies-card-content-avatar'>
                  {% if block.settings.avatar_image != blank %}
                    <div class='yb-case-studies-card-content-avatar-image'>
                      {{ block.settings.avatar_image | image_url: width: 200 | image_tag }}
                    </div>
                  {% endif %}
                  {% if block.settings.avatar_title != blank or block.settings.avatar_content != blank %}
                    <div class='yb-case-studies-card-content-avatar-content'>
                      {%- if block.settings.avatar_title != blank -%}
                        <div class='yb-case-studies-card-content-avatar-content-title'>
                          {{ block.settings.avatar_title }}
                        </div>
                      {%- endif -%}
                      {%- if block.settings.avatar_content != blank -%}
                        <div class='yb-case-studies-card-content-avatar-content-text'>
                          {{ block.settings.avatar_content }}
                        </div>
                      {%- endif -%}
                    </div>
                  {% endif %}
                </div>
              {% endif %}
              {% if block.settings.link != blank %}
                <a
                  class='yb-case-studies-card-content-link'
                  href='{{ block.settings.link }}'
                >
                  Learn More >
                </a>
              {% endif %}
            </div>
            {% if block.settings.media_image != blank
              or block.settings.media_local_video != blank
              or block.settings.media_external_youtube_video != blank
              or block.settings.media_external_video != blank
            %}
              <div class='yb-case-studies-card-media'>
                {% render 'yb-media', youtube_autoplay: '1', tag: 'media', settings: block.settings %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
    <div class='yb-case-studies-swiper-button-prev'></div>
    <div class='yb-case-studies-swiper-button-next'></div>
    <div class='yb-case-studies-swiper-pagination'></div>
  </div>
</div>
<script>
  (() => {
    const SELECTORS = {
      container: '.yb-case-studies-container',
      swiper: '.yb-case-studies-swiper',
      swiperButtonNext: '.yb-case-studies-swiper-button-next',
      swiperButtonPrev: '.yb-case-studies-swiper-button-prev',
      swiperPagination: '.yb-case-studies-swiper-pagination',
      swiperSlide: '.swiper-slide',
    };

    const containers = document.querySelectorAll(SELECTORS.container);

    const videoController = {
      play: async (video) => {
        console.log('play', video);
        try {
          if (video) {
            await video.play();
          }
        } catch (error) {
          console.warn('视频播放失败:', error);
        }
      },
      stop: (video) => {
        console.log('stop', video);
        if (!video) return;
        if (!video.paused) {
          video.currentTime = 0;
          video.pause();
        }
      },
    };

    const equalizeSlideHeights = (container) => {
      const slides = container.querySelectorAll(SELECTORS.swiperSlide);
      if (slides.length === 0) return;

      const windowWidth = window.innerWidth;

      // 只在移动端统一高度，PC端恢复自然高度
      if (windowWidth <= 959) {
        slides.forEach((slide) => {
          slide.style.height = 'auto';
        });

        requestAnimationFrame(() => {
          let maxHeight = 0;

          slides.forEach((slide) => {
            const slideHeight = slide.offsetHeight;
            if (slideHeight > maxHeight) {
              maxHeight = slideHeight;
            }
          });

          slides.forEach((slide) => {
            slide.style.height = `${maxHeight}px`;
          });
        });
      } else {
        slides.forEach((slide) => {
          slide.style.height = '360px';
        });
      }
    };

    const initSwiper = (container) => {
      const swiperConfig = {
        spaceBetween: 20,
        pagination: {
          el: SELECTORS.swiperPagination,
        },
        navigation: {
          nextEl: SELECTORS.swiperButtonNext,
          prevEl: SELECTORS.swiperButtonPrev,
        },
      };

      const updateSwiperPagination = (activeSlide) => {
        const slideHeight = activeSlide.offsetHeight;
        console.log(slideHeight);
        const pagination = container.querySelector(SELECTORS.swiperPagination);
        if (pagination) {
          pagination.style.top = `${slideHeight}px`;
        }
      };

      const updateSwiperButton = (activeSlide) => {
        const windowWidth = window.innerWidth;
        if (windowWidth <= 959) {
          return;
        }
        const slideHeight = activeSlide.offsetHeight;
        const swiperButtonNext = container.querySelector(SELECTORS.swiperButtonNext);
        if (swiperButtonNext) {
          const swiperButtonNextHeight = swiperButtonNext.offsetHeight;
          swiperButtonNext.style.top = `${(slideHeight - swiperButtonNextHeight) / 2}px`;
          swiperButtonNext.style.transform = `unset`;
        }
        const swiperButtonPrev = container.querySelector(SELECTORS.swiperButtonPrev);
        if (swiperButtonPrev) {
          const swiperButtonPrevHeight = swiperButtonPrev.offsetHeight;
          swiperButtonPrev.style.top = `${(slideHeight - swiperButtonPrevHeight) / 2}px`;
          swiperButtonPrev.style.transform = `unset`;
        }
      };

      const videos = container.querySelectorAll('video');
      swiperConfig.on = {
        slideChange: function () {
          videos.forEach((video) => {
            videoController.stop(video);
          });

          const activeSlide = this.slides[this.activeIndex];
          if (!activeSlide) return;

          const activeVideo = activeSlide.querySelector('video');
          if (activeVideo) {
            videoController.play(activeVideo);
          }
          updateSwiperPagination(activeSlide);
          updateSwiperButton(activeSlide);
        },
        init: function () {
          // equalizeSlideHeights(container);

          const firstVideo = this.slides[0]?.querySelector('video');
          if (firstVideo) {
            videoController.play(firstVideo);
          }
          updateSwiperPagination(this.slides[0]);
          updateSwiperButton(this.slides[0]);
        },
      };

      var swiper = new Swiper(container.querySelector(SELECTORS.swiper), swiperConfig);

      swiper.on('resize', function () {
        // equalizeSlideHeights(container);
        updateSwiperPagination(this.slides[this.activeIndex]);
        updateSwiperButton(this.slides[this.activeIndex]);
      });

      return swiper;
    };

    const init = () => {
      containers.forEach((container) => {
        initSwiper(container);
      });
    };

    init();
  })();
</script>
