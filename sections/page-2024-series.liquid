    <script>
      function scrollToTab(targetId, tab) {
        document.querySelectorAll('.tab-item').forEach((item) => {
          item.classList.remove('active');
          item.style.backgroundColor = 'transparent';
          item.style.color = item.dataset.tabTitleColor || '';
        });
        tab.classList.add('active');
        tab.style.backgroundColor = tab.dataset.activeTabBgColor || '';
        tab.style.color = tab.dataset.activeTabTitleColor || '';

        const target = document.getElementById(targetId);
        if (target) {
          window.scrollTo({
            top: target.offsetTop - 100,
            behavior: 'smooth',
          });
        }
      }

      function checkTabOverflow() {
        const wrapper = document.getElementById('tabsWrapper');
        const rightArrow = document.getElementById('scrollArrowRight');
        const leftArrow = document.getElementById('scrollArrowLeft');
        const threshold = 10;

        if (wrapper.scrollWidth > wrapper.clientWidth) {
          wrapper.style.justifyContent = 'flex-start';
          rightArrow.style.display =
            wrapper.scrollLeft + wrapper.clientWidth < wrapper.scrollWidth - threshold ? 'block' : 'none';
          leftArrow.style.display = wrapper.scrollLeft > threshold ? 'block' : 'none';
        } else {
          rightArrow.style.display = 'none';
          leftArrow.style.display = 'none';
        }
      }

      document.addEventListener('DOMContentLoaded', function () {
        const wrapper = document.getElementById('tabsWrapper');
        const rightArrow = document.getElementById('scrollArrowRight');
        const leftArrow = document.getElementById('scrollArrowLeft');

        rightArrow.addEventListener('click', function () {
          wrapper.scrollBy({ left: 100, behavior: 'smooth' });
          setTimeout(checkTabOverflow, 50);
        });

        leftArrow.addEventListener('click', function () {
          wrapper.scrollBy({ left: -100, behavior: 'smooth' });
          setTimeout(checkTabOverflow, 50);
        });

        wrapper.addEventListener('scroll', checkTabOverflow);
        checkTabOverflow();

        window.addEventListener('resize', checkTabOverflow);
      });
    </script>
