        }
      });
      window.addEventListener('scroll', function () {
        const element = document.querySelector('#yb-banner-swiper-mobile-cta-container__174891570992209d6525');
        if (!element) return;
        const scrollY = window.scrollY || document.documentElement.scrollTop;
        const mobileImage = document.querySelector('#yb-banner-swiper__174891570992209d6525 #yb-banner-mobile-image');
        const rect = mobileImage.getBoundingClientRect(); // 获取视口内坐标
        const topFromPage = rect.top; // 最终距离页面顶部的值
        if (rect.bottom <= 0) {
          // 滚动超过 100px 时触发吸顶
          element.classList.add('yb-banner-swiper-fixed-btns__operate');
        } else {
          element.classList.remove('yb-banner-swiper-fixed-btns__operate');
        }
      });

      // 锚点点击事件处理
      function initAnchorLinks() {
        document
          .querySelectorAll('#yb-banner-swiper__174891570992209d6525 .yb-banner-swiper-anchor-link')
          .forEach((link) => {
            link.addEventListener('click', function (e) {
              e.preventDefault();
              const anchorId = this.getAttribute('data-anchor-id');
              if (!anchorId) return;

              const anchorElement = document.getElementById(`shopify-section-${anchorId}`);
              if (anchorElement) {
                window.scrollTo({
                  top: anchorElement.offsetTop - 120,
                  behavior: 'smooth',
                });
              } else {
                console.warn(`[yb-banner-swiper] 未找到对应的锚点元素: shopify-section-${anchorId}`);
              }
            });
          });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAnchorLinks);
      } else {
        initAnchorLinks();
