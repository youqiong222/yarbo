<style>
  #shopify-section-{{ section.id }} {
    position: sticky;
    top: 0;
    z-index: 11;
  }
  .anchor-views-section {
    background: {{ section.settings.bg_color }};

    overflow: hidden;
  }
  .anchor-views-action span {
    display: block;
    padding: 0px 16px;
    transition: all 0.3s;
    cursor: pointer;
    white-space: nowrap;
    border-radius: 100px;
    color: {{ section.settings.label_color }};
  }

  .anchor-views-action span:hover,
  .anchor-views-action span.active {
    background-color: {{ section.settings.label_bac }};
    color: {{ section.settings.label_active_color }};
        text-decoration: underline;
  }
  #shopify-section-{{ section.id }} .swiper-slide {
    width: auto !important;
  }
  @media screen and (min-width: 1000px) {
    .anchor-views-action-container {
      display: flex;
    }
  }
  @media screen and (max-width: 999px) {
    .anchor-views-action-container {
      overflow: hidden;
      display: flex;
    }
    .anchor-views-action span {
      padding: 0px 8px;
    }
    .anchor-views-action {
      justify-content: flex-start;
    }
  }
  @media screen and (max-width: 768px) {
    .anchor-views-action-container {
      margin: 0 -12px;
    }
  }
</style>

{% if section.blocks.size > 0 %}
  <div class='anchor-views-section py-16'>
    <div class='container'>
      <div class='anchor-views-action-container'>
        <div class='swiper'>
          <div class='swiper-wrapper anchor-views-action'>
            {% for block in section.blocks %}
              <div class='swiper-slide'>
                <xo-animate xo-cascade>
                  <span
                    data-view='{{ block.settings.anchor_id }}'
                    class='{% if forloop.first %}active{% endif %} text-[14px] leading-[1.3] md:text-[18px]'
                  >
                    {{ block.settings.title }}
                  </span>
                </xo-animate>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
{% endif %}

<script>
  document.addEventListener('DOMContentLoaded', () => {
    let swiperInstance = null;

    // 绑定点击事件
    const bindClickEvents = () => {
      const section = document.querySelector('#shopify-section-{{ section.id }}');
      if (!section) return;

      const spans = section.querySelectorAll('.anchor-views-action span');

      spans.forEach((span) => {
        // 移除旧事件（模拟 .off('click')），在原生中通常通过替换节点或使用一次性监听，
        // 这里采用先移除监听器（需命名函数）或简单覆盖
        span.onclick = function () {
          // 移除所有 active 类
          spans.forEach((s) => s.classList.remove('active'));
          // 当前元素添加 active
          this.classList.add('active');

          // 横向居中当前 tab
          const slide = this.closest('.swiper-slide');
          if (slide) {
            slide.scrollIntoView({
              behavior: 'smooth',
              inline: 'center',
              block: 'nearest',
            });
          }

          // 获取 data-view
          const anchorKey = this.getAttribute('data-view');
          if (!anchorKey) return;

          // ✅ 改成通过 data-anchor-target-id 查找
          const target = document.querySelector(`[data-anchor-target-id="${anchorKey}"]`);
          if (!target) return;

          // header 高度
          const header = document.querySelector('.header');
          const headerHeight = header ? header.offsetHeight : 0;

          // 计算滚动位置
          // target.getBoundingClientRect().top 是相对于视口的距离，加上 window.scrollY 得到相对于文档顶部的距离
          const targetTop = target.getBoundingClientRect().top + window.scrollY;
          const offsetTop = targetTop - headerHeight - 10;

          // 原生平滑滚动
          window.scrollTo({
            top: offsetTop,
            behavior: 'smooth',
          });
        };
      });
    };

    const initProductViewsSwiper = (autoScroll = false) => {
      const swiperContainer = document.querySelector('#shopify-section-{{ section.id }} .swiper');
      if (!swiperContainer) return;

      if (swiperInstance) {
        // 已有实例，只更新
        swiperInstance.update();
      } else {
        // 首次初始化 Swiper (假设 Swiper 已全局引入)
        swiperInstance = new Swiper(swiperContainer, {
          slidesPerView: 'auto',
          centeredSlides: false,
          spaceBetween: 16,
          freeMode: true,
        });
      }

      bindClickEvents();
    };

    // 首次初始化
    initProductViewsSwiper(true);

    // resize 时只更新
    window.addEventListener('resize', () => {
      initProductViewsSwiper(false);
    });
  });
</script>

{% schema %}
{
  "name": "Special Offers Anchor",
  "tag": "section",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "header",
      "content": "color settings"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Bg Color",
      "default": "#349440"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "label_bac",
      "label": "Label Bac",
      "default": "#FEDB1E"
    },
    {
      "type": "color",
      "id": "label_active_color",
      "label": "Label Active Color",
      "default": "#02060B"
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "View Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "Anchor Id"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Special Offers Anchor",
      "settings": {}
    }
  ]
}
{% endschema %}
