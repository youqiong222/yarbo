<style>
  /* 整体容器 */
  .design-your-yarbo {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: end;
    background-color: #fff;
  }

  /* PC端左侧轮播 */
  .design-your-yarbo__pc-left-image-slideshow {
    position: sticky;
    top: 38px;
    height: 833px;
    left: 0;
    width: calc(100% - 456px);
  }


  .dyy-slideshow {
    height: 100%;
  }
  .dyy-slideshow__slide {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dyy-slideshow__slide.is-active {
    opacity: 1;
    position: relative;
  }

  .dyy-slideshow__slide img {
    max-width: 100%;
    max-height: 100%;
    width: 100%;
    height: 100%;
    object-fit: contain;
    outline: none;
  }

  /* 右侧产品选择区域 */
  .dyy-product-selector {
    width: 100%;
  }

  @media (min-width: 992px) {
    .dyy-product-selector {
      width: 456px;
      display: flex;
      flex-direction: column;
      gap: 280px;
      padding: 152px 48px 80px;
    }
  }

  /* 产品块样式 */

  .dyy-product__image {
    width: 100%;
    margin-bottom: 20px;
    display: none;
  }

  @media (max-width: 991px) {
    .dyy-product__image {
      display: block;
    }
  }

  .dyy-product__image img {
    width: 100%;
    height: auto;
    max-height: 400px;
    object-fit: contain;
  }

  .dyy-product__title {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #000;
    margin: 0;
  }

  .dyy-product__title--big {
    font-size: 40px;
  }

  .dyy-product__desc {
    font-size: 16px;
    line-height: 1.25;
    margin: 0;
    margin-top: calc(16px - 48px);
    color: #676a6d;
  }
  .dyy-product__content {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
  /* 特色功能 */
  .dyy-product__main-body-desc {
    margin: 0;
    display: flex;
    justify-content: space-between;
  }

  .dyy-product__featured {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .dyy-product__featured-icon {
    display: block;
    width: 48px;
    height: 48px;
  }

  .dyy-product__featured-name {
    font-size: 12px;
    line-height: 16px;
    color: #02060b;
  }

  /* 产品选项 */
  .dyy-product__group {
    border: none;
    padding: 0;
    margin: 0 0 16px 0;
  }

  .dyy-product__item {
    margin-bottom: 16px;
  }

  .dyy-product__option {
    cursor: pointer;
  }

  #shopify-section-{{section.id }} .dyy-product__option-input {
    display: none;
  }

  .dyy-product__option-label {
    display: flex;
    align-items: center;
    gap: 12px;
    border: 2px solid #cccdce;
    color: #676a6d;
    transition: all 0.3s;
    border-radius: 4px;
    padding: 16px;
    font-size: 14px;
    line-height: 20px;
    user-select: none;
  }

  .dyy-product__option-input:checked + .dyy-product__option-label {
    border-color: #000;
    background-color: #f9f9f9;
  }

  .dyy-product__option-icon {
    position: relative;
    color: #02060b;
    border-radius: 50%;
    width: 16px;
    height: 16px;
    border: 1px solid currentColor;
    background-color: #fff;
    transition: all 0.3s;
  }

  .dyy-product__option-icon svg {
    position: absolute;
    width: 8px;
    height: 8px;
    color: #fff;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }

  .dyy-product__option-input:checked + .dyy-product__option-label .dyy-product__option-icon {
    background-color: #000;
  }

  .dyy-product__option-title {
    flex: 1 0 0;
  }

  /* 提示文本 */
  .dyy-product__hint {
    font-size: 12px;
    line-height: 16px;
    color: #676a6d;
    padding: 14px 16px;
    background-color: #f4f4f4;
    margin: 0;
    border-radius: 4px;
  }

  /* 按钮 */
  .dyy-product__more-button {
    margin-top: 12px;
    background-color: #f4f4f4;
    color: #02060b;
    cursor: pointer;
    padding: 10px;
    font-size: 12px;
    line-height: 1;
    outline: none;
    border: 0;
    display: block;
    width: 100%;
    text-align: center;
    font-weight: bold;
    transition: all 0.3s;
    border-radius: 4px;
    text-decoration: none;
  }

  #shopify-section-{{section.id }} .dyy-product__more-button:hover {
    background-color: #000;
    color: #fff;
  }

  /* 弹出窗口 */
  .dyy-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .dyy-modal.is-visible {
    display: flex;
  }

  .dyy-modal__container {
    background-color: #fff;
    width: 90%;
    max-width: 1200px;
    max-height: 90vh;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
  }

  .dyy-modal__header {
    padding: 24px;
    border-bottom: 1px solid #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .dyy-modal__title {
    font-size: 24px;
    font-weight: 600;
    color: #000;
  }

  .dyy-modal__close {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    background: none;
  }

  .dyy-modal__close svg {
    width: 24px;
    height: 24px;
    color: #000;
  }

  .dyy-modal__content {
    padding: 24px;
    overflow-y: auto;
    max-height: calc(90vh - 80px);
  }

  .dyy-modal-slide__main {
    flex: 1;
    min-width: 0;
  }


  /* 隐藏类 */
  .dyy-hidden-md {
    display: none;
  }
  .design-your-yarbo-includes {
    position: sticky;
    top: 100%;
    z-index: 9;
    display: block;
    width: calc(100% - 456px);
  }
  .design-your-yarbo-includes .floating-button {
    position: absolute;
    top: auto;
    bottom: 0;
    left: 50%;
    width: fit-content;
    max-width: 100%;
    transform: translateX(-50%);
    white-space: nowrap;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    background-color: #f4f4f4;
    padding: 20px 32px;
    font-size: 18px;
    font-weight: 500;
    border: none;
  }
  .design-your-yarbo-includes .floating-button-container {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 24px;
  }
  .design-your-yarbo-includes .floating-button-toggle {
    display: flex;
    height: 32px;
    width: 32px;
    flex-shrink: 0;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background-color: white;
    box-shadow: inset 0 2px 4px 0 rgba(255, 255, 255, 0.1);
  }
  .design-your-yarbo-includes .floating-button-toggle svg {
    display: block;
    transform: rotate(-180deg);
    font-size: 16px;
  }
  .design-your-yarbo-includes .floating-button-divider {
    display: inline-block;
    height: 32px;
    width: 1px;
    border-radius: 9999px;
    background-color: #cccdce;
  }
  .design-your-yarbo-includes .floating-button-price-row {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .design-your-yarbo-includes .floating-button-total-price {
    font-size: 20px;
    font-size: clamp(16px, 1.6vw, 20px);
    line-height: 1.5;
    font-weight: 600;
  }
  .design-your-yarbo-includes .floating-button-total-price::before {
    content: 'Total Price: ';
  }
  .design-your-yarbo-includes .floating-button-buy {
    display: flex;
    gap: 6px;
    height: 42px;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background-color: #ffd700;
    padding: 0 32px;
    font-size: 16px;
    font-weight: 500;
    border: none;
  }
  .loading-overlay__spinner {
    display: none;
  }
  .design-your-yarbo-includes .modal-overlay {
    position: fixed;
    left: 0;
    top: 0;
    display: none;
    height: 100vh;
    width: 100vw;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.3);
    font-family: sans-serif;
    backdrop-filter: blur(4px);
    z-index: 1010;
  }
  .design-your-yarbo-includes .modal-overlay.active {
    display: flex;
    animation: design-your-yarbo-includes-fadeIn 0.26s ease-in-out;
  }
  .design-your-yarbo-includes .modal-container {
    display: flex;
    height: 100%;
    width: 100%;
    flex-direction: column;
    overflow: hidden;
    background-color: white;
    padding: 20px 24px 24px;
  }
  .design-your-yarbo-includes .modal-header {
    margin-bottom: 16px;
    display: flex;
    width: 100%;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
  }
  .design-your-yarbo-includes .modal-content {
    display: flex;
    width: 100%;
    flex: 1;
    flex-direction: column;
    overflow: hidden;
  }
  .design-your-yarbo-includes .modal-title {
    font-size: 20px;
    font-weight: 600;
    color: #02060b;
  }
  .design-your-yarbo-includes .modal-close {
    height: 36px;
    width: 36px;
    cursor: pointer;
    border-radius: 9999px;
    background-color: #f2f2f2;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .design-your-yarbo-includes .modal-close svg {
    font-size: 20px;
    line-height: 36px;
  }
  .design-your-yarbo-includes.empty .empty-cart-container {
    display: flex;
  }
  .design-your-yarbo-includes .empty-cart-container {
    display: none;
    height: 100%;
    width: 100%;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #fff;
  }
  .design-your-yarbo-includes .empty-cart-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .design-your-yarbo-includes .empty-cart-image {
    position: relative;
    margin-bottom: 8px;
    height: 149px;
    width: 200px;
  }
  .design-your-yarbo-includes .empty-cart-image img {
    position: absolute;
    height: 100%;
    width: 100%;
    inset: 0;
    color: transparent;
  }
  .design-your-yarbo-includes .empty-cart-message {
    margin-bottom: 20px;
    font-size: 14px;
    line-height: 1;
    color: #676a6d;
  }
  .design-your-yarbo-includes .empty-cart-button {
    cursor: pointer;
    border-radius: 9999px;
    border: 1px solid #000;
    padding: 16px 40px;
    font-size: 16px;
    line-height: 1;
  }
  .design-your-yarbo-includes .modal-product-list {
    display: flex;
    height: 100%;
    flex-direction: column;
    overflow: scroll;
    scrollbar-width: none;
  }
  .design-your-yarbo-includes .modal-product-item {
    display: flex;
    width: 100%;
    flex-direction: row;
    border-top: 1px solid #eee;
    padding-top: 12px;
    padding-bottom: 12px;
  }
  .design-your-yarbo-includes .modal-product-image {
    position: relative;
    margin-right: 16px;
    height: 88px;
    width: 88px;
  }
  .design-your-yarbo-includes .modal-product-image img {
    position: absolute;
    height: 100%;
    width: 100%;
    inset: 0;
    object-fit: cover;
  }
  .design-your-yarbo-includes .modal-product-info {
    flex: 1;
    padding-top: 12px;
  }
  .design-your-yarbo-includes .modal-product-price-row {
    margin-bottom: 16px;
    display: flex;
    width: 100%;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    line-height: 16px;
    font-size: 16px;
    font-weight: 500;
  }
  .design-your-yarbo-includes .modal-product-action-row {
    display: flex;
    width: 100%;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    color: #676a6d;
  }
  .design-your-yarbo-includes .modal-product-remove {
    font-size: 12px;
    text-decoration: underline;
    cursor: pointer;
  }
  .design-your-yarbo-includes .modal-product-original-price {
    font-size: 14px;
    text-decoration: line-through;
  }
  .design-your-yarbo-includes .modal-summary {
    height: fit-content;
    border-color: #eee;
    padding-top: 24px;
  }
  .design-your-yarbo-includes .modal-summary-total {
    width: 100%;
    font-size: 18px;
    line-height: 1.25;
    font-weight: 500;
  }
  .design-your-yarbo-includes .modal-summary-total span:first-child {
    margin-right: 28px;
  }
  .design-your-yarbo-includes.empty .modal-product-list,
  .design-your-yarbo-includes.empty .modal-summary {
    display: none;
  }
  /* 弹出窗口幻灯片 */
  .feature_details_popup {
    display: none;
  }

  .feature_details_popup.active {
    display: block;
  }

  .feature_details_popup{
    position: fixed;
    inset: 0;
    z-index: 1031;
    width: 60vw;
    height: fit-content;
    margin: auto;
    background-color: transparent;
    animation-duration: 0.2s;
    animation-timing-function: ease;
  }
  .feature_details_popup .swiper{
    overflow: unset;
    max-width: 996px;
  }
  .feature_details_popup .swiper-slide{
    display: flex;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 12px;
    background-color: #fff;
  }

  .dyy-modal-slide__title {
    font-size: 28px;
    line-height: 1;
    font-weight: 600;
    color: #000;
    margin: 0
  }
  #shopify-section-{{ section.id }} p{
    margin: 0;
  }
  .dyy-modal-slide__desc {
    font-size: 16px;
    line-height: 1.6;
    color: #333;
    margin-top: 16px;
    flex: 1 0 0;
  }

  .dyy-modal-slide__hint {
    font-size: 14px;
    color: #666;
    font-style: italic;
    margin-top: 16px;
  }

  .dyy-modal-slide__close-btn {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: none;
    cursor: pointer;
  }

  .dyy-modal-slide__close-btn svg {
    width: 24px;
    height: 24px;
    color: #000;
  }

  #shopify-section-{{ section.id }} .media-container {
    position: relative;
    overflow: hidden;
  }
  #shopify-section-{{ section.id }} .media-container video-intersection-insert,
  #shopify-section-{{ section.id }} .media-container img,
  #shopify-section-{{ section.id }} .media-container video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .feature_details_popup .left_image .media-container{
    flex: unset;
    border-radius: 0;
  }
  .feature_details_popup .left_image .dyy-modal-slide__main{
    flex: 1 0 0;
    text-align: left;
  }
  .feature_details_popup .media-container{
    height: 50vh;
    width: 100%;
    overflow: hidden;
  }
  .feature_details_popup .bottom_image .dyy-modal-slide__main{
    flex: 1 0 0;
    text-align: center;
  }
  .feature_details_popup .dyy-modal-slide__main{
    display: flex;
    flex-direction: column;
    text-align: center;
    color: #040921;
  }
  .feature_details_popup .swiper-btn.swiper-button-prev{
    left: 10%;
  }
  .feature_details_popup .swiper-btn.swiper-button-next{
    right: 10%;}
  .feature_details_popup .swiper-btn:after{
    content: unset;
  }
  .feature_details_popup .swiper-btn svg{
    width: 70%;
    height: 70%;
  }
  .feature_details_popup .swiper-pagination {
    bottom: 30px;
  }
  .feature_details_popup .swiper-pagination .swiper-pagination-bullet-active {
    background: #fff;
  }
  .feature_details_popup .swiper-btn {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 0;
    background-color: rgba(0, 0, 0, 0.4);
    outline: none;
    cursor: pointer;
    margin: 0;
    padding: 0;
    border-radius: 50%;
    color: #fff;
    z-index: 10;
    position: fixed;
  }
  .feature_details_popup .popup-overlay{
    height: 100%;
    width: 100%;
    background: #00000061;
    position: fixed;
    top: 0;
    left: 0;
  }
  .feature_details_popup .popup-close{
    position: absolute;
    top: 20px;
    right: 20px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: transparent;
    transition: background .3s;
    border: 0;
    outline: none;
    margin: 0;
    cursor: pointer;
  }
  .design-your-yarbo-includes.empty .floating-button-buy{
    cursor: no-drop;
    opacity: 0.8;
  }
  #shopify-section-{{ section.id }} div:empty {
    display: block!important;
  }
  @media (max-width: 958px) {
    .dyy-hidden-md {
      display: block !important;
    }
    .dyy-hidden-pc {
      display: none !important;
    }
    .design-your-yarbo__pc-left-image-slideshow{
      display: none;
    }
    .dyy-product__content {
      padding: 0 20px;
      gap: 48px;
    }
    .dyy-product__title{
      font-size: 28px;
      line-height: 34px;
    }
    .dyy-product__desc {
        margin-top: calc(16px - 32px);
    }
    .dyy-product__image img{
      aspect-ratio: 375 / 230;
      object-fit: contain;
    }
    .feature_details_popup{
      width: 86vw;
    }
    .feature_details_popup .swiper-slide{
      flex-direction: column;
      padding: 0;
      gap: 0;
      overflow: hidden;
      overflow-y: auto;
      display: block;
    }
    .feature_details_popup .dyy-modal-slide__main{
      padding: 24px 20px;
    }
    .dyy-modal-slide__title{
      text-align: center;
        font-size: 20px;
        line-height: 28px;
    }
    .dyy-modal-slide__desc{
      margin-top: 8px;
        text-align: center;
        word-spacing: -1px;
    }
    .feature_details_popup .media-container{
      aspect-ratio: 1 / 1;
      height: auto;
    }
    .feature_details_popup .swiper-pagination{
      bottom: -15%;
    }
    .feature_details_popup .popup-close{
      top: 16px;
        right: 16px;
        width: 32px;
        height: 32px;
        background-color: rgb(242 242 242 / 0.5);
        z-index: 10;
    }
    .design-your-yarbo-includes{
      top: 0;
    }
    .design-your-yarbo-includes .floating-button{
      top: 0;
      bottom: unset;
      left: 0;
      transform: unset;
      padding: 18px 16px;
      font-size: 16px;
      max-width: unset;
      width: 100%;
    }
    .design-your-yarbo-includes .floating-button-divider{
      display: none;
    }
    .design-your-yarbo-includes .floating-button-container{
      gap: 8px;
      justify-content: flex-start;
    }
    .design-your-yarbo-includes .floating-button-toggle{
      width: 18px;
      height: 18px;
    }
    .design-your-yarbo-includes .floating-button-content{
      flex: 1;
    }
    .design-your-yarbo-includes{
      width: 100%
    }
    .design-your-yarbo-includes .floating-button-buy{
      height: 26px;
      font-size: 12px;
      padding: 8px;
    }
    .design-your-yarbo-includes .modal-summary{
      width: 100%;
      border-top-width: 1px;
      border-top-style: solid;
    }
    .design-your-yarbo-includes .modal-product-price-row{
      gap: 8px;
    }
    .feature_details_popup .swiper{
      height: 490px;
    }
  }
  @media (min-width: 959px) {
    .dyy-hidden-md {
      display: none !important;
    }
    .dyy-hidden-pc {
      display: block !important;
    }
    .design-your-yarbo-includes .modal-container {
      height: 624px;
      width: 932px;
      border-radius: 8px;
      padding: 24px 32px;
      padding-top: 24px;
    }
    .design-your-yarbo-includes .modal-header {
      margin-bottom: 30px;
    }
    .design-your-yarbo-includes .modal-content {
      flex-direction: row;
      gap: 40px;
    }
    .design-your-yarbo-includes .modal-title {
      font-size: 28px;
    }
    .design-your-yarbo-includes .empty-cart-message {
      margin-bottom: 32px;
      font-size: 16px;
    }
    .design-your-yarbo-includes .modal-product-list {
      width: 50%;
    }
    .design-your-yarbo-includes .modal-summary {
      flex: 1;
      border-radius: 8px;
