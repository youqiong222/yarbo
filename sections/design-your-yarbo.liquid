<script>
  const dyySwiper = new Swiper('.dyy-slideshow', {
    slidesPerView: 1,
    speed: 500,
    allowTouchMove: false,
  });
  const blocks = document.querySelectorAll('.dyy-product-block');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const index = entry.target.dataset.blockIndex;

          if (typeof dyySwiper !== 'undefined') {
            dyySwiper.slideTo(index);
          }
        }
      });
    },
    {
      threshold: 0.7, // block 70% 出现才触发
    }
  );

  blocks.forEach((block) => observer.observe(block));

  document.addEventListener('DOMContentLoaded', () => {
    const inputs = document.querySelectorAll('.dyy-product__option-input');
    const productList = document.querySelector('[data-role="product-list"]');
    const template = document.querySelector('[data-role="product-item-template"]').innerHTML;
    const totalPriceEls = document.querySelectorAll('[data-role="total-price"]');
    const emptyContainer = document.querySelector('.empty-cart-container');
    function moneyFormat(cents) {
      return (
        '$' +
        (cents / 100).toLocaleString(undefined, {
          minimumFractionDigits: 2,
        })
      );
    }

    function renderProducts() {
      let total = 0;
      let html = '';

      const checkedInputs = document.querySelectorAll('.dyy-product__option-input:checked');

      checkedInputs.forEach((input) => {
        const price = parseInt(input.dataset.price || 0);
        const compare = parseInt(input.dataset.compare || 0);

        total += price;

        const itemHtml = template
          .replace('<%= image %>', input.dataset.image)
          .replace('<%= title %>', input.dataset.title)
          .replace('<%= price %>', moneyFormat(price))
          .replace('<%= compare_at_price %>', compare ? moneyFormat(compare) : '')
          .replace('<%= handle %>', input.dataset.product);

        html += itemHtml;
      });

      productList.innerHTML = html;

      // 更新总价
      totalPriceEls.forEach((el) => {
        el.textContent = moneyFormat(total);
      });

      // 空状态控制
      if (checkedInputs.length === 0) {
        document.querySelector('.design-your-yarbo-includes').classList.add('empty');
      } else {
        document.querySelector('.design-your-yarbo-includes').classList.remove('empty');
      }
    }
    function parseDiagram(arr) {
      const map = {};
      arr.forEach((line) => {
        if (!line) return;
        const index = line.indexOf(':');
        if (index === -1) return;
        const key = line.slice(0, index).trim();
        const url = line.slice(index + 1).trim();
        map[key] = url;
      });

      return map;
    }

    function getCurrentCombination(block) {
      const checked = block.querySelectorAll('.dyy-product__option-input:checked');

      const indexArr = [];

      checked.forEach((input) => {
        indexArr.push(input.dataset.productIndex);
      });

      return indexArr.sort().join('~');
    }
    function updateSlideImage(block) {
      const blockIndex = block.dataset.blockIndex;

      const dataEl = block.querySelector('[data-combination-diagram]');
      if (!dataEl) return;

      const mainImage = dataEl.dataset.mainImage;
      const diagramData = dataEl.dataset.combinationDiagram;

      let diagramMap = {};

      if (diagramData) {
        const diagramArr = JSON.parse(diagramData);
        diagramMap = parseDiagram(diagramArr);
      }

      const key = getCurrentCombination(block);

      /* ===== 计算最终图片 ===== */
      let finalUrl = mainImage;

      if (key && diagramMap[key]) {
        finalUrl = diagramMap[key];
      }

      /* ===== PC swiper 更新 ===== */
      const pcSlide = document.querySelector(`.dyy-slideshow__slide[data-block-index="${blockIndex}"]`);

      if (pcSlide) {
        const pcImg = pcSlide.querySelector('img');

        if (pcImg && pcImg.src !== finalUrl) {
          pcImg.src = finalUrl;
        }
      }

      /* ===== Mobile block 图片更新 ===== */
      const mobileImg = block.querySelector('[data-role^="mobile-product-image"] img');

      if (mobileImg && mobileImg.src !== finalUrl) {
        mobileImg.src = finalUrl;
      }
    }

    // 监听 checkbox
    inputs.forEach((input) => {
      input.addEventListener('change', () => {
        renderProducts();

        const block = input.closest('.dyy-product-block');
        updateSlideImage(block);
      });
    });

    renderProducts();
  });
  document.addEventListener('click', (e) => {
    /* ===== REMOVE ===== */
    const removeBtn = e.target.closest('[data-role="remove"]');
    if (removeBtn) {
      const handle = removeBtn.dataset.handle;

      const input = document.querySelector(`.dyy-product__option-input[data-product="${handle}"]`);
      if (input) {
        input.checked = false;
        input.dispatchEvent(new Event('change'));
      }

      return;
    }

    /* ===== 打开 modal ===== */
    const openBtn = e.target.closest('[data-modal-open]');
    if (openBtn) {
      const id = openBtn.dataset.modalOpen;
      const modal = document.querySelector(`[data-modal-id="${id}"]`);

      if (modal) {
        document.body.style.overflow = 'hidden';
        document.documentElement.style.overflow = 'hidden';
        modal.classList.add('active');
      }

      return;
    }

    /* ===== 关闭 modal ===== */
    const closeBtn = e.target.closest('[data-modal-close]');
    if (closeBtn) {
      const modal = closeBtn.closest('[data-modal-id]');

      if (modal) {
        modal.classList.remove('active');
        document.body.classList.remove('modal-open');
        document.body.style.overflow = '';
        document.documentElement.style.overflow = '';
      }
    }
    /* ===== 打开 popup ===== */
    const moreBtn = e.target.closest('.dyy-product__more-button');

    if (moreBtn) {
      const item = moreBtn.closest('.dyy-product__item');
      if (!item) return;

      const popup = item.querySelector('.feature_details_popup');
      if (!popup) return;

      popup.classList.add('active');
      document.body.style.overflow = 'hidden';
      document.documentElement.style.overflow = 'hidden';
      /* 初始化 swiper（避免重复初始化） */
      const swiperEl = popup.querySelector('.swiper');

      if (swiperEl && !swiperEl.swiper) {
        new Swiper(swiperEl, {
          slidesPerView: 1,
          spaceBetween: 64,
          pagination: {
            el: popup.querySelector('.swiper-pagination'),
            clickable: true,
          },
          navigation: {
            nextEl: popup.querySelector('.swiper-button-next'),
            prevEl: popup.querySelector('.swiper-button-prev'),
          },
        });
      }

      return;
    }

    /* ===== 点击 popup 背景关闭 ===== */
    const popup = e.target.closest('.feature_details_popup');

    if (popup && e.target === popup) {
      popup.classList.remove('active');
      document.body.style.overflow = '';
      document.documentElement.style.overflow = '';
    }
    if (e.target.closest('.popup-close')) {
      popup.classList.remove('active');
      document.body.style.overflow = '';
      document.documentElement.style.overflow = '';
    }
    if (e.target.classList.contains('popup-overlay')) {
      popup.classList.remove('active');
      document.body.style.overflow = '';
      document.documentElement.style.overflow = '';
    }
  });
  const addToCartBtn = document.querySelector('[data-role="add-to-cart"]');

  if (addToCartBtn) {
    addToCartBtn.addEventListener('click', async (e) => {
      e.preventDefault();

      // 显示加载状态
      const btn = e.currentTarget;
      btn.classList.add('loading');

      try {
        // 获取已选中的产品
        const checkedInputs = document.querySelectorAll('.dyy-product__option-input:checked');

        if (checkedInputs.length === 0) {
          alert('Please select at least one product before purchasing.');
          btn.classList.remove('loading');
          return;
        }

        // 准备购物车数据
        const items = Array.from(checkedInputs).map((input) => {
          return {
            id: parseInt(input.value), // Shopify产品ID
            quantity: 1,
          };
        });

        // 调用Shopify购物车API
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ items: items }),
        });

        if (response.ok) {
          const data = await response.json();

          // 可选：重定向到购物车页面
          window.location.href = '/cart';
        } else {
          throw new Error('Failed to add to cart');
        }
      } catch (error) {
        console.error('Error adding to cart:', error);
        alert('An error occurred while adding products to cart. Please try again.');
      } finally {
        btn.classList.remove('loading');
      }
    });
  }
</script>

