{% render 'section-padding', section_id: section.id, settings: section.settings %}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
<style>
  /* 整体手风琴列过渡效果 */
  #accordion-{{ section.id }} .accordion-item {
    flex: 1;
    transition: flex 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }
  #accordion-{{ section.id }} .accordion-item.is-active {
    flex: 3.3; /* 活动面板占据更大的比例，可根据需要微调 3 ~ 4 */
  }
  #accordion-{{ section.id }} .accordion-item.is-active svg path,
  #accordion-{{ section.id }} .accordion-item-h5.swiper-slide-active svg path {
    fill: #25282a;
  }
  /* 顶部图标与标题区域 */
  #accordion-{{ section.id }} .accordion-header {
    height: 40px;
    transition: all 0.3s ease;
  }
  #accordion-{{ section.id }} .accordion-item .tab-icon {
    filter: grayscale(100%);
    opacity: 0.4;
    transition: all 0.3s ease;
  }

  #accordion-{{ section.id }} .accordion-item.is-active .tab-icon {
    filter: grayscale(0%);
    opacity: 1;
  }

  /* 顶部标签文字伸缩动画 */
  #accordion-{{ section.id }} .accordion-item .tab-text {
    max-width: 0;
    opacity: 0;
    overflow: hidden;
    white-space: nowrap;
    transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }
  #accordion-{{ section.id }} .accordion-item.is-active .tab-text {
    max-width: 300px; /* 足够容纳展开后的文字宽度 */
    opacity: 1;
    margin-left: 12px;
  }

  /* 面板内部活动状态的内容淡入 */
  #accordion-{{ section.id }} .content-active {
    opacity: 0;
    transform: translateY(15px);
    transition: all 0.3s ease;
    transition-delay: 0s;
    pointer-events: none;
  }
  #accordion-{{ section.id }} .accordion-item.is-active .content-active {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 0.2s;
    pointer-events: auto;
  }

  /* 面板内部非活动状态的内容淡出 */
  #accordion-{{ section.id }} .content-inactive {
    opacity: 1;
    transform: translateY(0);
    transition: all 0.3s ease;
  }
  #accordion-{{ section.id }} .accordion-item.is-active .content-inactive {
    opacity: 0;
    transform: translateY(10px);
    pointer-events: none;
  }

  /* 确保 block-media 占满父容器 */
  #accordion-{{ section.id }} .accordion-media-wrapper .media-container {
    height: 100% !important;
    width: 100%;
  }
  #accordion-{{ section.id }} .accordion-media-wrapper img,
  #accordion-{{ section.id }} .accordion-media-wrapper video,
  #accordion-{{ section.id }} .accordion-media-wrapper .placeholder-svg {
    height: 100% !important;
    width: 100% !important;
    object-fit: cover;
  }
</style>

<div
  class='page-container {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}'
  id='accordion-{{ section.id }}'
>
  {% if section.settings.sub_title != blank or section.settings.title != blank %}
    <div class='mb-32 {% if section.settings.heading_alignment == "center" %}text-center{% elsif section.settings.heading_alignment == "right" %}text-right{% else %}text-left{% endif %}'>
      {% if section.settings.sub_title != blank %}
        <span class='mb-12 block text-[14px]/[1.4] font-medium text-[#515355] md:mb-16'>
          {{- section.settings.sub_title -}}
        </span>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class='mb-32 text-[26px]/[1.1] leading-[1.1] font-bold text-[#25282A] uppercase md:mb-40 md:text-[32px]'>
          <div class='hidden md:block'>
            {{ section.settings.title }}
          </div>
          <div class='md:hidden'>
            {{ section.settings.title | strip_html }}
          </div>
        </h2>
      {% endif %}
    </div>
  {% endif %}
  {% assign block_count = section.blocks.size %}
  {% if block_count > 0 %}
    <div class='hidden h-auto w-full gap-8 md:flex md:h-450 md:gap-12'>
      {% for block in section.blocks %}
        <div
          class='accordion-item group flex cursor-pointer flex-col overflow-hidden {% if forloop.first %}is-active{% endif %}'
          data-index='{{ forloop.index0 }}'
          {{ block.shopify_attributes }}
        >
          {% if block.settings.label != blank %}
            <div class='accordion-header mb-12 flex items-center px-4'>
              {% if block.settings.icon != blank %}
                <div class='tab-icon flex shrink-0 items-center justify-center'>
                  {{ block.settings.icon }}
                </div>
              {% else %}
                <div
                  class='tab-icon h-24 w-24 shrink-0 rounded-full bg-gray-300'
                ></div>
              {% endif %}
              <span class='theme-title tab-text shrink-0 text-[20px] font-bold text-[#515355] uppercase'>
                {{- block.settings.label -}}
              </span>
            </div>
          {% endif %}
          <div class='accordion-panel relative w-full flex-1 overflow-hidden'>
            <div class=' accordion-media-wrapper pointer-events-none absolute inset-0 z-0 h-full w-full transition-opacity duration-300'>
              {% render 'media-element',
                class: 'absolute inset-0 w-full h-full object-cover',
                media_type: block.settings.media_type,
                pc_image: block.settings.pc_image,
                h5_image: block.settings.h5_image,
                pc_video: block.settings.pc_video,
                h5_video: block.settings.h5_video,
                video_url: block.settings.video_url,
                other_url: block.settings.other_url
              %}
              {%- render 'sn-overlay', _settings: block.settings -%}
            </div>

            <div class='content-active absolute inset-0 z-20 flex flex-col justify-end p-24'>
              {% if block.settings.title != blank %}
                <h3 class='mb-12 text-[32px]/[1.1] font-black text-white uppercase'>
                  {{ block.settings.title }}
                </h3>
              {% endif %}

              {% if block.settings.desc != blank %}
                <div class='mb-24 text-[14px]/[1.3] text-white'>
                  {{ block.settings.desc }}
                </div>
              {% endif %}

              {% if block.settings.learn_more_url != blank and block.settings.show_btn %}
                <a
                  href='{{ block.settings.learn_more_url }}'
                  class='flex h-44 items-center justify-center self-start bg-white px-32 text-[14px]/[1.4] font-medium text-[#25282A] no-underline transition-colors duration-300 hover:bg-[#FEDB1E] '
                >
                  {{ 'button.learn_more' | t }}
                </a>
              {% endif %}
            </div>

            <div class='content-inactive absolute bottom-0 left-0 z-20 flex h-full w-full items-end p-20'>
              {% if block.settings.title != blank %}
                <h3 class='break-word text-[32px]/[1.1] text-white uppercase '>
                  {{ block.settings.title }}
                </h3>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
    <div class='md:hidden'>
      <div class='swiper [overflow:unset]'>
        <div class='swiper-wrapper'>
          {% for block in section.blocks %}
            <div
              class='swiper-slide accordion-item-h5 group flex cursor-pointer flex-col overflow-hidden'
              {{ block.shopify_attributes }}
            >
              {% if block.settings.icon != blank or block.settings.label != blank %}
                <div class='mb-12 flex items-center gap-4'>
                  {% if block.settings.icon != blank %}
                    <div class='flex shrink-0 items-center justify-center [&_svg]:h-auto [&_svg]:w-32'>
                      {{ block.settings.icon }}
                    </div>
                  {% else %}
                    <div
                      class='h-32 w-32 shrink-0 rounded-full bg-gray-300'
                    ></div>
                  {% endif %}
                  <span class='theme-title shrink-0 text-[17px] font-bold text-[#515355] uppercase'>
                    {{- block.settings.label -}}
                  </span>
                </div>
              {% endif %}
              <div class='relative aspect-300/375 w-full flex-1 overflow-hidden'>
                {% render 'media-element',
                  class: 'absolute inset-0 w-full h-full object-cover',
                  media_class: 'w-full h-full object-cover',
                  media_type: block.settings.media_type,
                  pc_image: block.settings.pc_image,
                  h5_image: block.settings.h5_image,
                  pc_video: block.settings.pc_video,
                  h5_video: block.settings.h5_video,
                  video_url: block.settings.video_url,
                  other_url: block.settings.other_url
                %}
                {%- render 'sn-overlay', _settings: block.settings -%}
                <div class='relative z-10 flex h-full w-full flex-col justify-end p-20'>
                  {% if block.settings.title != blank %}
                    <h3 class='mb-8 text-[26px]/[1.1] text-white uppercase'>
                      {{ block.settings.title }}
                    </h3>
                  {% endif %}

                  {% if block.settings.desc != blank %}
                    <div class='mb-20 text-[13px]/[1.3] text-white'>
                      {{ block.settings.desc }}
                    </div>
                  {% endif %}

                  {% if block.settings.learn_more_url != blank and block.settings.show_btn %}
                    <a
                      href='{{ block.settings.learn_more_url }}'
                      class='flex h-44 items-center justify-center self-start bg-white px-24 text-[14px]/[1.4] font-medium text-[#25282A] no-underline transition-colors md:px-32 '
                    >
                      {{ 'button.learn_more' | t }}
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}
</div>

<script>
  (() => {
    const sectionContainer = document.getElementById('accordion-{{ section.id }}');
    if (!sectionContainer) return;

    // 获取所有的“列”（包含了 header 和 panel）
    const items = sectionContainer.querySelectorAll('.accordion-item');

    const updateGalleryState = (activeIndex) => {
      items.forEach((item, index) => {
        if (index === activeIndex) {
          item.classList.add('is-active');
        } else {
          item.classList.remove('is-active');
        }
      });
    };

    // 绑定鼠标悬停事件
    items.forEach((item) => {
      item.addEventListener('mouseenter', () => {
        const index = parseInt(item.getAttribute('data-index'), 10);
        updateGalleryState(index);
      });
    });

    new Swiper(`#accordion-{{ section.id }} .swiper`, {
      slidesPerView: 1.2,
      spaceBetween: 12,
    });
  })();
</script>

