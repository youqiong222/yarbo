{% render 'section-padding', section_id: section.id, settings: section.settings %}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
{%- liquid
  assign s = section.settings
  assign pc_w = s.pc_aspect_ratio_w | default: 16
  assign pc_h = s.pc_aspect_ratio_h | default: 9
  assign pc_ratio = pc_w | append: '/' | append: pc_h
  assign h5_w = s.h5_aspect_ratio_w | default: 16
  assign h5_h = s.h5_aspect_ratio_h | default: 9
  assign h5_ratio = h5_w | append: '/' | append: h5_h
-%}
<style>
  #shopify-section-{{ section.id }}{
    background: {{ section.settings.bac }};
    position: relative;
    overflow: visible;

    {% if section.settings.show_before %}
      margin-top: 240px;
    {% else %}
      margin-top: 0;
    {% endif %}

    {% if section.settings.show_after %}
      margin-bottom: 240px;
    {% else %}
      margin-bottom: 0;
    {% endif %}
  }

  #shopify-section-{{ section.id }}::after,
  #shopify-section-{{ section.id }}::before{
    position: absolute;
    content: '';
    left: 0;
    width: 100%;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }}::after{
    top: 100%;
    background: linear-gradient(
      180deg,
      {{ section.settings.bac }} 0%,
      rgba(13, 13, 13, 0.5) 36.22%,
      rgba(0, 0, 0, 0) 72.44%
    );

    {% if section.settings.show_after %}
          aspect-ratio: 1440 / 240;
    {% endif %}
  }

  #shopify-section-{{ section.id }}::before{
    bottom: 100%;
    background: linear-gradient(
      0deg,
      {{ section.settings.bac }} 0%,
      rgba(13, 13, 13, 0.5) 36.22%,
      rgba(0, 0, 0, 0) 72.44%
    );

    {% if section.settings.show_before %}
          aspect-ratio: 1440 / 240;
    {% endif %}
  }

  @media screen and (max-width: 999px){

    #shopify-section-{{ section.id }}{

      {% if section.settings.show_before %}
        margin-top: 150px;
      {% else %}
        margin-top: 0;
      {% endif %}

      {% if section.settings.show_after %}
        margin-bottom: 150px;
      {% else %}
        margin-bottom: 0;
      {% endif %}
    }

    #shopify-section-{{ section.id }}::before{
      {% if section.settings.show_before %}
      aspect-ratio: 375/150;
      {% endif %}
    }

    #shopify-section-{{ section.id }}::after{
      {% if section.settings.show_after %}
        aspect-ratio: 375/150;
      {% endif %}
    }
  }
</style>
<div class='page-container'>
  <div
    style='
      --media-aspect-pc: {{ pc_ratio }};
      --media-aspect-h5: {{ h5_ratio }};
    '
    class='
      swiper
      relative

      md:aspect-(--media-aspect-pc) {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}
    '
  >
    <div class='swiper-wrapper'>
      {%- for block in section.blocks -%}
        <div
          class='swiper-slide aspect-(--media-aspect-h5) h-auto!'
          {{ block.shopify_attributes }}
          style='
            --title-color: {{ block.settings.title_color }};
            --sub-title-color: {{ block.settings.sub_title_color }};
            --desc-color: {{ block.settings.desc_color }};
            --content_width_pc: {{ block.settings.content_width_pc }}px;
          '
        >
          <div
            data-pos='{{ block.settings.content_position_pc }}'
            data-pos-h5='{{ block.settings.content_position_h5 }}'
            class='content-position relative flex h-full w-full p-16 sm:p-40 md:p-60'
          >
            {% render 'media-element',
              class: 'absolute inset-0 w-full h-full',
              media_class: 'w-full h-full object-cover',
              media_type: block.settings.media_type,
              pc_image: block.settings.pc_image,
              h5_image: block.settings.h5_image,
              pc_video: block.settings.pc_video,
              h5_video: block.settings.h5_video,
              video_url: block.settings.video_url,
              other_url: block.settings.other_url
            %}
            {%- render 'sn-overlay', _settings: block.settings -%}
            <div class='relative z-10 w-full md:max-w-(--content_width_pc)'>
              {% if block.settings.sub_title != blank %}
                <span class='mb-8 inline-block text-[15px] leading-[1.3] text-(--sub-title-color) md:mb-12 md:text-[18px]'>
                  {{- block.settings.sub_title -}}
                </span>
              {% endif %}

              {% if block.settings.title != blank %}
                <h2 class='hidden text-[36px] leading-none text-(--title-color) uppercase md:block md:text-[52px]'>
                  {{ block.settings.title }}
                </h2>
              {% endif %}
              {% if block.settings.title_m != blank %}
                <h2 class='text-[36px] leading-none text-(--title-color) uppercase md:hidden md:text-[52px]'>
                  {{ block.settings.title_m }}
                </h2>
              {% endif %}

              {%- if block.settings.desc != blank -%}
                <div class='mt-12 text-[15px] leading-[1.3] text-(--desc-color) md:mt-16 md:text-[18px]'>
                  {{ block.settings.desc }}
                </div>
              {%- endif -%}

              {% assign b_product = block.settings.featured_product %}
              {%- assign product_form_id = 'product-banner-' | append: section.id | append: '-' | append: forloop.index -%}
              {%- liquid
                assign show_btn1 = false
                if block.settings.show_button1 and block.settings.button1_text != blank and block.settings.button1_link != blank
                  assign show_btn1 = true
                endif
                assign show_btn2 = false
                if block.settings.show_button2 and block.settings.button2_text != blank and block.settings.button2_link != blank
                  assign show_btn2 = true
                endif
                assign show_add = false
                if block.settings.show_add_button and b_product != blank
                  assign show_add = true
                endif
                assign has_buttons = false
                if show_btn1 or show_btn2 or show_add
                  assign has_buttons = true
                endif
              -%}
              {% if has_buttons %}
                <div
                  class='content-position flex'
                  data-pos='{{ block.settings.content_position_pc }}'
                  data-pos-h5='{{ block.settings.content_position_h5 }}'
                >
                  <div
                    style='
                      --button1-border-color: {{ block.settings.button1_border_color }};
                      --button1-color: {{ block.settings.button1_color }};
                      --button1-bg-color: {{ block.settings.button1_bg_color }};
                      --button1-color-hover: {{ block.settings.button1_hover_color }};
                      --button1-bg-hover-color: {{ block.settings.button1_bg_hover_color }};
                      --button2-border-color: {{ block.settings.button2_border_color }};
                      --button2-color: {{ block.settings.button2_color }};
                      --button2-bg-color: {{ block.settings.button2_bg_color }};
                      --button2-color-hover: {{ block.settings.button2_hover_color }};
                      --button2-bg-hover-color: {{ block.settings.button2_bg_hover_color }};
                      --add-border-color: {{ block.settings.add_border_color }};
                      --add-color: {{ block.settings.add_color }};
                      --add-bg-color: {{ block.settings.add_bg_color }};
                      --add-color-hover: {{ block.settings.add_hover_color }};
                      --add-bg-hover-color: {{ block.settings.add_bg_hover_color }};
                    '
                    class='mt-32 flex flex-wrap gap-12 md:mt-40'
                  >
                    {%- if show_add -%}
                      {%- render 'sn-buy-buttons-new',
                        btn_class: 'self-start! h-44! min-h-44! min-w-110! border! border-(--add-border-color)! bg-(--add-bg-color)! px-24! text-[13px]/[1.3]! text-(--add-color)! hover:border-(--add-bg-hover-color)! hover:bg-(--add-bg-hover-color)! hover:text-(--add-color-hover)! sm:px-32! md:min-w-170! md:text-[14px]/[1.4]!',
                        product: b_product,
                        product_form_id: product_form_id,
                        section_id: section.id,
                        add_text: block.settings.add_text
                      -%}
                    {%- endif -%}
                    {% if show_btn1 %}
                      <a
                        href='{{ block.settings.button1_link | default: '#' }}'
                        {% if block.settings.button1_anchor_id != blank %}
                          data-anchor-id='{{ block.settings.button1_anchor_id }}'
                        {% endif %}
                        class='
                          inline-flex
                          h-44 min-w-110 items-center
                          justify-center
                          self-start
                          border
                          border-(--button1-border-color) bg-(--button1-bg-color)
                          px-24
                          text-[13px]/[1.3]
                          tracking-[0]
                          text-(--button1-color)
                          no-underline
                          transition-colors
                          duration-300
                          hover:border-(--button1-bg-hover-color)
                          hover:bg-(--button1-bg-hover-color)
                          hover:text-(--button1-color-hover)
                          sm:px-32
                          md:min-w-170
                          md:text-[14px]/[1.4]
                        '
                      >
                        {{ block.settings.button1_text }}
                      </a>
                    {% endif %}
                    {%- if show_btn2 -%}
                      <a
                        href='{{ block.settings.button2_link | default: '#' }}'
                        {% if block.settings.button2_anchor_id != blank %}
                          data-anchor-id='{{ block.settings.button2_anchor_id }}'
                        {% endif %}
                        class='
                          inline-flex
                          h-44
                          min-w-110 items-center
                          justify-center
                          self-start
                          border
                          border-(--button2-border-color)
                          bg-(--button2-bg-color) px-24
                          text-[13px]/[1.3]
                          tracking-[0]
                          text-(--button2-color)
                          no-underline
                          transition-colors
                          duration-300
                          hover:border-(--button2-bg-hover-color)
                          hover:bg-(--button2-bg-hover-color)
                          hover:text-(--button2-color-hover)
                          sm:px-32
                          md:min-w-170
                          md:text-[14px]/[1.4]
                        '
                      >
                        {{ block.settings.button2_text }}
                      </a>
                    {%- endif -%}
                  </div>
                </div>
              {% endif %}

              {% if block.settings.show_product_card and b_product != blank %}
                {%- capture buy_buttons_html -%}
                  {%- render 'sn-buy-buttons-new',
                    btn_class: 'h-32 min-h-32 min-w-90 px-16 text-[12px]',
                    product: b_product,
                    product_form_id: product_form_id,
                    section_id: section.id
                  -%}
                {%- endcapture -%}
                <div class='mt-32 flex max-md:hidden md:mt-32'>
                  <a
                    href='{{ b_product.url }}'
                    class='group pointer-events-auto inline-flex items-center bg-white p-8 text-[#25282A] no-underline transition-transform duration-300'
                  >
                    <div class='h-92 w-92 shrink-0 bg-[#f2f2f2]'>
                      <img
                        src='{{ b_product.featured_image | image_url: width: 184 }}'
                        alt='{{ b_product.title | escape }}'
                        width='auto'
                        height='auto'
                        class='h-full w-full object-contain transition-transform duration-500 group-hover:scale-105'
                      >
                    </div>
                    <div class='flex min-w-250 flex-col items-start justify-center py-8 pl-16'>
                      <h3 class='text-20px mb-12 line-clamp-2 text-[20px] leading-[1.1] uppercase'>
                        {{ b_product.title }}
                      </h3>
                      {{ buy_buttons_html }}
                    </div>
                  </a>
                </div>
              {% endif %}
            </div>
          </div>
          {% comment %} 手机端 {% endcomment %}
          {% if block.settings.show_product_card and b_product != blank %}
            <div class='block px-16 pb-24 md:hidden'>
              <div class='w-full'>
                <a
                  href='{{ b_product.url }}'
                  class='pointer-events-auto inline-flex w-full items-center bg-white p-8 text-[#25282A] no-underline transition-transform duration-300 hover:scale-[1.02]'
                >
                  <div class='h-92 w-92 shrink-0 bg-[#f2f2f2]'>
                    <img
                      src='{{ b_product.featured_image | image_url: width: 184 }}'
                      alt='{{ b_product.title | escape }}'
                      width='auto'
                      height='auto'
                      class='h-full w-full object-contain transition-transform duration-500'
                    >
                  </div>
                  <div class='flex min-w-0 flex-1 flex-col items-start justify-center py-8 pl-16'>
                    <h3 class='mb-12 line-clamp-2 text-[20px] leading-[1.1] uppercase'>
                      {{ b_product.title }}
                    </h3>
                    {{ buy_buttons_html }}
                  </div>
                </a>
              </div>
            </div>
          {% endif %}
        </div>
      {%- endfor -%}
    </div>
  </div>
  {% if section.blocks.size > 1 %}
    <div class='pointer-events-auto mt-24 flex justify-center md:mt-32'>
      <div class='flex h-52 items-center space-x-4 rounded-full bg-[#E9E9E9] px-20 backdrop-blur-[5px]'>
        <span class='hero-prev flex shrink-0 cursor-pointer sm:mr-32 [&.swiper-button-disabled_path]:stroke-[#A6A6A6]'>
          <svg
            style='scale: -1;'
            width='20'
            height='20'
            viewBox='0 0 20 20'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d="M7.50065 4.1665L13.334 9.99984L7.50065 15.8332" stroke="black" stroke-width="2" stroke-linecap="square"/>
          </svg>
        </span>

        <div class='hero-pagination flex items-center space-x-3'></div>

        <span class='hero-next flex shrink-0 cursor-pointer sm:ml-32 [&.swiper-button-disabled_path]:stroke-[#A6A6A6]'>
          <svg
            width='20'
            height='20'
            viewBox='0 0 20 20'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d="M7.50065 4.1665L13.334 9.99984L7.50065 15.8332" stroke="black" stroke-width="2" stroke-linecap="square"/>
          </svg>
        </span>
      </div>
    </div>
  {% endif %}
</div>

<script>
  (() => {
    const sectionElement = document.querySelector('#shopify-section-{{ section.id }}');
    if (!sectionElement) return;

    const heroSwiperElement = sectionElement.querySelector('.swiper');

    if (heroSwiperElement) {
      const heroSwiper = new Swiper(heroSwiperElement, {
        effect: 'fade',
        fadeEffect: {
          crossFade: true,
        },
        navigation: {
          nextEl: sectionElement.querySelector('.hero-next'),
          prevEl: sectionElement.querySelector('.hero-prev'),
        },
        pagination: {
          el: sectionElement.querySelector('.hero-pagination'),
          clickable: true,
          renderBullet: function (index, className) {
            const bulletClasses = `
              ${className}
              rounded-none
              w-8 h-8 bg-[#CCCCCC]! transition-all duration-300 block cursor-pointer m-0
              hover:bg-white
              [&.swiper-pagination-bullet-active]:w-50 [&.swiper-pagination-bullet-active]:h-8 [&.swiper-pagination-bullet-active]:bg-[#25282A]!
            `;
            return `<span class="${bulletClasses.trim().replace(/\s+/g, ' ')}"></span>`;
          },
        },
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Product Single Banner",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor Id"
    },
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_top",
      "label": "H5 Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_bottom",
      "label": "H5 Padding Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Media Settings"
    },
    {
      "type": "number",
      "id": "pc_aspect_ratio_w",
      "label": "PC Aspect Ratio Width",
      "default": 16
    },
    {
      "type": "number",
      "id": "pc_aspect_ratio_h",
      "label": "PC Aspect Ratio Height",
      "default": 9
    },
    {
      "type": "number",
      "id": "h5_aspect_ratio_w",
      "label": "Mobile Aspect Ratio Width",
      "default": 4
    },
    {
      "type": "number",
      "id": "h5_aspect_ratio_h",
      "label": "Mobile Aspect Ratio Height",
      "default": 5
    },
    {
      "type": "color",
      "id": "bac",
      "label": "Background color",
      "default": "#0d0d0d"
    },
    {
      "type": "checkbox",
      "id": "show_before",
      "label": "Show top gradient",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_after",
      "label": "Show bottom gradient",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Media Settings"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Shopify Video"
            },
            {
              "value": "video_url",
              "label": "External Video URL"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "pc_image",
          "label": "PC Image"
        },
        {
          "type": "image_picker",
          "id": "h5_image",
          "label": "H5 Image"
        },
        {
          "type": "video",
          "id": "pc_video",
          "label": "PC Shopify Video"
        },
        {
          "type": "video",
          "id": "h5_video",
          "label": "H5 Shopify Video(Optional)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Platform Video URL (YouTube/Vimeo)",
          "accept": ["youtube", "vimeo"],
          "default": "https://www.youtube.com/watch?v=NpEaa2P7qZI"
        },
        {
          "type": "text",
          "id": "other_url",
          "label": "Other Video URL",
          "info": "ex: xxx.mp4 (If filled, this takes priority over the Platform Video URL)"
        },
        {
          "type": "header",
          "content": "Overlay Settings"
        },
        {
          "type": "checkbox",
          "id": "show_overlay",
          "label": "Show Media Overlay",
          "default": false
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay Opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 40
        },
        {
          "type": "header",
          "content": "Content Settings"
        },
        {
          "type": "range",
          "id": "content_width_pc",
          "label": "Content Width (PC)",
          "default": 1320,
          "min": 400,
          "max": 1320,
          "step": 20,
          "unit": "px"
        },
        {
          "type": "select",
          "id": "content_position_pc",
          "label": "Content Position (PC)",
          "options": [
            { "value": "top-left", "label": "Top Left" },
            { "value": "top-center", "label": "Top Center" },
            { "value": "top-right", "label": "Top Right" },
            { "value": "middle-left", "label": "Middle Left" },
            { "value": "middle-center", "label": "Middle Center" },
            { "value": "middle-right", "label": "Middle Right" },
            { "value": "bottom-left", "label": "Bottom Left" },
            { "value": "bottom-center", "label": "Bottom Center" },
            { "value": "bottom-right", "label": "Bottom Right" }
          ],
          "default": "middle-left"
        },
        {
          "type": "select",
          "id": "content_position_h5",
          "label": "Content Position (Mobile)",
          "options": [
            { "value": "top-left", "label": "Top Left" },
            { "value": "top-center", "label": "Top Center" },
            { "value": "top-right", "label": "Top Right" },
            { "value": "middle-left", "label": "Middle Left" },
            { "value": "middle-center", "label": "Middle Center" },
            { "value": "middle-right", "label": "Middle Right" },
            { "value": "bottom-left", "label": "Bottom Left" },
            { "value": "bottom-center", "label": "Bottom Center" },
            { "value": "bottom-right", "label": "Bottom Right" }
          ],
          "default": "middle-left"
        },
        {
          "type": "richtext",
          "id": "sub_title",
          "label": "Sub Title"
        },
        {
          "type": "color",
          "id": "sub_title_color",
          "label": "Sub Title Color",
          "default": "#E6E6E6"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "title_m",
          "label": "Mobile Title"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Title Color",
          "default": "#FFFFFF"
        },
        {
          "type": "richtext",
          "id": "desc",
          "label": "Description"
        },
        {
          "type": "color",
          "id": "desc_color",
          "label": "Description Color",
          "default": "#FFFFFF"
        },
        {
          "type": "header",
          "content": "Button1 Settings"
        },
        {
          "type": "checkbox",
          "id": "show_button1",
          "label": "Show Button1",
          "default": false
        },
        {
          "type": "text",
          "id": "button1_text",
          "label": "Button1 Text",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "button1_link",
          "label": "Button1 Link"
        },
        {
          "type": "text",
          "id": "button1_anchor_id",
          "label": "Button1 Anchor Id"
        },
        {
          "type": "header",
          "content": "Button1 Color Settings"
        },
        {
          "type": "color",
          "id": "button1_color",
          "label": "Button1 Color",
          "default": "#25282A"
        },
        {
          "type": "color",
          "id": "button1_border_color",
          "label": "Button1 Border Color",
          "default": "#FEDB1E"
        },
        {
          "type": "color",
          "id": "button1_bg_color",
          "label": "Button1 Background Color",
          "default": "#FEDB1E"
        },
        {
          "type": "color",
          "id": "button1_hover_color",
          "label": "Button1 Hover Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "button1_bg_hover_color",
          "label": "Button1 Background Hover Color",
          "default": "#25282A"
        },
        {
          "type": "header",
          "content": "Button2 Settings"
        },
        {
          "type": "checkbox",
          "id": "show_button2",
          "label": "Show Button2",
          "default": false
        },
        {
