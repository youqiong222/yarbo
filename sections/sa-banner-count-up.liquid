{% render 'section-padding', section_id: section.id, settings: section.settings %}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
{%- liquid
  assign s = section.settings
  assign pc_w = s.pc_aspect_ratio_w | default: 16
  assign pc_h = s.pc_aspect_ratio_h | default: 9
  assign pc_ratio = pc_w | append: '/' | append: pc_h
  assign h5_w = s.h5_aspect_ratio_w | default: 16
  assign h5_h = s.h5_aspect_ratio_h | default: 9
  assign h5_ratio = h5_w | append: '/' | append: h5_h
-%}
<div class='page-container max-sm:p-0 {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}'>
  <div
    style='
      --media-aspect-pc: {{ pc_ratio }};
      --media-aspect-h5: {{ h5_ratio }};
    '
    class='
      swiper
      relative
      aspect-(--media-aspect-h5)
      md:aspect-(--media-aspect-pc)
    '
  >
    <div class='swiper-wrapper'>
      {%- for block in section.blocks -%}
        <div
          class='swiper-slide h-auto!'
          {{ block.shopify_attributes }}
          style='
            --title-color: {{ block.settings.title_color }};
            --sub-title-color: {{ block.settings.sub_title_color }};
            --desc-color: {{ block.settings.desc_color }};
            --content_width_pc: {{ block.settings.content_width_pc }}px;
          '
        >
          <div
            data-pos='{{ block.settings.content_position_pc }}'
            data-pos-h5='{{ block.settings.content_position_h5 }}'
            class='content-position relative flex h-full w-full p-24 sm:p-40 md:p-60'
          >
            {% render 'media-element',
              class: 'absolute inset-0 w-full h-full',
              media_class: 'w-full h-full object-cover',
              media_type: block.settings.media_type,
              pc_image: block.settings.pc_image,
              h5_image: block.settings.h5_image,
              pc_video: block.settings.pc_video,
              h5_video: block.settings.h5_video,
              video_url: block.settings.video_url,
              other_url: block.settings.other_url
            %}
            {%- render 'sn-overlay', _settings: block.settings -%}
            <div class='relative z-10 w-full text-white md:max-w-(--content_width_pc)'>
              {% if block.settings.title != blank %}
                <h2 class='text-[36px] leading-none uppercase md:text-[52px]'>
                  {{ block.settings.title }}
                </h2>
              {% endif %}
              <div class='mt-40 flex gap-24 border-t border-white pt-24 md:mt-40 md:pt-24'>
                {%- for count_block in (1..3) -%}
                  {% assign count_key = 'count_' | append: count_block %}
                  {% assign unit_key = 'unit_' | append: count_block %}
                  {% assign desc_key = 'description_' | append: count_block %}
                  <div class='mt-24 flex-1'>
                    {% if block.settings[count_key] != blank %}
                      <h3 class='text-[44px] leading-none font-bold md:text-[44px]'>
                        {{ block.settings[count_key] -}}
                        {{- block.settings[unit_key] }}
                      </h3>
                      {% if block.settings[desc_key] != blank %}
                        <p class='mt-4 text-[14px] leading-[1.3] md:text-[14px]'>
                          {{ block.settings[desc_key] }}
                        </p>
                      {% endif %}
                    {% endif %}
                  </div>
                {%- endfor -%}
              </div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
  {% if section.blocks.size > 1 %}
    <div class='pointer-events-auto mt-24 flex justify-center md:mt-32'>
      <div class='flex h-52 items-center space-x-4 rounded-full bg-[#E9E9E9] px-20 backdrop-blur-[5px]'>
        <span class='prev flex shrink-0 cursor-pointer sm:mr-32 [&.swiper-button-disabled_path]:stroke-[#A6A6A6]'>
          <svg
            style='scale: -1;'
            width='20'
            height='20'
            viewBox='0 0 20 20'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d="M7.50065 4.1665L13.334 9.99984L7.50065 15.8332" stroke="black" stroke-width="2" stroke-linecap="square"/>
          </svg>
        </span>

        <div class='pagination flex items-center space-x-3'></div>

        <span class='next flex shrink-0 cursor-pointer sm:ml-32 [&.swiper-button-disabled_path]:stroke-[#A6A6A6]'>
          <svg
            width='20'
            height='20'
            viewBox='0 0 20 20'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d="M7.50065 4.1665L13.334 9.99984L7.50065 15.8332" stroke="black" stroke-width="2" stroke-linecap="square"/>
          </svg>
        </span>
      </div>
    </div>
  {% endif %}
</div>

<script>
  (() => {
    const sectionElement = document.querySelector(
      '#shopify-section-{{ section.id }}',
    );
    if (!sectionElement) return;
    const heroSwiperElement = sectionElement.querySelector('.swiper');
    if (heroSwiperElement) {
      const heroSwiper = new Swiper(heroSwiperElement, {
        effect: 'fade',
        fadeEffect: {
          crossFade: true,
        },
        {%- if section.settings.auto_rotate %}
        autoplay: { delay: {{ section.settings.change_slides_speed | times: 1000 }}, disableOnInteraction: false },
        {% endif -%}
        navigation: {
          nextEl: sectionElement.querySelector('.next'),
          prevEl: sectionElement.querySelector('.prev'),
        },
        pagination: {
          el: sectionElement.querySelector('.pagination'),
          clickable: true,
          renderBullet: function (index, className) {
            const bulletClasses = `
              ${className}
              rounded-none
              w-8 h-8 bg-[#CCCCCC]! transition-all duration-300 block cursor-pointer m-0
              hover:bg-white
              [&.swiper-pagination-bullet-active]:w-50 [&.swiper-pagination-bullet-active]:h-8 [&.swiper-pagination-bullet-active]:bg-[#25282A]!
            `;
            return `<span class="${bulletClasses.trim().replace(/\s+/g, ' ')}"></span>`;
          },
        },
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Banner Count Up",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor Id"
    },
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_top",
      "label": "H5 Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_bottom",
      "label": "H5 Padding Bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Media Settings"
    },
    {
      "type": "number",
      "id": "pc_aspect_ratio_w",
      "label": "PC Aspect Ratio Width",
      "default": 16
    },
    {
      "type": "number",
      "id": "pc_aspect_ratio_h",
      "label": "PC Aspect Ratio Height",
      "default": 9
    },
    {
      "type": "number",
      "id": "h5_aspect_ratio_w",
      "label": "Mobile Aspect Ratio Width",
      "default": 4
    },
    {
      "type": "number",
      "id": "h5_aspect_ratio_h",
      "label": "Mobile Aspect Ratio Height",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate slides",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "s",
      "label": "Change slides every",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "header",
          "content": "Media Settings"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Shopify Video"
            },
            {
              "value": "video_url",
              "label": "External Video URL"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "pc_image",
          "label": "PC Image"
        },
        {
          "type": "image_picker",
          "id": "h5_image",
          "label": "H5 Image"
        },
        {
          "type": "video",
          "id": "pc_video",
          "label": "PC Shopify Video"
        },
        {
          "type": "video",
          "id": "h5_video",
          "label": "H5 Shopify Video(Optional)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Platform Video URL (YouTube/Vimeo)",
          "accept": ["youtube", "vimeo"],
          "default": "https://www.youtube.com/watch?v=NpEaa2P7qZI"
        },
        {
          "type": "text",
          "id": "other_url",
          "label": "Other Video URL",
          "info": "ex: xxx.mp4 (If filled, this takes priority over the Platform Video URL)"
        },
        {
          "type": "header",
          "content": "Overlay Settings"
        },
        {
          "type": "checkbox",
          "id": "show_overlay",
          "label": "Show Media Overlay",
          "default": false
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay Opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 40
        },
        {
          "type": "header",
          "content": "Content Settings"
        },
        {
          "type": "range",
          "id": "content_width_pc",
          "label": "Content Width (PC)",
          "default": 1320,
          "min": 400,
          "max": 1320,
          "step": 20,
          "unit": "px"
        },
        {
          "type": "select",
          "id": "content_position_pc",
          "label": "Content Position (PC)",
          "options": [
            { "value": "top-left", "label": "Top Left" },
            { "value": "top-center", "label": "Top Center" },
            { "value": "top-right", "label": "Top Right" },
            { "value": "middle-left", "label": "Middle Left" },
            { "value": "middle-center", "label": "Middle Center" },
            { "value": "middle-right", "label": "Middle Right" },
            { "value": "bottom-left", "label": "Bottom Left" },
            { "value": "bottom-center", "label": "Bottom Center" },
            { "value": "bottom-right", "label": "Bottom Right" }
          ],
          "default": "middle-left"
        },
        {
          "type": "select",
          "id": "content_position_h5",
          "label": "Content Position (Mobile)",
          "options": [
            { "value": "top-left", "label": "Top Left" },
            { "value": "top-center", "label": "Top Center" },
            { "value": "top-right", "label": "Top Right" },
            { "value": "middle-left", "label": "Middle Left" },
            { "value": "middle-center", "label": "Middle Center" },
            { "value": "middle-right", "label": "Middle Right" },
            { "value": "bottom-left", "label": "Bottom Left" },
            { "value": "bottom-center", "label": "Bottom Center" },
            { "value": "bottom-right", "label": "Bottom Right" }
          ],
          "default": "middle-left"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "number",
          "id": "count_1",
          "label": "Count1"
        },
        {
          "type": "text",
          "id": "unit_1",
          "label": "Unit1"
        },
        {
          "type": "text",
          "id": "description_1",
          "label": "Description1"
        },
        {
          "type": "number",
          "id": "count_2",
          "label": "Count2"
        },
        {
          "type": "text",
          "id": "unit_2",
          "label": "Unit2"
        },
        {
          "type": "text",
          "id": "description_2",
          "label": "Description2"
        },
        {
          "type": "number",
          "id": "count_3",
          "label": "Count3"
        },
        {
          "type": "text",
          "id": "unit_3",
          "label": "Unit3"
        },
        {
          "type": "text",
          "id": "description_3",
          "label": "Description3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Count Up",
      "blocks": [{ "type": "slide" }]
    }
  ]
}
{% endschema %}
