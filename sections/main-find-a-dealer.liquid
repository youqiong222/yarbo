  <main style='background-color: rgb(245 245 245)'>
    <div class='w-full'>
      <section
        class='mobile:px-[16PX] map-container relative mx-auto w-full lg:px-[48PX]'
      >
        <i class='mobile:h-5 block h-[115px] w-full'></i>
        <div class='w-full'>
          <h2
            class='mobile:text-xl/6 text-center text-4xl/[43px] font-extrabold text-[#02060B]'
          >
            Find a Dealer
          </h2>
          <p
            class='mobile:text-sm/5 mb-8 text-center text-2xl/[34px] font-semibold text-[#676A6D]'
          >
           Find your local Yarbo dealer for demos, sales inquiries, and service support.
          </p>
          <div class='bg-[#02060B] p-4 md:rounded-xl'>
            <div class='mobile:flex-col mobile:gap-[10px] flex gap-7'>
              <div class='mobile:justify-center flex items-center gap-4'>
                <div
                  id='CountrySelect'
                  class='ant-select ant-select-lg ant-select-outlined mobile:w-[200px] css-kghr11 ant-select-single ant-select-allow-clear ant-select-show-arrow ant-select-show-search w-[343px]'
                ></div>
                <p
                  class='mobile:w-20 mobile:text-sm/none text-xl font-medium text-[#E6E6E7]'
                >
                  Country
                </p>
              </div>
              <div class='mobile:justify-center flex items-center gap-4'>
                <div
                  id='StateSelect'
                  class='ant-select ant-select-lg ant-select-outlined mobile:w-[200px] css-kghr11 ant-select-single ant-select-allow-clear ant-select-show-arrow ant-select-show-search w-[343px]'
                ></div>
                <p
                  class='mobile:w-20 mobile:text-sm/none text-xl font-medium text-[#E6E6E7]'
                >
                  State/City
                </p>
              </div>
            </div>
          </div>
          <div
            class='mobile:flex-col-reverse mobile:gap-[10px] mobile:px-4 mt-3 flex'
          >
            <div
              class='mobile:h-[380px] mobile:w-full mobile:p-3 h-[500px] rounded-xl bg-[#F5F5F5] px-4 pt-3 md:basis-2/5'
            >
              <ul
                id='dealerUlList'
                class='flex max-h-full w-full cursor-grab flex-col gap-4 overflow-y-auto'
              ></ul>
            </div>
            <div
              class='mobile:h-[343px] mobile:w-full z-0 h-[500px] md:basis-3/5 md:pl-3'
            >
              <div class='my-map h-full w-full overflow-hidden rounded-xl'>
                <div
                  class='leaflet-container leaflet-touch leaflet-fade-anim leaflet-touch-zoom h-full w-full'
                  id='my-leafmap'
                  tabindex='0'
                  data-gesture-handling-touch-content='使用双指移动地图'
                  data-gesture-handling-scroll-content='按住 ⌘ 并滚动鼠标滚轮才可缩放地图'
                  style='position: relative'
                >
                  <div class='leaflet-control-container'>
                    <div class='leaflet-top leaflet-left'>
                      <div
                        class='leaflet-control-zoom leaflet-bar leaflet-control'
                      >
                        <a
                          class='leaflet-control-zoom-in'
                          href='#'
                          title='Zoom in'
                          role='button'
                          aria-label='Zoom in'
                          aria-disabled='false'
                        >
                          <span aria-hidden='true'>+</span>
                        </a>
                        <a
                          class='leaflet-control-zoom-out leaflet-disabled'
                          href='#'
                          title='Zoom out'
                          role='button'
                          aria-label='Zoom out'
                          aria-disabled='true'
                        >
                          <span aria-hidden='true'>−</span>
                        </a>
                        <a
                          class='leaflet-control-zoom-fullscreen fullscreen-icon'
                          href='#'
                          title='[object Object]'
                          role='button'
                          aria-label='[object Object]'
                        ></a>
                      </div>
                      <div
                        class='leaflet-control-locate leaflet-bar leaflet-control'
                      >
                        <a
                          class='leaflet-bar-part leaflet-bar-part-single'
                          title='Show me where I am'
                          href='#'
                          role='button'
                        >
                          <span
                            class='leaflet-control-locate-location-arrow'
                          ></span>
                        </a>
                      </div>
                    </div>
                    <div class='leaflet-top leaflet-right'></div>
                    <div class='leaflet-bottom leaflet-left'></div>
                    <div class='leaflet-bottom leaflet-right'>
                      <div
                        class='leaflet-control-attribution leaflet-control'
                      >
                        <a
                          href='https://leafletjs.com'
                          title='A JavaScript library for interactive maps'
                        >
                          <svg
                            aria-hidden='true'
                            xmlns='http://www.w3.org/2000/svg'
                            width='12'
                            height='8'
                            viewBox='0 0 12 8'
                            class='leaflet-attribution-flag'
                          >
                            <path fill="#4C7BE1" d="M0 0h12v4H0z"></path>
                            <path fill="#FFD500" d="M0 4h12v3H0z"></path>
                            <path fill="#E0BC00" d="M0 7h12v1H0z"></path>
                          </svg>
                          Leaflet
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <i class='mobile:h-10 block h-[115px] w-full'></i>
