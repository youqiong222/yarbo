{% render 'yb-section-style', section: section %}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
<div class='padding-{{ section.id }} custom_tri_column_outter'>
  <div class='yb-section-container'>
    {% if section.settings.heading != blank %}
      <div class='lcf-section_header'>
        {% if section.settings.heading != blank %}
          <div class='headerTitle'>
            <h3 class='lcf-section-title'>{{ section.settings.heading }}</h3>
            <div class='bz-body-2 lcf-section-des lcf-section-des-style'>{{ section.settings.text }}</div>
          </div>
        {% else %}
          <div class='headerTitle'>
            <h3 class='lcf-section-title'>{{ section.settings.heading }}</h3>
            <div class='bz-body-2 lcf-section-des'>{{ section.settings.text }}</div>
          </div>
        {% endif %}
        {% if section.settings.button_text != blank %}
          <div class=' {% if section.settings.heading != blank or section.settings.text != blank %}rich-texts-button{% endif %}'>
            {% render 'yb-button', class: 'button bz-btn-1 custom_button lcf_button', tag: 'button', config: section.settings %}
          </div>
        {% endif %}
      </div>
    {% endif %}
    <div class='custom_tri_column_inner'>
      <div
        class='custom_tri_column_wrapper'
        blocks_count='{{ section.blocks.size }}'
      >
        {% for block in section.blocks %}
          <div class='lcf_custom_tri_column-card'>
            <div
              class='lcf_custom_tri_column_image_wrapper'
              {% if block.settings.image == blank %}
                style='background: #e6e6e7;'
              {% endif %}
            >
              {% render 'yb-image', style: 'width:100%;height:100%', mobile_size: '100%', data: block.settings.image %}
            </div>
            <h4 class='lcf_bz-head-4'>{{ block.settings.heading }}</h4>
            <div class='lcf_yb-tri-col-body'>{{ block.settings.text }}</div>
            {% unless forloop.last %}
              <div class='vertical-line'></div>
              <div class='column-arrow-separator'>
                <svg
                  class='icon'
                  viewBox='298 42 470 940'
                  version='1.1'
                  xmlns='http://www.w3.org/2000/svg'
                  width='40'
                  height='80'
                >
                  <path d="M298.666667 42.666667v287.744L480.298667 512 298.666667 693.76V981.333333l469.333333-469.290666L298.666667 42.666667z" fill="#FEDB1E"></path>
                </svg>
              </div>
            {% endunless %}
          </div>
        {% endfor %}
      </div>
      <div class='custom_bottom_buttons'>
        {% if section.settings.button2_text != blank %}
          {% render 'yb-button', class: 'bz-btn-1 custom_button lcf_button lcf_margin_bottom', tag: 'button2', config: section.settings %}
        {% endif %}
        {% if section.settings.button3_text != blank %}
          {% render 'yb-button', class: 'bz-btn-1 custom_underline_button', tag: 'button3', config: section.settings %}
        {% endif %}
      </div>
    </div>
  </div>
</div>
