      object-fit: cover;
      width: 100%;
      height: 100%;
    }

    .custom_tri_column_outter .section_header {
      max-width: 1000px;
      margin-left: auto;
      margin-right: auto;
    }

    .custom_tri_column_image_wrapper {
      display: flex;
      width: 48.5%;
      justify-content: center;
      align-items: center;
      margin: auto;
    }

    .custom_tri_column-card {
      width: calc((100% - 32px) / 3);
      background: white;
      border-radius: 16px;
      padding-top: 31px;
      border: 1px solid #d9d9d9;
      padding-bottom: 60px;
      position: relative;
      z-index: 1;
      overflow: hidden;
    }

    .custom_tri_column-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: inherit;
      border-radius: 20px;
      z-index: -1;
      box-shadow: 80px 0px 2px -79px #fedb1e;
    }

    .yb-tri-col-body {
      font-size: 14px;
    }

    .custom_tri_column-card .bz-head-4 {
      margin-top: 16px;
      margin-bottom: 12px;
    }

    .custom_tri_column-card .yb-tri-col-body,
    .custom_tri_column-card .bz-head-4 {
      line-height: 140%;
      padding-left: 31px;
      padding-right: 31px;
    }

    .yb-section-container .yb-section-des {
      margin-bottom: 40px;
      line-height: 140%;
      margin-top: 16px;
    }

    .yb-section-container .yb-section-title {
      line-height: 140%;
    }

    .custom_tri_column_wrapper .custom_tri_column-card {
      box-shadow: 80px 0px 2px -79px #fedb1e;
    }

    .custom_tri_column_wrapper[blocks_count='3'] .custom_tri_column-card:last-child,
    .custom_tri_column_wrapper[blocks_count='2'] .custom_tri_column-card:last-child,
    .custom_tri_column_wrapper[blocks_count='1'] .custom_tri_column-card {
      box-shadow: none;
    }

    .custom_button {
      padding: 11.2px 43px;
    }

    .custom_bottom_buttons {
      display: flex;
      align-items: center;
      flex-direction: column;
      margin-top: 40px;
    }

    .lcf_margin-bottom {
      margin-bottom: 24px;
    }

    .custom_underline_button {
      text-decoration: underline !important;
      color: #636363 !important;
      font-weight: 600;
      height: 16px;
      line-height: 100%;
      font-size: 16px;
      border: none;
      background: #0000;
      font-family: NunitoSans, 'ui-sans-serif', 'system-ui', 'sans-serif';
    }

    .lcf_button {
      height: 48px;
      line-height: 48px;
      font-weight: 600;
      font-size: 16px;
      padding: 0 40px;
      border-radius: 30px;
      color: #000;
      border: 0;
