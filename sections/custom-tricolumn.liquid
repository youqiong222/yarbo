    }
    /* Custom TriColumn CSS */
    .lcf-section_header {
      text-align: center;
    }

    .custom_tri_column_wrapper {
      display: flex;
      justify-content: center;
      gap: 16px;
      text-align: center;
    }

    .custom_tri_column_image_wrapper img {
