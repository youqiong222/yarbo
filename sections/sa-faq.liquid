{% render 'section-padding', section_id: section.id, settings: section.settings %}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
<div class='page-container {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}'>
  <div
    x-data="tabsComponent('tab_0')"
    x-init='updateSlider()'
    @resize.window='updateSlider()'
    class='md:flex md:w-full'
  >
    <!-- 左侧 tab 列表 -->
    <div class='h-fit md:sticky md:top-0 md:flex md:w-[34%] md:flex-col'>
      <div class='mb-32 flex flex-col justify-center gap-16 text-left md:mb-80 md:gap-12'>
        <h2 class=' text-[36px]  leading-none uppercase  md:text-[44px] '>
          {{ section.settings.title }}
        </h2>
        <div class='text-[14px] leading-[1.3] text-[#515355]'>
          {{ section.settings.text }}
        </div>
      </div>

      <div class='relative mb-24 flex w-full items-end justify-between md:flex-col md:items-start md:gap-40'>
        {% if section.settings.enable_tabs %}
          <div
            class='absolute bottom-0 left-0 z-0 block! h-4 w-full bg-[#CCCCCC] md:opacity-0'
          ></div>
          <div class='no-scrollbar relative z-10 flex w-full gap-24 overflow-x-auto pb-12 md:mb-0 md:flex-col md:items-start  md:border-none md:pb-0'>
            {% assign tab_blocks = section.blocks | where: 'type', 'tab' %}
            {% for block in tab_blocks %}
              <div
                x-ref='tab_{{ forloop.index0 }}'
                x-bind="tabButton('tab_{{ forloop.index0 }}')"
                class='theme-title shrink-0 cursor-pointer text-[16px]/[1.1] font-bold uppercase transition-colors before:absolute before:left-0 before:h-10 before:bg-amber-300 before:transition-transform before:duration-300 md:flex md:items-center md:text-[32px]'
                :class='activeTab === "tab_{{ forloop.index0 }}" ? "text-[#25282A] md:text-amber-300 md:pl-22 md:before:w-10" : "text-[#A6A6A6]"'
                data-tab-index='{{ forloop.index0 }}'
              >
                {{ block.settings.label }}
              </div>
            {% endfor %}

            <div
              class='absolute bottom-0 left-0 block! h-4 bg-[#25282A] transition-all duration-300 ease-out md:opacity-0'
              :style='`width: ${sliderWidth}px; transform: translateX(${sliderOffset}px);`'
            ></div>
          </div>
        {% endif %}
        {% if section.settings.see_all_text != blank %}
          <a
            href='{{ section.settings.see_all_url | default: "#" }}'
            class='product-learn_more  hidden h-30 w-fit items-center justify-center border border-solid border-[#CCCCCC] px-32 text-[12px]/[1.4] font-medium text-[#25282a] no-underline md:flex   md:h-44 md:text-[14px]/[1.4]'
            id='shop-all-{{ section.id }}'
          >
            {{- section.settings.see_all_text -}}
          </a>
        {% endif %}
      </div>
    </div>

    <!-- 右侧 FAQ 列表 -->
    <div class='right_container md:w-[66%] md:pl-60'>
      {% assign qa_blocks = section.blocks | where: 'type', 'qa' %}
      {% if section.settings.enable_tabs %}
        {% for block in tab_blocks %}
          {% assign current_idx = forloop.index | append: '' %}
          <div
            class='tab-pane tab-content transition-opacity duration-300 '
            id='tab-content-{{ section.id }}-{{ forloop.index }}'
            x-bind:class="
              activeTab === 'tab_{{ forloop.index0 }}'
              ? 'opacity-100 visible relative'
              : 'opacity-0 invisible absolute top-0 left-0'
            "
            x-cloak
            x-transition.opacity.duration.300ms
            data-pane-index='{{ forloop.index0 }}'
          >
            <div
              class='flex flex-col gap-20 md:gap-24'
              x-data='{ active: null }'
            >
              {% for qa in qa_blocks %}
                {% if qa.settings.tab == current_idx and qa.settings.question != blank %}
                  <div class='faq-item border-b border-[#cccccc] pb-20 md:pb-24'>
                    <!-- 标题 -->
                    <div
                      @click='active = active === {{ forloop.index }} ? null : {{ forloop.index }}'
                      class='flex cursor-pointer items-center justify-between gap-10 text-[14px] leading-[1.3] font-bold'
                    >
                      <span>{{ qa.settings.question }}</span>

                      <div
                        class='flex items-center'
                      >
                        <svg
                          x-show='active !== {{ forloop.index }}'
                          width='14'
                          height='14'
                          viewBox='0 0 15 15'
                          fill='none'
                        >
                          <path d="M7.31706 0.649902L7.31706 13.9832M13.9837 7.31657L0.650391 7.31657" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
                        </svg>
                        <svg
                          width='14'
                          height='2'
                          viewBox='0 0 15 2'
                          fill='none'
                          x-show='active === {{ forloop.index }}'
                        >
                          <path d="M13.9837 0.649902L0.650391 0.649902" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
                        </svg>
                      </div>
                    </div>

                    <!-- 内容 -->
                    <div
                      class='grid  transition-[grid-template-rows] duration-300 ease-in-out '
                      :class="active === {{ forloop.index }} ? 'grid-rows-[1fr] ' : 'grid-rows-[0fr]'"
                    >
                      <div class='overflow-hidden'>
                        <div class='faq-content pt-12 text-[14px] leading-[1.3] md:pt-16'>
                          {{ qa.settings.answer }}
                        </div>
                      </div>
                    </div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      {% else %}
        <div
          class='flex flex-col gap-20 md:gap-24'
          x-data='{ active: null }'
        >
          {% for qa in qa_blocks %}
            <div class='faq-item border-b border-[#cccccc] pb-20 md:pb-24'>
              <!-- 标题 -->
              <div
                @click='active = active === {{ forloop.index }} ? null : {{ forloop.index }}'
                class='flex cursor-pointer items-center justify-between gap-10 text-[14px] leading-[1.3] font-bold'
              >
                <span>{{ qa.settings.question }}</span>

                <div
                  class='flex items-center'
                >
                  <svg
                    x-show='active !== {{ forloop.index }}'
                    width='14'
                    height='14'
                    viewBox='0 0 15 15'
                    fill='none'
                  >
                    <path d="M7.31706 0.649902L7.31706 13.9832M13.9837 7.31657L0.650391 7.31657" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
                  </svg>
                  <svg
                    width='14'
                    height='2'
                    viewBox='0 0 15 2'
                    fill='none'
                    x-show='active === {{ forloop.index }}'
                  >
                    <path d="M13.9837 0.649902L0.650391 0.649902" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
                  </svg>
                </div>
              </div>

              <!-- 内容 -->
              <div
                class='grid  transition-[grid-template-rows] duration-300 ease-in-out '
                :class="active === {{ forloop.index }} ? 'grid-rows-[1fr] ' : 'grid-rows-[0fr]'"
              >
                <div class='overflow-hidden'>
                  <div
                    class='
                      faq-content
                      pt-12
                      text-[14px]
                      leading-[1.3]
                      md:pt-16
                      [&_:is(p)]:my-12
                      [&_:is(ul,ol)]:my-12
                      [&_:is(ul,ol)]:pl-18
                      [&_li]:my-6
                      [&_li]:list-disc
                    '
                  >
                    {{ qa.settings.answer }}
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
      {% if section.settings.see_all_text != blank %}
        <a
          href='{{ section.settings.see_all_url | default: "#" }}'
          class='product-learn_more mt-24 flex h-44 w-full items-center justify-center border border-solid border-[#CCCCCC] px-16 text-[14px]/[1.4] font-medium text-[#25282a] no-underline md:hidden'
          id='shop-all-{{ section.id }}'
        >
          {{- section.settings.see_all_text -}}
        </a>
      {% endif %}
    </div>
  </div>
</div>

