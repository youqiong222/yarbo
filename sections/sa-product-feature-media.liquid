{% render 'section-padding', section_id: section.id, settings: section.settings %}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
<style>
  #shopify-section-{{ section.id }}  {
    overflow: visible;
  }
</style>
<div class='page-container {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}'>
  <div class='flex items-start max-md:flex-col'>
    <div class='md:sticky md:top-80 md:w-[43%]'>
      {%- liquid
        assign s = section.settings
        assign pc_w = s.pc_aspect_ratio_w | default: 16
        assign pc_h = s.pc_aspect_ratio_h | default: 9
        assign pc_ratio = pc_w | append: '/' | append: pc_h
        assign h5_w = s.h5_aspect_ratio_w | default: 16
        assign h5_h = s.h5_aspect_ratio_h | default: 9
        assign h5_ratio = h5_w | append: '/' | append: h5_h
      -%}
      <div
        style='
          --media-aspect-pc: {{ pc_ratio }};
          --media-aspect-h5: {{ h5_ratio }};
        '
        class='
          relative
          aspect-(--media-aspect-h5)
          md:aspect-(--media-aspect-pc)
        '
      >
        {% render 'media-element',
          class: 'absolute inset-0 w-full h-full',
          media_class: 'w-full h-full object-cover',
          media_type: section.settings.media_type,
          pc_image: section.settings.pc_image,
          h5_image: section.settings.h5_image,
          pc_video: section.settings.pc_video,
          h5_video: section.settings.h5_video,
          video_url: section.settings.video_url,
          other_url: section.settings.other_url
        %}
        {%- render 'sn-overlay', _settings: section.settings -%}
      </div>
    </div>
    <div class='flex-1 max-md:mt-60 md:ml-60'>
      <h2 class='text-[32px] leading-none md:text-[44px]'>
        {{ section.settings.right_side_title }}
      </h2>
      <div class='mt-12 text-[16px] leading-[1.3] text-[#515355] md:mt-12 md:text-[18px]'>
        {{ section.settings.right_side_desc }}
      </div>
      <div class=' mt-60 flex flex-col gap-48 md:gap-60'>
        {% for block in section.blocks %}
          <div>
            {%- liquid
              assign b = block.settings
              assign pc_w = b.pc_aspect_ratio_w | default: 16
              assign pc_h = b.pc_aspect_ratio_h | default: 9
              assign pc_ratio = pc_w | append: '/' | append: pc_h
              assign h5_w = b.h5_aspect_ratio_w | default: 16
              assign h5_h = b.h5_aspect_ratio_h | default: 9
              assign h5_ratio = h5_w | append: '/' | append: h5_h
            -%}
            <div
              style='
                --media-aspect-pc: {{ pc_ratio }};
                --media-aspect-h5: {{ h5_ratio }};
              '
              class='
                relative
                aspect-(--media-aspect-h5)
                md:aspect-(--media-aspect-pc)
              '
            >
              {% render 'media-element',
                class: 'absolute inset-0 w-full h-full',
                media_class: 'w-full h-full object-cover',
                media_type: block.settings.media_type,
                pc_image: block.settings.pc_image,
                h5_image: block.settings.h5_image,
                pc_video: block.settings.pc_video,
                h5_video: block.settings.h5_video,
                video_url: block.settings.video_url,
                other_url: block.settings.other_url
              %}
              {%- render 'sn-overlay', _settings: block.settings -%}
            </div>
            <div class='mt-20 md:mt-24'>
              <h3 class='leading-1.1 text-[26px] md:text-[32px] '>
                {{ block.settings.title }}
              </h3>
              <div class='mt-8  text-[14px] leading-[1.3] text-[#515355] md:mt-12'>
                {{ block.settings.desc }}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Feature Media",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
