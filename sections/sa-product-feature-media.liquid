        },
        {
          "type": "header",
          "content": "Overlay Settings"
        },
        {
          "type": "checkbox",
          "id": "show_overlay",
          "label": "Show Media Overlay",
          "default": false
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay Opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 40
        },
        {
          "type": "header",
          "content": "Media Aspect Ratio"
        },
        {
          "type": "number",
          "id": "pc_aspect_ratio_w",
          "label": "PC Ratio Width"
        },
        {
          "type": "number",
          "id": "pc_aspect_ratio_h",
          "label": "PC Ratio Height"
        },
        {
          "type": "number",
          "id": "h5_aspect_ratio_w",
          "label": "Mobile Ratio Width"
        },
        {
          "type": "number",
          "id": "h5_aspect_ratio_h",
          "label": "Mobile Ratio Height"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Item Title"
        },
        {
          "type": "richtext",
          "id": "desc",
          "label": "Item Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Feature Media",
      "settings": {
        "right_side_title": "<p>Non-Slip Design</p>",
        "right_side_desc": "<p>No more worrying about slips or uneven terrain — Yarbo stays firmly in control, giving you a safe, stable, and reliable clearing experience. Its innovative non-slip design ensures traction in snow, ice, and tricky slopes, so every pass is precise and effortless.</p>"
