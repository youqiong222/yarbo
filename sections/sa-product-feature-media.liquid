        {
          "type": "block",
          "settings": {
            "title": "<p>Tread Pattern</p>",
            "desc": "<p>The deep-bite tread pattern provides reliable traction and smooth movement across all snowy and icy terrain. Stay balanced, precise, and in control every time.</p>"
