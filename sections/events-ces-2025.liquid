  <div class="shopline-section section nsa-accesstive" id="shopify-section-1741662050229e50836f">
    <style>
      .spacing-1741662050229e50836f__container {
        height: 30px;
      }

      @media screen and (max-width: 959px) {
        .spacing-1741662050229e50836f__container {
          height: 30px;
        }
      }
    </style>
    <div class="spacing-1741662050229e50836f__container nsa-accesstive"></div>
  </div>
  <div class="shopline-section section index-section--hero nsa-accesstive" id="shopify-section-1741661837157ab91681">
    <slider-component
      autoplay="false"
      class="slideshow slideshow-layout--text-inside page-width section--padding nsa-accesstive"
      current="1"
      loop="true"
      speed="3"
      style="
        --slideshow-speed: 3s;
        --slideshow-pc-height: natural;
        --slideshow-mobile-height: natural;
        --slideshow-text-color-1: , , ;
      "
    >
      <div class="slideshow__slider slider nsa-accesstive" id="Slider-1741661837157ab91681">
        <div
          class="slideshow__slide slider__slide is-active nsa-accesstive"
          id="Slide-1741661837158f19c1ea"
          style="
            --slideshow-overlay-opacity: 0;
            --slideshow-title-size: 70px;
            --slideshow-pc-text-position-vertical: center;
            --slideshow-pc-text-position-horizontal: flex-end;
            --slideshow-mobile-text-position-vertical: center;
            --slideshow-mobile-text-position-horizontal: center;
            --slideshow-pc-text-align: center;
            --slideshow-mobile-text-align: center;
            --slideshow-pc-text-color: rgba(0, 0, 0);
            --slideshow-text-color--mb: rgba(0, 0, 0);
            --slideshow-text-area-bg-color: rgb(161.04, 163.02, 165.66);
          "
        >
          <div class="slideshow-slide__media nsa-accesstive" style="--image-show-position: center center;">
            <img
              class="slideshow-slide__image display-none display-block-desktop nsa-accesstive"
              src="https://cdn.shopify.com/s/files/1/0604/5394/5441/files/22.png?v=1772521682"
            >
            <img
              class="slideshow-slide__image display-none-desktop nsa-accesstive"
              src="https://cdn.shopify.com/s/files/1/0604/5394/5441/files/555555.png?v=1772521857"
            >
          </div>
          <div class="slideshow-slide__text-wrapper nsa-accesstive">
            <div class="slideshow-slide__text nsa-accesstive">
              <div class="slideshow-slide__buttons nsa-accesstive"></div>
            </div>
          </div>
        </div>
      </div>
    </slider-component>
