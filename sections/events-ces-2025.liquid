<style>
  .image-container img {
    width: 100%;
    height: auto;
  }

  @media screen and (max-width: 768px) {
    .hidden-phone {
      display: none !important;
    }
  }

  @media screen and (min-width: 769px) {
    .hidden-tablet-and-up {
      display: none !important;
    }
  }
</style>
<div class="migrated-page">
  <div class="image-container">
    <img
      class="hidden-phone"
      src="https://cdn.shopify.com/s/files/1/0604/5394/5441/files/1308a855880f4ea59921021e37b3c7da.png?v=1772521101"
    >
    <img
