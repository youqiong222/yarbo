          "default": false
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay Opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 40
        },
        {
          "type": "header",
          "content": "Media Aspect Ratio"
        },
        {
          "type": "number",
          "id": "modal_pc_aspect_ratio_w",
          "label": "Modal Media PC Ratio Width"
        },
        {
          "type": "number",
          "id": "modal_pc_aspect_ratio_h",
          "label": "Modal Media PC Ratio Height"
        },
        {
          "type": "number",
          "id": "modal_h5_aspect_ratio_w",
          "label": "Modal Media Mobile Ratio Width"
        },
        {
          "type": "number",
          "id": "modal_h5_aspect_ratio_h",
