            <div class="input-container">
              <input id="signDate" name="signDate" readonly="" required="" type="text">
              <span class="underline"></span>
              <div class="error-message" id="dateError"></div>
            </div>
          </div>
          <button class="submit-button" style="display: none;" type="submit">Submit Signature</button>
          <div class="success-message" id="successMessage"></div>
        </form>
      </div>
