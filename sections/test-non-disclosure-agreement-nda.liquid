    <style>
      .signature-form-container {
        max-width: 800px;
        margin: 40px auto;
        padding: 20px;
      }

      .signature-form {
        display: flex;
        flex-direction: column;
        gap: 30px;
      }

      .checkbox-group {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 20px;
      }

      .checkbox-group input[type="checkbox"] {
        width: 20px;
        height: 20px;
        margin-top: 2px;
        appearance: none;
        -webkit-appearance: none;
        border: 2px solid #333;
        border-radius: 4px;
        outline: none;
        cursor: pointer;
        position: relative;
      }

      .checkbox-group input[type="checkbox"]:checked {
        background-color: rgb(255, 215, 0);
        border-color: rgb(255, 215, 0);
      }

      .checkbox-group input[type="checkbox"]:checked::after {
        content: '';
        position: absolute;
        left: 5px;
        top: 1px;
        width: 6px;
        height: 11px;
        border: solid black;
        border-width: 0 2px 2px 0;
        transform: rotate(45deg);
      }

      .checkbox-group label {
        font-size: 16px;
        color: #333;
        line-height: 1.4;
      }

      .signature-description {
        font-style: italic;
        color: #666;
        margin: 10px 0 30px;
      }

      .form-group {
        position: relative;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 20px;
      }

      .form-group label {
        font-size: 18px;
        font-weight: 500;
        color: #333;
        min-width: 60px;
        margin: 0;
      }

      .input-container {
        flex: 1;
        position: relative;
      }

      .form-group input {
        width: 100%;
        border: none;
        border-bottom: 1px solid #333;
        border-radius: 0;
        padding: 8px 0;
        font-size: 16px;
        background: transparent;
      }

      .form-group input:focus {
        outline: none;
        border-bottom-color: rgb(255, 215, 0);
      }

      .underline {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 1px;
        background: #333;
      }

      .nda-title {
        font-size: 16px;
        color: #333;
        text-decoration: underline;
        text-decoration-style: dotted;
        text-underline-offset: 4px;
      }

      .submit-button {
        background-color: rgb(255, 215, 0);
        color: black;
        padding: 12px 24px;
        border: none;
        border-radius: 4px;
        font-size: 16px;
        cursor: pointer;
        transition: background-color 0.3s;
        margin-top: 20px;
      }

      .submit-button:hover {
        background-color: rgba(255, 215, 0, 0.8);
      }

      .submit-button:disabled {
        background-color: #ccc;
        cursor: not-allowed;
      }

      .error-message {
        color: #ff4d4f;
        font-size: 14px;
        margin-top: 4px;
        position: absolute;
        bottom: -20px;
        left: 0;
      }

      .success-message {
        color: #52c41a;
        font-size: 14px;
        margin-top: 4px;
      }
    </style>
    <yarbo-signature-form-two>
      <div class="signature-form-container">
