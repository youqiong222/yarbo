    email:
      /^(([^<>()\[\]\\.,;:\s@"]+(\.[^<>()\[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/,
    password: /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@$!%*?&.])[A-Za-z\d@$!%*?&.]{8,22}$/,
  };

  const API = {
    sendCode: 'https://4zx17x5q7l.execute-api.us-east-1.amazonaws.com/Stage/yarbo/message-service/msg/mail/captcha',
    register: 'https://4zx17x5q7l.execute-api.us-east-1.amazonaws.com/Stage/yarbo/commonUser/register',
  };

  let state = {
    isCodeValid: false,
    isEmailValid: false,
    isPasswordValid: false,
    isConfirmValid: false,
    isAgreementChecked: false,
  };

  const debounceInput = (fn, delay = 300) => {
    let timer;
    return (...args) => {
      clearTimeout(timer);
      timer = setTimeout(() => fn(...args), delay);
    };
  };

  const showError = (element, message) => {
    // Add error class to the form item
    const formItem = element.closest('.ant-form-item');
    if (formItem) {
      formItem.classList.add('ant-form-item-has-error');
    }

    // Add error class to input wrapper if it exists
    const inputWrapper = element.closest('.ant-input-affix-wrapper');
    if (inputWrapper) {
      inputWrapper.classList.add('ant-input-affix-wrapper-status-error');
    } else if (element.classList.contains('ant-input')) {
      // Add error class directly to input if it's not in a wrapper
      element.classList.add('ant-input-status-error');
    }

    // Get the form item row element
    const formItemRow = element.closest('.ant-form-item-row');
    if (formItemRow) {
      // Check if error element already exists
      let errorElement = formItemRow.nextElementSibling;
      if (!errorElement || !errorElement.classList.contains('ant-form-item-explain-error')) {
        // Create error element if it doesn't exist
        errorElement = document.createElement('div');
        errorElement.className = 'ant-form-item-explain ant-form-item-explain-error';
        formItemRow.parentNode.insertBefore(errorElement, formItemRow.nextSibling);
      }

      // Set error message
      errorElement.textContent = message;
      errorElement.style.display = 'flex';
      errorElement.style.position = 'absolute';
      errorElement.style.width = '22.5rem';
      errorElement.style.fontSize = '.75rem';

      // Adjust the margin of the form item to accommodate the error message
      setTimeout(() => {
        const errorHeight = errorElement.offsetHeight;
        const formItem = element.closest('.ant-form-item');
        if (formItem && errorHeight > 0) {
          // Add extra margin to prevent overlap with next form item
          formItem.style.marginBottom = `${errorHeight}px`;
        }

        // If ResizeObserver is available, use it to monitor height changes
        if (window.ResizeObserver && !errorElement._resizeObserver) {
          const observer = new ResizeObserver(() => {
            const newHeight = errorElement.offsetHeight;
            if (formItem && newHeight > 0) {
              formItem.style.marginBottom = `${newHeight}px`;
            }
          });
          observer.observe(errorElement);
          errorElement._resizeObserver = observer;
        } else {
          // Fallback: add resize listener if not already added
          if (!window._errorResizeListener) {
            window.addEventListener('resize', () => {
              document.querySelectorAll('.ant-form-item-explain-error').forEach((el) => {
                if (el.style.display !== 'none') {
                  const height = el.offsetHeight;
                  const item = el.closest('.ant-form-item');
                  if (item && height > 0) {
                    item.style.marginBottom = `${height}px`;
                  }
                }
              });
            });
            window._errorResizeListener = true;
          }
        }
      }, 0);
    }
  };

  const hideError = (element) => {
    // Remove error class from the form item
    const formItem = element.closest('.ant-form-item');
    if (formItem) {
      formItem.classList.remove('ant-form-item-has-error');
      // Reset the margin to the default
      formItem.style.marginBottom = '';
    }

    // Remove error class from input wrapper if it exists
    const inputWrapper = element.closest('.ant-input-affix-wrapper');
    if (inputWrapper) {
      inputWrapper.classList.remove('ant-input-affix-wrapper-status-error');
    } else if (element.classList.contains('ant-input')) {
      // Remove error class directly from input if it's not in a wrapper
      element.classList.remove('ant-input-status-error');
    }

    // Get the form item row element
    const formItemRow = element.closest('.ant-form-item-row');
    if (formItemRow) {
      // Check if error element exists
      let errorElement = formItemRow.nextElementSibling;
      if (errorElement && errorElement.classList.contains('ant-form-item-explain-error')) {
        // Hide the error element
        errorElement.style.display = 'none';
      }
    }
  };

  const validateEmail = (email) => {
    if (!email) {
      showError(DOM.emailInput, 'Email cannot be empty.');
      return false;
    }
    if (!REGEX.email.test(email)) {
      showError(DOM.emailInput, 'Incorrect email format');
      return false;
    }
    hideError(DOM.emailInput);
    return true;
  };

  const validateCode = () => {
    const code = DOM.codeInput.value.trim();
    if (!code) {
      showError(DOM.codeInput, 'Please enter the email verification code');
      return false;
    }
    hideError(DOM.codeInput);
    return true;
  };

  const validatePassword = (password) => {
    if (!password) {
      showError(DOM.passwordInput, 'Password cannot be empty.');
      return false;
    }
    if (!REGEX.password.test(password)) {
      showError(DOM.passwordInput, 'Use 8-22 characters with uppercase, lowercase, numbers, and special characters.');
      return false;
    }
    hideError(DOM.passwordInput);
    return true;
  };

  const validateConfirmPassword = (password, confirmPassword) => {
    if (!confirmPassword) {
      showError(DOM.confirmPasswordInput, 'Confirm password cannot be empty.');
      return false;
    }
    if (password !== confirmPassword) {
      showError(DOM.confirmPasswordInput, 'Confirmed password does not match the new password, please enter again');
      return false;
    }
    hideError(DOM.confirmPasswordInput);
    return true;
  };

  const handleAgreementCheck = () => {
    const isChecked = DOM.checkbox.checked;

    if (!isChecked) {
      const formItemRow = DOM.checkbox.closest('.ant-form-item-row');
      if (formItemRow) {
        // Check if error element already exists
        let errorElement = formItemRow.nextElementSibling;
        if (!errorElement || !errorElement.classList.contains('ant-form-item-explain-error')) {
          // Create error element if it doesn't exist
          errorElement = document.createElement('div');
          errorElement.className = 'ant-form-item-explain ant-form-item-explain-error';
          formItemRow.parentNode.insertBefore(errorElement, formItemRow.nextSibling);
        }
        // Set error message
        errorElement.textContent = 'Should accept agreement';
        errorElement.style.display = 'flex';
        errorElement.style.position = 'absolute';
        errorElement.style.fontSize = '12px';
      }
    } else {
      // If checkbox is checked, remove error message
      const formItemRow = DOM.checkbox.closest('.ant-form-item-row');
      if (formItemRow) {
        let errorElement = formItemRow.nextElementSibling;
        if (errorElement && errorElement.classList.contains('ant-form-item-explain-error')) {
          errorElement.style.display = 'none';
        }
      }
    }

    return isChecked;
  };

  const encrypt = (string) => {
    const publicKey = `-----BEGIN PUBLIC KEY-----
    
    -----END PUBLIC KEY-----`;
    const rsaEncrypt = new JSEncrypt();
    rsaEncrypt.setPublicKey(publicKey);
    return rsaEncrypt.encrypt(string);
  };

  const updateSessionStorage = (referralCode) => {
    if (referralCode) {
      // Update tradeAttributeInfo
      const tradeAttributeInfo = {
        referralCode: {
          value: referralCode,
          source: 'Member',
        },
        sourceType: {
          value: 'member_plugin_referral',
          source: 'Member',
        },
      };
      sessionStorage.setItem('tradeAttributeInfo', JSON.stringify(tradeAttributeInfo));

      // Update REGISTER_EXTRA_INFO
      const registerExtraInfo = {
        memberReferralCode: {
          value: referralCode,
          source: 'Member',
        },
      };
      sessionStorage.setItem('REGISTER_EXTRA_INFO', JSON.stringify(registerExtraInfo));
    }
  };

  const handleSendCode = (e) => {
    e.preventDefault();
    const email = DOM.emailInput.value.trim();
    if (!validateEmail(email)) return;
    startCountdown();

    try {
      fetch(API.sendCode, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: 1, target: email }),
      })
        .then((res) => {
          return res.json();
        })
        .then((data) => {
          if (!data.success) {
            notification.error({
              message: data.message,
              closeIcon: false,
              duration: 3,
              placement: 'top', // Use placement property instead of just top
            });
            return;
          }
          notification.success({
            message: 'The email verification code has been sent',
            closeIcon: false,
            duration: 3,
            placement: 'top', // Use placement property instead of just top
          });
        });
    } catch (error) {
      console.error('Send Code Error:', error);
    }
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    const email = DOM.emailInput.value.trim();
    const password = DOM.passwordInput.value.trim();
    const confirmPassword = DOM.confirmPasswordInput.value.trim();
    const code = DOM.codeInput.value.trim();
    const referralCode = DOM.referralInput.value.trim();

    // Update session storage if referral code exists
    if (referralCode) {
      updateSessionStorage(referralCode);
    }

    state.isEmailValid = validateEmail(email);
    state.isPasswordValid = validatePassword(password);
    state.isConfirmValid = validateConfirmPassword(password, confirmPassword);
    state.isAgreementChecked = handleAgreementCheck();
    state.isCodeValid = validateCode();

    // 加密
    const raw = `${email}:${code}:${password}`;
    const encrypted = rsaEncrypt(raw);
    if (!encrypted) {
      console.error('RSA encryption failed');
      return;
    }

    if (!Object.values(state).every((v) => v)) return;

    try {
      const response = await fetch(API.register, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ registerData: encrypted }),
      });

      const data = await response.json();

      if (data.success || data.code === 200) {
        notification.success({
          message: 'Registration successful',
          closeIcon: false,
          duration: 2,
          placement: 'top',
        });
        setTimeout(() => {
          window.location.href = '{{ routes.account_login_url }}';
        }, 1000);
      } else {
        notification.error({
          message: data.message || 'Registration failed, please try again.',
          closeIcon: false,
          duration: 3,
          placement: 'top',
        });
      }
    } catch (error) {
      console.error('error:', error);
      notification.error({
        message: '注册失败，请稍后重试',
        closeIcon: false,
        duration: 3,
        placement: 'top',
      });
    }
  };

  const startCountdown = () => {
    let countdown = 60;
    DOM.sendCodeButton.disabled = true;

    const interval = setInterval(() => {
      DOM.sendCodeButton.textContent = `${countdown--}s`;
      if (countdown <= 0) {
        clearInterval(interval);
        DOM.sendCodeButton.disabled = false;
        DOM.sendCodeButton.textContent = 'Send Code';
      }
    }, 1000);
  };

  DOM.checkbox.addEventListener('click', handleAgreementCheck);
  DOM.sendCodeButton.addEventListener('click', handleSendCode);
  DOM.submitButton.addEventListener('click', handleSubmit);

  DOM.emailInput.addEventListener(
    'input',
    debounceInput(() => (state.isEmailValid = validateEmail(DOM.emailInput.value.trim()))),
  );

  DOM.passwordInput.addEventListener(
    'input',
    debounceInput(() => {
      state.isPasswordValid = validatePassword(DOM.passwordInput.value.trim());
    }),
  );

  DOM.confirmPasswordInput.addEventListener(
    'input',
    debounceInput(() => (state.isConfirmValid = validateConfirmPassword(DOM.passwordInput.value.trim(), DOM.confirmPasswordInput.value.trim()))),
  );

  DOM.codeInput.addEventListener('input', () => {
    validateCode();
  });
</script>
{% schema %}
{
  "name": "main signup",
  "class": "migrated-page",
  "settings": [
    {
      "type": "url",
      "id": "privacy_policy_url",
      "label": "Privacy Policy URL"
    },
    {
      "type": "url",
      "id": "terms_of_service_url",
      "label": "Terms of Use URL"
    }
  ]
}
{% endschema %}
