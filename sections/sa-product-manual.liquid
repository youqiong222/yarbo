        },
        {
          "type": "manual",
          "settings": {
            "link": "/",
            "title": "2024 Yarbo Y Core + Snow Blower User Manual"
          }
        },
        {
          "type": "manual",
          "settings": {
            "link": "/",
            "title": "2024 Yarbo Y Core User Manual"
          }
        },
        {
          "type": "video",
          "settings": {
            "video_title": "Yarbo Installation Guide"
          }
        },
        {
          "type": "video",
          "settings": {
            "video_title": "Yarbo Snow Blower Installation Guide"
          }
        },
        {
          "type": "video",
          "settings": {
            "video_title": "Yarbo App Setup Tutorial"
          }
        },
        {
