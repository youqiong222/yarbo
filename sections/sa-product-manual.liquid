{% render 'section-padding', section_id: section.id, settings: section.settings %}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}

<div class='overflow-hidden {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}'>
  <div class='page-container'>
    <div class='flex flex-col gap-32 md:flex-row md:gap-80'>
      <div class='flex-1'>
        {% if section.settings.installation_title != blank %}
          <h3 class='mb-20 text-[26px] leading-[1.1] md:mb-32 md:text-[32px]'>
            {{ section.settings.installation_title }}
          </h3>
        {% endif %}
        {%- assign video_blocks = section.blocks | where: 'type', 'video' -%}
        <div class='swiper [overflow: unset] md:overflow-hidden'>
          <div class='swiper-wrapper md:grid md:grid-cols-2 md:gap-x-14 md:gap-y-24'>
            {% for video_block in video_blocks %}
              <div
                x-data='{ open: false }'
                class='swiper-slide relative md:w-full'
                {{ video_block.shopify_attributes }}
              >
                {%- assign cover = video_block.settings.video_cover -%}
                {%- assign cover_mobile = video_block.settings.h5_video_cover | default: cover -%}

                <div
                  class='group relative aspect-304/171 w-full cursor-pointer overflow-hidden md:aspect-300/170'
                >
                  {% if cover != blank %}
                    <picture>
                      <source
                        media='(max-width: 768px)'
                        srcset='{{ cover_mobile | image_url: width: 750 }}'
                      >
                      <img
                        src='{{ cover | image_url }}'
                        alt='{{ cover.alt | escape }}'
                        width='auto'
                        height='auto'
                        class='h-full w-full object-cover transition-transform duration-500 group-hover:scale-105'
                      >
                    </picture>
                  {% else %}
                    <div class='flex h-full w-full items-center justify-center bg-gray-200 text-gray-400'>
                      {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
                    </div>
                  {% endif %}
                  <div
                    @click='open = true'
                    class='absolute inset-0 flex items-center justify-center'
                  >
                    <div
                      class='
                        relative
                        flex
                        h-48
                        w-48
                        items-center
                        justify-center
                        overflow-hidden
                        rounded-full
                        before:absolute
                        before:inset-0
                        before:bg-[#CCCCCC66]
                        before:backdrop-blur-[5px]
                      '
                    >
                      <svg
                        class='relative'
                        width='11'
                        height='13'
                        viewBox='0 0 11 13'
                        fill='none'
                        xmlns='http://www.w3.org/2000/svg'
                      >
                        <path d="M9.1448 5.79497C10.0395 6.28853 10.0428 6.9094 9.1448 7.46741L2.20628 12.0996C1.33447 12.5602 0.742359 12.2883 0.680203 11.2917L0.650761 1.59657C0.631133 0.678614 1.39499 0.41926 2.12286 0.859376L9.1448 5.79497Z" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
                      </svg>
                    </div>
                  </div>
                </div>
                {% if video_block.settings.video_title != blank %}
                  <div class='mt-12  text-[14px]/[1.3] text-[#515355]'>
                    {{ video_block.settings.video_title }}
                  </div>
                {% endif %}
                <template x-teleport='body'>
                  <div class='css-reset tailwind-layout modal'>
                    <div
                      x-cloak
                      x-show='open'
                      x-transition.opacity.duration.300ms
                      class='fixed inset-0 z-50 flex items-center justify-center bg-[#25282A]/80'
                    >
                      <div
                        @click.outside='open = false;'
                        x-transition.scale.95.duration.300ms
                        class='relative mx-4 aspect-video w-full max-w-960 bg-black'
                      >
                        {% comment %} 关闭按钮 {% endcomment %}
                        <button
                          @click='open = false;'
                          class='absolute -top-12 -right-12 z-10 flex h-40 w-40 cursor-pointer items-center justify-center rounded-full border-0 bg-white text-black hover:bg-gray-100'
                        >
                          <svg
                            width='12'
                            height='12'
                            viewBox='0 0 12 12'
                            fill='none'
                          >
                            <path d="M10.918 0.919237L0.917969 10.9192M10.918 10.9192L0.917969 0.919235" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
                          </svg>
                        </button>

                        {% render 'media-element',
                          class: 'absolute inset-0 w-full sm:h-full z-0 h-[calc(100%-100px)]',
                          media_class: 'w-full h-full object-cover',
                          media_type: video_block.settings.media_type,
                          pc_image: video_block.settings.pc_image,
                          h5_image: video_block.settings.h5_image,
                          pc_video: video_block.settings.pc_video,
                          h5_video: video_block.settings.h5_video,
                          video_url: video_block.settings.video_url,
                          other_url: video_block.settings.other_url,
                          controls: true,
                          muted: false,
                          is_modal: true
                        %}
                      </div>
                    </div>
                  </div>
                </template>
              </div>
            {% endfor %}
          </div>
        </div>
      </div>
      <div class='flex-1'>
        <h3 class='mb-20 text-[26px] leading-[1.1] md:mb-32 md:text-[32px]'>
          {{ section.settings.manuals_title }}
        </h3>
        {%- assign manual_blocks = section.blocks | where: 'type', 'manual' -%}
        <div class='flex flex-col gap-12'>
          {% for manual_block in manual_blocks %}
            <a
              href='{{ manual_block.settings.link }}'
              target='_blank'
              class='flex items-center gap-12 text-[14px] font-bold text-[#25282A] no-underline hover:underline'
            >
              <svg
                width='20'
                height='20'
                viewBox='0 0 20 20'
                fill='none'
                xmlns='http://www.w3.org/2000/svg'
              >
                <path d="M3.33398 16.9856C3.67124 17.315 4.12866 17.5 4.60561 17.5H15.3957C15.8726 17.5 16.3301 17.315 16.6673 16.9856M10.0017 2.5V12.4521M10.0017 12.4521L14.1122 8.64941M10.0017 12.4521L5.89115 8.64941" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
              </svg>

              {{ manual_block.settings.title }}
            </a>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const sectionElement = document.querySelector('#shopify-section-{{ section.id }}');
    if (!sectionElement) return;

    const swiperContainer = sectionElement.querySelector('.swiper');
    if (!swiperContainer) return;

    // 声明一个变量来存储 swiper 实例
    let mySwiper = null;

    // 定义媒体查询：1000px 及以上
    const mediaQuery = window.matchMedia('(min-width: 1000px)');
    // 核心控制函数
    const handleSwiper = (e) => {
      console.log('Media Query Matched:', e.matches);
      // 如果屏幕宽度 >= 1000px
      if (e.matches) {
        if (mySwiper !== null) {
          mySwiper.destroy(true, true);
          mySwiper = null;
        }
      }
      // 如果屏幕宽度 < 1000px
      else {
        if (mySwiper === null) {
          mySwiper = new Swiper(swiperContainer, {
            slidesPerView: 1.2,
            spaceBetween: 12,
            breakpoints: {
              768: {
                slidesPerView: 2.2,
                spaceBetween: 24,
              },
            },
          });
        }
      }
    };

    // 页面加载时执行一次判断
    handleSwiper(mediaQuery);

    // 监听窗口尺寸变化，实时销毁或创建
    mediaQuery.addEventListener('change', handleSwiper);
  })();
</script>
{% schema %}
{
  "name": "Product Manuals",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor Id"
    },
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_top",
      "label": "H5 Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_bottom",
      "label": "H5 Padding Bottom",
      "default": 0
    },
    {
      "type": "text",
      "id": "installation_title",
      "label": "Installation Title"
    },
    {
      "type": "text",
      "id": "manuals_title",
      "label": "Manuals Title"
    }
  ],
  "blocks": [
    {
      "name": "video",
      "type": "video",
      "settings": [
        {
          "type": "image_picker",
          "id": "video_cover",
          "label": "Video Cover"
        },
        {
          "type": "image_picker",
          "id": "h5_video_cover",
          "label": "Mobile Video Cover (Optional)"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type",
          "options": [
            {
              "value": "video",
              "label": "Shopify Video"
            },
            {
              "value": "video_url",
              "label": "External Video URL"
            }
          ],
          "default": "video"
        },
        {
          "type": "video",
          "id": "pc_video",
          "label": "PC Shopify Video"
        },
        {
          "type": "video",
          "id": "h5_video",
          "label": "H5 Shopify Video(Optional)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Platform Video URL (YouTube/Vimeo)",
          "accept": ["youtube", "vimeo"],
          "default": "https://www.youtube.com/watch?v=NpEaa2P7qZI"
        },
        {
          "type": "text",
          "id": "other_url",
          "label": "Other Video URL",
          "info": "ex: xxx.mp4 (If filled, this takes priority over the Platform Video URL)"
        },
        {
          "type": "header",
          "content": "Overlay Settings"
        },
        {
          "type": "checkbox",
          "id": "show_overlay",
          "label": "Show Media Overlay",
          "default": false
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay Opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 40
        },
        {
          "type": "text",
          "id": "video_title",
          "label": "Video Title"
        }
      ]
    },
    {
      "name": "manual",
      "type": "manual",
      "settings": [
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Manuals",
