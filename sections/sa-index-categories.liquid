          }
        },
        {
          "type": "block",
          "settings": {
            "text": "<p>Yarbo Y Series</p>"
          }
        },
        {
          "type": "block",
          "settings": {
            "text": "<p>Bundles</p>"
          }
        },
        {
          "type": "block",
          "settings": {
            "text": "<p>Modules</p>"
          }
        },
        {
          "type": "block",
          "settings": {
            "text": "<p>Accessories</p>"
