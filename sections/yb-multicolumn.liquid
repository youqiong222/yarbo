{% if section.settings.dark_mode %}
  <script>
    (function () {
      const sectionId = '{{ section.id | remove: "-" }}';
      const section = document.querySelector('#shopify-section-{{ section.id }}');
      if (!section) return;

      function applyDarkModeStyles() {
        const darkModeItems = section.querySelectorAll('.multicolumn-item-inner.is-dark-mode, .multicolumn-item-inner[data-dark-mode="true"]');
        darkModeItems.forEach(function (item) {
          item.style.backgroundColor = '#1F1F1F';
          item.style.background = '#1F1F1F';

          const titles = item.querySelectorAll('.block-title');
          titles.forEach(function (title) {
            title.style.color = '#fff';
          });

          const descriptions = item.querySelectorAll('.block-description');
          descriptions.forEach(function (desc) {
            desc.style.color = '#E6E6E7';
          });
        });

        const headings = section.querySelectorAll('.heading.yb-section-title');
        headings.forEach(function (heading) {
          heading.style.color = '#fff';
        });

        const descriptions = section.querySelectorAll('.rich-text-description');
        descriptions.forEach(function (desc) {
          desc.style.color = '#fff';
        });
      }

      applyDarkModeStyles();

      setTimeout(applyDarkModeStyles, 100);
      setTimeout(applyDarkModeStyles, 500);
      setTimeout(applyDarkModeStyles, 1000);

      if (window.MutationObserver) {
        const observer = new MutationObserver(function (mutations) {
          applyDarkModeStyles();
        });
        observer.observe(section, { childList: true, subtree: true });
      }
    })();
  </script>
{% endif %}

{% schema %}
{
  "name": "Yb Multicolumn",
  "class": "migrated-page",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor Id"
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "标题"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "描述"
    },
    {
      "type": "range",
      "id": "pc_grid_columns",
      "label": "PC end columns",
      "default": 1,
      "min": 1,
      "max": 3,
      "step": 1
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "是否显示评分",
      "default": false
    },
    {
      "type": "text",
      "id": "common_button_class",
      "label": "按钮类名"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "按钮文字"
    },
    {
      "type": "select",
      "id": "button_type",
      "label": "按钮类型",
      "default": "link",
      "options": [
        { "value": "link", "label": "链接" },
        { "value": "anchor", "label": "锚点" },
        {
          "value": "modal",
          "label": "弹窗"
        }
      ]
    },
    {
      "type": "text",
      "id": "button_link",
      "label": "按钮链接"
    },
    {
      "type": "text",
      "id": "button_anchor",
      "label": "按钮锚点ID"
    },
    {
      "type": "text",
      "id": "button_modal_title",
      "label": "按钮弹窗标题"
    },
    {
      "type": "html",
      "id": "button_modal_content",
      "label": "按钮弹窗内容"
    },
    {
      "type": "checkbox",
      "id": "dark_mode",
      "label": "深色模式",
      "info": "默认白色模式",
      "default": false
    },
