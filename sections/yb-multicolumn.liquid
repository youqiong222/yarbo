{% render 'yb-section-style', section: section %}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
<div
  class='multicolumn-image-with-text {% if section.settings.dark_mode %}is-dark-mode{% endif %}'
  {% if section.settings.dark_mode %}
    data-dark-mode='true'
  {% endif %}
>
  <div class='multicolumn-image-with-text-wrapper'>
    {% if section.settings.title != blank or section.settings.description != blank %}
      <div class='multicolumn-heading'>
        {% if section.settings.title != blank %}
          <div class='heading yb-section-title'>{{ section.settings.title }}</div>
          {% if section.settings.description != blank %}
            <div class='margin-top-description-style'>
              <div class='rich-text-description yb-body-3 lcf-section-des'>{{ section.settings.description }}</div>
            </div>
          {% endif %}
        {% else %}
          {% if section.settings.description != blank %}
            <div class='rich-text-description yb-body-3 lcf-section-des'>{{ section.settings.description }}</div>
          {% endif %}
        {% endif %}

        {% if section.settings.button_text != blank %}
          <div class='{% if section.settings.title != blank or section.settings.description != blank %}rich-text-button{% endif %}'>
            {% assign btn_class = section.settings.common_button_class | append: ' yb-single-video-btn' %}
            {% render 'yb-button', type: section.settings.button_type, class: btn_class, tag: 'button', config: section.settings %}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class='multicolumn-items'>
      <div
        class='multicolumn-items-wrapper grid-column-{{ section.settings.pc_grid_columns }}'
        style='grid-template-columns: repeat({{ section.settings.pc_grid_columns }}, 1fr);'
      >
        {% for block in section.blocks %}
          {% if block.type == 'image_item' %}
            <div
              class='multicolumn-item-inner {% if section.settings.dark_mode %}is-dark-mode{% endif %}'
              {% if section.settings.dark_mode %}
                data-dark-mode='true'
              {% endif %}
              {{ block.shopify_attributes }}
            >
              <div class='multicolumn-contents'>
                {% if block.settings.block_image != blank %}
                  <div class='multicolumn-image'>
                    {{ block.settings.block_image | image_url: width: 400 | image_tag: class: 'image', loading: 'lazy' }}
                  </div>
                {% endif %}

                {% if block.settings.block_title != blank or block.settings.block_description != blank %}
                  <div class='multicolumn-image-content'>
                    {% if block.settings.block_title != blank %}
                      <div class='block-title'>{{ block.settings.block_title }}</div>
                      {% if section.settings.show_rating %}
                        <div class='block-rating'>
                          {% for i in (1..5) %}
                            {% assign half_star = i | minus: 0.5 %}
                            {% if block.settings.block_rating >= i %}
                              <svg
                                class='icon star-svg'
                                viewBox='0 0 1024 1024'
                                width='20'
                                height='20'
                                xmlns='http://www.w3.org/2000/svg'
                              >
                                <path d="M905.216 446.58688c28.672-24.576 16.384-69.632-24.576-73.728l-208.896-24.576c-12.288 0-24.576-12.288-36.864-24.576l-90.112-192.512c-16.384-36.864-61.44-36.864-77.824 0l-81.92 188.416c-12.288 12.288-24.576 20.48-36.864 20.48l-208.896 32.768c-36.864 4.096-53.248 49.152-24.576 73.728l151.552 143.36c8.192 8.192 16.384 24.576 12.288 40.96l-40.96 204.8c-8.192 36.864 32.768 65.536 65.536 49.152l180.224-102.4c12.288-8.192 32.768-8.192 45.056 0l180.224 102.4c32.768 16.384 69.632-8.192 65.536-49.152l-36.864-204.8c-4.096-12.288 0-32.768 12.288-40.96l155.648-143.36z" fill="#FFB21C"></path>
                              </svg>
                            {% elsif block.settings.block_rating >= half_star %}
                              <svg
                                class='icon star-svg'
                                viewBox='0 0 1024 1024'
                                width='20'
                                height='20'
                                xmlns='http://www.w3.org/2000/svg'
                              >
                                <path d="M512 147.57888c-16.384 0-28.672 8.192-40.96 24.576l-77.824 176.128c-8.192 12.288-20.48 20.48-32.768 20.48l-192.512 28.672c-32.768 4.096-49.152 45.056-24.576 69.632l139.264 131.072c8.192 8.192 16.384 24.576 12.288 36.864l-36.864 188.416c-8.192 32.768 28.672 61.44 61.44 45.056l167.936-94.208c8.192-4.096 16.384-8.192 24.576-4.096v-622.592z" fill="#FFB21C"></path>
                              </svg>
                            {% else %}
                              <svg
                                class='icon star-svg'
                                viewBox='0 0 1024 1024'
                                width='20'
                                height='20'
                                xmlns='http://www.w3.org/2000/svg'
                              >
                                <path d="M905.216 446.58688c28.672-24.576 16.384-69.632-24.576-73.728l-208.896-24.576c-12.288 0-24.576-12.288-36.864-24.576l-90.112-192.512c-16.384-36.864-61.44-36.864-77.824 0l-81.92 188.416c-12.288 12.288-24.576 20.48-36.864 20.48l-208.896 32.768c-36.864 4.096-53.248 49.152-24.576 73.728l151.552 143.36c8.192 8.192 16.384 24.576 12.288 40.96l-40.96 204.8c-8.192 36.864 32.768 65.536 65.536 49.152l180.224-102.4c12.288-8.192 32.768-8.192 45.056 0l180.224 102.4c32.768 16.384 69.632-8.192 65.536-49.152l-36.864-204.8c-4.096-12.288 0-32.768 12.288-40.96l155.648-143.36z" fill="#E0E0E0"></path>
                              </svg>
                            {% endif %}
                          {% endfor %}
                        </div>
                      {% endif %}
                      {% if block.settings.block_description != blank %}
                        <div class='block-description'>{{ block.settings.block_description }}</div>
                      {% endif %}
                    {% else %}
                      {% if block.settings.block_description != blank %}
                        <div class='block-description'>{{ block.settings.block_description }}</div>
                      {% endif %}
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

