  <script>
    const initMediaHoverSwitch = () => {
      // ==========================================
      // 视频播放控制器 (核心播放/暂停逻辑)
      // ==========================================
      const handleVideoPlayer = (slide, action) => {
        if (!slide) return;
        const videos = slide.querySelectorAll('video');
        videos.forEach(vid => {
          vid.muted = true; // 必须强制静音，否则浏览器会拦截自动播放
          if (action === 'play') {
            const playPromise = vid.play();
            if (playPromise !== undefined) {
              playPromise.catch(e => console.log('视频自动播放被拦截:', e));
            }
          } else {
            vid.pause();
          }
        });
      };

      const containers = document.querySelectorAll('[data-section-type="media-hover-switch"]');

      containers.forEach((container) => {
        const pcContainer = container.querySelector('.advc-container--pc');
        const mbContainer = container.querySelector('.advc-container--mb');
        const videoEls = container.querySelectorAll('.video-slide');

        // ==========================================
        // PC 端逻辑
        // ==========================================
        if (pcContainer) {
          const slides = pcContainer.querySelectorAll('.media-slide');
          const length = slides.length;

          // 初始将所有视频暂停并静音
          pcContainer.querySelectorAll('video').forEach(vid => {
            vid.muted = true;
            vid.pause();
          });

          const calcTransform = (activeIndex) => {
            if (!pcContainer.querySelector('.media-slide.is-active')) return;
            const activeWidth = pcContainer.querySelector('.media-slide.is-active').offsetWidth;

            let totalProcess = 0;
            const transformData = [];

            for (let i = 0; i < length; ++i) {
              const process = i - activeIndex;
              const sign = Math.sign(process);
              const scale = Math.pow(0.9, Math.abs(process));
              const logScale = 1 - Math.log(Math.abs(process - sign) + 1) / length;
              const offsetX = -activeWidth * (1 - scale) / 2 + -activeWidth * (1 - logScale) / 2 + 113 * logScale;

              totalProcess += (activeWidth + 113) * scale;
              transformData.push({ process, scale, offsetX, sign });
            }

            const swiperWidth = pcContainer.querySelector('.swiper') ? pcContainer.querySelector('.swiper').offsetWidth : activeWidth;
            const rxRatio = ((totalProcess += 113) - swiperWidth) / (totalProcess - (activeWidth + 226));

            for (let i = 0; i < length; ++i) {
              transformData[i].Rx = (activeWidth + 113) * transformData[i].scale * rxRatio;
            }
            for (let i = 0; i < length; ++i) {
              let translate = transformData[i].offsetX - transformData[i].Rx;
              const sign = Math.sign(transformData[i].process);
              const filters = transformData.filter(t => t.process !== 0 && t.sign === sign && Math.abs(t.process) < Math.abs(transformData[i].process));

              for (let j = 0; j < filters.length; ++j) {
                translate = translate + filters[j].offsetX - filters[j].Rx;
              }
              translate *= sign;
              transformData[i].translate = translate;
            }

            const baseTranslate = Math.abs(transformData[0].process) * activeWidth;
            let offsetTranslate = 0;

            for (let i = 0; i < length; ++i) {
              if (transformData[i].sign < 0) {
                offsetTranslate += (activeWidth + 113) * transformData[i].scale - transformData[i].Rx;
              }
            }

            const finalOffset = offsetTranslate - baseTranslate;
            const dir = document.dir === 'rtl' ? -1 : 1;

            for (let i = 0; i < length; ++i) {
              transformData[i].translate += finalOffset;
              slides[i].style.transform = `translate3d(${dir * transformData[i].translate}px, 0px, 0px) scale3d(${transformData[i].scale}, ${transformData[i].scale}, 1)`;
              slides[i].style.zIndex = 9 - Math.abs(transformData[i].process);
            }
          };

          if (length > 0) {
            const initialIndex = Math.floor((length - 1) / 2);
            calcTransform(initialIndex);

            // 初始化播放中间的高亮视频
            const initialActive = pcContainer.querySelector('.media-slide.is-active');
            handleVideoPlayer(initialActive, 'play');

            slides.forEach((slide) => {
              slide.addEventListener('mouseenter', (e) => {
                const target = e.currentTarget;
                const currentActive = pcContainer.querySelector('.media-slide.is-active');

                // 判断：只有移入新的卡片才执行切换
                if (currentActive && currentActive !== target) {
                  currentActive.classList.remove('is-active');
                  handleVideoPlayer(currentActive, 'pause'); // 旧的暂停

                  target.classList.add('is-active');
                  handleVideoPlayer(target, 'play'); // 新的播放

                  calcTransform(Number(target.dataset.index));
                }
              });
            });
          }
        }

        // ==========================================
        // H5 端逻辑 (带克隆节点的无缝循环 Touch Swipe)
        // ==========================================
        if (mbContainer) {
          const wrapper = mbContainer.querySelector('.swiper-wrapper') || mbContainer.querySelector('.swiper');
          const originalSlides = Array.from(wrapper.querySelectorAll('.media-slide'));
          const originalLength = originalSlides.length;

          if (wrapper && originalLength > 0) {
            // H5 初始将所有视频暂停并静音
            mbContainer.querySelectorAll('video').forEach(vid => {
              vid.muted = true;
              vid.pause();
            });

            // --- 1. 克隆节点以实现无限循环 ---
            const loopCount = Math.min(3, originalLength);

            const createClones = (slidesArr) => {
              return slidesArr.map(s => {
                const clone = s.cloneNode(true);
                clone.setAttribute('data-clone', '1');
                clone.classList.remove('is-active');
                return clone;
              });
            };

            const prependClones = createClones(originalSlides.slice(-loopCount));
            const appendClones = createClones(originalSlides.slice(0, loopCount));

            prependClones.forEach(clone => wrapper.insertBefore(clone, originalSlides[0]));
            appendClones.forEach(clone => wrapper.appendChild(clone));

            const slides = Array.from(wrapper.querySelectorAll('.media-slide'));
            const totalLength = slides.length;

            // --- 2. 状态变量 ---
            let currentIndex = loopCount;
            let floatIndex = currentIndex;
            let isDragging = false;
            let startX = 0;
            let currentX = 0;
            let slideWidth = 0;
            let rAF = null;

            // --- 3. 核心渲染与动画 ---
            const render = (fIndex) => {
              slides.forEach((slide, i) => {
                const diff = i - fIndex;
                const absDiff = Math.abs(diff);
                const scale = Math.max(0, 1 - absDiff * 0.1);
                const xPercent = -100 * i;
                const xPx = diff * 24;

                slide.style.transform = `scale(${scale}) translate3d(calc((${xPercent}% + ${xPx}px) / ${scale}), 0, 0)`;
                slide.style.transformOrigin = diff <= 0 ? 'left' : 'right';
                slide.style.zIndex = Math.floor(18 - absDiff);

                // 判断逻辑：当前卡片是否应该是 active
                const shouldBeActive = (absDiff < 0.5 && !slide.hasAttribute('data-clone'));
                const isActive = slide.classList.contains('is-active');

                // 核心控制：只有状态发生翻转的一瞬间，才执行播放或暂停
                if (shouldBeActive && !isActive) {
                  slide.classList.add('is-active');
                  handleVideoPlayer(slide, 'play');
                } else if (!shouldBeActive && isActive) {
                  slide.classList.remove('is-active');
                  handleVideoPlayer(slide, 'pause');
                }
              });
            };

            const lerp = (start, end, amt) => (1 - amt) * start + amt * end;

            const animateSnap = () => {
              if (isDragging) return;

              if (Math.abs(currentIndex - floatIndex) > 0.001) {
                floatIndex = lerp(floatIndex, currentIndex, 0.15);
                render(floatIndex);
                rAF = requestAnimationFrame(animateSnap);
              } else {
                floatIndex = currentIndex;

                if (currentIndex < loopCount) {
                  currentIndex += originalLength;
                  floatIndex = currentIndex;
                } else if (currentIndex >= originalLength + loopCount) {
                  currentIndex -= originalLength;
                  floatIndex = currentIndex;
                }

                render(floatIndex);
              }
            };

            // --- 4. 触摸事件绑定 ---
            const touchStart = (e) => {
              isDragging = true;
              startX = e.type.includes('mouse') ? e.pageX : e.touches[0].clientX;
              currentX = startX;
              slideWidth = slides[0].offsetWidth || window.innerWidth * 0.75;
              cancelAnimationFrame(rAF);
            };

            const touchMove = (e) => {
              if (!isDragging) return;
              currentX = e.type.includes('mouse') ? e.pageX : e.touches[0].clientX;
              const dragDist = currentX - startX;
              floatIndex = currentIndex - (dragDist / slideWidth);
              floatIndex = Math.max(0, Math.min(totalLength - 1, floatIndex));
              render(floatIndex);
            };

            const touchEnd = () => {
              if (!isDragging) return;
              isDragging = false;
              const dragDist = currentX - startX;

              if (Math.abs(dragDist) > slideWidth * 0.15) {
                if (dragDist < 0 && currentIndex < totalLength - 1) {
                  currentIndex++;
                } else if (dragDist > 0 && currentIndex > 0) {
                  currentIndex--;
                }
              }
              animateSnap();
            };

            wrapper.addEventListener('touchstart', touchStart, { passive: true });
            wrapper.addEventListener('touchmove', touchMove, { passive: true });
            wrapper.addEventListener('touchend', touchEnd);

            wrapper.addEventListener('mousedown', touchStart);
            wrapper.addEventListener('mousemove', touchMove);
            wrapper.addEventListener('mouseup', touchEnd);
            wrapper.addEventListener('mouseleave', () => {
              if (isDragging) touchEnd();
            });

            // 初始化首次渲染 (触发第一张真实幻灯片的自动播放)
            render(floatIndex);
          }
        }

        // ==========================================
        // 视频弹窗逻辑 (已修复双端隔离与关闭逻辑)
        // ==========================================
        const sectionId = container.getAttribute('data-section-id');

        videoEls.forEach((videoEl) => {
          videoEl.addEventListener('click', (e) => {
            const isMobileSlide = videoEl.closest('.advc-container--mb') !== null;
            const wrapperClass = isMobileSlide ? '.media-slide-video-wrapper-mobile' : '.media-slide-video-wrapper';
            const wrapper = videoEl.querySelector(wrapperClass);

            if (wrapper) {
              const videoId = wrapper.getAttribute('data-video-id');
              const dataId = wrapper.getAttribute('data-id');
              const dataEl = wrapper.querySelector(`#Video-data-${dataId}`);

              if (videoId && dataEl) {
                try {
                  const videoData = JSON.parse(dataEl.innerHTML);
                  const videoUrl = isMobileSlide && videoData.mobile_video_url ? videoData.mobile_video_url : videoData.video_url;

                  const suffix = isMobileSlide ? 'mb' : 'pc';
                  const modalId = `advc-previewer-${sectionId}-${suffix}`;
                  const modal = document.getElementById(modalId);

                  if (modal) {
                    const modalArea = modal.querySelector('.advc-previewer__area');

                    modalArea.innerHTML = `
                    <video src="${videoUrl}" controls autoplay playsinline
                           style="width:100%; height:100%;position: absolute; object-fit: contain;">
                    </video>
                  `;

                    modal.classList.remove('hide');

                    const closeBtn = modal.querySelector('.advc-previewer__close-btn');
                    const mask = modal.querySelector('.advc-previewer__mask');

                    const closeModal = () => {
                      modal.classList.add('hide');
                      modalArea.innerHTML = '';
                    };

                    if (closeBtn) closeBtn.onclick = closeModal;
                    if (mask) mask.onclick = closeModal;
                  }
                } catch (err) {
                  console.error('解析视频数据失败:', err);
                }
              }
            }
          });
        });
      });
    };

    // 确保 DOM 加载完毕后再执行
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMediaHoverSwitch);
    } else {
      initMediaHoverSwitch();
    }
  </script>
</div>
<script>
  (() => {
    const debounce = (fn, delay, immediate) => {
      let timer;
      return function(...args) {
        const context = this;
        const callNow = immediate && !timer;
        clearTimeout(timer);
        timer = setTimeout(() => {
          timer = null;
          if (!immediate) fn.apply(context, args);
        }, delay);
        if (callNow) fn.apply(context, args);
      };
    };

    const isMobilePlatform = () => {
      let detector = document.querySelector('i[data-advc-platform]');
      if (!detector) {
        detector = document.createElement('i');
        detector.setAttribute('data-advc-platform', '');
        document.body.append(detector);
      }
      return window.getComputedStyle(detector).display === 'block';
    };

    class AdvcCollapse {
      constructor(container, options = {}) {
        this.classes = {
          collapse: 'advc-collapse',
          panel: 'advc-collapse__panel',
          open: 'is-open',
          closed: 'is-closed',
          header: 'advc-collapse__panel-header',
          content: 'advc-collapse__panel-content',
          video: 'video'
        };

        this.container = container;
        this.panels = this.container.getElementsByClassName(this.classes.panel);
        this.platform = this.container.getAttribute('data-platform');

        this.initialized = false;
        this.resizeHandler = null;

        this.onChange = options.onChange;
        this.initPanel = options.initPanel;
        this.onResizeShow = options.onResizeShow;
        this.onResizeHide = options.onResizeHide;

        this.resizeInit();
      }

      init() {
        if (this.initialized) return;

        Array.from(this.panels).forEach((panel) => {
          const header = panel.getElementsByClassName(this.classes.header)[0];
          const content = panel.getElementsByClassName(this.classes.content)[0];
          const key = panel.getAttribute('data-key');

          if (this.initPanel) this.initPanel(panel, key);

          header.addEventListener('click', () => {
            this.togglePanel({ panel, content, key });
          });
        });

        this.initialized = true;
      }

      togglePanel({ panel, content, key }) {
        const isOpen = panel.classList.contains(this.classes.open);

        const targetHeight = isOpen ? 0 : content.scrollHeight + 30;
        content.style.height = `${targetHeight}px`;

        const handleTransitionEnd = () => {
          content.style.height = '';
          content.removeEventListener('transitionend', handleTransitionEnd);
        };
        content.addEventListener('transitionend', handleTransitionEnd);

        if (isOpen) {
          panel.classList.add(this.classes.closed);
          panel.classList.remove(this.classes.open);
        } else {
          panel.classList.add(this.classes.open);
          panel.classList.remove(this.classes.closed);
        }

        if (this.onChange) this.onChange(panel, key);
      }

      resizeInit() {
        if (this.platform && this.platform !== 'all') {
          let isVisible = false;
          let isHidden = false;

          const checkPlatform = debounce(() => {
            const currentPlatform = isMobilePlatform() ? 'm' : 'pc';

            if (this.platform === currentPlatform) {
              isHidden = false;
              this.init();
              if (!isVisible && this.onResizeShow) {
                isVisible = true;
                this.onResizeShow();
              }
            } else {
              if (!isHidden && this.onResizeHide) {
                isVisible = false;
                isHidden = true;
                this.onResizeHide();
              }
            }
          }, 50);

          checkPlatform();
          this.resizeHandler = checkPlatform;
          window.addEventListener('resize', checkPlatform);
        } else {
          this.init();
        }
      }

      unload() {
        if (this.resizeHandler) {
          window.removeEventListener('resize', this.resizeHandler);
        }
      }
    }
    const collapseContainers = document.querySelectorAll('.advc-collapse');
    collapseContainers.forEach(container => {
      new AdvcCollapse(container);
    });
  })();
</script>
