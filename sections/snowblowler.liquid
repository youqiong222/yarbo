        <script>
          (() => {
            document.addEventListener('DOMContentLoaded', function () {
              const tabList = document.querySelector('.advc-tabs-controls--scroller');
              const tabListLi = document.querySelectorAll('.advc-tabs-controls--scroller li');
              const contentContainer = document.querySelector('.advc-tabs-panel-content');

              const allContents = contentContainer.querySelectorAll('.advc-tabs-panel-content__item');

              tabListLi.forEach(li => {
                li.addEventListener('click', function (e) {
                  // 修改处 1：使用 e.currentTarget 获取绑定事件的 li，而不是点击的 p
                  const currentLi = e.currentTarget;
                  const tabKey = currentLi.getAttribute('data-tab-key');

                  // 隐藏所有内容
                  allContents.forEach(content => content.classList.remove('is-active'));

                  // 显示对应的内容
                  const targetContent = contentContainer.querySelector(`div[data-tab-key="${tabKey}"]`);
                  if (targetContent) {
                    targetContent.classList.add('is-active');
                  }

                  // 移除所有 li 的 active 类
                  tabList.querySelectorAll('li').forEach(item => item.classList.remove('is-active'));

                  // 修改处 2：为当前的 li (即 currentLi) 添加 active 类
                  currentLi.classList.add('is-active');
                });
              });
            })
          })();
        </script>
