    /* 基础布局 */
    .advc-section-container {
      margin: 0 auto;
      padding: 100px 40px;
      max-width: 1420px;
      background-color: #ffffff;
    }

    .advc-text-with-video {
      display: flex;
      align-items: center;
      gap: 40px;
      /* 视频和文本之间的间距 */
    }

    /* 左右布局控制 */
    .advc-text-with-video__position-left {
      flex-direction: row;
    }

    .advc-text-with-video__position-right {
      flex-direction: row-reverse;
    }

    /* 视频容器与文本容器各占一半 */
    .advc-text-with-video__videowrap,
    .advc-text-with-video__block {
      flex: 1;
      width: 50%;
    }

    /* 视频圆角 */
    .advc-video-wrapper {
      border-radius: 22px;
      overflow: hidden;
      line-height: 0;
    }

    /* 文本样式 (继承默认字体) */
    .advc-title {
      font-size: 36px;
      font-weight: 600;
      color: #000000;
      line-height: 1.2;
      margin-bottom: 20px;
    }

    .advc-body {
      font-size: 16px;
      font-weight: 400;
      color: #000000;
      line-height: 1.6;
    }

    /* 移动端适配 */
    @media only screen and (max-width: 750px) {
      .advc-section-container {
        padding: 40px 20px;
      }

      .advc-text-with-video {
        flex-direction: column !important;
        /* 强制垂直排列 */
        gap: 24px;
      }

      .advc-text-with-video__videowrap,
      .advc-text-with-video__block {
        width: 100%;
      }

      .advc-title {
        font-size: 24px;
      }

      .advc-body {
        font-size: 14px;
      }
    }
  </style>
