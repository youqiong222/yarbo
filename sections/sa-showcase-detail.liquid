<main>
  <div
    id='showcase-detail-root'
    class='w-full bg-white'
  >
    <div
      id='case-loading-container'
      class='page-container flex min-h-[60vh] items-center justify-center py-40 md:py-60'
    >
      <div class='text-center'>
        <div class='mb-4 inline-block h-12 w-12 animate-spin rounded-full border-b-2 border-[#FEDB1E]'></div>
        <p class='text-[18px] text-[#676A6D]'>Loading Product Demo Host details...</p>
      </div>
    </div>
  </div>
</main>

<script>
  // 初始化函数
  async function initShowcaseDetail() {
    // 统一定义需要操作的 DOM 节点 ID
    const LOADING_CONTAINER_ID = 'case-loading-container';

    try {
      const urlParams = new URLSearchParams(window.location.search);
      const id = urlParams.get('id');

      if (!id) {
        window.location.href = '/pages/product-program-search';
        return;
      }

      const url = 'https://dev.yarbo.ai/backend/v3/ambassador/detail';

      const res = await fetch(`${url}?id=${id}`, {
        headers: {
          'Content-Type': 'application/json',
        },
        method: 'GET',
      });

      const resData = await res.json();
      console.log('API Response:', resData);

      // 注意：请确保后端的成功码确实是 0，如果是 200 请修改此处
      if (resData.code === 0 && resData.data) {
        const matchedMessage = resData.data;
        const bigImgBox = document.getElementById('showcase-detail-root');
        const loadingContainer = document.getElementById(LOADING_CONTAINER_ID);

        // 隐藏 loading 状态 (也可以直接被 innerHTML 覆盖)
        if (loadingContainer) {
          loadingContainer.style.display = 'none';
        }

        // 渲染内容
        bigImgBox.innerHTML = `
        <div class="page-container py-40 md:py-60 min-h-[60vh]">

            <!-- 标题 -->
            <h1 class="mb-20 text-[22px]/[1.2] text-[#25282A] md:mb-40 md:text-[40px]/[1.1]">
              ${matchedMessage.first_name}'s Product Demo
              <span class="text-[#8C8F91]">in ${matchedMessage.city}, ${matchedMessage.state}</span>
            </h1>

            <!-- 图片轮播 -->
            <div class="relative mb-32 aspect-[16/9] overflow-hidden bg-[#F2F2F2] md:mb-48 md:aspect-[1400/720]">
                <div class="case-swiper swiper h-full w-full">
                    <div class="swiper-wrapper">
                        ${
                          Array.isArray(matchedMessage.yarbo_photos) && matchedMessage.yarbo_photos.length > 0
                            ? matchedMessage.yarbo_photos
                                .map(
                                  (image) => `
                                <div class="swiper-slide" style="height:100%">
                                    <div style="position:relative;width:100%;height:100%;overflow:hidden;">
                                        <div style="position:absolute;inset:0;background-image:url('${image}');background-size:cover;background-position:center;transform:scale(1.1);"></div>
                                        <div style="position:absolute;inset:0;backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);"></div>
                                        <img alt="" loading="lazy" src="${image}" style="position:absolute;inset:0;width:100%;height:100%;object-fit:contain;">
                                    </div>
                                </div>`,
                                )
                                .join('')
                            : `<div class="swiper-slide flex min-h-200 items-center justify-center bg-[#F2F2F2] md:min-h-400">
                                <p class="text-[14px] text-[#8C8F91]">No photos available</p>
                               </div>`
                        }
                    </div>
                </div>
                <!-- 导航按钮 -->
                ${
                  !matchedMessage.yarbo_photos || matchedMessage.yarbo_photos.length <= 1
                    ? ''
                    : `
                <button id="prevButton" class="absolute left-12 top-1/2 z-10 flex h-40 w-40 -translate-y-1/2 items-center justify-center bg-white/80 text-[#25282A] transition-colors hover:bg-white md:h-48 md:w-48">
                    <svg width="10" height="16" viewBox="0 0 10 16" fill="none"><path d="M8.5 1L1.5 8L8.5 15" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/></svg>
                </button>
                <button id="nextButton" class="absolute right-12 top-1/2 z-10 flex h-40 w-40 -translate-y-1/2 items-center justify-center bg-white/80 text-[#25282A] transition-colors hover:bg-white md:h-48 md:w-48">
                    <svg width="10" height="16" viewBox="0 0 10 16" fill="none"><path d="M1.5 1L8.5 8L1.5 15" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/></svg>
                </button>`
                }
            </div>

            <!-- 内容区：左侧信息 + 右侧简介 -->
            <div class="flex flex-col gap-32 md:flex-row md:gap-60">

                <!-- 左：主办人信息 -->
                <div class="flex flex-col gap-24 md:w-[300px] md:flex-shrink-0 md:gap-32">

                    <!-- Hosted by -->
                    <div class="flex flex-col gap-8">
                        <p class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#8C8F91]">Hosted by</p>
                        <div class="flex items-center gap-12">
                            ${
                              matchedMessage.profile_file
                                ? `
                            <div class="h-48 w-48 flex-shrink-0 overflow-hidden rounded-full bg-[#F2F2F2]">
                                <img src="${matchedMessage.profile_file}" alt="${matchedMessage.first_name}" class="h-full w-full object-cover">
                            </div>`
                                : `
                            <div class="flex h-48 w-48 flex-shrink-0 items-center justify-center rounded-full bg-[#F2F2F2] text-[18px] font-bold text-[#25282A]">
                                ${matchedMessage.first_name.charAt(0)}
                            </div>`
                            }
                            <p class="text-[16px] font-bold text-[#25282A] md:text-[18px]">${matchedMessage.first_name} ${matchedMessage.last_name || ''}</p>
                        </div>
                    </div>

                    <!-- 分割线 -->
                    <div class="h-px w-full bg-[#F0F0F0]"></div>

                    <!-- Location -->
                    <div class="flex flex-col gap-8">
                        <p class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#8C8F91]">Location</p>
                        <p class="text-[15px] text-[#25282A] md:text-[16px]">${matchedMessage.city}, ${matchedMessage.state}</p>
                    </div>

                    ${
                      Array.isArray(matchedMessage.products_owned) && matchedMessage.products_owned.length > 0
                        ? `
                    <!-- 分割线 -->
                    <div class="h-px w-full bg-[#F0F0F0]"></div>
                    <!-- Owned Yarbo -->
                    <div class="flex flex-col gap-8">
                        <p class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#8C8F91]">Owned Yarbo</p>
                        <div class="flex flex-wrap gap-8">
                            ${matchedMessage.products_owned.map((p) => `<span class="border border-[#E5E5E5] px-10 py-4 text-[13px] text-[#515355]">${p}</span>`).join('')}
                        </div>
                    </div>`
                        : ''
                    }

                    ${
                      Array.isArray(matchedMessage.yard_conditions) && matchedMessage.yard_conditions.length > 0
                        ? `
                    <!-- 分割线 -->
                    <div class="h-px w-full bg-[#F0F0F0]"></div>
                    <!-- Yard Conditions -->
                    <div class="flex flex-col gap-8">
                        <p class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#8C8F91]">Yard Conditions</p>
                        <div class="flex flex-wrap gap-8">
                            ${matchedMessage.yard_conditions.map((c) => `<span class="border border-[#E5E5E5] px-10 py-4 text-[13px] text-[#515355]">${c}</span>`).join('')}
                        </div>
                    </div>`
                        : ''
                    }
                </div>

                <!-- 右：简介 + 预约 -->
                <div class="flex flex-1 flex-col gap-24 md:gap-32">
                    <div class="flex flex-col gap-16">
                        <p class="text-[13px] leading-[1.6] text-[#515355] md:text-[15px]">
                            Click the <b>"Book Appointment"</b> button below to schedule your visit, or email us at
                            <a href="mailto:showcase@yarbo.com" class="text-[#25282A] underline">showcase@yarbo.com</a>
                            and we'll arrange an <b>in-person visit at this host's location</b>. The exact address will be shared after confirmation.
                        </p>
                    </div>

                    ${
                      matchedMessage.introduction
                        ? `
                    <div class="h-px w-full bg-[#F0F0F0]"></div>
                    <div class="flex flex-col gap-12">
                        <p class="text-[11px] font-bold uppercase tracking-[0.08em] text-[#8C8F91]">About this Product Demo</p>
                        <p class="whitespace-pre-line text-[14px] leading-[1.7] text-[#515355] md:text-[15px]">${matchedMessage.introduction}</p>
                    </div>`
                        : ''
                    }

                    <div class="mt-8">
                        <a href="https://forms.zoho.com/yarbo/form/ShowcaseCustomerBookingFormWebsiteEmbedded"
                           target="_blank"
                           class="booking-form-btn inline-flex h-44 items-center justify-center bg-[#FEDB1E] px-24 text-[14px]/[1.4] tracking-[0] text-[#25282A] no-underline transition-colors duration-300 hover:bg-[#25282a] hover:text-white sm:px-32">
                            Book Appointment
                        </a>
                    </div>
                </div>

            </div>
        </div>
        `;

        // 安全初始化 Swiper
        if (typeof Swiper !== 'undefined') {
          requestAnimationFrame(() => {
            const swiper = new Swiper('.case-swiper', { slidesPerView: 1 });
            const prevBtn = document.getElementById('prevButton');
            const nextBtn = document.getElementById('nextButton');

            if (prevBtn) prevBtn.addEventListener('click', () => swiper.slidePrev());
            if (nextBtn) nextBtn.addEventListener('click', () => swiper.slideNext());
          });
        } else {
          console.warn('Swiper is not defined. Please check if the script is loaded.');
        }

        // 安全绑定追踪事件
        const bookingBtn = document.querySelector('.booking-form-btn');
        if (bookingBtn) {
          bookingBtn.addEventListener('click', () => {
            if (typeof window.reportEvent === 'function') {
              window.reportEvent({
                event: 'page_showcase_search_click',
                name: matchedMessage.first_name,
                country: matchedMessage.country,
                city: matchedMessage.city,
                type: 'book',
              });
            } else {
              console.warn('window.reportEvent is not a function');
            }
          });
        }
      } else {
        // API返回错误或数据为空 (修复了这里的 ID 选择器)
        const loadingContainer = document.getElementById(LOADING_CONTAINER_ID);
        if (loadingContainer) {
          loadingContainer.innerHTML = `
            <div class="text-center">
                <div class="text-red-500 mb-4">
                    <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                    </svg>
                </div>
                <h2 class="text-xl font-semibold text-[#02060B] mb-2">Failed to load Product Demo Host</h2>
                <p class="text-[#676A6D]">${resData.msg || 'Unable to load Product Demo Host details. Please try again later.'}</p>
            </div>
          `;
        }
      }
    } catch (error) {
      console.error('Error initializing showcase detail:', error);

      // 显示错误状态 (修复了这里的 ID 选择器)
      const loadingContainer = document.getElementById(LOADING_CONTAINER_ID);
      if (loadingContainer) {
        loadingContainer.innerHTML = `
            <div class="text-center">
                <div class="text-red-500 mb-4">
                    <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
                    </svg>
                </div>
                <h2 class="text-xl font-semibold text-[#02060B] mb-2">Something went wrong</h2>
                <p class="text-[#676A6D]">Unable to load Product Demo Host details. Please try again later.</p>
            </div>
        `;
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShowcaseDetail);
  } else {
    initShowcaseDetail();
  }
</script>

{% schema %}
{
  "name": "main show case detail",
  "class": "css-reset tailwind-layout"
}
{% endschema %}
