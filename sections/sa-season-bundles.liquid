{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script
    src='{{ 'product-form.js' | asset_url }}'
    defer='defer'
  ></script>
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script
    src='{{ 'quick-add.js' | asset_url }}'
    defer='defer'
  ></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script
    src='{{ 'quick-add-bulk.js' | asset_url }}'
    defer='defer'
  ></script>
  <script
    src='{{ 'quantity-popover.js' | asset_url }}'
    defer='defer'
  ></script>
  <script
    src='{{ 'price-per-item.js' | asset_url }}'
    defer='defer'
  ></script>
  <script
    src='{{ 'quick-order-list.js' | asset_url }}'
    defer='defer'
  ></script>
{%- endif -%}
{% render 'section-padding', section_id: section.id, settings: section.settings %}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}
<div
  id='section-{{ section.id }}'
>
  <div
    x-data="tabsComponent('tab_0')"
    x-init='updateSlider()'
    @resize.window='updateSlider()'
    class='w-full {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}'
  >
    <div
      class='page-container heading-page-container'
    >
      <div class='mb-32 flex flex-col items-center justify-center gap-16 text-center md:mb-40 md:gap-18'>
        <h2 class=' text-[36px]  leading-none uppercase  md:text-[52px] '>
          {{ section.settings.title }}
        </h2>
        <div class='text-[16px] leading-[1.3] text-[#515355] md:text-[18px]'>
          {{ section.settings.text }}
        </div>
      </div>

      <div class='relative mb-24 flex w-full items-end justify-between'>
        <div
          class='absolute bottom-0 left-0 z-0 block! h-4 w-full bg-[#CCCCCC]'
        ></div>

        <div class='no-scrollbar relative z-10 flex w-full gap-24 overflow-x-auto pb-12 md:pb-16'>
          {% for block in section.blocks %}
            <div
              x-ref='tab_{{ forloop.index0 }}'
              x-bind="tabButton('tab_{{ forloop.index0 }}')"
              class='theme-title shrink-0 cursor-pointer text-[16px]/[1.1] font-bold uppercase transition-colors md:text-[22px]/[1.2] md:hover:text-[#25282A]'
              :class='activeTab === "tab_{{ forloop.index0 }}" ? "text-[#25282A]" : "text-[#A6A6A6]"'
              data-tab-index='{{ forloop.index0 }}'
            >
              {{ block.settings.label }}
            </div>
          {% endfor %}

          <div
            class='absolute bottom-0 left-0 block! h-4 bg-[#25282A] transition-all duration-300 ease-out'
            :style='`width: ${sliderWidth}px; transform: translateX(${sliderOffset}px);`'
          ></div>
        </div>
      </div>
    </div>
    <div class='tabs-content'>
      {% for block in section.blocks %}
        <div
          x-show="activeTab === 'tab_{{ forloop.index0 }}'"
          x-cloak
          x-transition.opacity.duration.300ms
          data-pane-index='{{ forloop.index0 }}'
          class='tab-pane transition-opacity duration-300 '
          id='tab-content-{{ section.id }}-{{ forloop.index }}'
        >
          {% for i in (1..4) %}
            {% assign pc_key = 'pc_image_' | append: i %}
            {% assign h5_key = 'h5_image_' | append: i %}
            {% assign product_key = 'product_list_' | append: i %}
            {% assign title_key = 'title_' | append: i %}
            {% assign text_key = 'text_' | append: i %}

            {% assign pc_image = block.settings[pc_key] %}
            {% assign h5_image = block.settings[h5_key] %}
            {% assign product_list = block.settings[product_key] %}
            {% assign title = block.settings[title_key] %}
            {% assign text = block.settings[text_key] %}

            <div class='bundle-row items-center md:flex  md:items-stretch {%  unless forloop.first %} mt-48 md:mt-0 {% endunless %}'>
              <!-- 左侧图片 -->
              <div class='relative w-[100%] md:flex md:w-[46%]'>
                {% render 'media-element',
                  media_type: 'image',
                  media_class: 'w-full h-full   object-cover',
                  class: 'h-full flex-1',
                  pc_image: pc_image,
                  h5_image: h5_image
                %}
                <div class='top-0 left-0 flex h-full w-full flex-col justify-end px-16 py-32 text-[#25282a] md:absolute md:bg-[linear-gradient(0deg,rgba(0,0,0,0.8)_0%,rgba(0,0,0,0)_44.63%)] md:p-60 md:text-white'>
                  <h4 class='text-[36px] font-bold uppercase md:text-[52px]'>
                    {{ title }}
                  </h4>
                  <div class='mt-12 text-[16px] leading-[1.3] md:mt-16 md:text-[18px]'>
                    {{ text }}
                  </div>
                </div>
              </div>

              <!-- 右侧产品 -->
              <div class='right_wrapper w-[100%] min-w-0 flex-1 px-16 md:gap-40 md:px-60 md:py-20 md:pr-40 lg:pr-[calc(50%-660px)]'>
                <div class='swiper bundle-swiper-{{ section.id }}-{{ forloop.parentloop.index }}-{{ i }}'>
                  <!-- 按钮 -->
                  <div class='hidden-phone'>
                    <div class='mb-24 flex items-center justify-end gap-8 '>
                      <div class='swiper-button-prev relative left-0 mt-0 flex h-48 w-48 items-center justify-center rounded-[50%] border border-[#cccccc] after:hidden hover:bg-[#ccc] [&.swiper-button-disabled]:bg-[#ccc]'>
                        <svg
                          width='8'
                          height='14'
                          viewBox='0 0 8 14'
                          fill='none'
                          xmlns='http://www.w3.org/2000/svg'
                        >
                          <path d="M6.75325 12.5859L0.919923 6.7526L6.75325 0.91927" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
                        </svg>
                      </div>

                      <div class='swiper-button-next relative right-0 mt-0 flex h-48 w-48 items-center justify-center rounded-[50%] border border-[#cccccc] after:hidden hover:bg-[#ccc] [&.swiper-button-disabled]:bg-[#ccc]'>
                        <svg
                          width='8'
                          height='14'
                          viewBox='0 0 8 14'
                          fill='none'
                          xmlns='http://www.w3.org/2000/svg'
                        >
                          <path d="M0.91862 0.919434L6.75195 6.75277L0.91862 12.5861" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
                        </svg>
                      </div>
                    </div>
                  </div>
                  <div class='swiper-wrapper'>
                    {% for product in product_list %}
                      <div class='swiper-slide'>
                        {% render 'sn-card-product',
                          card_product: product,
                          media_aspect_ratio: section.settings.image_ratio,
                          image_shape: section.settings.image_shape,
                          show_rating: section.settings.show_rating,
                          show_secondary_image: section.settings.show_secondary_image,
                          quick_add: section.settings.quick_add
                        %}
                      </div>
                    {% endfor %}
                    {% for product in product_list %}
                      <div class='swiper-slide'>
                        {% render 'sn-card-product',
                          card_product: product,
                          media_aspect_ratio: section.settings.image_ratio,
                          image_shape: section.settings.image_shape,
                          show_rating: section.settings.show_rating,
                          show_secondary_image: section.settings.show_secondary_image,
                          quick_add: section.settings.quick_add
                        %}
                      </div>
                    {% endfor %}
                    {% for product in product_list %}
                      <div class='swiper-slide'>
                        {% render 'sn-card-product',
                          card_product: product,
                          media_aspect_ratio: section.settings.image_ratio,
                          image_shape: section.settings.image_shape,
                          show_rating: section.settings.show_rating,
                          show_secondary_image: section.settings.show_secondary_image,
                          quick_add: section.settings.quick_add
                        %}
                      </div>
                    {% endfor %}
                  </div>

                  <div
                    class='hero-pagination hidden-lap-and-up mx-auto mt-32 flex w-fit items-center space-x-3'
                  ></div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>
