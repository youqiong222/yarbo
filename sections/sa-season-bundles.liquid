  (() => {
    // 2. Tab 切换与 Tailwind 类名控制
    const sectionContainer = document.getElementById('section-{{ section.id }}');
    if (!sectionContainer) return;

    const tabBtns = sectionContainer.querySelectorAll('.tab-btn');
    const tabContents = sectionContainer.querySelectorAll('.tab-content');
    const shopAllLinks = sectionContainer.querySelectorAll('#shop-all-{{ section.id }}');

    document.querySelectorAll('[class*="bundle-swiper-"]').forEach((swiperEl) => {
      new Swiper(swiperEl, {
        slidesPerView: 2,
        spaceBetween: 12,
        navigation: {
          nextEl: swiperEl.querySelector('.swiper-button-next'),
          prevEl: swiperEl.querySelector('.swiper-button-prev'),
        },
        pagination: {
          el: swiperEl.querySelector('.hero-pagination'),
          clickable: true,
          renderBullet: function (index, className) {
            const bulletClasses = `
              ${className}
              rounded-none opacity-100
              w-8 h-8 bg-[#CCCCCC] transition-all duration-300 block cursor-pointer m-0
              hover:bg-white
              [&.swiper-pagination-bullet-active]:w-50 [&.swiper-pagination-bullet-active]:h-8 [&.swiper-pagination-bullet-active]:bg-[#25282a]
            `;
            return `<span class="${bulletClasses.trim().replace(/\s+/g, ' ')}"></span>`;
          },
        },
      });
    });
  })();
</script>
{% schema %}
{
  "name": "Season Bundles",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor Id"
    },
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    {
      "type": "header",
      "content": "Spacing Settings"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_top",
      "label": "H5 Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_bottom",
      "label": "H5 Padding Bottom",
      "default": 0
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "header",
      "content": "t:sections.featured-collection.settings.header.content"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.featured-collection.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.featured-collection.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.featured-collection.settings.image_ratio.options__3.label"
        }
      ],
      "default": "adapt",
      "label": "t:sections.featured-collection.settings.image_ratio.label"
    },
    {
      "type": "select",
      "id": "image_shape",
      "options": [
        {
          "value": "default",
          "label": "t:sections.all.image_shape.options__1.label"
        },
        {
          "value": "arch",
          "label": "t:sections.all.image_shape.options__2.label"
        },
        {
          "value": "blob",
          "label": "t:sections.all.image_shape.options__3.label"
        },
        {
          "value": "chevronleft",
          "label": "t:sections.all.image_shape.options__4.label"
        },
        {
          "value": "chevronright",
          "label": "t:sections.all.image_shape.options__5.label"
        },
        {
          "value": "diamond",
          "label": "t:sections.all.image_shape.options__6.label"
        },
        {
          "value": "parallelogram",
          "label": "t:sections.all.image_shape.options__7.label"
        },
        {
          "value": "round",
          "label": "t:sections.all.image_shape.options__8.label"
        }
      ],
      "default": "default",
      "label": "t:sections.all.image_shape.label"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_image",
      "default": false,
      "label": "t:sections.main-collection-product-grid.settings.show_secondary_image.label"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": false,
      "label": "t:sections.featured-collection.settings.show_rating.label",
      "info": "t:sections.featured-collection.settings.show_rating.info"
    },
    {
      "type": "select",
      "id": "quick_add",
      "default": "none",
      "label": "t:sections.main-collection-product-grid.settings.quick_add.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.main-collection-product-grid.settings.quick_add.options.option_1"
        },
        {
          "value": "standard",
          "label": "t:sections.main-collection-product-grid.settings.quick_add.options.option_2"
        },
        {
          "value": "bulk",
          "label": "t:sections.main-collection-product-grid.settings.quick_add.options.option_3"
        }
      ]
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Product List",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Tab Label",
          "default": "Label"
        },
        { "type": "header", "content": "Group 1" },
        { "type": "image_picker", "id": "pc_image_1", "label": "PC Image" },
        { "type": "image_picker", "id": "h5_image_1", "label": "Mobile Image" },
        { "type": "product_list", "id": "product_list_1", "label": "Products" },
        { "type": "richtext", "id": "title_1", "label": "Title" },
        { "type": "richtext", "id": "text_1", "label": "Text" },

        { "type": "header", "content": "Group 2" },
        { "type": "image_picker", "id": "pc_image_2", "label": "PC Image" },
        { "type": "image_picker", "id": "h5_image_2", "label": "Mobile Image" },
        { "type": "product_list", "id": "product_list_2", "label": "Products" },
        { "type": "richtext", "id": "title_2", "label": "Title" },
        { "type": "richtext", "id": "text_2", "label": "Text" },

        { "type": "header", "content": "Group 3" },
        { "type": "image_picker", "id": "pc_image_3", "label": "PC Image" },
        { "type": "image_picker", "id": "h5_image_3", "label": "Mobile Image" },
        { "type": "product_list", "id": "product_list_3", "label": "Products" },
        { "type": "richtext", "id": "title_3", "label": "Title" },
        { "type": "richtext", "id": "text_3", "label": "Text" },

        { "type": "header", "content": "Group 4" },
        { "type": "image_picker", "id": "pc_image_4", "label": "PC Image" },
        { "type": "image_picker", "id": "h5_image_4", "label": "Mobile Image" },
        { "type": "product_list", "id": "product_list_4", "label": "Products" },
        { "type": "richtext", "id": "title_4", "label": "Title" },
        { "type": "richtext", "id": "text_4", "label": "Text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Season Bundles"
    }
  ]
}
{% endschema %}
