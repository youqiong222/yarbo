{% render 'yb-section-style', section: section %}
<div class='horizontal-slide-video-main-box'>
  <div class='horizontal-slide-video-small-box'>
    <div class='horizontal-slide-video-show-box'>
      {% render 'yb-section-common', section: section %}
      <div class='horizontal-slide-video-show'>
        <div class='horizontal-slide-video-left horizontal-slide-video'>
          {% if section.settings.video_title != blank %}
            <div class='horizontal-slide-video-title'>
              {{ section.settings.video_title }}
            </div>
          {% endif %}
          {% if section.settings.video_content != blank %}
            <div class='horizontal-slide-video-content'>
              {{ section.settings.video_content }}
            </div>
          {% endif %}
          <div class='horizontal-slide-label-box'>
            <div class='horizontal-slide-label'>
              {% if section.settings.video_label_title_1 != blank %}
                <div class='horizontal-slide-label-title'>
                  {{ section.settings.video_label_title_1 }}
                </div>
              {% endif %}
              {% if section.settings.video_label_content_1 != blank %}
                <div class='horizontal-slide-label-content'>
                  {{ section.settings.video_label_content_1 }}
                </div>
              {% endif %}
            </div>
            <div class='horizontal-slide-label'>
              {% if section.settings.video_label_title_2 != blank %}
                <div class='horizontal-slide-label-title'>
                  {{ section.settings.video_label_title_2 }}
                </div>
              {% endif %}
              {% if section.settings.video_label_content_2 != blank %}
                <div class='horizontal-slide-label-content'>
                  {{ section.settings.video_label_content_2 }}
                </div>
              {% endif %}
            </div>
            <div class='horizontal-slide-label'>
              {% if section.settings.video_label_title_3 != blank %}
                <div class='horizontal-slide-label-title'>
                  {{ section.settings.video_label_title_3 }}
                </div>
              {% endif %}
              {% if section.settings.video_label_content_3 != blank %}
                <div class='horizontal-slide-label-content'>
                  {{ section.settings.video_label_content_3 }}
                </div>
              {% endif %}
            </div>
          </div>
        </div>
        <div class='horizontal-slide-video-right horizontal-slide-video'>
          {% render 'video-show',
            controlslist: 'nofullscreen',
            firework_video: section.settings.picture_firework_video_url,
            video: section.settings.video,
            external_video: section.settings.picture_youtube_video_url
          %}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
      overflow: visible !important;
  }
  #shopify-section-{{ section.id }} > .horizontal-slide-video-main-box {
      width: 100%;
      height: 200vh;
      position: relative;
      overflow: visible;
  }
  .horizontal-slide-video-main-box video, .horizontal-slide-video-main-box iframe {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover;
      max-width: none !important;
  }
  .horizontal-slide-video-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      opacity: 0;
  }
  #shopify-section-{{ section.id }} .horizontal-slide-video-small-box {
      width: 100%;
      height: 100vh;
      position: sticky;
      top: 0;
  }
  .horizontal-slide-video-show-box {
      position: relative;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      max-width: 1400px;
  }
  .horizontal-slide-video-left {
      width: 692px;
  }
  .horizontal-slide-video-show {
      margin-top: 64px;
      display: flex;
      gap: 58px;
  }
  .horizontal-slide-label-box {
      display: flex;
      gap: 16px;
  }
  .horizontal-slide-label {
      display: flex;
      justify-content: center;
      flex-direction: column;
      align-items: center;
      min-height: 92px;
      min-width: 180px;
      border-radius: 16px;
      background-color: #F5F5F5;
      padding: 20px 16px;
      text-align: center;
  }
  .horizontal-slide-video-right {
      width: 650px;
      aspect-ratio: 650 / 460;
      overflow: hidden;
      position: relative;
      pointer-events: none;
      border-radius: 24px;
      background-color: #676A6D;
  }

  {% if section.settings.picture != blank %}
  #shopify-section-{{ section.id }} .horizontal-slide-video-right {
      background-image: url('{{ section.settings.picture | image_url }}');
      background-repeat: no-repeat;
      background-size: cover;
      background-position: center;
  }
  {% endif %}

  .horizontal-slide-video-title {
      font-size: 32px;
      font-weight: 800;
      line-height: 120%;
      color: #02060B;
  }
  .horizontal-slide-video-content {
      font-size: 18px;
      font-weight: 400;
      line-height: 140%;
      color: #6E6E73;
  }

  {% if section.settings.video_title != blank %}
      .horizontal-slide-video-content {
          margin-top: 24px;
      }
  {% endif %}

  .horizontal-slide-label-box {
      margin-top: 40px;
  }
  .horizontal-slide-label-title {
      font-size: 20px;
      font-weight: 700;
      line-height: 140%;
      color: #02060B;
  }
  .horizontal-slide-label-content {
      font-size: 14px;
      font-weight: 400;
      line-height: 140%;
      color: #02060B;
  }
  .horizontal-slide-video-left {
      left: 50%;
      transform: translateX(-50%);
      position: relative;
  }
  .horizontal-slide-video-right {
      left: -50%;
      transform: translateX(50%);
  }

