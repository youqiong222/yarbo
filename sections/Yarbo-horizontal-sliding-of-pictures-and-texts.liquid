</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const container{{ section.id | replace: '-', '_' }} = document.querySelector('#shopify-section-{{ section.id }} .horizontal-slide-video-main-box');
    const containerlLeft{{ section.id | replace: '-', '_' }} = document.querySelector('#shopify-section-{{ section.id }} .horizontal-slide-video-left');
    const containerlRight{{ section.id | replace: '-', '_' }} = document.querySelector('#shopify-section-{{ section.id }} .horizontal-slide-video-right');
    const video{{ section.id | replace: '-', '_' }} = document.querySelector('#shopify-section-{{ section.id }} video');
    const iframe{{ section.id | replace: '-', '_' }} = document.querySelector('#shopify-section-{{ section.id }} iframe');

    let lastScrollTop = window.pageYOffset || document.documentElement.scrollTop;
    let topnumber = 50;
    let boxOpacity = 0;

    function playMedia() {
        if (video{{ section.id | replace: '-', '_' }}) {
            video{{ section.id | replace: '-', '_' }}.play();
            video{{ section.id | replace: '-', '_' }}.loop = true;
        }
        if (iframe{{ section.id | replace: '-', '_' }}) {
            const src = iframe{{ section.id | replace: '-', '_' }}.src;
            if (src.includes('youtube')) {
                const videoId = src.match(/[?&]v=([^&]+)/)?.[1];
                if (!src.includes('enablejsapi=1')) {
                    iframe{{ section.id | replace: '-', '_' }}.src = src + (src.includes('?') ? '&' : '?') + 'enablejsapi=1&controls=0&modestbranding=1&disablekb=1&loop=1&playlist=' + videoId;
                }
                iframe{{ section.id | replace: '-', '_' }}.contentWindow.postMessage('{"event":"command","func":"playVideo","args":""}', '*');
            }
        }
    }

    function pauseMedia() {
        if (video{{ section.id | replace: '-', '_' }}) {
            video{{ section.id | replace: '-', '_' }}.pause();
            video{{ section.id | replace: '-', '_' }}.currentTime = 0;
        }
        if (iframe{{ section.id | replace: '-', '_' }}) {
            const src = iframe{{ section.id | replace: '-', '_' }}.src;
            if (src.includes('youtube')) {
                iframe{{ section.id | replace: '-', '_' }}.contentWindow.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
                iframe{{ section.id | replace: '-', '_' }}.contentWindow.postMessage('{"event":"command","func":"seekTo","args":[0]}', '*');
            }
        }
    }

    function handleScroll() {
        if (window.innerWidth >= 960) {
            let scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            let rect = container{{ section.id | replace: '-', '_' }}.getBoundingClientRect();
            let elementHeight = rect.height;

            if (rect.top <= 0 && rect.bottom >= elementHeight / 2) {
                playMedia();
                if (scrollTop > lastScrollTop) {
                    boxOpacity = Math.min(1, boxOpacity + 0.05);
                    topnumber = Math.max(0, topnumber - 2.5);
                } else {
                    boxOpacity = Math.max(0, boxOpacity - 0.05);
                    topnumber = Math.min(50, topnumber + 2.5);
                }
                containerlLeft{{ section.id | replace: '-', '_' }}.style.opacity = boxOpacity;
                containerlLeft{{ section.id | replace: '-', '_' }}.style.transform = `translateX(-${topnumber}%)`;
                containerlRight{{ section.id | replace: '-', '_' }}.style.transform = `translateX(${topnumber}%)`;
                containerlLeft{{ section.id | replace: '-', '_' }}.style.left = `${topnumber}%`;
                containerlRight{{ section.id | replace: '-', '_' }}.style.left = `-${topnumber}%`;

                if (topnumber <= 0) {
                    boxOpacity = 1;
                    topnumber = 0;
                    containerlLeft{{ section.id | replace: '-', '_' }}.style.opacity = boxOpacity;
                    containerlLeft{{ section.id | replace: '-', '_' }}.style.transform = `translateX(-${topnumber}%)`;
                    containerlRight{{ section.id | replace: '-', '_' }}.style.transform = `translateX(${topnumber}%)`;
                    containerlLeft{{ section.id | replace: '-', '_' }}.style.left = `${topnumber}%`;
                    containerlRight{{ section.id | replace: '-', '_' }}.style.left = `-${topnumber}%`;
                    if (typeof collisionPlayMedia{{ section.id | replace: '-', '_' }} === 'function') {
                        collisionPlayMedia{{ section.id | replace: '-', '_' }}(video{{ section.id | replace: '-', '_' }}, iframe{{ section.id | replace: '-', '_' }});
                    }
                }
            } else if (rect.bottom < elementHeight / 2 && rect.bottom > 0) {
                playMedia();
                boxOpacity = 1;
                topnumber = 0;
                containerlLeft{{ section.id | replace: '-', '_' }}.style.opacity = boxOpacity;
                containerlLeft{{ section.id | replace: '-', '_' }}.style.transform = `translateX(-${topnumber}%)`;
                containerlRight{{ section.id | replace: '-', '_' }}.style.transform = `translateX(${topnumber}%)`;
                containerlLeft{{ section.id | replace: '-', '_' }}.style.left = `${topnumber}%`;
                containerlRight{{ section.id | replace: '-', '_' }}.style.left = `-${topnumber}%`;
            } else if (rect.top < 100 && rect.top > 0) {
                playMedia();
            } else {
                pauseMedia();
                boxOpacity = 0;
                topnumber = 50;
                containerlLeft{{ section.id | replace: '-', '_' }}.style.opacity = boxOpacity;
                containerlLeft{{ section.id | replace: '-', '_' }}.style.transform = `translateX(-${topnumber}%)`;
                containerlRight{{ section.id | replace: '-', '_' }}.style.transform = `translateX(${topnumber}%)`;
                containerlLeft{{ section.id | replace: '-', '_' }}.style.left = `${topnumber}%`;
                containerlRight{{ section.id | replace: '-', '_' }}.style.left = `-${topnumber}%`;
            }
            lastScrollTop = scrollTop;
        } else {
            let rect = container{{ section.id | replace: '-', '_' }}.getBoundingClientRect();
            let elementHeight = rect.height;
            if (rect.top < 300 && rect.bottom > 0) {
                playMedia();
            } else {
                pauseMedia();
            }
            boxOpacity = 1;
            topnumber = 0;
            containerlLeft{{ section.id | replace: '-', '_' }}.style.opacity = boxOpacity;
            containerlLeft{{ section.id | replace: '-', '_' }}.style.transform = `translateX(-${topnumber}%)`;
            containerlRight{{ section.id | replace: '-', '_' }}.style.transform = `translateX(${topnumber}%)`;
            containerlLeft{{ section.id | replace: '-', '_' }}.style.left = `${topnumber}%`;
            containerlRight{{ section.id | replace: '-', '_' }}.style.left = `-${topnumber}%`;
        }
    }

    function debounce(func, wait) {
        let timeout;
        return function() {
            clearTimeout(timeout);
            timeout = setTimeout(func, wait);
        };
    }

    window.addEventListener('scroll', debounce(handleScroll, 10));
    window.addEventListener('resize', handleScroll);
    handleScroll();
});
</script>

