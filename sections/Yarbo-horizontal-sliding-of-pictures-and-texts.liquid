          width: 568px;
      }
      .horizontal-slide-video-show {
          margin-top: 56px;
          gap: 56px;
      }
      .horizontal-slide-video-right {
          width: 576px;
          aspect-ratio: 576 / 408;
          border-radius: 24px;
      }
      .horizontal-slide-video-title {
          font-size: 28px;
      }
      .horizontal-slide-video-content {
          font-size: 16px;
      }
      {% if section.settings.video_title != blank %}
          .horizontal-slide-video-content {
              margin-top: 16px;
          }
      {% endif %}
      .horizontal-slide-label-box {
          margin-top: 32px;
      }
      .horizontal-slide-label-title {
          font-size: 20px;
      }
      .horizontal-slide-label-content {
          font-size: 14px;
      }
