          min-height: 50px;
          flex: 0 0 calc((100% - 32px) / 3);
          border-radius: 8.68px;
          padding: 6px;
      }
      .horizontal-slide-video-show-box {
          top: 0;
          left: 0;
          transform: translate(0, 0);
      }
      .horizontal-slide-video-left, .horizontal-slide-video-right {
          left: 0;
          transform: translateX(0);
          position: relative;
      }
      .horizontal-slide-video-main-box {
          width: calc(100% - 32px) !important;
          margin: 0 auto;
          height: auto !important;
      }
      .horizontal-slide-video-left {
          width: 100%;
          opacity: 1 !important;
      }
      .horizontal-slide-video-show {
