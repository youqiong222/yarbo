  @media (min-width: 960px) and (max-width: 1439px) {
      .horizontal-slide-label {
          min-height: 69px;
          min-width: 135px;
          border-radius: 12px;
          padding: 13px 20px;
      }
      .horizontal-slide-video-show-box {
          max-width: 900px;
      }
      .horizontal-slide-video-left {
          width: 426px;
      }
      .horizontal-slide-video-show {
          margin-top: 48px;
          gap: 42px;
      }
      .horizontal-slide-video-right {
          width: 432px;
          aspect-ratio: 432 / 306;
          border-radius: 18px;
      }
      .horizontal-slide-video-title {
          font-size: 20px;
      }
      .horizontal-slide-video-content {
          font-size: 14px;
      }
      {% if section.settings.video_title != blank %}
          .horizontal-slide-video-content {
              margin-top: 12px;
          }
      {% endif %}
      .horizontal-slide-label-box {
          margin-top: 24px;
      }
      .horizontal-slide-label-title {
          font-size: 16px;
      }
      .horizontal-slide-label-content {
          font-size: 12px;
      }
  }
  @media (min-width: 680px) and (max-width: 959px) {
      .horizontal-slide-video-small-box {
          height: auto !important;
      }
      .horizontal-slide-video-left, .horizontal-slide-video-right {
          left: 0;
          transform: translateX(0);
          position: relative;
      }
      .horizontal-slide-video-show-box {
          top: 0;
          left: 0;
          transform: translate(0, 0);
      }
      .horizontal-slide-video {
          left: 0;
          transform: none !important;
      }
      .horizontal-slide-label {
          min-height: 92px;
          flex: 0 0 calc((100% - 32px) / 3);
          border-radius: 16px;
      }
      .horizontal-slide-video-main-box {
          width: calc(100% - 48px) !important;
          margin: 0 auto;
          height: auto !important;
      }
      .horizontal-slide-video-left {
          width: 100%;
          opacity: 1 !important;
      }
      .horizontal-slide-video-show {
          margin-top: 48px;
          gap: 24px;
          flex-direction: column-reverse;
      }
      .horizontal-slide-video-right {
          width: 100%;
          aspect-ratio: 632 / 448;
          border-radius: 24px;
      }
      .horizontal-slide-video-title {
          font-size: 28px;
      }
      .horizontal-slide-video-content {
          font-size: 16px;
      }
      {% if section.settings.video_title != blank %}
          .horizontal-slide-video-content {
              margin-top: 24px;
          }
      {% endif %}
      .horizontal-slide-label-box {
          margin-top: 24px;
          justify-content: space-between;
      }
      .horizontal-slide-label-title {
          font-size: 20px;
      }
      .horizontal-slide-label-content {
