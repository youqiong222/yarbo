<link
  href='https://cdn.shopify.com/s/files/1/0604/5394/5441/files/section-main-installer.css'
  rel='stylesheet'
  type='text/css'
  media='all'
>
<script
  type='text/babel'
>
    const INSTALLERS_API_URL = "https://dev.yarbo.ai/backend/v2/install/installer/approval/list";

    initializeInstallerMap();

    function initializeInstallerMap() {
        const map = initMap();

        fetch(INSTALLERS_API_URL, {
            method: "GET",
        })
            .then((response) => {
                if (response.ok) {
                    return response.json();
                }
            })
            .then((data) => {
                if (data.code === 0 && data.data) {
                    if (data.data.length > 0) {
                        const layerGroup = L.layerGroup();
                        updateMap(map, data.data, layerGroup);
                    }
                } else {
                    console.error(data.msg);
                    return [];
                }
            })
            .catch((error) => {
                console.error(error);
            });
    }

    function initMap() {
        const map = L.map("my-leafmap", {
            scrollWheelZoom: false,
            gestureHandling: true,
            attributionControl: false
        }).setView([51.505, -0.09], 3);

        L.tileLayer("http://mt1.google.com/vt/lyrs=m&hl=en&x={x}&y={y}&z={z}", {
            attribution: "",
        }).addTo(map);

        return map;
    }

    function updateMap(map, installers, layerGroup) {
        const markerCluster = createInstallerMarkers(map, installers, layerGroup);
        addMapControls(map, markerCluster, layerGroup);
        layerGroup.addTo(map);
    }

    function createInstallerMarkers(map, installers, layerGroup) {
        const markers = L.markerClusterGroup();
        const markersArray = [];
        installers.forEach((installer) => {
            const marker = L.marker([installer.latitude, installer.longitude], {
                icon: L.icon({
                    iconUrl:
                        "https://imagedelivery.net/FCXqi8BC3uKlNw5AGYVCpw/86824486-daba-4844-ed8f-fa4226762400/q=100",
                    iconSize: [28, 28],
                    iconAnchor: [14, 28],
                }),
                title: installer.public_name,
                searchQuery: installer.public_name
            }).bindPopup(createInstallerPopup(installer));
            markersArray.push(marker);
        });
        markers.addLayers(markersArray);
        layerGroup.addLayer(markers);
        return markers;
    }

    function createInstallerPopup(installer) {
        const profileImage =
            installer.public_picture_urls?.length > 0
                ? installer.public_picture_urls[0]
                : "hhttps://cdn.shopify.com/s/files/1/0604/5394/5441/files/7cfd3dd079ff4c10ad10344fe9582140.png";

        return `
            <div style="max-width: 280px;">
                <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                    <img src="${profileImage}"
                         style="width: 80px; height: 80px; object-fit: cover; border-radius: 4px;"
                         alt="${installer.public_name}">
                    <div>
                        <div style="margin-bottom: 5px;">
                            <span style="color: #666; font-size: 0.9em;">Name: </span>
                            <strong>${installer.public_name}</strong>
                        </div>
                        <div style="margin-bottom: 5px;">
                            <span style="color: #666; font-size: 0.9em;">Modules: </span>
                            ${installer.public_yarbo_owned.join(", ")}
                        </div>
                        <button
                           style="color: #1890ff; font-size: 0.9em;cursor: pointer;"
                           onclick="handleContact('${installer.uuid}')">
                            Get in Touch with This Installer
                        </button>
                    </div>
                </div>
                <div style="background: #f5f5f5; padding: 10px; border-radius: 4px; max-height: 120px; overflow-y: auto;">
                    ${installer.public_comments.replace(/\n/g, "<br/>")}
                </div>
            </div>`;
    }

    function addMapControls(map, markerLayer, layerGroup) {
        L.control.fullscreen({ position: "topleft" }).addTo(map);

        const searchControl = new L.Control.Search({
            position: "topleft",
            layer: layerGroup,
            initial: false,
            zoom: 12,
            marker: false,
            propertyName: 'searchQuery',
        });

        map.addControl(searchControl);

        L.control.locate({
            position: "topleft",
            locateOptions: { maxZoom: 16 },
        }).addTo(map);
    }

    const { Button, Form, Input, Select, Modal, DatePicker } = antd;
    const { Option } = Select;

    const Yarbo_owned = [
        { value: "yarbo_core_2024", label: "Yarbo Core 2024" },
        { value: "yarbo_core_2023", label: "Universal Body 2023" },
        { value: "lawn_mower", label: "Lawn Mower" },
        { value: "snow_blower", label: "Snow Blower" },
        { value: "blower", label: "Blower" }
    ];

    let agreement = false;
    const email = '{{ customer.email | default: "" }}';
    const authorization = btoa(email + '.yarbo');

    async function getCustomerAgreementState(){
        await fetch('https://dev.yarbo.ai/backend/v2/install/installer/state', {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer ' + authorization
            }
        })
        .then(response => {
            if (response.ok) return response.json();
        })
        .then(data => {
            if (data && typeof data.data === 'number' && data.data === 2) {
                agreement = true;
            }
        })
        .catch(error => {
            console.error(error);
        });
    }

    async function agree(){
        await fetch('https://dev.yarbo.ai/backend/v2/install/user/agreement', {
            method: 'POST',
            headers: {
                'Authorization': 'Bearer ' + authorization
            }
        })
        .then(response => {
            if (response.ok) return response.json();
        })
        .then(data => {
            agreement = true;
        })
        .catch(error => {
            console.error(error);
        });
    }

    function getFormData() {
        const productsSelect = document.querySelector('.ant-select.agreement-form-select');
        let selectedProducts = [];

        if (productsSelect) {
            const selectedNodes = productsSelect.querySelectorAll('.ant-select-selection-item');
            selectedNodes.forEach(node => {
                selectedProducts.push(node.getAttribute('title'));
            });
        }

        const datePicker = document.querySelector('.ant-picker-input input');
        const dateValue = datePicker ? datePicker.value : '';

        let phoneCountryCode = '+1';
        const phoneCountrySelect = document.querySelector('.agreement-form-phone-country-select');

        if (phoneCountrySelect) {
            const selectedItem = phoneCountrySelect.querySelector('.ant-select-selection-item');
            if (selectedItem) {
                const labelText = selectedItem.textContent || selectedItem.innerText || '';
                const codeMatch = labelText.match(/\+\d+/);
                if (codeMatch) {
                    phoneCountryCode = codeMatch[0];
                }
            }
        }

        return {
            name: document.getElementById('name').value,
            phoneCountryCode: phoneCountryCode,
            phone: document.getElementById('phone').value,
            address: document.getElementById('address').value,
            productsYouBought: selectedProducts,
            problems: document.getElementById('problems').value,
            expectedServiceTime: dateValue,
            extraInformation: document.getElementById('extra_information').value
        };
    }

    function validateForm() {
        let isValid = true;
        const requiredFields = [
            { id: 'name', label: 'Name!' },
            { id: 'phone', label: 'Phone number!' },
            { id: 'address', label: 'Address!' },
            { id: 'products_you_bought', label: 'Products!' },
            { id: 'problems', label: 'Problems!' },
            { id: 'expected_service_time', label: 'Expected service time!' },
            { id: 'extra_information', label: 'information!' }
        ];

        requiredFields.forEach(({ id, label }) => {
            if (id === 'products_you_bought' || id === 'expected_service_time') return;

            const element = document.getElementById(id);
            if (element && (!element.value || element.value.trim() === '')) {
                displayFieldError(element, label);
                isValid = false;
            }
        });

        const productsSelect = document.querySelector('.ant-select.agreement-form-select');
        if (productsSelect) {
            const selectedNodes = productsSelect.querySelectorAll('.ant-select-selection-item');
            if (selectedNodes.length === 0) {
                displayFieldError(document.getElementById('products_you_bought'), 'Products!');
                isValid = false;
            }
        }

        const datePicker = document.querySelector('.ant-picker-input input');
        if (!datePicker || !datePicker.value) {
            displayFieldError(document.getElementById('expected_service_time'), 'Expected service time!');
            isValid = false;
        }

        return isValid;
    }

    function displayFieldError(element, fieldLabel) {
        if (element.id === 'products_you_bought' || element.id === 'expected_service_time') {
            const formItem = document.querySelector(`.agreement-form-item:has(#${element.id})`);
            if (formItem) {
                const existingError = formItem.querySelector('.error-message');
                if (existingError) {
                    formItem.removeChild(existingError);
                }

                if (element.id === 'products_you_bought') {
                    const selectElement = formItem.querySelector('.ant-select-selector');
                    if (selectElement) {
                        selectElement.style.borderColor = '#ff4d4f';
                        selectElement.style.boxShadow = '0 0 0 2px rgba(255, 77, 79, 0.2)';
                    }
                }

                if (element.id === 'expected_service_time') {
                    const datePickerElement = formItem.querySelector('.ant-picker');
                    if (datePickerElement) {
                        datePickerElement.style.borderColor = '#ff4d4f';
                        datePickerElement.style.boxShadow = '0 0 0 2px rgba(255, 77, 79, 0.2)';
                    }
                }

                const errorMsg = document.createElement('div');
                errorMsg.className = 'error-message';
                errorMsg.style.color = '#ff4d4f';
                errorMsg.style.fontSize = '14px';
                errorMsg.style.lineHeight = '1.5715';
                errorMsg.style.marginTop = '2px';
                errorMsg.textContent = `Please input your ${fieldLabel}`;
                formItem.appendChild(errorMsg);

                if (element.id === 'products_you_bought') {
                    formItem.querySelector('.ant-select').addEventListener('click', function() {
                        const selectElement = formItem.querySelector('.ant-select-selector');
                        if (selectElement) {
                            selectElement.style.borderColor = '';
                            selectElement.style.boxShadow = '';
                        }
                        const errorMsg = formItem.querySelector('.error-message');
                        if (errorMsg) formItem.removeChild(errorMsg);
                    }, { once: true });
                } else if (element.id === 'expected_service_time') {
                    formItem.querySelector('.ant-picker').addEventListener('click', function() {
                        this.style.borderColor = '';
                        this.style.boxShadow = '';
                        const errorMsg = formItem.querySelector('.error-message');
                        if (errorMsg) formItem.removeChild(errorMsg);
                    }, { once: true });
                }
            }
        } else {
            element.style.borderColor = '#ff4d4f';
            element.style.boxShadow = '0 0 0 2px rgba(255, 77, 79, 0.2)';

            const formItem = element.closest('.agreement-form-item');
            if (formItem) {
                const existingError = formItem.querySelector('.error-message');
                if (existingError) {
                    formItem.removeChild(existingError);
                }

                const errorMsg = document.createElement('div');
                errorMsg.className = 'error-message';
                errorMsg.style.color = '#ff4d4f';
                errorMsg.style.fontSize = '14px';
                errorMsg.style.lineHeight = '1.5715';
                errorMsg.style.marginTop = '2px';
                errorMsg.textContent = `Please input your ${fieldLabel}`;
                formItem.appendChild(errorMsg);
            }

            element.addEventListener('input', function() {
                this.style.borderColor = '';
                this.style.boxShadow = '';

                const formItem = this.closest('.agreement-form-item');
                if (formItem) {
                    const errorMsg = formItem.querySelector('.error-message');
                    if (errorMsg) {
                        formItem.removeChild(errorMsg);
                    }
                }
            }, { once: true });
        }
    }

    function submitContactForm(installerUuid) {
        const formData = getFormData();

        if (!validateForm()) {
            return;
        }

        const requestData = {
            installer_uuid: installerUuid,
            name: formData.name,
            phone: `${formData.phoneCountryCode}${formData.phone}`,
            address: formData.address,
            products: formData.productsYouBought,
            problems: formData.problems,
            expected_service_time: formData.expectedServiceTime,
            extra_information: formData.extraInformation || '',
            email: email
        };

        formNext(requestData);
    }

    function handleContact(installer_uuid) {
        if(email === ''){
            window.location.href = '/account/login?checkout_url=/installer';
            return;
        }

        getCustomerAgreementState();

        Modal.confirm({
            width: '73vw',
            icon: null,
            closable: true,
            closeIcon: <span className="antd-close-btn">×</span>,
            maskClosable: true,
            okButtonProps: { style: { display: 'none' } },
            footer: null,
            content: (
            <Form layout="horizontal" className="agreement-form">
                <p className="pb-8 text-center text-2xl/none font-extrabold mobile:pb-2 mobile:text-base/none agreement-form-title">Provide Your Information for the Installer</p>
                <div className="grid grid-cols-2 gap-x-[24px] gap-y-[16px] w-full mobile:grid-cols-1 agreement-form-div">
                    <Form.Item label="Name" required className="agreement-form-item">
                        <Input id="name"/>
                    </Form.Item>
                    <Form.Item label="Phone" required className="agreement-form-item">
                        <Input.Group compact>
                            <Select
                                id="phone_country_code"
                                defaultValue="+1"
                                className="agreement-form-phone-country-select"
                                showSearch
                                dropdownMatchSelectWidth={false}
                                optionLabelProp="label"
                                optionFilterProp="children"
                            >
                                <Option value="+1" label="🇺🇸 +1">🇺🇸 United States +1</Option>
                                <Option value="+44" label="🇬🇧 +44">🇬🇧 United Kingdom +44</Option>
                                <Option value="+86" label="🇨🇳 +86">🇨🇳 China +86</Option>
                                <Option value="+49" label="🇩🇪 +49">🇩🇪 Germany +49</Option>
                                <Option value="+33" label="🇫🇷 +33">🇫🇷 France +33</Option>
                                <Option value="+81" label="🇯🇵 +81">🇯🇵 Japan +81</Option>
                                <Option value="+82" label="🇰🇷 +82">🇰🇷 South Korea +82</Option>
                                <Option value="+61" label="🇦🇺 +61">🇦🇺 Australia +61</Option>
                                <Option value="+39" label="🇮🇹 +39">🇮🇹 Italy +39</Option>
                                <Option value="+7" label="🇷🇺 +7">🇷🇺 Russia +7</Option>
                                <Option value="+36" label="🇭🇺 +36">🇭🇺 Hungary +36</Option>
                                <Option value="+385" label="🇭🇷 +385">🇭🇷 Croatia +385</Option>
                                <Option value="+45" label="🇩🇰 +45">🇩🇰 Denmark +45</Option>
                                <Option value="+46" label="🇸🇪 +46">🇸🇪 Sweden +46</Option>
                                <Option value="+47" label="🇳🇴 +47">🇳🇴 Norway +47</Option>
                                <Option value="+30" label="🇬🇷 +30">🇬🇷 Greece +30</Option>
                                <Option value="+358" label="🇫🇮 +358">🇫🇮 Finland +358</Option>
                                <Option value="+48" label="🇵🇱 +48">🇵🇱 Poland +48</Option>
                                <Option value="+351" label="🇵🇹 +351">🇵🇹 Portugal +351</Option>
                                <Option value="+353" label="🇮🇪 +353">🇮🇪 Ireland +353</Option>
                                <Option value="+386" label="🇸🇮 +386">🇸🇮 Slovenia +386</Option>
                                <Option value="+420" label="🇨🇿 +420">🇨🇿 Czech Republic +420</Option>
                                <Option value="+34" label="🇪🇸 +34">🇪🇸 Spain +34</Option>
                                <Option value="+371" label="🇱🇻 +371">🇱🇻 Latvia +371</Option>
                                <Option value="+370" label="🇱🇹 +370">🇱🇹 Lithuania +370</Option>
                                <Option value="+31" label="🇳🇱 +31">🇳🇱 Netherlands +31</Option>
                                <Option value="+32" label="🇧🇪 +32">🇧🇪 Belgium +32</Option>
                                <Option value="+359" label="🇧🇬 +359">🇧🇬 Bulgaria +359</Option>
                                <Option value="+372" label="🇪🇪 +372">🇪🇪 Estonia +372</Option>
                                <Option value="+43" label="🇦🇹 +43">🇦🇹 Austria +43</Option>
                                <Option value="+381" label="🇷🇸 +381">🇷🇸 Serbia +381</Option>
                                <Option value="+421" label="🇸🇰 +421">🇸🇰 Slovakia +421</Option>
                                <Option value="+357" label="🇨🇾 +357">🇨🇾 Cyprus +357</Option>
                                <Option value="+40" label="🇷🇴 +40">🇷🇴 Romania +40</Option>
                                <Option value="+356" label="🇲🇹 +356">🇲🇹 Malta +356</Option>
                                <Option value="+352" label="🇱🇺 +352">🇱🇺 Luxembourg +352</Option>
                            </Select>
                            <Input id="phone" className="agreement-form-phone-input"/>
