    async function formNext(requestData){
        await fetch('https://dev.yarbo.ai/backend/v2/install/user', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer ' + authorization
            },
            body: JSON.stringify(requestData)
        })
        .then(response => {
            if (response.ok) {
            }
        }).catch(error => {
            console.error(error);
        });

        const modalContent = document.querySelector('.ant-modal-content');
        let modalBodyRoot = null;
        if (modalContent) {
            const modalBody = modalContent.querySelector('.ant-modal-body');
            modalBodyRoot = ReactDOM.createRoot(modalBody);
        }

        if(agreement){
            finishFrom(modalBodyRoot);
        }else{
            openAgreement(modalBodyRoot);
        }
    }

    const notification = antd.notification;

    function openAgreement(modalBodyRoot){
