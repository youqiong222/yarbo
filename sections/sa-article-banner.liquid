<style>
    #shopify-section-{{ section.id }}{
    background:#f2f2f2
  }
</style>
{% render 'section-padding', section_id: section.id, settings: section.settings %}
<div
  class='page-container flex  flex-col  justify-between gap-32 md:flex-row md:gap-120'
>
  <div class='relative flex flex-1 flex-col  justify-end'>
    <div
      class='mb-32 flex cursor-pointer items-center gap-6 text-[14px] leading-[1.3] md:absolute md:-top-18 md:mb-20 md:text-[15px]'
      onclick='history.back()'
    >
      <svg
        width='6'
        height='10'
        viewBox='0 0 6 10'
        fill='none'
        xmlns='http://www.w3.org/2000/svg'
      >
        <path d="M5.00228 9.08594L0.918946 5.0026L5.00228 0.919271" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
      </svg>

      <span>{{ 'navigation.back' | t }}</span>
    </div>
    <div>
      {% if article.tags.size > 0 %}
        <div class='mb-16 flex flex-wrap text-[14px] leading-[1.3] md:text-[15px]'>
          {% for tag in article.tags %}
            <span>
              {{ tag }}
              {% unless forloop.last %},{% endunless %}
            </span>
          {% endfor %}
        </div>
      {% endif %}
      <h1 class=' text-[36px]  leading-none uppercase  md:text-[52px] '>
        {{ article.title }}
      </h1>
      <div class=' mt-24 text-[14px] leading-[1.3] font-normal text-black md:mt-32'>
        {{ article.published_at | time_tag: format: 'date' }}
      </div>
    </div>
  </div>

  <div
    class='md:w-[38%]'
  >
    {%- liquid
      assign s = section.settings
      assign pc_w = s.pc_aspect_ratio_w | default: 16
      assign pc_h = s.pc_aspect_ratio_h | default: 10
      assign pc_ratio = pc_w | append: '/' | append: pc_h
      assign h5_w = s.h5_aspect_ratio_w | default: 16
      assign h5_h = s.h5_aspect_ratio_h | default: 10
      assign h5_ratio = h5_w | append: '/' | append: h5_h
    -%}
    <div
      style='
        --media-aspect-pc: {{ pc_ratio }};
        --media-aspect-h5: {{ h5_ratio }};
      '
      class='
        relative aspect-(--media-aspect-h5) w-full
        overflow-hidden md:aspect-(--media-aspect-pc)
      '
    >
      {% render 'media-element',
        class: 'absolute inset-0 w-full h-full object-cover',
        media_class: 'inset-0 w-full h-full',
        media_type: 'image',
        pc_image: article.image
      %}
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Article banner",

  "tag": "section",
  "class": "tailwind-layout",
  "settings": [
    { "type": "header", "content": "Spacing Settings" },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_top",
      "label": "H5 Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_bottom",
      "label": "H5 Padding Bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Article banner",
      "settings": {}
    }
  ]
}
{% endschema %}
