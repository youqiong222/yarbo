{%- liquid
  assign s = section.settings

  assign pc_w = s.pc_aspect_ratio_w | default: 16
  assign pc_h = s.pc_aspect_ratio_h | default: 9
  assign pc_ratio = pc_w | append: '/' | append: pc_h

  assign h5_w = s.h5_aspect_ratio_w | default: 16
  assign h5_h = s.h5_aspect_ratio_h | default: 9
  assign h5_ratio = h5_w | append: '/' | append: h5_h
-%}
{% render 'sn-anchor-target', anchor_id: section.settings.anchor_id %}

<div
  class='overflow-hidden {% if section.settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %} bg-[#0D0D0D] pt-(--pt-h5) pb-(--pb-h5) md:pt-(--pt-pc) md:pb-(--pb-pc)'
  style='
    --pt-pc: {{ s.padding_top }}px;
    --pb-pc: {{ s.padding_bottom }}px;
    --pt-h5: {{ s.h5_padding_top }}px;
    --pb-h5: {{ s.h5_padding_bottom }}px;
  '
>
  <div class='page-container'>
    <header
      class='
        flex
        items-center
        justify-between gap-12
      '
    >
      <h2
        class='
          text-[32px]
          leading-none
          text-white
          uppercase
          md:text-[44px]
        '
      >
        {{ section.settings.title }}
      </h2>
      <div class='hidden gap-8 md:flex'>
        <div class='swiper-button-prev  static m-0 flex h-48 w-48 items-center justify-center rounded-full border border-[#cccccc] bg-white backdrop-blur-[5px] transition-colors duration-300 after:hidden [&.swiper-button-disabled]:bg-[#ccc] [&.swiper-button-disabled]:opacity-100 [&.swiper-button-disabled_path]:stroke-[#A6A6A6] [&:hover]:bg-[#ccc]'>
          <svg
            width='8'
            height='14'
            viewBox='0 0 8 14'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d="M6.75325 12.5859L0.919923 6.7526L6.75325 0.91927" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
          </svg>
        </div>

        <div class='swiper-button-next static m-0 flex h-48 w-48 items-center justify-center rounded-full border border-[#cccccc] bg-white backdrop-blur-[5px] transition-colors duration-300 after:hidden [&.swiper-button-disabled]:bg-[#ccc] [&.swiper-button-disabled]:opacity-100 [&.swiper-button-disabled_path]:stroke-[#A6A6A6] [&:hover]:bg-[#ccc]'>
          <svg
            width='8'
            height='14'
            viewBox='0 0 8 14'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d="M0.91862 0.919434L6.75195 6.75277L0.91862 12.5861" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
          </svg>
        </div>
      </div>
    </header>
    <main class='mt-32 md:mt-40'>
      <div class='swiper [overflow:unset]'>
        <div class='swiper-wrapper'>
          {%- for block in section.blocks -%}
            <div class='swiper-slide'>
              <div {{ block.shopify_attributes }}>
                <div
                  style='
                    --media-aspect-pc: {{ pc_ratio }};
                    --media-aspect-h5: {{ h5_ratio }};
                  '
                  class='
                    relative mr-12
                    aspect-(--media-aspect-h5)
                    overflow-hidden
                    md:aspect-(--media-aspect-pc)
                  '
                >
                  {% render 'media-element',
                    class: 'absolute inset-0 w-full h-full',
                    media_class: 'w-full h-full object-cover',
                    media_type: block.settings.media_type,
                    pc_image: block.settings.pc_image,
                    h5_image: block.settings.h5_image,
                    pc_video: block.settings.pc_video,
                    h5_video: block.settings.h5_video,
                    video_url: block.settings.video_url,
                    other_url: block.settings.other_url
                  %}
                  {%- render 'sn-overlay', _settings: block.settings -%}
                </div>
                <div
                  class='
                    relative
                    mt-24
                    pt-12
                    pr-24
                    before:absolute
                    before:top-0
                    before:left-0
                    before:h-10
                    before:w-10
                    before:rounded-full
                    before:bg-[#FEDB1E]
                    after:absolute
                    after:top-3
                    after:left-0
                    after:h-4
                    after:w-full
                    after:bg-[#FEDB1E]
                    md:mt-32
                    md:pr-32
                  '
                >
                  <div class='text-[32px] leading-none font-bold text-[#FEDB1E] md:mt-12 md:text-[44px]'>
                    {{ block.settings.year }}
                  </div>
                  <div class='mt-16 text-[15px] leading-[1.3] text-white md:mt-16 md:text-[14px] [&_strong]:font-bold'>
                    {{ block.settings.desc }}
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </main>
  </div>
</div>

<script>
  (() => {
    new Swiper('#shopify-section-{{ section.id }} .swiper', {
      observer: true,
      observeParents: true,
      spaceBetween: 0,
      slidesPerView: 1.15,
      breakpoints: {
        768: {
          slidesPerView: 2.1,
        },
        1000: {
          slidesPerView: 3.1,
        },
        1400: {
          slidesPerView: 4.1,
        },
      },
      navigation: {
        nextEl: '#shopify-section-{{ section.id }} .swiper-button-next',
        prevEl: '#shopify-section-{{ section.id }} .swiper-button-prev',
      },
    });
  })();
</script>
{% schema %}
{
  "name": "Timeline Swiper",
  "class": "css-reset tailwind-layout",
  "settings": [
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor Id"
    },
    {
      "type": "checkbox",
      "id": "animations_reveal_on_scroll",
      "label": "t:settings_schema.animations.settings.animations_reveal_on_scroll.label",
      "default": false
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_top",
      "label": "H5 Padding Top",
      "default": 0
    },
    {
      "type": "number",
      "id": "h5_padding_bottom",
      "label": "H5 Padding Bottom",
      "default": 0
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "header",
      "content": "Media Aspect Ratio"
    },
    {
      "type": "number",
      "id": "pc_aspect_ratio_w",
      "label": "PC Ratio Width"
    },
    {
      "type": "number",
      "id": "pc_aspect_ratio_h",
      "label": "PC Ratio Height"
    },
    {
      "type": "number",
      "id": "h5_aspect_ratio_w",
      "label": "Mobile Ratio Width"
    },
    {
      "type": "number",
      "id": "h5_aspect_ratio_h",
      "label": "Mobile Ratio Height"
    }
  ],
  "blocks": [
    {
      "name": "block",
      "type": "Block",
      "settings": [
        {
          "type": "header",
          "content": "Media Settings"
        },
        {
          "type": "select",
          "id": "media_type",
          "label": "Media Type",
          "options": [
            {
              "value": "image",
              "label": "Image"
            },
            {
              "value": "video",
              "label": "Shopify Video"
            },
            {
              "value": "video_url",
              "label": "External Video URL"
            }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "pc_image",
          "label": "PC Image"
        },
        {
          "type": "image_picker",
          "id": "h5_image",
          "label": "H5 Image"
        },
        {
          "type": "video",
          "id": "pc_video",
          "label": "PC Shopify Video"
        },
        {
          "type": "video",
          "id": "h5_video",
          "label": "H5 Shopify Video(Optional)"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "label": "Platform Video URL (YouTube/Vimeo)",
          "accept": ["youtube", "vimeo"],
          "default": "https://www.youtube.com/watch?v=NpEaa2P7qZI"
        },
        {
          "type": "text",
          "id": "other_url",
          "label": "Other Video URL",
          "info": "ex: xxx.mp4 (If filled, this takes priority over the Platform Video URL)"
        },
        {
          "type": "header",
          "content": "Overlay Settings"
        },
        {
          "type": "checkbox",
          "id": "show_overlay",
          "label": "Show Media Overlay",
          "default": false
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay Color",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay Opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 40
        },
        {
          "type": "text",
          "id": "year",
          "label": "Year"
        },
        {
          "type": "richtext",
          "id": "desc",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Timeline Swiper",
      "settings": {}
    }
  ]
}
{% endschema %}
