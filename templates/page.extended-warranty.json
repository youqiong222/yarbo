          "settings": {
            "question": "How do I purchase the YarboCare™ Extended Warranty?",
            "answer": "<ol><li>Visit the Extended Warranty page on <a href=\"https://www.yarbo.com/\" target=\"_blank\">Yarbo.com</a>.</li><li>Enter your order number and email to verify eligibility.</li><li>Choose from the three available plans based on your product’s price range.</li><li>Complete your purchase.</li><li>XCotton (our authorized service provider) will activate your coverage and email your policy confirmation.</li></ol>"
          }
        },
        "faq_EPgFt7": {
          "type": "faq",
          "settings": {
            "question": "What if my order cannot be verified?",
            "answer": "<p>If verification fails, you may see one of these messages:</p><ul><li><strong>“No order found.”</strong> — Invalid order number or not purchased from Yarbo.com.</li><li><strong>“This order already has an extended warranty.”</strong> — An extended plan already exists for this product.</li><li><strong>“This order exceeded the 60-day purchase window.”</strong> — Your product is outside the eligible timeframe.</li></ul><p>Correct any errors and try again.<br/><br/></p>"
