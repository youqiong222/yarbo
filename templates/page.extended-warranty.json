        "faq_Kd7XVT": {
          "type": "faq",
          "settings": {
            "question": "What is the YarboCare™ Extended Warranty?",
            "answer": "<p>The YarboCare™ Extended Warranty is an optional post-purchase protection plan for existing Yarbo users. It extends your coverage by up to 3 additional years and also offers optional Accidental Damage (AD) protection depending on the plan you choose:</p><ul><li><strong>3-Years Extended Warranty (EW)</strong></li><li><strong>1-Year Accidental Damage + 3-Years Extended Warranty</strong></li><li><strong>3-Years Accidental Damage + 3-Years Extended Warranty</strong></li></ul><p>This plan ensures continued protection beyond your standard warranty period, covering manufacturing defects, performance issues, and more (depending on the plan selected).<br/><br/></p>"
          }
        },
        "faq_Dzp8Lg": {
          "type": "faq",
          "settings": {
            "question": "Who is eligible to purchase this Extended Warranty?",
            "answer": "<p>You can purchase this plan only if you:</p><ul><li>Purchased your Yarbo product directly from Yarbo’s official website (<a href=\"https://www.yarbo.com/\"><strong>www.yarbo.com</strong></a>).</li><li>Have not previously purchased any extended warranty for this product.</li><li>Purchase the extended warranty <strong>within 60 days after your product has been shipped.</strong></li><li>Provide a valid order number and email for verification.</li></ul><p>Orders from Amazon or third-party retailers are <strong>not eligible</strong>. Accessories and standalone modules are excluded.<br/><br/></p>"
          }
        },
        "faq_zxcJ33": {
          "type": "faq",
          "settings": {
            "question": "Which Yarbo products qualify for the Extended Warranty?",
            "answer": "<p>All Yarbo products that include a<strong> Yarbo Core </strong>are eligible, including:</p><ul><li>Yarbo Lawn Mower</li><li>Yarbo Lawn Mower Pro</li><li>Yarbo Snow Blower </li><li>Yarbo Blower</li><li> Yarbor Core</li><li>Bundles (e.g., Yarbo Lawn Mower + Snow Blower, Yarbo Lawn Mower Pro + Blower, etc.)</li></ul><p>Accessories, SAM Module and Trimmer package are<strong> not eligible</strong>.<br/><br/><br/><br/></p>"
          }
        },
        "faq_M4Ngex": {
          "type": "faq",
          "settings": {
            "question": "When should I purchase the Extended Warranty?",
            "answer": "<p>You must purchase the YarboCare™ Extended Warranty<strong>within 60 days after your product is delivered</strong>.Orders that exceed the 60-day purchase window cannot be verified and are<strong>not eligible</strong>.<br/><br/></p>"
          }
        },
