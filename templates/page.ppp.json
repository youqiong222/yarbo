    "yb_faq_new_wFMjfQ": {
      "type": "yb-faq-new",
      "blocks": {
        "faq_item_69q9py": {
          "type": "item",
          "settings": {
            "title": "<p>Who is eligible to apply for the PPP?</p>",
            "description": "<p>Current Yarbo users who own a Yarbo product and are active users are eligible to apply. Applicants should also have technical proficiency, commitment to testing, and good communication skills.</p>"
          }
        },
        "faq_item_EXYjVk": {
          "type": "item",
          "settings": {
            "title": "<p>How do I apply for the PPP?</p>",
            "description": "<p>You can apply by filling out the application form on this page. Make sure to provide your personal information, answer the mandatory questions before submitting your application.</p>"
          }
        },
        "faq_item_JmkHqf": {
          "type": "item",
          "settings": {
            "title": "<p>What kind of feedback is expected from PPP members?</p>",
            "description": "<p>We expect detailed feedback on your experiences with Yarbo products, including any challenges or issues during setup, usage, and testing. Your observations and suggestions will help us improve our products.</p>"
          }
        },
        "faq_item_aGzw97": {
          "type": "item",
          "settings": {
            "title": "<p>Can I share my experiences publicly?</p>",
            "description": "<p>Yes, you are welcome to share your experiences and thoughts publicly. We value and encourage diverse feedback, as it helps us improve our products.</p>"
          }
        },
        "faq_item_tzDFPF": {
          "type": "item",
          "settings": {
            "title": "<p>What if I encounter issues with the product during testing?</p>",
            "description": "<p>Please contact us directly with any issues or concerns. Our team is ready to help you resolve any problems you encounter.</p>"
          }
        },
        "faq_item_8aJ8ch": {
          "type": "item",
          "settings": {
            "title": "<p>Is there a cost to join the PPP?</p>",
            "description": "<p>There is no cost to join the PPP. Your participation and feedback are valuable to us.</p>"
          }
        },
        "faq_item_97bwKB": {
          "type": "item",
          "settings": {
            "title": "<p>Is there a limit to the number of PPP members?</p>",
            "description": "<p>Yes, there is a limit to the number of members we can accept into the PPP to ensure we can provide adequate support and gather meaningful feedback. The exact number may vary depending on our current capacity and the specific needs of each testing phase.</p>"
          }
        }
      },
