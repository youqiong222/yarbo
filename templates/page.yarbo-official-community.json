    "yarbo_comments_display_KrjbHc": {
      "type": "yarbo-comments-display",
      "blocks": {
        "image_text_block_BjctWR": {
          "type": "image_text_block",
          "settings": {
            "comments_title": "<p>@Kent Ross</p>",
            "comments_small_title": "<p>Yarbo User</p>",
            "comments_text": "<p>\"Wanna race?!\" My neighbor and my 2023 M1. His is faster, but mine involves a cup of coffee and talking to the family and watching TV.\"</p>",
            "people_url": "",
            "picture_image": "shopify://shop_images/Frame-2036456260-0_08746bcc-3a0b-47c8-a63c-b36adff93429.webp",
            "picture_url": "",
            "picture_youtube_video_url": "",
            "picture_firework_video_url": ""
          }
        },
        "image_text_block_7dVAM7": {
          "type": "image_text_block",
          "settings": {
            "comments_title": "<p>@Steve Thibodeau</p>",
            "comments_small_title": "<p>Yarbo User</p>",
            "comments_text": "<p>\"Based on a suggestion from a fellow backer that lives near me and came by Sunday to see Yarbo in person, I picked up a couple pallets and used my leftover decking planks to make a permanent docking station.\"<br/></p>",
            "people_url": "",
            "picture_image": "shopify://shop_images/8c35abe9-f09a-43ec-aded-248741849aa6.webp",
            "picture_url": "",
            "picture_youtube_video_url": "",
            "picture_firework_video_url": ""
          }
        },
        "image_text_block_pFxfp7": {
          "type": "image_text_block",
          "settings": {
            "comments_title": "<p>@Scott Grams</p>",
            "comments_small_title": "<p>Yarbo User</p>",
            "comments_text": "<p>\"Out looking for some snow and there is none in Wisconsin either. so just going to get some well deserved throttle therapy instead. Yarbo is doing a great job keeping it snow free around me.\"</p>",
            "people_url": "",
            "picture_image": "shopify://shop_images/Frame-2036456262-_1_-0_45dcc56a-1607-4555-87da-63a61425e0c1.webp",
            "picture_url": "",
            "picture_youtube_video_url": "",
            "picture_firework_video_url": ""
          }
        },
        "image_text_block_yEKzzg": {
          "type": "image_text_block",
          "settings": {
            "comments_title": "<p>@Alex Glanville</p>",
            "comments_small_title": "<p>Yarbo User</p>",
            "comments_text": "<p>\"My Yarbo journey involved me manually controlling Yarbo to my neighbors sidewalk and clearing it for them. I cleared my driveway with a shovel before work and again afterwork -- I bet if I let it be there would have been adequate snow for Yarbo to eat after I got home.\"</p>",
            "people_url": "",
            "picture_image": "shopify://shop_images/832ac74e-d873-4dd5-8105-deb37dddf1cd.webp",
            "picture_url": "",
            "picture_youtube_video_url": "",
            "picture_firework_video_url": ""
          }
        }
      },
