    "sa_faq_yxcKwx": {
      "type": "sa-faq",
      "blocks": {
        "qa_M7jY3F": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>WHAT IS A YARBO CERTIFIED REFURBISHED PRODUCT?</p>",
            "answer": "<p>A Yarbo Certified Refurbished product is a pre-owned unit that has undergone our rigorous, factory-authorized refurbishment process. These units are thoroughly inspected, cleaned, and tested to ensure they meet the same functional performance standards as a new Yarbo. While they offer the same cutting-edge technology and intelligence, they come at a significantly more accessible price point.</p>"
          }
        },
        "qa_X8MNTP": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>WHAT DOES \"GRADE B\" CONDITION MEAN FOR A REFURBISHED YARBO?</p>",
            "answer": "<p>Grade B refers to the cosmetic condition of the unit. While 100% functionally equivalent to a new machine, Grade B units may show minor signs of previous use, such as superficial scratches, light scuffs, or minor surface discoloration on the outer shell. These imperfections are strictly cosmetic and do not affect the robot’s performance, durability, or autonomous capabilities.</p>"
          }
        },
        "qa_N9L7eC": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>WHAT IS INCLUDED IN THE BOX WITH A REFURBISHED YARBO?</p>",
            "answer": "<p>Your refurbished package will include all the essential components required for operation, mirroring a new set. This typically includes the Yarbo Core, your selected module (Snow Blower or Lawn Mower), the Docking Station, the Battery, and the Accessory Kit. All items have been cleaned and verified for complete functionality.</p>"
          }
        },
        "qa_qi3Awa": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>CAN I RETURN MY REFURBISHED YARBO IF I CHANGE MY MIND?</p>",
            "answer": "<p>Customers may request a return within 14 days of receiving the product.However, returns based on non-defective reasons (e.g., no longer wanting the product) will not be accepted.</p>"
          }
        },
        "qa_LjqYHT": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>CAN I EXCHANGE MY REFURBISHED UNIT FOR A NEW ONE?</p>",
            "answer": "<p>No. All exchanges for certified refurbished products are limited to refurbished replacement units only, not new units.</p><p>If you wish to request an exchange, it must be submitted within 20 days of delivery and is subject to Yarbo’s review and approval. </p>"
          }
        },
        "qa_XQKjPX": {
          "type": "qa",
          "settings": {
            "tab": "2",
            "question": "<p>HOW DO I INITIATE A RETURN OR AN EXCHANGE FOR A REFURBISHED UNIT?</p>",
            "answer": "<p>To request a return, please email our support team at <a href=\"mailto:support@yarbo.com\" target=\"_blank\"><strong>support@yarbo.com </strong></a>within 14 days of receipt. Include your order number and the reason for the return. Our team will conduct an initial assessment and provide you with a return shipping label and detailed instructions if the request is approved.</p>"
          }
        },
        "qa_6infmm": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>I PARTICIPATED IN THE PRODUCT DEMO PROGRAM. CAN I USE MY DISCOUNT ON A REFURBISHED UNIT?</p>",
            "answer": "<p>Absolutely! As a participant in the Yarbo Product Demo Program, you are eligible for a fixed $200 discount voucher. This voucher can be applied toward the purchase of a Certified Refurbished unit, allowing you to enjoy even greater savings on your journey toward autonomous yard care.   </p>"
          }
        },
        "qa_pAEK9Q": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>DOES THE REFURBISHED YARBO COME WITH A WARRANTY?</p>",
            "answer": "<p>Yes. Every Yarbo Certified Refurbished product includes a 2-year official warranty. This warranty covers manufacturing defects, electronic malfunctions, and motor/sensor issues. The coverage begins on the date of activation or three (3) days after delivery, whichever occurs first.</p>"
          }
        },
        "qa_XrLKcA": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>IS IT POSSIBLE TO PURCHASE AN EXTENDED WARRANTY (YARBOCARE™) FOR A REFURBISHED PRODUCT?</p>",
            "answer": "<p>At this time, refurbished products are not eligible for extended warranty plans or YarboCare™ protection packages. The 2-year official warranty provides comprehensive coverage for your initial two years of ownership.</p>"
          }
        }
