    "yb_faq_categories_ajFtcA": {
      "type": "yb-faq-categories",
      "blocks": {
        "category_N4QYHk": {
          "type": "category",
          "settings": {
            "title": "Volunteer Installer",
            "bg_color": "#e5e5e5"
          }
        },
        "faq_NiwE7H": {
          "type": "faq",
          "settings": {
            "question": "Can I get payment from the user I help?",
            "answer": "<p>Yes, this is possible and is a matter to be agreed upon between you and the user; Yarbo does not intervene in these transactions.</p>"
          }
        },
        "faq_DKwMR8": {
          "type": "faq",
          "settings": {
            "question": "What details must I share publicly as a Yarbo Volunteer Installer?",
            "answer": "<p>Yarbo collects your name, contact email, phone number, and address for verification, but only your name and edited comments will be visible on the Installer map. Your contact details may be used for notifications, and your address helps determine your location on the map (Your approximate location will be shown, while your precise address will remain undisclosed.)</p>"
          }
        },
        "faq_7zCnRT": {
          "type": "faq",
          "settings": {
            "question": "What's the responsibility of becoming a Volunteer Installer?",
            "answer": "<p>You need to complete the official training, pass the required tasks, and keep your installation skills up to date. You are only responsible for basic installations and have the right to decline any work that you consider hazardous.</p>"
          }
        },
        "category_MdmUkN": {
          "type": "category",
          "settings": {
            "title": "Helped Person",
            "bg_color": "#e5e5e5"
          }
        },
        "faq_cQNxdM": {
          "type": "faq",
          "settings": {
            "question": "What's the process if I want to get help from a Volunteer Installer?",
            "answer": "<p>Research and contact the installer, coordinate meetup details, and carry out the meetup at the agreed time and place for an installation service.</p>"
          }
        },
        "faq_gfzGYJ": {
          "type": "faq",
          "settings": {
            "question": "How can I ensure I get good service from a Volunteer Installer?",
            "answer": "<p>You can rate the installer's service through Yarbo Support Center</p>"
          }
        },
        "faq_iEdnU8": {
          "type": "faq",
          "settings": {
            "question": "What if I encounter problems after the installation?",
            "answer": "<p>Volunteer installers are responsible for basic installation only. For other issues, please reach out to Yarbo Support Center.</p>"
          }
        },
        "faq_bGbDgW": {
          "type": "faq",
          "settings": {
            "question": "Can I compensate the installer for their assistance?",
            "answer": "<p>Yes, it's up to you, but Yarbo won't be involved in these transactions.</p>"
          }
        }
      },
