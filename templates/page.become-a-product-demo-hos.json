    "yarbo_comments_display_WVLdUH": {
      "type": "yarbo-comments-display",
      "blocks": {
        "image_text_block_Vg3z7e": {
          "type": "image_text_block",
          "settings": {
            "comments_title": "<p>@Bryan</p>",
            "comments_small_title": "<p>VA, US</p>",
            "comments_text": "<p>\"There is no other machine quite like it on the market. The company truly cares about its customer and is passionate about their product. I enjoy watching mine run its work plans automated. I can’t wait to see what new modules they come up with.\"<br/></p>",
