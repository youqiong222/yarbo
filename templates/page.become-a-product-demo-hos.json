        "image_text_block_CQHR6i": {
          "type": "image_text_block",
          "settings": {
            "comments_title": "<p>@Scott</p>",
            "comments_small_title": "<p>MN, US</p>",
            "comments_text": "<p>\"My mission is to demo my Yarbo family and the incredible capabilities of the current Yarbo model by sharing my positive experiences with potential customers.\"</p>",
            "people_url": "",
            "picture_image": "shopify://shop_images/Frame-2036456262-_1_-0_45dcc56a-1607-4555-87da-63a61425e0c1.webp",
