          }
        },
        "image_text_block_mch4Yg": {
          "type": "image_text_block",
          "settings": {
            "comments_title": "<p>@Kent</p>",
            "comments_small_title": "<p>NY, US</p>",
            "comments_text": "<p>\"Today as a PPP member (tester) I get to work closer with Yarbo staff on both the 2023 and 2024 systems. I have lots of experience with the Lawn Mower, Snow Blower, and Plow Blade as well.\"</p>",
            "people_url": "",
            "picture_image": "shopify://shop_images/Frame-2036456260-0_08746bcc-3a0b-47c8-a63c-b36adff93429.webp",
