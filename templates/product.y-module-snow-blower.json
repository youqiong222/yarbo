    "sa_product_img_swiper_with_modal_EFQBEB": {
      "type": "sa-product-img-swiper-with-modal",
      "blocks": {
        "block_Anjw7E": {
          "type": "Block",
          "settings": {
            "title": "<p>CUSTOM SCHEDULES</p>",
            "desc": "",
            "text_layout": "bottom",
            "show_modal": true,
            "show_modal_media": false,
            "modal_title": "<p>Snow Clearing. On Your Schedule.</p>",
            "modal_desc": "<p>Plan yard care easily in the Yarbo app using custom schedules. Set your preferred times and let Yarbo handle snow clearing automatically, helping keep outdoor areas clear with less day-to-day effort.Yarbo is designed to keep scheduled snow clearing on track with auto-recharge. If the battery drops below 20%, it automatically returns to the dock to recharge and resumes snow clearing once it reaches over 80%, helping the task continue without manual intervention.With custom schedules in place across mapped outdoor areas, Yarbo follows your planned snow clearing routine more consistently over time, helping keep driveways, pathways, and entrances clearer and easier to manage.</p>",
            "modal_media_type": "image",
            "modal_video_url": "",
            "modal_other_url": "",
            "media_type": "image",
            "pc_image": "shopify://shop_images/Frame_2036458234.png",
            "video_url": "https://www.youtube.com/watch?v=NpEaa2P7qZI",
            "other_url": "",
            "show_overlay": false,
            "overlay_color": "#000000",
            "overlay_opacity": 40
          }
        },
        "block_CLFGPH": {
          "type": "Block",
          "settings": {
            "title": "<p>ZONE MAPPING & ALERTS</p>",
            "desc": "",
            "text_layout": "bottom",
            "show_modal": true,
            "show_modal_media": false,
            "modal_title": "<p>Manage Multiple Zones with Ease.</p>",
            "modal_desc": "<p>Easily map your yard in the Yarbo app and divide it into separate mowing zones based on your layout. Whether it is the front yard, backyard, or side yard, Yarbo helps you manage each area more clearly and precisely.Each mapped zone can be handled more independently, making it easier to organize mowing across different parts of your property and stay updated on task progress in the app.With multi-zone mapping in place, Yarbo helps make lawn care more flexible and easier to manage across your entire yard over time.</p>",
            "modal_media_type": "image",
            "modal_video_url": "",
            "modal_other_url": "",
            "media_type": "image",
            "pc_image": "shopify://shop_images/Frame_2036458235.png",
            "video_url": "https://www.youtube.com/watch?v=NpEaa2P7qZI",
            "other_url": "",
            "show_overlay": false,
            "overlay_color": "#000000",
            "overlay_opacity": 40
          }
        },
        "block_BW3fmA": {
          "type": "Block",
          "settings": {
            "title": "<p>YARD LIVE VIEW</p>",
            "desc": "",
            "text_layout": "bottom",
            "show_modal": true,
            "show_modal_media": false,
            "modal_title": "<p>Check In Anytime, Anywhere.</p>",
            "modal_desc": "<p>Stay connected to your yard with Live Yard View through Smart Vision in the Yarbo app. View real-time footage from your phone and check what’s happening around your property whenever you need. With live access through Smart Vision, you can watch yard conditions, check on ongoing tasks, and see the area around your machine in real time. Whether you are away from home or simply want added reassurance, Live Yard View helps you stay visually connected to your yard, giving you an added layer of awareness.</p>",
            "modal_media_type": "image",
            "modal_pc_image": "shopify://shop_images/Frame_2036458231.png",
            "modal_video_url": "",
            "modal_other_url": "",
            "media_type": "image",
            "pc_image": "shopify://shop_images/Frame_2036458227.png",
            "video_url": "https://www.youtube.com/watch?v=NpEaa2P7qZI",
            "other_url": "",
            "show_overlay": false,
