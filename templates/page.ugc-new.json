    "sa_faq_nE76Lp": {
      "type": "sa-faq",
      "blocks": {
        "qa_iaPU49": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>Contest Overview</p>",
            "answer": "<p>The \"Your Yarbo Journey Wanted\" Contest (“Contest”) invites Yarbo owners to submit original video content showcasing their Yarbo units in real-world scenarios. The Contest is conducted on an ongoing, weekly basis starting from August 4, 2025.</p>"
          }
        },
        "qa_Q3Jgwm": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>Eligibility</p>",
            "answer": "<p>Participants must be verified Yarbo product owners. Submissions will only be accepted when made using the email address linked to the participant’s Yarbo unit. Unauthorized submissions by non-owners or unverifiable accounts will be disqualified.</p>"
          }
        },
        "qa_Q7egaQ": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>Submission Guidelines</p>",
            "answer": "<p>Submissions must be made through the designated form on this page. Participants may either:</p><ul><li>Upload raw video files (within 200M) directly through the form, or</li><li>Submit links to their video posts on social media platforms.</li><li>Only submissions made through this official page will be considered valid.</li></ul>"
          }
        },
        "qa_7gaGFt": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p><strong>Content Requirements</strong></p>",
            "answer": "<p>All submitted videos must meet the following shooting specifications:</p><ul><li>Orientation: Landscape (16:9) or Portrait (9:16)</li><li>Duration: Between 30 seconds and 3 minutes</li><li>Video Quality: High-definition, unfiltered, and authentically shot</li><li>Audio: Natural sound or objective voiceover preferred</li><li>Lighting: Use natural lighting; avoid poor visibility</li><li>Focus: Show Yarbo in performance, especially in challenging scenarios (e.g., steep slopes, muddy terrain, snow, or complex environments)</li><li>Optional: Videos may include lifestyle elements such as people, pets, or home settings to enhance storytelling</li></ul>"
          }
        },
        "qa_UErq3T": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p><strong>Submission Categories & Rewards</strong></p>",
            "answer": "<p>While weekly themes may vary, the quest level definitions remain consistent:</p><ul><li>Epic Quests – In-depth, high-quality videos showing Yarbo taking on complex tasks or a full user review</li><li>Rare Quests – Creative or uniquely captured footage of Yarbo in action</li><li>Advanced Quests – Videos of Yarbo performing under demanding or challenging conditions</li><li>Standard Quests – Footage of Yarbo completing routine daily tasks</li></ul><p><strong>Weekly Prizes:</strong></p><ul><li>1 winner each from Epic, Rare, and Advanced Quests</li><li>2 winners from Standard Quests</li><li>Prizes may include cash rewards, gift cards, Yarbo products, account credits, or discount codes. Details for each week’s rewards and themes will be posted on Yarbo’s official social media accounts and the <a href=\"https://www.yarbo.com/boost/yarbo-official-community\" target=\"_blank\">Yarbo Facebook Group</a>.</li></ul>"
          }
        },
        "qa_izRFxp": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p><strong>Judging Criteria</strong></p>",
            "answer": "<p>Submissions will be reviewed by Team Yarbo based on the following:</p><ul><li>Creativity and originality</li><li>Visual and audio quality</li><li>Relevance to weekly theme</li><li>Accuracy and clarity in showcasing Yarbo’s performance</li><li>Compliance with shooting guidelines</li></ul>"
          }
        },
        "qa_hwYahr": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p><strong>Winner Notification</strong></p>",
            "answer": "<p>Winning entries will be announced weekly on the Contest page. Winners will also be contacted via the email address used for submission.</p>"
          }
        },
        "qa_9KBRDb": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>Intellectual Property & Usage Rights</p>",
            "answer": "<p>By submitting content, participants grant Yarbo the non-exclusive, royalty-free right to use, reproduce, modify, adapt, publish, and distribute the content for marketing, promotional, and commercial purposes across digital and print channels. All rights must be cleared before submission; no third-party materials or copyrighted content may be included without proper authorization.</p>"
          }
        },
        "qa_VCyyXz": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>Prohibited Content</p>",
            "answer": "<p>Submissions must not include:</p><ul><li>Third-party or copyrighted content without permission</li><li>Misleading claims or inaccurate representations of Yarbo</li><li>Inappropriate, offensive, or sensitive content</li><li>Excessive use of filters, AI-generated visuals, or overly edited footage</li><li>Any content that infringes on privacy, safety, or intellectual property rights</li></ul>"
          }
        },
        "qa_thYw7L": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>Disqualification and Disputes</p>",
            "answer": "<p>Yarbo reserves the right to reject or remove any submission that violates these Terms and Conditions. All decisions made by Yarbo regarding eligibility, judging, and awarding are final and binding.</p>"
          }
        }
      },
