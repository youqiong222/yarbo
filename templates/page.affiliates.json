    "sa_faq_BbJDwD": {
      "type": "sa-faq",
      "blocks": {
        "qa_MqzFDC": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>What is an Affiliate Program?</p>",
            "answer": "<p>Affiliate marketing relies on a relationship between a merchant and you, the affiliate, as well as between you and consumers. When you promote the merchant's product or service and a consumer purchases through your link, you earn a share of the sale. Compensation can include incentives, discounts, giveaways, bonuses, and commissions.</p>"
          }
        },
        "qa_Vmg6EW": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>How long can l get my commission?</p>",
            "answer": "<p>Commissions are paid 60 days after the order is confirmed to account for returns and cancellations.</p>"
          }
        },
        "qa_GBRCBT": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>How can I track my performance?</p>",
            "answer": "<p>Simply log in to your Impact affiliate account to view your sales, clicks, and commission earnings in real time.</p>"
          }
        },
        "qa_ri8n8h": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>Do I need to request payment manually?</p>",
            "answer": "<p>No, payments are processed automatically by Impact once the commission is approved and the threshold is met.</p>"
          }
        },
        "qa_D7YVcT": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>Is it safe around people, pets, and obstacles?</p>",
            "answer": "<p>Yarbo uses smart mapping and sensors to navigate your yard, clearing snow automatically without manual supervision. You just set the boundaries in the app.</p>"
          }
        }
      },
