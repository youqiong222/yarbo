    "sa_faq_Kc3pyP": {
      "type": "sa-faq",
      "blocks": {
        "tab_gdjDKz": {
          "type": "tab",
          "settings": {
            "label": "Products Features"
          }
        },
        "qa_9G93DN": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>Is the Yarbo Lawn Mower suitable for large lawns?</p>",
            "answer": "<p>Yes, Yarbo Lawn Mower maintains up to 6 acres (25,000 m²) with recommended twice-weekly mowing schedules. It operates for approximately 120 minutes, covering around 0.25 acres (1,000 m²). With fast 90-minute recharging and up to 7 daily cycles, Yarbo Lawn Mower autonomously maintains large properties—making it an ideal autonomous mower for homeowners seeking hands-free lawn care.</p>"
          }
        },
        "qa_fmy6Rf": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>Can the Yarbo Lawn Mower handle steep slopes and complex terrain?</p>",
            "answer": "<p>Absolutely. Yarbo Lawn Mower navigates slopes up to 35° (70%) and adapts to complex terrain, including ditches, trees, and ponds. The tracked drive system and powerful motors deliver reliable performance on uneven, rugged lawns—ensuring Yarbo Lawn Mower maintains consistent cutting quality even on challenging properties.</p>"
          }
        },
        "qa_7maweM": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>How's the mowing quality of the Yarbo Lawn Mower?</p>",
            "answer": "<p>Yarbo Lawn Mower features dual floating cutting discs, each with five razor-sharp blades, delivering a 20-inch (50 cm) cutting width—among the widest in its class. Cutting height adjusts from 1.2 to 4.0 inches (3–10.2 cm), ensuring clean, even cuts across various grass types. Yarbo Lawn Mower delivers professional-grade results comparable to traditional mowers.</p>"
          }
        },
        "qa_WAYgLq": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>How does Yarbo handle obstacles and uneven terrain?</p>",
            "answer": "<p>Yarbo uses multi-sensor detection combined with adaptive mobility systems to identify and respond to obstacles in real time. It can navigate around objects, adjust to uneven surfaces, and maintain stable performance on slopes, irregular terrain, and complex outdoor environments.</p>"
          }
        },
        "qa_XnVHNf": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>How does Yarbo Lawn Mower ensure precise navigation?</p>",
            "answer": "<p>Yarbo Lawn Mower uses RTK-GPS correction data from the included Data Center for centimeter-level accuracy. The Data Center connects to your router via wired Ethernet for stable signal transmission. Combined with binocular cameras, ultrasonic radar, IMU, and ODOM sensors, Yarbo Lawn Mower navigates with precision—no boundary wires required.</p>"
          }
        },
        "qa_YyqthA": {
          "type": "qa",
          "settings": {
            "tab": "1",
            "question": "<p>What's the battery life and coverage per charge?</p>",
            "answer": "<p>Yarbo Lawn Mower delivers 120 minutes of runtime per charge (80% to 20%), covering approximately 0.25 acres (1,000 m²). Using full battery capacity (100% to 0%), it covers up to 0.43 acres (1,600 m²). Yarbo Lawn Mower automatically returns to dock at 20% battery, recharges to 80% in 90 minutes, and resumes mowing—enabling up to 1.7 acres daily without manual intervention. Advanced battery management protects against overheating, short circuits, and overcharging.</p>"
          }
        },
        "tab_6NDXL6": {
          "type": "tab",
          "settings": {
            "label": "Support & Care"
          }
        },
        "qa_WTa6aV": {
          "type": "qa",
          "settings": {
            "tab": "2",
            "question": "<p>What maintenance is needed for blades, tracks, and general upkeep?</p>",
            "answer": "<p>Minimal upkeep keeps Yarbo Lawn Mower performing optimally. Replace blades every 3 months with heavy use (tool-free replacement). Clean and lubricate tracks regularly, checking tension periodically. Monthly maintenance: clean cameras and sensors, wipe exterior housing, update firmware via the Yarbo app. During storage, charge the battery for 15 minutes every 3 months to prevent degradation. A seasonal inspection is recommended.</p>"
          }
        },
        "qa_dtnpww": {
          "type": "qa",
          "settings": {
            "tab": "2",
            "question": "<p>I'm having trouble with setup—what should I do?</p>",
            "answer": "<p>Follow the step-by-step guide in the Yarbo App or included user manual. For additional help, visit wiki.yarbo.com, join our Discord Forum, or connect with users in our Official Facebook Group. Reach 24/7 support at 1 (631) 818-1850, email <a href=\"mailto:support@yarbo.com\">support@yarbo.com</a>, or submit a ticket through the Yarbo App.</p>"
          }
        },
        "qa_dAGQna": {
          "type": "qa",
          "settings": {
            "tab": "2",
            "question": "<p>What is Yarbo’s return policy?</p>",
            "answer": "<p>Yarbo offers a <strong>30-day return policy</strong> for eligible products.To qualify for a return:</p><ul><li> The product must be in <strong>original packaging</strong></li><li> All accessories and documentation must be included </li><li> The item must be in <strong>resalable condition</strong></li></ul><p>Return shipping fees and packaging costs may be deducted if applicable.</p>"
          }
        },
        "qa_NPLq9p": {
          "type": "qa",
          "settings": {
            "tab": "2",
            "question": "<p>What warranty does Yarbo offer?</p>",
            "answer": "<p>Yarbo products include a <strong>2-year limited warranty</strong>.You can also choose an <strong>optional 3-year extended warranty</strong>, providing up to <strong>5 years of total coverage</strong> (available in select regions).</p>"
          }
        },
        "qa_D8GcmM": {
          "type": "qa",
          "settings": {
            "tab": "2",
            "question": "<p>Can I cancel my order after placing it?</p>",
            "answer": "<p>Yes—orders can be canceled before shipment.<br/>If the order has already shipped, it will be treated as a return and subject to the return policy.</p>"
          }
        },
        "qa_qHcHYE": {
          "type": "qa",
          "settings": {
            "tab": "2",
            "question": "<p>What if my delivery is delayed?</p>",
            "answer": "<p>While Yarbo aims for fast delivery, delays may occur due to:</p><ul><li> Weather conditions </li><li> Carrier issues </li><li> High seasonal demand </li></ul><p>Yarbo will keep you updated with tracking and support assistance.</p>"
          }
        },
        "qa_7TaenY": {
          "type": "qa",
          "settings": {
            "tab": "2",
            "question": "<p>How can I contact Yarbo support?</p>",
            "answer": "<p>You can reach Yarbo through:</p><ul><li> Email: <strong>support@yarbo.com</strong></li><li> Phone: <strong>+1 (631) 818-1850</strong></li><li> Yarbo App support system </li></ul><p>Support is available <strong>24/7</strong>.</p>"
          }
        },
        "qa_tcpiyb": {
          "type": "qa",
          "settings": {
            "tab": "2",
            "question": "<p>How long does Yarbo shipping take?</p>",
            "answer": "<p>Yarbo orders typically ship within <strong>3–8 business days</strong> for in-stock products in the United States.<br/> For <strong>pre-order items</strong>, delivery timelines are shown on the product page.For <strong>Canada and Europe</strong>:</p><ul><li> Core & Modules: 3–8 business days </li><li> Accessories: 10–15 business days </li></ul>"
          }
        }
