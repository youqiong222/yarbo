                              // 将 $4999.00 转换为 499900 (美分)
                              const priceNumber = parseFloat(buyPriceStr.replace(/[$,]/g, ''));
                              const priceCents = Math.round(priceNumber * 100);
                              splititEl.setAttribute('data-amount', priceCents);
                              splititEl.removeAttribute('data-buy-price');
                            }
                          })();
                        </script>
