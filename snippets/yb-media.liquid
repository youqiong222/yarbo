{% comment %}
  {% render "yb-media", autoplay: true, controls: true, tag: 'media', settings: block.settings %}

  配置
  {
    "id": "media_image",
    "type": "image_picker",
    "label": "图片"
  },
  {
    "id": "media_local_video",
    "type": "video",
    "label": "本地视频"
  },
  {
    "id": "media_external_youtube_video",
    "type": "video_url",
    "accept": ["youtube"],
    "label": "youtube视频链接",
    "placeholder": "https://www.youtube.com/watch?v=V7BEzkRBp_g",
    "info": "支持youtube"
  },
  {
    "id": "media_external_video",
    "type": "text",
    "label": "外部视频链接",
    "placeholder": "https://cdn4.fireworktv.com/medias/2025/1/14/1736847602-iqkgazld/watermarked/720/smart_pc.mp4",
    "info": "支持firework"
  }
{% endcomment %}

{% assign media_tag = tag | default: 'media' %}

{% assign local_video_str = media_tag | append: '_local_video' %}
{% assign local_video = settings[local_video_str] %}
{% assign external_youtube_video_str = media_tag | append: '_external_youtube_video' %}
{% assign external_youtube_video = settings[external_youtube_video_str] %}
{% assign external_video_str = media_tag | append: '_external_video' %}
{% assign external_video = settings[external_video_str] %}
{% assign image_str = media_tag | append: '_image' %}
{% assign image = settings[image_str] %}

{% if autoplay %}
  {% assign autoplay = true %}
{% else %}
  {% assign autoplay = false %}
{% endif %}

{% if controls %}
  {% assign controls = true %}
{% else %}
  {% assign controls = false %}
{% endif %}

{% if local_video %}
  {{ local_video | video_tag:
    autoplay: autoplay,
    controls: controls,
    preload: 'auto',
    muted: true,
    loop: true,
    playsinline: true
  }}
{% elsif external_youtube_video %}
  {% if controls %}
    {% assign yt_controls = 1 %}
  {% else %}
    {% assign yt_controls = 0 %}
  {% endif %}

  {% if autoplay %}
    {% assign yt_autoplay = 1 %}
  {% else %}
    {% if youtube_autoplay %}
      {% assign yt_autoplay = 1 %}
    {% else %}
      {% assign yt_autoplay = 0 %}
    {% endif %}
  {% endif %}

  <iframe
    src="https://www.youtube.com/embed/{{ external_youtube_video.id }}?playlist={{ external_youtube_video.id }}&loop=1&autoplay={{ yt_autoplay }}&controls={{ yt_controls }}&playsinline=1&mute=1&rel=0"
    data-lazyframe
    frameborder="0"
    loading="lazy"
    style="pointer-events:none"
  ></iframe>
{% elsif external_video != blank %}
  <video
    src="{{ external_video }}"
    preload="metadata"
    {% if autoplay %}autoplay{% endif %}
    {% if controls %}controls{% endif %}
    muted
    loop
    playsinline
  ></video>
{% elsif image %}
  {% render "yb-image", data: image %}
{% endif %}
