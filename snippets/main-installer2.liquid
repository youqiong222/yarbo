                const selector = fieldParent.querySelector('.ant-select-selector');

                if (selectContainer && selector) {
                    // Add click event to the selector to clear error when clicked
                    selector.addEventListener('click', () => {
                        clearFieldError(fieldId);
                        selector.style.borderColor = '#40a9ff';
                    });

                    // Add mutation observer to detect when selection changes
                    const observer = new MutationObserver((mutations) => {
                        mutations.forEach((mutation) => {
                            if (mutation.type === 'childList' || mutation.type === 'attributes') {
                                const hasSelection = selector.querySelector('.ant-select-selection-item');
                                if (hasSelection) {
