    function uploadImg(file){

        // Get a unique object key based on file name and timestamp
        const timestamp = new Date().getTime();
        const fileName = file.name;
        const objectKey = `installer-photos/${timestamp}-${fileName}`;

        // Set up request parameters for getting presigned URL
        const requestParams = {
            bucket: "yarbo-market",
            items: [
                {
                    objectKey: objectKey,
                    contentType: file.type
                }
            ]
        };

        // Make request to get presigned URL
        fetch('https://4zx17x5q7l.execute-api.us-east-1.amazonaws.com/Stage/yarbo/common/presignedUrlMultiple' , {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(requestParams)
        })
        .then(response => response.json())
        .then(data => {
            if (data.success && data.data && data.data[objectKey]) {
                const presignedData = data.data[objectKey];
                const formData = new FormData();
                Object.keys(presignedData.fields).forEach(key => {
                    formData.append(key, presignedData.fields[key]);
                });
                formData.append('file', file);
                try{
                    fetch(presignedData.url, {
                        method: 'POST',
                        body: formData
                    })
                } catch (error) {
                    console.error('Error uploading image:', error);
                }
            } else {
                console.error('Error uploading image');
            }
        });

        console.log('Uploading file:', file, 'to object key:', objectKey);

        return objectKey;

    }

    // Declare quizSwiper in a broader scope so it can be accessed by other functions
    let quizSwiper;

    // Add event listeners when DOM is ready
    const startButton = document.getElementById('startButton');

    if (startButton) {
        startButton.addEventListener('click', function() {
            if (!handleInstallerStateCheck()) return;
            // Hide current view (the start screen)
            document.getElementById('quizBox').style.display = 'none';
            // Show the quiz section
            // Initialize Swiper for quiz
            quizSwiper = new Swiper("#YarbosectionBox .swiper", {
                slidesPerView: 1,
                spaceBetween: 30,
                allowTouchMove: true, // Prevent swiping to ensure quiz order
                on: {
                    slideChange: function() {
                        // Update progress bar
                        const progressBar = document.querySelector('#YarbosectionBox .bg-\\[\\#00C441\\]');
                        if (progressBar) {
                            const progress = ((this.activeIndex + 1) / this.slides.length) * 100;
                            progressBar.style.width = progress + '%';
                        }

                        // Enable/disable prev button based on slide index
                        const prevButton = document.getElementById('PreviousButton')
                        if (prevButton) {
                            if (this.activeIndex === 0) {
                                prevButton.disabled = true;
                                prevButton.classList.add('cursor-not-allowed');
                            } else {
                                prevButton.disabled = false;
                                prevButton.classList.remove('cursor-not-allowed');
                            }
                        }
                    }
                }
            });

            // Add event listeners to the next and previous buttons
            const nextButton = document.getElementById('NextButton');
            const prevButton = document.getElementById('PreviousButton')

            // Function to update the section title based on the current slide index
            function updateSectionTitle(index) {
                const titleElement = document.querySelector('#YarbosectionBox p:first-child');
                if (!titleElement) return;

                if (index < 7) {
                    titleElement.textContent = 'Yarbo section';
                } else if (index < 12) {
                    titleElement.textContent = 'Data center section';
                } else {
                    titleElement.textContent = 'Docking station section';
                }
            }

            // Set initial section title
            updateSectionTitle(0);

            // Add event to update section title when slides change
            quizSwiper.on('slideChange', function() {
                updateSectionTitle(this.activeIndex);
            });

            if (nextButton) {
                nextButton.addEventListener('click', function() {
                    if (quizSwiper.isEnd) {
                        // We're at the last slide, submit the quiz
                        const answers = [];
                        document.querySelectorAll('#YarbosectionBox .swiper-slide').forEach((slide, index) => {
                            const selectedOption = slide.querySelector('.border-\\[\\#00C441\\]');
                            if (selectedOption) {
                                answers.push({
                                    questionIndex: index,
                                    selectedOption: Array.from(slide.querySelectorAll('.border')).indexOf(selectedOption)
                                });
                            }
                        });

                        console.log('Quiz answers:', answers);

                        // Correct answers (0-indexed, so subtract 1 from each value in the correct answer sequence)
                        const correctAnswers = [1, 0, 2, 2, 1, 2, 2, 0, 0, 1, 1, 2, 2, 2, 1, 2];

                        // Calculate score (6.25 points per correct answer)
                        const answerScore = answers.reduce((score, answer) => {
                            const questionIndex = answer.questionIndex;
                            const selectedOption = answer.selectedOption;
                            
                            // Check if the selected option matches the correct answer
                            if (questionIndex < correctAnswers.length && selectedOption === correctAnswers[questionIndex]) {
                                return score + 6.25;
                            }
                            return score;
                        }, 0);

                        // the answerScore and submit it to the API
                        updateBoxByScore(answerScore);

                        // Submit quiz answers
                        fetch("https://dev.yarbo.ai/backend/v2/install/installer/complete/question/" + answerScore, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'Authorization': 'Bearer ' + authorization
                            }
                        })
                        .then(response => response.json())
                        .then(data => {
                            console.log('Quiz submitted:', data);
                        })
                        .catch(error => {
                            console.error('Error submitting quiz:', error);
                        });

                    } else {
                        // Not at the last slide, just go to next slide
                        quizSwiper.slideNext();
                    }
                });
            }

            if (prevButton) {
                prevButton.addEventListener('click', function() {
                    quizSwiper.slidePrev();
                });
            }

            // Add click handlers for question answers
            document.querySelectorAll('#YarbosectionBox .swiper-slide .border').forEach(option => {
                option.addEventListener('click', function() {
                    // Remove selected class from all options in this slide
                    const currentSlide = this.closest('.swiper-slide');
                    const options = currentSlide.querySelectorAll('.border');
                    options.forEach(opt => {
                        opt.classList.remove('border-[#00C441]', 'bg-[rgba(0,196,65,0.05)]');
                        const icon = opt.querySelector('.iconfont');
                        if (icon) {
                            icon.classList.remove('icon-A7');
                            icon.classList.remove('text-[#00C441]');
                            icon.classList.add('icon-A8');
                        }
                    });

                    // Add selected class to clicked option
                    this.classList.add('border-[#00C441]', 'bg-[rgba(0,196,65,0.05)]');
                    const icon = this.querySelector('.iconfont');
                    if (icon) {
                        icon.classList.remove('icon-A8');
                        icon.classList.add('icon-A7');
                        icon.classList.add('text-[#00C441]');
                    }
                });
            });
            document.getElementById('YarbosectionBox').style.display = 'flex';


        });
    }

    function updateBoxByScore(answerScore){
        // Hide quiz section
        document.getElementById('quizBox').style.display = 'none';
        document.getElementById('YarbosectionBox').style.display = 'none';

        // Determine which result screen to show based on score
        const isPass = answerScore >= 60;
        const resultSection = document.getElementById(isPass ? 'endSuccessSection' : 'endErrorSection');
        resultSection.style.display = 'flex';

        // Update score display
        const scoreElement = resultSection.querySelector('p:nth-child(4)');
        if (scoreElement) {
            scoreElement.textContent = `Your score: ${answerScore}`;
        }

        // Add event listener for Try Again button
        const tryAgainButton = resultSection.querySelector('button');
        if (tryAgainButton) {
            tryAgainButton.addEventListener('click', function() {
                // Hide result section
                resultSection.style.display = 'none';

                if (!quizSwiper) {
                    startButton.click();
                    return;
                }
                
                // Reset all selected answers
                document.querySelectorAll('#YarbosectionBox .swiper-slide .border-\\[\\#00C441\\]').forEach(option => {
                    option.classList.remove('border-[#00C441]', 'bg-[rgba(0,196,65,0.05)]');
                    const icon = option.querySelector('.iconfont');
                    if (icon) {
                        icon.classList.remove('icon-A7', 'text-[#00C441]');
                        icon.classList.add('icon-A8');
                    }
                });
                
                // Reset to first slide and update progress
                quizSwiper.slideTo(0);
                
                // Update progress bar to beginning
                const progressBar = document.querySelector('#YarbosectionBox .bg-\\[\\#00C441\\]');
                if (progressBar) {
                    progressBar.style.width = '6.25%';
                }
                
                // Disable previous button 
                const prevButton = document.getElementById('PreviousButton');
                if (prevButton) {
                    prevButton.disabled = true;
                    prevButton.classList.add('cursor-not-allowed');
                }
                
                // Show quiz section again to restart
                document.getElementById('YarbosectionBox').style.display = 'flex';
            });
        }
    }
</script>

<script>
    // 2. This code loads the IFrame Player API code asynchronously.
    var tag = document.createElement("script");

    tag.src = "https://www.youtube.com/iframe_api";
    var firstScriptTag = document.getElementsByTagName("script")[0];
    firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

    // 3. This function creates an <iframe> (and YouTube player)
    //    after the API code downloads.
    var player;
    function onYouTubeIframeAPIReady() {
        player = new YT.Player("YouTubevideoplayer", {
            videoId: "",
            height: "100%",
            width: "100%",
            playerVars: {
                playsinline: 1,
                controls: "aspect-[16/9]",
                loop: 1,
                start: 0,
                cc_load_policy: 0,
                modestbranding: 1,
                autoplay: 1,
                rel: 0,
                showinfo: 1,
                fs: 0,
            },
        });
    }

    function stopVideo() {
        player.stopVideo();
    }

    document.querySelectorAll(".yarbo_video_image").forEach((element) => {
        element.addEventListener("click", () => {
            document.getElementById("showVideo").style.display = "flex";
            const videoId = element.querySelector("img").alt;
            player.loadVideoById(videoId);
        });
    });

    document.getElementById("closeVideo").addEventListener("click", () => {
        document.getElementById("showVideo").style.display = "none";
        player.stopVideo();
    });

    // Add video upload and preview functionality
    document.addEventListener("DOMContentLoaded", function () {
        // Create a hidden file input element for video uploads
        const fileInput = document.createElement("input");
        fileInput.type = "file";
        fileInput.id = "videoFile";
        fileInput.accept = "video/*";
        fileInput.style.display = "none";
        document.body.appendChild(fileInput);

        // Add click event to the upload video button
        const uploadBtn = document.getElementById("uploadvideoFile");
        if (uploadBtn) {
            uploadBtn.addEventListener("click", function () {
                // First check installer state before allowing upload
                if (!handleInstallerStateCheck()) return;

                // Trigger file input click
                fileInput.click();
            });
        }

        // Handle file selection
        fileInput.addEventListener("change", function (event) {
            const file = event.target.files[0];
            if (!file) return;

            // Validate file type is video
            if (!file.type.startsWith("video/")) {
                notification.error({
                    message: "Please upload a video file",
                    closeIcon: false,
                    duration: 3,
                    placement: "top",
                });
                return;
            }

            // Create video element to display the preview
            const videoPreviewBox = document.getElementById("videoPreviewBox");
            videoPreviewBox.innerHTML = ""; // Clear previous content

            const videoElement = document.createElement("video");
            videoElement.controls = true;
            videoElement.autoplay = false;
            videoElement.style.width = "100%";
            videoElement.style.height = "100%";
            videoElement.style.objectFit = "cover";
            videoElement.style.borderRadius = "16px";

            // Create URL for the video file
            const videoURL = URL.createObjectURL(file);
            videoElement.src = videoURL;

            // Add video to the preview box
            videoPreviewBox.appendChild(videoElement);

            // Optional: Add file name and size display
            const fileInfo = document.createElement("div");
            fileInfo.className = "file-info";
            fileInfo.style.position = "absolute";
            fileInfo.style.bottom = "10px";
            fileInfo.style.left = "10px";
            fileInfo.style.color = "white";
            fileInfo.style.backgroundColor = "rgba(0,0,0,0.5)";
            fileInfo.style.padding = "5px 10px";
            fileInfo.style.borderRadius = "4px";
            fileInfo.style.fontSize = "12px";
            fileInfo.innerHTML = `${file.name} (${(
                file.size /
                (1024 * 1024)
            ).toFixed(2)} MB)`;
            videoPreviewBox.appendChild(fileInfo);

            // In a real implementation, you would upload to your server here
            console.log("Video selected for upload:", file);

            // Update installer state to indicate video upload
            submitVideoToAPI(file);
        });
    });

    // Once the video is processed, submit to the installer API
    async function submitVideoToAPI(file) {
        const objectKey = uploadVideo(file);

        console.log("Video uploaded to S3, object key:", objectKey);

        const response = await fetch(
            "https://dev.yarbo.ai/backend/v2/install/installer/complete/upload/video",
            {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    Authorization: "Bearer " + authorization,
                },
                body: JSON.stringify({
                    video_key: objectKey,
                }),
            }
        );

        if (response.ok) {
            const data = await response.json();
            console.log("Video submission successful:", data);
        } else {
            throw new Error("Video submission failed");
        }
    }

    // Upload video using presignedUrlPut endpoint
    function uploadVideo(file) {
        // Get a unique object key based on file name and timestamp
        const timestamp = new Date().getTime();
        const fileName = file.name;
        const objectKey = `installer-videos/${timestamp}-${fileName}`;

        // Request parameters for getting presigned URL
        const requestParams = {
            bucket: "yarbo-market",
            contentType: file.type,
            objectKey: objectKey,
        };

        // Make request to get presigned URL
        fetch(
            "https://4zx17x5q7l.execute-api.us-east-1.amazonaws.com/Stage/yarbo/common/presignedUrlPut",
            {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                },
                body: JSON.stringify(requestParams),
            }
        )
            .then((response) => response.json())
            .then((data) => {
                if (data.success && data.data) {
                    const presignedData = data.data;
                    const formData = new FormData();
                    Object.keys(presignedData.fields).forEach((key) => {
                        formData.append(key, presignedData.fields[key]);
                    });
                    formData.append("file", file);
                    try {
                        fetch(presignedData.url, {
                            method: "POST",
                            body: formData,
                        });
                    } catch (error) {
                        console.error("Error uploading image:", error);
                    }
                } else {
                    throw new Error("Failed to get presigned URL");
                }
            });

        return objectKey;
    }
</script>