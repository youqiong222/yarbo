            // Add event listeners to clear error on focus/hover
            // Different handling for regular inputs vs select components
            if (field.tagName === 'INPUT' || field.tagName === 'TEXTAREA') {
                field.addEventListener('focus', () => clearFieldError(fieldId), { once: true });
                field.addEventListener('blur', () => {
                    // Revalidate on blur
                    if (!field.value.trim()) {
                        showFieldError(fieldId, `Please input your ${field.getAttribute('placeholder') || 'value'}!`);
                    }
                });
                field.addEventListener('mouseenter', () => {
