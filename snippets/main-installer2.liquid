    // This function gets called when installer_state is 1
    async function updateInstallerForm() {

        // Fetch installer data from API
        fetch('https://dev.yarbo.ai/backend/v2/install/installer/me', {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer ' + authorization
            }
        })
        .then(response => {
            if (response.ok) {
                return response.json();
            }
        })
        .then(data => {
            console.log('Installer data:', data);
            if (data && data.code === 0 && data.data) {
                populateFormWithData(data.data);
            }
        })
        .catch(error => {
            console.error('Error fetching installer data:', error);
        });
    }

    const uploadedFiles = [];

    // This function populates the form fields with the retrieved data
    function populateFormWithData(data) {
        // Populate text inputs
        document.getElementById('installer_first_name').value = data.first_name || '';
        document.getElementById('installer_last_name').value = data.last_name || '';
        document.getElementById('installer_address_line_1').value = data.address_line_1 || '';
        document.getElementById('installer_address_line_2').value = data.address_line_2 || '';
        document.getElementById('installer_city_or_town').value = data.city_or_town || '';
        document.getElementById('installer_state_or_province').value = data.state_or_province || '';
        document.getElementById('installer_zip_or_postal_code').value = data.zip_or_postal_code || '';
        document.getElementById('installer_facebook_account').value = data.facebook_account || '';
        document.getElementById('installer_comments').value = data.comments || '';
        document.getElementById('installer_public_name').value = data.public_name || '';
        document.getElementById('installer_public_comments').value = data.public_comments || '';

        // Set country in select
        if (data.country) {
            countrySelectRoot.render(
                <Select
                    defaultValue={data.country}
                    key={data.country}
                    options={Object.keys(countries).map((key) => ({
