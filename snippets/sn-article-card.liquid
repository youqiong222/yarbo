{%- assign _pc_img = pc_image | default: article.metafields.custom.cover_bac | default: article.image -%}
{%- assign _h5_img = h5_image | default: article.metafields.custom.cover_bac | default: article.image -%}
<a
  href='{{ article.url }}'
  class='group flex h-full flex-row-reverse items-center bg-[#f2f2f2] no-underline md:flex-col'
>
  {% render 'media-element',
    media_type: 'image',
    class: 'md:w-full w-[40%] overflow-hidden md:aspect-3/2 aspect-1/1',
    media_class: 'w-full h-full object-cover flex transition-transform duration-300 group-hover:scale-110',
    pc_image: _pc_img,
    h5_image: _h5_img
  %}
  <div class='flex-1 p-20 md:p-24'>
    {% if article.tags.size > 0 %}
      <div class='mb-8 flex flex-wrap text-[12px] text-[#515355]'>
        {% for tag in article.tags %}
          <span>
            {{ tag }}
            {% unless forloop.last %},{% endunless %}
          </span>
        {% endfor %}
      </div>
    {% endif %}
    <h4 class='line-clamp-3 text-[18px] leading-[1.1] text-[#25282a] uppercase hover:underline md:line-clamp-2 md:text-[20px]'>
      {{ article.title }}
    </h4>
    <div class='hidden-phone mt-16 flex items-center gap-9 text-[14px] leading-[1.3] text-[#25282a]'>
      {{ 'blogs.article.read_more' | t }}
      <svg
        class='transition-transform duration-300 group-hover:translate-x-6'
        width='6'
        height='10'
        viewBox='0 0 6 10'
        fill='none'
        xmlns='http://www.w3.org/2000/svg'
      >
        <path d="M0.919597 0.919434L5.00293 5.00277L0.919596 9.0861" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
      </svg>
    </div>
  </div>
</a>
