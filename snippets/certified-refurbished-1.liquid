          window.addEventListener('scroll', function () {
            const element = document.querySelector('#yb-banner-swiper-mobile-cta-container__175688183261798e9aa1');
            if (!element) return;
            const scrollY = window.scrollY || document.documentElement.scrollTop;
            const mobileImage = document.querySelector('#yb-banner-swiper__175688183261798e9aa1 #yb-banner-mobile-image');
            const rect = mobileImage.getBoundingClientRect(); // 获取视口内坐标
            const topFromPage = rect.top; // 最终距离页面顶部的值
            if (rect.bottom <= 0) {
