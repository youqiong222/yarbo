                         * @param {HTMLElement} container - 容器元素
                         */
                        function calculateMonthlyPayment(container) {
                          if (!container) return;
  
                          // 先设置颜色
                          setupColor(container);
  
                          // 从 data-amount 属性获取金额（单位：美分）
                          // 优先从容器本身获取，如果没有则从父元素获取
                          let amount = container.getAttribute('data-amount');
  
                          if (!amount) {
                            const parent = container.parentElement;
                            if (parent) {
                              amount = parent.getAttribute('data-amount');
                            }
                          }
  
                          // 如果没有金额，隐藏容器
                          if (!amount) {
                            container.style.display = 'none';
                            return;
                          }
  
                          // 显示容器
                          container.style.display = '';
  
                          // 转换为数字
                          amount = Number(amount);
  
                          // 验证金额有效性
                          if (!amount || isNaN(amount) || amount <= 0) {
                            container.style.display = 'none';
                            return;
                          }
  
                          // 将美分转换为美元，然后除以6个月（0% APR，6期）
                          const totalPrice = amount / 100;
