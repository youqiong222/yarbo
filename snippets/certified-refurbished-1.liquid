                          // 优先从容器本身获取，如果没有则从父元素获取
                          let textColor = container.getAttribute('data-color');
  
                          if (!textColor || textColor === '') {
                            const parent = container.parentElement;
                            if (parent && parent.hasAttribute('data-color')) {
                              textColor = parent.getAttribute('data-color');
