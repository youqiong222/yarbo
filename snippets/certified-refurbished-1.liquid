          // 锚点点击事件处理
          function initAnchorLinks() {
            document
              .querySelectorAll('#yb-banner-swiper__175688183261798e9aa1 .yb-banner-swiper-anchor-link')
              .forEach((link) => {
                link.addEventListener('click', function (e) {
                  e.preventDefault();
                  const anchorId = this.getAttribute('data-anchor-id');
                  if (!anchorId) return;
  
                  const anchorElement = document.getElementById(`shopify-section-${anchorId}`);
                  if (anchorElement) {
                    window.scrollTo({
                      top: anchorElement.offsetTop - 120,
                      behavior: 'smooth',
