    function updateTabsIndicator1764578921657450c84e() {
      const container = document.querySelector('#shopify-section-1764578921657450c84e');
      if (!container) return;
      const tabsList = container.querySelector('.Yarbo-Product-tabs-list');
      const activeTab = container.querySelector('.Yarbo-Product-tab-item.active');
      if (!tabsList || !activeTab) return;
      const bulletWidth = activeTab.offsetWidth;
      const bulletLeft = activeTab.offsetLeft;
      tabsList.style.setProperty('--slide-width', `${bulletWidth}px`);
      tabsList.style.setProperty('--slide-left', `${bulletLeft}px`);
    }
    function initProductTabs1764578921657450c84e() {
      const container = document.querySelector('#shopify-section-1764578921657450c84e');
      if (!container) return;
      const tabItems = container.querySelectorAll('.Yarbo-Product-tab-item');
      const contentCards = container.querySelectorAll('.Yarbo-Product-tabs-display-one');
      tabItems.forEach((tab, index) => {
        tab.addEventListener('click', () => {
          tabItems.forEach((t) => t.classList.remove('active'));
          contentCards.forEach((c) => c.classList.remove('active'));
          tab.classList.add('active');
          if (contentCards[index]) {
            contentCards[index].classList.add('active');
            updateTabsIndicator1764578921657450c84e();
          }
        });
      });
      updateTabsIndicator1764578921657450c84e();
      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(updateTabsIndicator1764578921657450c84e, 150);
      });
    }
    initProductTabs1764578921657450c84e();
