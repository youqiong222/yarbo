      tabsList.style.setProperty('--slide-width', `${bulletWidth}px`);
      tabsList.style.setProperty('--slide-left', `${bulletLeft}px`);
    }

    // 初始化 Tabs 切换功能
    function initProductTabs1764578921657450c84e() {
      const container = document.querySelector('#shopify-section-1764578921657450c84e');
      if (!container) return;

      const tabItems = container.querySelectorAll('.Yarbo-Product-tab-item');
      const contentCards = container.querySelectorAll('.Yarbo-Product-tabs-display-one');

      // 为每个 tab 添加点击事件
      tabItems.forEach((tab, index) => {
        tab.addEventListener('click', () => {
          // 移除所有 active 状态
          tabItems.forEach((t) => t.classList.remove('active'));
          contentCards.forEach((c) => c.classList.remove('active'));

          // 添加当前 active 状态
          tab.classList.add('active');
