    /* Tabs 容器样式 - 参考 yb-image-text-swiper */
    .Yarbo-Product-tabs-container {
      width: 100%;
      display: flex;
      justify-content: center;
      margin-bottom: 32px;
      margin-top: 32px;
    }

    .Yarbo-Product-tabs-list {
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 24px;
      background-color: #ffffff;
      padding: 0;
      position: relative;
      gap: 0;
    }

    /* 滑动高亮背景 */
    .Yarbo-Product-tabs-list::before {
      content: "";
      position: absolute;
      height: 48px;
      background: #fedb1e;
      border-radius: 24px;
      transition: all 0.3s ease;
      z-index: 0;
      width: var(--slide-width, 0);
      transform: translateX(var(--slide-left, 0));
      left: 0;
      top: 0;
    }

    .Yarbo-Product-tab-item {
      width: auto;
      height: 48px;
      padding-left: 40px;
      padding-right: 40px;
      background-color: transparent;
      font-size: 16px;
      font-weight: 700;
      border-radius: 24px;
      display: flex;
      align-items: center;
      margin: 0 !important;
      white-space: nowrap;
      cursor: pointer;
      position: relative;
