  <script>
    // 更新 tabs 高亮指示器位置
    function updateTabsIndicator1764578921657450c84e() {
      const container = document.querySelector('#shopify-section-1764578921657450c84e');
      if (!container) return;

      const tabsList = container.querySelector('.Yarbo-Product-tabs-list');
      const activeTab = container.querySelector('.Yarbo-Product-tab-item.active');

      if (!tabsList || !activeTab) return;

      const bulletWidth = activeTab.offsetWidth;
