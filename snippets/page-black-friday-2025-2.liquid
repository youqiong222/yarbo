                    for 6 months at 0% APR with Splitit.</span
                  >
                </span>
              </div>
              <style>
                .stage-splitit-snipp__container {
                  width: 100%;
                  display: inline-flex;
                  align-items: center;
                  justify-content: flex-start;
                  font-size: 0.875rem;
                  line-height: 1.5;
                  /* 使用 CSS 变量，默认值为 #666 */
                  color: var(--splitit-text-color, #666);
                }

                .stage-splitit-snipp__text {
                  flex-wrap: wrap;
                  gap: 0.25rem;
                  color: inherit;
                }

                .stage-splitit-snipp__monthly-amount {
                  font-weight: 700;
                  font-size: 1.5em;
                  /* 月付金额颜色，默认比文字颜色深一些 */
                  color: var(--splitit-amount-color, var(--splitit-text-color, #333));
                }

                .stage-splitit-snipp__apr-text {
                  font-weight: 400;
                  font-size: 1em;
                  color: inherit;
                }

                /* 移动端适配 */
                @media (max-width: 767px) {
                  .stage-splitit-snipp__container {
                    font-size: 0.75rem;
                  }
                }
              </style>
              <script>
                (function () {
                  'use strict';

                  /**
                   * 设置颜色配置
                   * @param {HTMLElement} container - 容器元素
                   */
                  function setupColor(container) {
                    if (!container) return;

                    // 从 data-color 属性获取颜色
                    // 优先从容器本身获取，如果没有则从父元素获取
                    let textColor = container.getAttribute('data-color');

                    if (!textColor || textColor === '') {
                      const parent = container.parentElement;
                      if (parent && parent.hasAttribute('data-color')) {
                        textColor = parent.getAttribute('data-color');
                      }
                    }

                    // 如果设置了颜色，应用到 CSS 变量
                    if (textColor && textColor !== '') {
                      container.style.setProperty('--splitit-text-color', textColor);
                    }

                    // 从 data-amount-color 属性获取月付金额颜色（可选）
                    let amountColor = container.getAttribute('data-amount-color');

                    if (!amountColor || amountColor === '') {
                      const parent = container.parentElement;
                      if (parent && parent.hasAttribute('data-amount-color')) {
                        amountColor = parent.getAttribute('data-amount-color');
                      }
                    }

                    // 如果设置了月付金额颜色，应用到 CSS 变量
                    if (amountColor && amountColor !== '') {
                      container.style.setProperty('--splitit-amount-color', amountColor);
                    }
                  }

                  /**
                   * 计算月付金额并更新显示
                   * @param {HTMLElement} container - 容器元素
                   */
                  function calculateMonthlyPayment(container) {
                    if (!container) return;

                    // 先设置颜色
                    setupColor(container);

                    // 从 data-amount 属性获取金额（单位：美分）
                    // 优先从容器本身获取，如果没有则从父元素获取
                    let amount = container.getAttribute('data-amount');

                    if (!amount) {
                      const parent = container.parentElement;
                      if (parent) {
                        amount = parent.getAttribute('data-amount');
                      }
                    }

                    // 如果没有金额，隐藏容器
                    if (!amount) {
                      container.style.display = 'none';
                      return;
                    }

                    // 显示容器
                    container.style.display = '';

                    // 转换为数字
                    amount = Number(amount);

                    // 验证金额有效性
                    if (!amount || isNaN(amount) || amount <= 0) {
                      container.style.display = 'none';
                      return;
                    }

                    // 将美分转换为美元，然后除以6个月（0% APR，6期）
                    const totalPrice = amount / 100;
                    const monthlyPayment = totalPrice / 6;

                    // 格式化金额，不保留小数（四舍五入到整数），并添加千分位分隔符
                    const roundedMonthly = Math.round(monthlyPayment);
                    const formattedMonthly = roundedMonthly.toLocaleString('en-US');

                    // 更新显示的每月金额
                    const monthlyElement = container.querySelector('.stage-splitit-snipp__monthly-amount');
                    if (monthlyElement) {
                      monthlyElement.textContent = '$' + formattedMonthly + '/mo';
                    }
                  }

                  /**
                   * 初始化所有容器
                   */
                  function initAllContainers() {
                    const containers = document.querySelectorAll('.stage-splitit-snipp__container');
                    containers.forEach((container) => {
                      setupColor(container);
                      calculateMonthlyPayment(container);
                    });
                  }

                  /**
                   * 监听 data-amount 和 data-color 属性变化
                   */
                  function setupMutationObserver() {
                    const observer = new MutationObserver(function (mutations) {
                      mutations.forEach(function (mutation) {
                        const target = mutation.target;
                        if (target.classList && target.classList.contains('stage-splitit-snipp__container')) {
                          if (mutation.attributeName === 'data-amount') {
                            calculateMonthlyPayment(target);
                          } else if (
                            mutation.attributeName === 'data-color' ||
                            mutation.attributeName === 'data-amount-color'
                          ) {
                            setupColor(target);
                          }
                        }
                      });
                    });

                    // 观察所有容器
                    document.querySelectorAll('.stage-splitit-snipp__container').forEach((container) => {
                      observer.observe(container, {
                        attributes: true,
                        attributeFilter: ['data-amount', 'data-color', 'data-amount-color'],
                      });
                    });
                  }

                  // 页面加载完成后初始化
                  if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', function () {
                      initAllContainers();
                      setupMutationObserver();
                    });
                  } else {
                    initAllContainers();
                    setupMutationObserver();
                  }

                  // 暴露更新函数，方便外部调用
                  window.updateStageSplititSnipp = function (selector, amount) {
                    const container = typeof selector === 'string' ? document.querySelector(selector) : selector;

                    if (container && container.classList.contains('stage-splitit-snipp__container')) {
                      container.setAttribute('data-amount', amount);
                      calculateMonthlyPayment(container);
                    }
                  };
                })();
              </script>
