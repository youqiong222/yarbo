<style>
  /* JS dynamically injects this element — cannot use HTML class */
  .yb-subscribe-klaviyo-desc {
    font-size: 14px;
    margin: 0 0 12px 0;
    line-height: 1.4;
  }

  /* JS toggles yb-subscribe-klaviyo-checkbox-checked — must stay in CSS */
  .yb-subscribe-klaviyo-checkbox-wrapper::before {
    content: '';
    position: absolute;
    width: 14px;
    height: 14px;
    background-image: url('https://cdn.shopify.com/s/files/1/0604/5394/5441/files/subscribe-unchecked2.svg?v=1778204404');
    background-size: contain;
    background-repeat: no-repeat;
    left: 0;
    top: 0;
  }
  .yb-subscribe-klaviyo-checkbox-wrapper.yb-subscribe-klaviyo-checkbox-checked::before {
    background-image: url('https://cdn.shopify.com/s/files/1/0604/5394/5441/files/checkbox-checked_1.svg?v=1778204627');
  }

  /* subscribe-popup recheck state (toggled by JS) */
  .yb-subscribe-klaviyo .subscribe-popup-container-recheck.subscribe-popup-container-recheck-show {
    display: flex;
  }

  /* loading state on suffix button */
  .yb-subscribe-klaviyo-suffix.is-loading {
    pointer-events: none;
    opacity: 0.7;
  }
</style>
<script
  src='{{ 'sn-subscribe-klaviyo.js' | asset_url }}'
  defer
></script>

{% assign country = null %}
{% if localization.country.iso_code == 'AU' %}
  {% assign country = 'AU' %}
{% endif %}
{%- assign _popup_id = popup_id | default: section.id | prepend: 'sub-popup-' -%}

<yb-subscribe-klaviyo
  class='yb-subscribe-klaviyo flex flex-col {{ class }}'
  data-email-only='true'
  data-popup-id='{{ _popup_id }}'
  {% if popup_to_body %}
    data-popup-to-body='true'
  {% endif %}
  {% if step2 %}
    data-step2='{{ step2 }}'
  {% endif %}
  {% if step3 %}
    data-step3='{{ step3 }}'
  {% endif %}
  {% if step2Placeholder %}
    data-step2Placeholder='{{ step2Placeholder }}'
  {% endif %}
  {% if step3Placeholder %}
    data-step3Placeholder='{{ step3Placeholder }}'
  {% endif %}
  {% if country == 'AU' %}
    data-country='{{ country }}'
  {% endif %}
>
  <!-- Input row -->
  <div
    class='
      yb-subscribe-klaviyo-input-wrapper yb-subscribe-klaviyo-input-email subscribe-tel-input
      relative flex h-52 w-full items-center border border-[#e5e5e5] bg-white
    '
    data-step='email'
  >
    <div class='yb-subscribe-klaviyo-prefix rounded-l-16 flex w-38 items-center justify-center bg-white min-[680px]:w-37'>
      <svg
        width='21'
        height='20'
        viewBox='0 0 21 20'
        fill='none'
        xmlns='http://www.w3.org/2000/svg'
      >
        <path d="M3 2.25C2.30964 2.25 1.75 2.80964 1.75 3.5V16.5C1.75 17.1904 2.30964 17.75 3 17.75H18C18.6904 17.75 19.25 17.1904 19.25 16.5V3.5C19.25 2.80964 18.6904 2.25 18 2.25H3ZM3.25 6.89965V3.75H17.75V6.9002L17.7114 6.80762L10.4999 9.81242L3.28835 6.80762L3.25 6.89965ZM3.25 8.41664L9.97104 11.2171C10.3095 11.3581 10.6903 11.3581 11.0287 11.2171L17.75 8.41654V16.25H3.25V8.41664Z" fill="#ACACAC"/>
      </svg>
    </div>

    <input
      class='yb-subscribe-klaviyo-input min-w-0 flex-1 self-stretch rounded-none border-0 bg-white text-[#25282A] outline-none'
      placeholder='{% if step1Placeholder %}{{ step1Placeholder }}{% else %}Email{% endif %}'
    >

    <div
      class='yb-subscribe-klaviyo-suffix mr-5 flex h-40 min-w-120 cursor-pointer items-center justify-center bg-[#25282A] px-24 text-[14px] leading-[1.3] text-white no-underline transition-colors duration-300 hover:bg-[#FEDB1E] hover:text-[#25282A] md:px-32'
      data-email-type='{{ emailType }}'
      {% if klaviyoListId %}
        data-klaviyo-list-id='{{ klaviyoListId }}'
      {% endif %}
      {% if emailType == 'footer' %}
        data-dataLayer='footer_EmailSubscribe' data-btn-name='footer_EmailSubscribe'
      {% endif %}
    >
      <span class='yb-subscribe-klaviyo-btn-text'>
        {% if step1 %}{{ step1 }}{% else %}Subscribe{% endif %}
      </span>
    </div>

    {% render 'subscribe-klaviyo-country-list' %}

    <div class='yb-subscribe-klaviyo-errors absolute top-full left-0 text-[12px] text-[rgb(227,46,33)]'></div>
  </div>

  <!-- Policy -->
  <div class='yb-subscribe-klaviyo-policy mt-16 flex items-start justify-start'>
    <div class='yb-subscribe-klaviyo-checkbox-wrapper yb-subscribe-klaviyo-checkbox-checked relative mr-8 inline-flex cursor-pointer'>
      <input
        checked
        class='yb-subscribe-klaviyo-checkbox m-0 h-14 w-14 opacity-0'
        type='checkbox'
        name='subscribe'
      >
    </div>
    <span class='text-[12px] font-normal {{ policy_class }}'>
      I understand the&nbsp;
      <a
        class='subscribe-klaviyo-link underline'
        href='/pages/legal-privarcy-policy'
        target='_blank'
      >
        Privacy Policy
      </a>
      &nbsp;and agree to receive personalized messages from Yarbo by email or SMS.
    </span>
  </div>

  {% render 'subscribe-popup', popup_id: _popup_id %}
</yb-subscribe-klaviyo>
