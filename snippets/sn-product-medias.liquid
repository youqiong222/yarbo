<div class='absolute top-24 left-24 z-2 flex'>
  {%- if product.metafields.custom.tag != blank -%}
    <span class='flex h-22 items-center justify-center px-12 py-4 text-[14px] leading-[1.3] font-bold {% if card_product.metafields.custom.tag_style %} bg-[#FEDB1E] text-[#25282a] {% else %} bg-[#25282a] text-white {% endif %}'>
      {{ product.metafields.custom.tag }}
    </span>
  {%- endif -%}
  {% unless product.selected_or_first_available_variant.available %}
    <span class='bg-[#515355] px-12 py-4 text-[14px] font-bold text-[#E6E6E6]'>
      {{ 'products.product.sold_out' | t }}
    </span>
  {% endunless %}
</div>
<div
  class='absolute top-20 right-20 z-2 cursor-pointer md:top-24 md:right-24'
  onclick="(() => { const swiper = this.closest('product-media-swiper')?.querySelector('.swiper')?.swiper; window.dispatchEvent(new CustomEvent('open-product-zoom', { detail: { index: swiper ? swiper.realIndex : 0 } })); })()"
>
  <svg
    width='40'
    height='40'
    viewBox='0 0 40 40'
    fill='none'
    xmlns='http://www.w3.org/2000/svg'
  >
    <foreignObject x="-5" y="-5" width="50" height="50">
      <div xmlns="http://www.w3.org/1999/xhtml"
        style="backdrop-filter:blur(2.5px);clip-path:url(#bgblur_0_9036_98927_clip_path);height:100%;width:100%">
      </div>
    </foreignObject>
    <g data-figma-bg-blur-radius="5">
      <rect x="0.5" y="0.5" width="39" height="39" rx="19.5" fill="white" />
      <rect x="0.5" y="0.5" width="39" height="39" rx="19.5" stroke="#CCCCCC" />
      <path
        d="M21.8394 13.3333H26.6673M26.6673 13.3333V18.1609M26.6673 13.3333L21.0348 18.9655M18.1619 26.6667H13.334M13.334 26.6667V21.8391M13.334 26.6667L18.9665 21.0345"
        stroke="#25282A" stroke-width="1.3" stroke-linecap="square" />
    </g>
    <defs>
      <clipPath id="bgblur_0_9036_98927_clip_path" transform="translate(5 5)">
        <rect x="0.5" y="0.5" width="39" height="39" rx="19.5" />
      </clipPath>
    </defs>
  </svg>
</div>

<product-media-swiper class='block aspect-340/430 md:aspect-auto md:h-full md:w-full'>
  <div class='swiper h-full w-full [overflow:unset] '>
    <div class='swiper-wrapper'>
      {%- for media in product.media -%}
        <div
          class='swiper-slide flex cursor-pointer items-center justify-center opacity-50 [&_img]:w-full [&_img]:border-0 [&_img]:bg-transparent [&_img]:object-contain [&.swiper-slide-active]:opacity-100'
        >
          {% render 'product-media', media: media, loop: true, variant_image: true %}
        </div>
      {%- endfor -%}
    </div>
    <div
      class='pagination absolute right-0 bottom-20 left-0 z-10 flex items-center justify-center gap-4 md:hidden'
    ></div>
    <div class='absolute bottom-24 left-24 hidden md:block'>
      <div class='gap-8 md:flex'>
        <div class='swiper-button-prev  static m-0 flex h-48 w-48 items-center justify-center rounded-full border border-[#cccccc] bg-white backdrop-blur-[5px] transition-colors duration-300 after:hidden [&.swiper-button-disabled]:bg-[#ccc] [&.swiper-button-disabled]:opacity-100 [&.swiper-button-disabled_path]:stroke-[#A6A6A6] [&:hover]:bg-[#ccc]'>
          <svg
            width='8'
            height='14'
            viewBox='0 0 8 14'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d="M6.75325 12.5859L0.919923 6.7526L6.75325 0.91927" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
          </svg>
        </div>
        <div class='swiper-button-next static m-0 flex h-48 w-48 items-center justify-center rounded-full border border-[#cccccc] bg-white backdrop-blur-[5px] transition-colors duration-300 after:hidden [&.swiper-button-disabled]:bg-[#ccc] [&.swiper-button-disabled]:opacity-100 [&.swiper-button-disabled_path]:stroke-[#A6A6A6] [&:hover]:bg-[#ccc]'>
          <svg
            width='8'
            height='14'
            viewBox='0 0 8 14'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d="M0.91862 0.919434L6.75195 6.75277L0.91862 12.5861" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</product-media-swiper>
