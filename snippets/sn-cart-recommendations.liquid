{% comment %}
  Renders a "Recommended for you" swiper in the cart drawer.
  Based on the first cart item's product ID, fetches Shopify product recommendations
  via Section Rendering API (sections/cart-recommendations.liquid).

  Usage:
  {% render 'sn-cart-recommendations' %}
{% endcomment %}

{% if cart.items.size > 0 %}
  {% assign first_product_id = cart.items.first.product_id %}

  <cart-recommendations
    class='block'
    data-product-id='{{ first_product_id }}'
    data-recommendations-url='{{ routes.product_recommendations_url }}'
  >
    {%- comment -%} Skeleton loading — replaced by section rendering content {%- endcomment -%}
    <div class='cart-recs__header flex items-center justify-between py-12'>
      <h3 class='text-[13px] leading-[1.1] uppercase md:text-[22px]'>
        {{ 'sections.cart.recommended_products' | t }}
      </h3>
      <div class='flex items-center justify-end gap-8 '>
        <div class='swiper-button-prev relative left-0 mt-0 flex h-40 w-40 items-center justify-center rounded-[50%] border border-[#cccccc] after:hidden hover:bg-[#ccc] [&.swiper-button-disabled]:bg-[#ccc]'>
          <svg
            width='8'
            height='14'
            viewBox='0 0 8 14'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d="M6.75325 12.5859L0.919923 6.7526L6.75325 0.91927" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
          </svg>
        </div>

        <div class='swiper-button-next relative right-0 mt-0 flex h-40 w-40 items-center justify-center rounded-[50%] border border-[#cccccc] after:hidden hover:bg-[#ccc] [&.swiper-button-disabled]:bg-[#ccc]'>
          <svg
            width='8'
            height='14'
            viewBox='0 0 8 14'
            fill='none'
            xmlns='http://www.w3.org/2000/svg'
          >
            <path d="M0.91862 0.919434L6.75195 6.75277L0.91862 12.5861" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
          </svg>
        </div>
      </div>
    </div>
    <div class='swiper cart-recs__swiper [overflow:unset]'>
      <div class='swiper-wrapper cart-recs__list'>
        <div class='swiper-slide'>
          <div class='cart-recs__skeleton-card flex items-center bg-white p-8'>
            <div
              class='h-92 w-92 shrink-0 animate-pulse rounded bg-[#f2f2f2]'
            ></div>
            <div class='flex flex-1 flex-col gap-8 py-8 pl-16'>
              <div class='h-14 w-3/4 animate-pulse rounded bg-[#f2f2f2]'></div>
              <div class='h-14 w-1/2 animate-pulse rounded bg-[#f2f2f2]'></div>
              <div class='h-36 w-full animate-pulse rounded bg-[#f2f2f2]'></div>
            </div>
          </div>
        </div>
        <div class='swiper-slide'>
          <div class='cart-recs__skeleton-card flex items-center bg-white p-8'>
            <div
              class='h-92 w-92 shrink-0 animate-pulse rounded bg-[#f2f2f2]'
            ></div>
            <div class='flex flex-1 flex-col gap-8 py-8 pl-16'>
              <div class='h-14 w-3/4 animate-pulse rounded bg-[#f2f2f2]'></div>
              <div class='h-14 w-1/2 animate-pulse rounded bg-[#f2f2f2]'></div>
              <div class='h-36 w-full animate-pulse rounded bg-[#f2f2f2]'></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </cart-recommendations>
{% endif %}
