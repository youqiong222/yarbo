  <script>
    const faq_triggers = document.querySelectorAll('.faq-of-competencies__trigger');
    let currentFaqActiveIndex = 0;

    function activateFaqModule(index) {
      // Close all drawers
      document.querySelectorAll('.faq-of-competencies__drawer').forEach((d) => {
        d.classList.remove('active');
      });
      document.querySelectorAll('.faq-of-competencies__trigger').forEach((t) => {
        t.classList.remove('active');
      });

      // Activate the selected module
      const selectedTrigger = faq_triggers[index];
      const selectedDrawer = selectedTrigger.nextElementSibling;

      selectedDrawer.classList.add('active');
      selectedTrigger.classList.add('active');

      currentFaqActiveIndex = index;
    }

    faq_triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', function () {
        const isCurrentlyActive = this.classList.contains('active');

        // If the clicked module is not the currently active one, activate it
        // If it's currently active, close it
        if (!isCurrentlyActive) {
          activateFaqModule(index);
        } else {
          // Close the currently active drawer
          document.querySelectorAll('.faq-of-competencies__drawer').forEach((d) => {
            d.classList.remove('active');
          });
          document.querySelectorAll('.faq-of-competencies__trigger').forEach((t) => {
            t.classList.remove('active');
          });
          currentFaqActiveIndex = -1;
        }
      });
    });
  </script>
