  <script>
    const faqTriggers = document.querySelectorAll('.faq-of-competencies__trigger');
    let currentFaqActiveIndex = -1;

    function activateFaqModule(index) {
      document.querySelectorAll('.faq-of-competencies__drawer').forEach((d) => d.classList.remove('active'));
      document.querySelectorAll('.faq-of-competencies__trigger').forEach((t) => t.classList.remove('active'));

      const selectedTrigger = faqTriggers[index];
      const selectedDrawer = selectedTrigger.nextElementSibling;

      selectedDrawer.classList.add('active');
      selectedTrigger.classList.add('active');

      currentFaqActiveIndex = index;
    }

    faqTriggers.forEach((trigger, index) => {
      trigger.addEventListener('click', function () {
        const isCurrentlyActive = this.classList.contains('active');

        if (!isCurrentlyActive) {
          activateFaqModule(index);
        } else {
          document.querySelectorAll('.faq-of-competencies__drawer').forEach((d) => d.classList.remove('active'));
          document.querySelectorAll('.faq-of-competencies__trigger').forEach((t) => t.classList.remove('active'));
          currentFaqActiveIndex = -1;
        }
      });
    });
  </script>
