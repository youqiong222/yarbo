{% comment %}
  Renders a header drawer menu for mobile and desktop.

  Usage:
  {% render 'header-drawer' %}
{% endcomment %}
<style>
  .menu-drawer-container .drawer__content {
    height: calc(100% - 110px);
  }
</style>
<header-drawer
  data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}"
>
  <details
    id="Details-menu-drawer-container"
    class="menu-drawer-container"
  >
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="Menu"
    >
      <span class="h-24 w-24">
        <svg
          class="icon icon-hamburger"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path d="M20 18H4M20 12H4M20 6H4" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
        </svg>
        <svg
          class="icon icon-close"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path d="M18 6L6 18M18 18L6 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="square"/>
        </svg>
      </span>
    </summary>
    <div
      id="menu-drawer"
      class="gradient menu-drawer motion-reduce text-[#25282a] color-{{ section.settings.menu_color_scheme }}"
    >
      <div class="drawer__content overflow-scroll">
        <ul
          class="mobile-nav list--unstyled list-none pl-0"
          role="list"
        >
          {%- for link in menu.links -%}
            {%- assign link_title_downcase = forloop.index -%}
            {%- assign mega_menu_block = '' -%}

            {%- for block in section.blocks -%}
              {%- assign menu_item_downcase = block.settings.column | abs -%}
              {%- case block.type -%}
                {%- when 'mega_menu' -%}
                  {%- if menu_item_downcase == link_title_downcase -%}
                    {%- assign mega_menu_block = block -%}
                    {%- break -%}
                  {%- endif -%}
              {%- endcase -%}
            {%- endfor -%}
            {% assign product_limit = mega_menu_block.settings.product_limit %}
            <li class="accordion  border-[#f2f2f2] not-first:border-t">
              {%- if link.links.size > 0 or mega_menu_block != blank -%}
                <details
                  id="Details-{{ block.id }}-{{ section.id }}"
                >
                  <summary id="Summary-{{ block.id }}-{{ section.id }}">
                    <h3 class="accordion__title inline-richtext h4 px-16 py-20 text-[26px]/[1.1] uppercase">
                      {{- link.title -}}
                    </h3>
                    {{- 'icon-caret.svg' | inline_asset_content -}}
                  </summary>
                  <div
                    class="accordion__content flex flex-col gap-12 border-t border-[#f2f2f2]"
                    id="CollapsibleAccordion-{{ block.id }}-{{ section.id }}"
                    role="region"
                    aria-labelledby="Summary-{{ block.id }}-{{ section.id }}"
                  >
                    {%- if link.links.size > 0 -%}
                      {% assign has_child_links = false %}
                      {% for sub_link in link.links %}
                        {% if sub_link.links.size > 0 %}
                          {% assign has_child_links = true %}
                          {% break %}
                        {% endif %}
                      {% endfor %}
                      <ul
                        class="
                          mobile-nav list--unstyled list-none  pl-0 {% if mega_menu_block == blank or mega_menu_block.settings.dropdown_style
                          == '2' or has_child_links == false %}  py-20 pl-16 pr-16 bg-[#f2f2f2] flex flex-col gap-12 {% endif %}
                        "
                        role="list"
                      >
                        {%- for sub_link in link.links -%}
                          {% if mega_menu_block != blank and sub_link.links.size < 1 %}
                            <div class="flex flex-col gap-12 not-first:mt-4">
                              <div class=" flex items-center gap-8 text-[14px]">
                                <span class="font-bold text-[#515355]">
                                  {{ sub_link.title }}
                                </span>
                                <a
                                  href="{{ sub_link.url }}?p=t"
                                  class="flex items-center gap-7"
                                >
                                  {{ 'button.view_all' | t }}
                                  <svg
                                    width="9"
                                    height="9"
                                    viewBox="0 0 9 9"
                                  >
                                    <path d="M1.77014 0.657715L7.51885 0.725021M7.51885 0.725021L7.58528 6.39198M7.51885 0.725021L0.919189 7.32468"
                                      stroke="#25282A" stroke-width="1.3"/>
                                  </svg>
                                </a>
                              </div>
                              {% if sub_link.url contains '/collections/' %}
                                {% assign handle = sub_link.url | split: '/collections/' | last | split: '/' | first %}

                                {% assign collection = collections[handle] %}
                                {% if collection and collection.products_count > 0 %}
                                  <div class=" grid grid-cols-1 gap-8">
                                    {% for product in collection.products limit: product_limit %}
                                      <a
                                        href="{{ product.url }}"
                                        class="group flex items-center gap-16 bg-white p-8"
                                      >
                                        {% render 'media-element',
                                          media_type: 'image',
                                          class: 'max-w-86 flex h-fit flex relative ',
                                          media_class: 'w-full h-auto',
                                          pc_image: product.featured_image
                                        %}

                                        <div class=" theme-title text-[17px]/[1.1] font-bold text-black uppercase">
                                          <span class="text-[#ddba00]">
                                            {{- product.metafields.custom.nav_tag -}}
                                          </span>
                                          {{ product.title }}
                                        </div>
                                      </a>
                                    {% endfor %}
                                  </div>
                                {% endif %}
                              {% endif %}
                            </div>
                          {% else %}
                            <li
                              class="mobile-nav__item {% if mega_menu_block.settings.dropdown_style == '2' %} flex flex-col gap-32 {% endif %}"
                              data-level="2"
                            >
                              {%- if sub_link.links.size > 0 -%}
                                {% if mega_menu_block.settings.dropdown_style == '2' %}
                                  <div
                                    class="flex flex-col gap-12"
                                  >
                                    <a
                                      href="{{ sub_link.url }}?p=t"
                                      class="border-b border-[#e6e6e6] pb-12 text-[13px]/[1.3] font-bold text-[#515355]"
                                    >
                                      {{ sub_link.title }}
                                    </a>
                                    <ul class="grid list-none gap-12 pl-0">
                                      {% for sub_sub_link in sub_link.links %}
                                        <li class="flex flex-col">
                                          <a
                                            href="{{ sub_sub_link.url }}?p=t"
                                            class="text-[13px]/[1.3]"
                                          >
                                            {{ sub_sub_link.title }}
                                          </a>
                                        </li>
                                      {% endfor %}
                                    </ul>
                                  </div>
                                {% else %}
                                  <details
                                    id="SubDetails-{{ section.id }}-{{ forloop.parentloop.index }}-{{ forloop.index }}"
                                    class="sub-accordion open:bg-[#f2f2f2]"
                                  >
                                    <summary
                                      id="SubSummary-{{ section.id }}-{{ forloop.parentloop.index }}-{{ forloop.index }}"
                                      aria-controls="SubContent-{{ section.id }}-{{ forloop.parentloop.index }}-{{ forloop.index }}"
                                      class="mobile-nav__link flex cursor-pointer items-center justify-between p-16 text-[15px] font-bold"
                                    >
                                      {{ sub_link.title }}
                                      {{- 'icon-caret.svg' | inline_asset_content -}}
                                    </summary>

                                    <!-- 三级 -->
                                    <div
                                      id="SubContent-{{ section.id }}-{{ forloop.parentloop.index }}-{{ forloop.index }}"
                                      role="region"
                                      aria-labelledby="SubSummary-{{ section.id }}-{{ forloop.parentloop.index }}-{{ forloop.index }}"
                                    >
                                      <ul class="mobile-nav list--unstyled flex list-none flex-col gap-20 px-16 py-20 pl-16">
                                        {%- for sub_sub_link in sub_link.links -%}
                                          <li
                                            class="mobile-nav__item "
                                            data-level="3"
                                          >
                                            <div class=" flex items-center gap-8 text-[13px]/[1.3]">
                                              <span class="font-bold text-[#515355]">
                                                {{ sub_sub_link.title }}
                                              </span>
                                              <a
                                                href="{{ sub_sub_link.url }}?p=t"
                                                class="flex items-center gap-7"
                                              >
                                                {{ 'button.view_all' | t }}
                                                <svg
                                                  width="9"
                                                  height="9"
                                                  viewBox="0 0 9 9"
                                                >
                                                  <path d="M1.77014 0.657715L7.51885 0.725021M7.51885 0.725021L7.58528 6.39198M7.51885 0.725021L0.919189 7.32468"
                                                    stroke="#25282A" stroke-width="1.3"/>
                                                </svg>
                                              </a>
                                            </div>
                                            {% if sub_sub_link.url contains '/collections/' %}
                                              {% assign handle = sub_sub_link.url
                                                | split: '/collections/'
                                                | last
                                                | split: '/'
                                                | first
                                              %}

                                              {% assign collection = collections[handle] %}
                                              {% if collection and collection.products_count > 0 %}
                                                {% if mega_menu_block.settings.dropdown_style == '1' %}
                                                  {% if forloop.index == 3 %}
                                                    {%- assign show_tag = true -%}
                                                  {% else %}
                                                    {%- assign show_tag = false -%}
                                                  {% endif %}
                                                  <div class="mt-12 flex flex-col gap-12">
                                                    {% for product in collection.products limit: product_limit %}
                                                      <a
                                                        href="{{ product.url }}"
                                                        class="group flex  items-center gap-16 bg-white p-8"
                                                      >
                                                        {% render 'media-element',
                                                          media_type: 'image',
                                                          class: 'max-w-86 flex h-fit flex relative ',
                                                          media_class: 'w-full h-auto',
                                                          pc_image: product.featured_image
                                                        %}

                                                        <div class="flex flex-col gap-8">
                                                          {%- if product.metafields.custom.tag != blank and show_tag -%}
                                                            <div class="flex h-22 w-fit items-center justify-center px-12 py-3 text-[12px] leading-[1.3] font-bold {% if card_product.metafields.custom.tag_style %} bg-[#FEDB1E] text-[#25282a] {% else %} bg-[#25282a] text-white {% endif %}">
                                                              {{ product.metafields.custom.tag }}
                                                            </div>
                                                          {%- endif -%}
                                                          <div class=" theme-title  line-clamp-1 text-[17px]/[1.1] font-bold text-black uppercase">
                                                            {%- unless product.metafields.custom.tag != blank
                                                              and show_tag
                                                            -%}
                                                              <span class="text-[#ddba00]">
                                                                {{- product.metafields.custom.nav_tag -}}
                                                              </span>
                                                            {%- endunless -%}
                                                            {{- product.title }}
                                                          </div>
                                                        </div>
                                                      </a>
                                                    {% endfor %}
                                                  </div>
                                                {% endif %}
                                              {% endif -%}
                                            {% endif %}
                                          </li>
                                        {%- endfor -%}
                                      </ul>
                                    </div>
                                  </details>
                                {% endif %}
                              {%- else -%}
                                <a
                                  href="{{ sub_link.url }}?p=t"
                                  class="mobile-nav__link text-[13px]/[1.3]"
                                >
                                  {{- sub_link.title -}}
                                </a>
                              {%- endif -%}
                            </li>
                          {% endif %}
                        {%- endfor -%}
                      </ul>
                    {%- endif -%}
                    {% if mega_menu_block.settings.image_1 != blank
                      or mega_menu_block.settings.image_2 != blank
                      or mega_menu_block.settings.view_more != blank
                    %}
                      <div class="flex flex-col gap-12 px-16 py-20">
                        {% if mega_menu_block.settings.image_1 != blank or mega_menu_block.settings.image_2 != blank %}
                          <div class=" flex flex-col gap-12">
                            {% for i in (1..2) %}
                              {% assign image_key = 'image_' | append: i %}
                              {% assign link_key = 'link_' | append: i %}
                              {% assign title_key = 'title_' | append: i %}
                              {% assign calculate_key = 'enter_calculate_' | append: i %}
                              {% assign image = mega_menu_block.settings[image_key] %}
                              {% assign link = mega_menu_block.settings[link_key] %}
                              {% assign title = mega_menu_block.settings[title_key] %}
                              {% assign calculate = mega_menu_block.settings[calculate_key] %}
                              {% if image != blank %}
                                {% if calculate %}
                                  <div class="yb-savings-calculator-btn relative flex h-fit overflow-hidden">
                                {% else %}
                                  <a
                                    class="relative flex h-fit overflow-hidden"
                                    href="{{ link }}"
                                  >
                                {% endif %}

                                {% render 'media-element',
                                  media_type: 'image',
                                  class: 'w-full h-full flex',
                                  media_class: 'w-full h-full object-cover transition duration-500 group-hover:scale-105 m-0',
                                  pc_image: image,
                                  h5_image: block.settings.h5_image
                                %}

                                {% if title != blank %}
                                  <div
                                    class="
                                      theme-title absolute inset-0 flex items-center justify-between
                                      bg-[linear-gradient(360deg,rgba(0,0,0,0)_0%,rgba(0,0,0,0.5)_90%)]
                                      p-24 text-[20px]/[1.1] font-bold text-white uppercase
                                      md:p-32
                                    "
                                  >
                                    {{ title }}

                                    <svg
                                      width="14"
                                      height="14"
                                      viewBox="0 0 14 14"
                                    >
                                      <path d="M2.51931 0.758789L12.3743 0.874172M12.3743 0.874172L12.4881 10.589M12.3743 0.874172L1.06055 12.1879"
                                        stroke="white" stroke-width="1.5" stroke-linecap="square"/>
                                    </svg>
                                  </div>
                                {% endif %}
                                {% if calculate %}
                                  </div>
                                {% else %}
                                  </a>
                                {% endif %}
                              {% endif %}
                            {% endfor %}
                          </div>
                        {% endif %}
                        {%- if mega_menu_block.settings.view_more != blank -%}
                          <a
                            href="{{ link.url }}?p=t"
                            class=" flex h-39 items-center justify-center gap-7 border border-[#ccc] text-[13px]/[1.3]"
                          >
                            {{- mega_menu_block.settings.view_more -}}
                          </a>
                        {%- endif -%}
                      </div>
                    {% endif %}
                  </div>
                </details>

              {%- else -%}
                <a
                  href="{{ link.url }}?p=t"
                  class="mobile-nav__link heading flex px-16 py-20 text-[26px]/[1.1] font-bold {% if settings.heading_text_transform == 'uppercase' %}h6{% else %}h5{% endif %}"
                >
                  {{- link.title -}}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
          {% if section.settings.show_live %}
            <li class="accordion border-t border-[#f2f2f2]">
              <a
                href="{{ section.settings.live_link }}"
                class="flex items-center justify-between px-16 py-20 text-[26px]/[1.1] font-bold uppercase"
              >
                <span>{{ section.settings.live_nav }}</span>
                <span class="relative flex [&_path]:fill-[#fedb1e]!">
                  <svg
                    width="25"
                    height="25"
                    viewBox="0 0 25 25"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <g clip-path="url(#clip0_13456_21043)">
                    <circle cx="16.5" cy="7" r="1.5" fill="#FAFAFA"/>
                    <path d="M22.8559 8.32707L20.4205 9.6224V6.34357C20.4205 5.19874 19.3153 4.27002 17.953 4.27002H2.4665C1.10415 4.27002 -0.00104523 5.19874 -0.00104523 6.34357V19.1965C-0.00104523 20.3413 1.10415 21.27 2.4665 21.27H17.953C19.3153 21.27 20.4205 20.3413 20.4205 19.1965V15.8302L22.8222 17.1937C23.7483 17.7198 24.999 17.1615 24.999 16.2225V9.31754C24.9974 8.39396 23.7851 7.83312 22.8559 8.32707ZM14.5103 13.7566L8.89713 16.7409C8.06594 17.1821 6.98371 16.6804 6.98371 15.8546V9.68414C6.98371 8.84417 8.10115 8.34508 8.92928 8.81587L14.5425 12.0021C15.288 12.4253 15.2711 13.3527 14.5103 13.7566ZM16.5416 8.31807C15.8268 8.31807 15.2466 7.83055 15.2466 7.22984C15.2466 6.62913 15.8268 6.14161 16.5416 6.14161C17.2565 6.14161 17.8366 6.62913 17.8366 7.22984C17.8366 7.83055 17.2565 8.31807 16.5416 8.31807Z" fill="#FF3045"/>
                    <path d="M20.7716 9.6224V6.34357C20.7716 5.19874 19.6473 4.27002 18.263 4.27002H2.50756C1.12167 4.27002 -0.00104523 5.19874 -0.00104523 6.34357V19.1965C-0.00104523 20.3413 1.12323 21.27 2.50756 21.27H11.8537C16.8491 18.8157 20.359 14.5143 20.999 9.50405L20.7716 9.6224Z" fill="#FF4653"/>
                    <path d="M-0.00104523 6.21821V17.27C2.56758 16.9786 4.96704 16.2844 7.08868 15.271C9.86744 14.1169 11.5186 12.4275 13.1137 10.6805C14.7092 8.75025 15.6977 6.55393 15.999 4.27002H2.49929C1.11953 4.27002 -0.00104523 5.14193 -0.00104523 6.21821Z" fill="#FF5C64"/>
                    <path d="M-0.00104523 6.28737V11.27C3.88255 9.87127 7.0692 7.38433 8.99895 4.27002H2.42394C1.08576 4.27002 -0.00104523 5.17288 -0.00104523 6.28737Z" fill="#FF716E"/>
                    </g>
                    <defs>
                    <clipPath id="clip0_13456_21043">
                    <rect width="25" height="25" fill="white"/>
                    </clipPath>
                    </defs>
                  </svg>
                  <i class="Header_linePart__1tpw_ Header_line_1__TNAKB"></i>
                  <i class="Header_linePart__1tpw_ Header_line_2___ZHFt"></i>
                  <i class="Header_linePart__1tpw_ Header_line_3__5T_j9"></i>
                </span>
              </a>
            </li>
          {% endif %}
          <div class="fixed bottom-0 flex w-full flex-col gap-16 bg-white p-16">
            <div class="country_nationalFlag flex items-center gap-4 text-[15px]/[1.3]">
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12ZM21 12C20.3067 11.6403 19.5379 11.312 18.7569 11.3077H15.8077C15.1651 11.3077 14.5487 11.563 14.0943 12.0174C13.6399 12.4718 13.3846 13.0881 13.3846 13.7308C13.3846 14.3734 13.6399 14.9897 14.0943 15.4441C14.5487 15.8986 15.1651 16.1538 15.8077 16.1538C16.2667 16.1538 16.7069 16.3362 17.0315 16.6608C17.3561 16.9854 17.5385 17.4256 17.5385 17.8846V19.0892M3.69231 15.4615H6.11538C6.75802 15.4615 7.37434 15.2063 7.82876 14.7518C8.28317 14.2974 8.53846 13.6811 8.53846 13.0385V10.9615C8.53846 10.3189 8.79375 9.70259 9.24816 9.24817C9.70258 8.79376 10.3189 8.53847 10.9615 8.53847C11.6042 8.53847 12.2205 8.28318 12.6749 7.82877C13.1293 7.37435 13.3846 6.75803 13.3846 6.11539V3.09693" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"/>
              </svg>
              {{ localization.country.name }} (
              {{- localization.country.currency.iso_code -}}
              )
            </div>
            {%- if shop.customer_accounts_enabled -%}
              <a
                href="{%- if customer -%}{{ routes.account_url }}{%- else -%}/customer_authentication/login?return_to={{ "/pages/orders" | url_encode }}{%- endif -%}"
                class="flex h-39 w-full items-center  justify-center border border-[#ccc] p-10 text-[13px]/[1.3]"
              >
                {% if customer %}Account{% else %}Log In{% endif %}
              </a>
            {%- endif -%}
          </div>
        </ul>
      </div>
    </div>
    <div class="menu-overlay"></div>
  </details>
</header-drawer>
