{% if template.name == 'collection' %}
<script type="text/javascript">
  setag('event', 'view_category', {
    content: {{ collection.title | json }}
  });
</script>
{% endif %}

{% if template.name == 'index' %}
<script type="text/javascript">
  setag('event', 'home');
</script>
{% endif %}

{% if search.performed %}
<script type="text/javascript">
  setag('event', 'search', {
    content: {{ search.terms | json }}
  });
</script>
{% endif %}

{% if template.name == 'register' %}
<script type="text/javascript">
  setag('event', 'sign_up');
</script>
{% endif %}

{% if template.name == 'login' %}
<script type="text/javascript">
  setag('event', 'login');
</script>
{% endif %}