<style>
  desktop-navigation {
    position: relative;
  }
  .header-nav-indicator {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: currentColor;
    pointer-events: none;
    opacity: 0;
    transition:
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      width 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.15s ease;
    will-change: transform, width, opacity;
  }

  /* Override mega-menu to fixed positioning below header */
  desktop-navigation .mega-menu {
    position: fixed;
    top: var(--mega-menu-top, 56px);
    left: 0;
    width: 100%;
    border-top: 1px solid #e6e6e6;
  }

  /* Fix overlay height for fixed mega-menu */
  desktop-navigation .mega-menu::after {
    height: calc(100vh - 100%);
  }

  /* Remove original link--animated underline, indicator bar replaces it */
  desktop-navigation .link--animated::after {
    display: none;
  }
</style>

<desktop-navigation class="h-full">
  <ul
    class="header__linklist list--unstyled h-full {% unless bottom_navigation %}hidden-pocket hidden-lap{% endunless %}"
    role="list"
  >
    {%- for link in section.settings.menu.links -%}
      {%- assign link_title_downcase = forloop.index -%}
      {%- assign mega_menu_block = '' -%}

      {%- for block in section.blocks -%}
        {%- assign menu_item_downcase = block.settings.column | abs -%}
        {%- case block.type -%}
          {%- when 'mega_menu' -%}
            {%- if menu_item_downcase == link_title_downcase -%}
              {%- assign mega_menu_block = block -%}
              {%- break -%}
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}

      <li
        class="header__linklist-item h-full text-[14px] md:text-[15px] {% if link.links.size > 0 or mega_menu_block != ''  %}has-dropdown{% endif %}"
        data-item-title="{{ link.title | escape }}"
      >
        {%- if link.links.size > 0 or mega_menu_block != '' -%}
          <div
            class="header__linklist-link header_linklist_item link--animated flex h-full items-center font-bold uppercase"
            {% if link.links.size > 0 or mega_menu_block != '' %}
              aria-controls="desktop-menu-{{ forloop.index }}"
              aria-expanded="false"
            {% endif %}
          >
            {{- link.title -}}
          </div>
        {% else %}
          <a
            class="header__linklist-link header_linklist_item link--animated flex h-full items-center font-bold uppercase"
            href="{{ link.url }}?p=t"
            {% if link.links.size > 0 or mega_menu_block != '' %}
              aria-controls="desktop-menu-{{ forloop.index }}"
              aria-expanded="false"
            {% endif %}
          >
            {{- link.title -}}
          </a>
        {% endif %}

        {%- if mega_menu_block != '' -%}
          <div
            hidden
            id="desktop-menu-{{ forloop.index }}"
            class="mega-menu mega_menu"
            {{ mega_menu_block.shopify_attributes }}
          >
            {% assign product_limit = mega_menu_block.settings.product_limit %}
            <div class="page-container">
              <div
                x-data="{ activeIndex: 0 }"
                class="mega_menu__inner flex gap-40 py-40"
              >
                {% if mega_menu_block.settings.dropdown_style == '2' %}
                  <div class="flex gap-40">
                    <div class="grid w-[45%] grid-cols-2 gap-40">
                      {% for sub_link in link.links %}
                        <div
                          class="flex flex-col gap-24"
                        >
                          <a
                            href="{{ sub_link.url }}?p=t"
                            class="text-[14px]/[1.3] font-bold text-[#515355]"
                          >
                            {{ sub_link.title }}
                          </a>
                          <ul class="grid list-none gap-12 pl-0">
                            {% for sub_sub_link in sub_link.links %}
                              <li>
                                <a
                                  href="{{ sub_sub_link.url }}?p=t"
                                  class="text-[14px]/[1.3]"
                                >
                                  {{ sub_sub_link.title }}
                                </a>
                              </li>
                            {% endfor %}
                          </ul>
                        </div>
                      {% endfor %}
                    </div>
                    {% if mega_menu_block.settings.image_1 != blank or mega_menu_block.settings.image_2 != blank %}
                      <div class="grid w-[55%] grid-cols-2 gap-12">
                        {% for i in (1..2) %}
                          {% assign image_key = 'image_' | append: i %}
                          {% assign link_key = 'link_' | append: i %}
                          {% assign title_key = 'title_' | append: i %}
                          {% assign calculate_key = 'enter_calculate_' | append: i %}

                          {% assign image = mega_menu_block.settings[image_key] %}
                          {% assign link_url = mega_menu_block.settings[link_key] %}
                          {% assign title = mega_menu_block.settings[title_key] %}
                          {% assign calculate = mega_menu_block.settings[calculate_key] %}

                          {% if image != blank %}
                            {% if calculate %}
                              <div class="yb-savings-calculator-btn relative block h-fit overflow-hidden">
                            {% else %}
                              <a
                                class="relative block h-fit overflow-hidden"
                                href="{{ link_url }}"
                              >
                            {% endif %}
                            {% render 'media-element',
                              media_type: 'image',
                              class: 'w-full h-full',
                              media_class: 'w-full h-full object-cover transition duration-500 group-hover:scale-105',
                              pc_image: image,
                              h5_image: block.settings.h5_image
                            %}

                            {% if title != blank %}
                              <div
                                class="
                                  theme-title absolute inset-0 flex items-center justify-between
                                  bg-[linear-gradient(360deg,rgba(0,0,0,0)_0%,rgba(0,0,0,0.5)_90%)]
                                  p-24 text-[32px]/[1.1] font-bold text-white uppercase
                                  md:p-32
                                "
                              >
                                {{ title }}

                                <svg
                                  width="14"
                                  height="14"
                                  viewBox="0 0 14 14"
                                >
                                  <path d="M2.51931 0.758789L12.3743 0.874172M12.3743 0.874172L12.4881 10.589M12.3743 0.874172L1.06055 12.1879"
                                    stroke="white" stroke-width="1.5" stroke-linecap="square"/>
                                </svg>
                              </div>
                            {% endif %}
                            {% if calculate %}
                              </div>
                            {% else %}
                              </a>
                            {% endif %}
                          {% endif %}
                        {% endfor %}
                      </div>
                    {% endif %}
                  </div>
                {% else %}
                  <!-- 左侧（二级菜单） -->
                  <div class="mega_menuLeft flex w-[21.5%] max-w-[280px] flex-col justify-between gap-12">
                    <div>
                      {% for sub_link in link.links %}
                        {% if sub_link.links.size > 0 %}
                          <div
                            @mouseenter="activeIndex = {{ forloop.index0 }}"
                            :class="{ 'bg-[#fff1a5]': activeIndex === {{ forloop.index0 }} }"
                            class="flex cursor-pointer items-center justify-between gap-10 p-12 text-[14px]/[1.3] font-bold"
                          >
                            <a
                              href="{{ sub_link.url }}?p=t"
                              class="flex-1"
                            >
                              {{ sub_link.title }}
                            </a>

                            <svg
                              width="6"
                              height="10"
                              viewBox="0 0 6 10"
                              fill="none"
                              xmlns="http://www.w3.org/2000/svg"
                            >
                              <path d="M0.919597 0.919434L5.00293 5.00277L0.919596 9.0861" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"></path>
                            </svg>
                          </div>
                        {% endif %}
                      {% endfor %}
                      {% if mega_menu_block.settings.image_1 != blank or mega_menu_block.settings.image_2 != blank %}
                        <div class="flex flex-col gap-12 {% if mega_menu_block.settings.enter_line %}pt-24 mt-24 border-t border-[#ccc] {% endif %}">
                          {% for i in (1..2) %}
                            {% assign image_key = 'image_' | append: i %}
                            {% assign link_key = 'link_' | append: i %}
                            {% assign title_key = 'title_' | append: i %}
                            {% assign calculate_key = 'enter_calculate_' | append: i %}

                            {% assign image = mega_menu_block.settings[image_key] %}
                            {% assign link_url = mega_menu_block.settings[link_key] %}
                            {% assign title = mega_menu_block.settings[title_key] %}
                            {% assign calculate = mega_menu_block.settings[calculate_key] %}
                            {% if image != blank %}
                              {% if calculate %}
                                <div
                                  class="yb-savings-calculator-btn relative block h-fit cursor-pointer overflow-hidden 111-{{ calculate }}"
                                >
                              {% else %}
                                <a
                                  class="relative block h-fit overflow-hidden 111-{{ calculate }}"
                                  href="{{ link_url }}"
                                >
                              {% endif %}

                              {% render 'media-element',
                                media_type: 'image',
                                class: 'w-full h-full',
                                media_class: 'w-full h-full object-cover transition duration-500 group-hover:scale-105',
                                pc_image: image,
                                h5_image: block.settings.h5_image
                              %}

                              {% if title != blank %}
                                <div
                                  class="
                                    theme-title absolute inset-0 flex items-center justify-between
                                    bg-[linear-gradient(360deg,rgba(0,0,0,0)_0%,rgba(0,0,0,0.5)_90%)]
                                    p-24 text-[20px]/[1.1] font-bold text-white uppercase
                                    md:p-32
                                  "
                                >
                                  {{ title }}

                                  <svg
                                    width="14"
                                    height="14"
                                    viewBox="0 0 14 14"
                                  >
                                    <path d="M2.51931 0.758789L12.3743 0.874172M12.3743 0.874172L12.4881 10.589M12.3743 0.874172L1.06055 12.1879"
                                      stroke="white" stroke-width="1.5" stroke-linecap="square"/>
                                  </svg>
                                </div>
                              {% endif %}
                              {% if calculate %}
                                </div>
                              {% else %}
                                </a>
                              {% endif %}
                            {% endif %}
                          {% endfor %}
                        </div>
                      {% endif %}
                    </div>
                    {%- if mega_menu_block.settings.view_more != blank -%}
                      <a
                        href="{{ link.url }}?p=t"
                        class="group flex items-center gap-7 text-[14px]/[1.3]"
                      >
                        {{- mega_menu_block.settings.view_more -}}
                        <svg
                          class="transition-transform duration-300 group-hover:translate-x-6"
                          width="9"
                          height="9"
                          viewBox="0 0 9 9"
                          fill="none"
                          xmlns="http://www.w3.org/2000/svg"
                        >
                          <path d="M1.77014 0.657715L7.51885 0.725021M7.51885 0.725021L7.58528 6.39198M7.51885 0.725021L0.919189 7.32468" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"></path>
                        </svg>
                      </a>
                    {%- endif -%}
                  </div>

                  <!-- 右侧（三级菜单） -->
                  <div class="mega_menuRight grid flex-1 gap-24">
                    {% for sub_link in link.links %}
                      {% if sub_link.links.size > 0 %}
                        <div
                          x-show="activeIndex === {{ forloop.index0 }}"
                          x-cloak
                        >
                          <!-- ✅ 有三级 -->
                          <div class="grid gap-24 {% if mega_menu_block.settings.dropdown_style == "1" and sub_link.links.size == 3 %} grid grid-cols-3 grid-rows-2 {%  else %} grid-cols-1  {% endif %}">
                            {% for sub_sub_link in sub_link.links %}
                              <div
                                class="
                                  {% if mega_menu_block.settings.dropdown_style
                                      == "1"
                                  %}
                                    {% case forloop.index %}
                                      {% when 1 %}
                                        col-start-1 col-end-3 row-start-1
                                        row-end-2
                                      {% when 2 %}
                                        col-start-1 col-end-3 row-start-2
                                        row-end-3
                                      {% when 3 %}
                                        col-start-3 col-end-4 row-start-1
                                        row-end-3
                                    {% endcase %}
                                  {% else %}
                                    w-full
                                  {% endif %}
                                "
                              >
                                <div class="mb-8 flex items-center gap-8 text-[15px]">
                                  <span class="font-bold text-[#515355]">
                                    {{ sub_sub_link.title }}
                                  </span>

                                  <a
                                    href="{{ sub_sub_link.url }}?p=t"
                                    class="group flex items-center gap-7"
                                  >
                                    {{ 'button.view_all' | t }}
                                    <svg
                                      class="transition-transform duration-300 group-hover:translate-x-6"
                                      width="9"
                                      height="9"
                                      viewBox="0 0 9 9"
                                      fill="none"
                                      xmlns="http://www.w3.org/2000/svg"
                                    >
                                      <path d="M1.77014 0.657715L7.51885 0.725021M7.51885 0.725021L7.58528 6.39198M7.51885 0.725021L0.919189 7.32468" stroke="#25282A" stroke-width="1.3" stroke-linecap="square"></path>
                                    </svg>
                                  </a>
                                </div>
                                {% if sub_sub_link.url contains '/collections/' %}
                                  {% assign handle = sub_sub_link.url
                                    | split: '/collections/'
                                    | last
                                    | split: '/'
                                    | first
                                  %}

                                  {% assign collection = collections[handle] %}
                                  {% if collection and collection.products_count > 0 %}
                                    {% if mega_menu_block.settings.dropdown_style == '1' %}
                                      {% if forloop.index == 3 %}
                                        <div class="mt-12 flex flex-col gap-12">
                                          {% for product in collection.products limit: product_limit %}
                                            <a
                                              href="{{ product.url }}"
                                              class="group flex  items-center gap-12 bg-[#f2f2f2] p-8"
                                            >
                                              {% render 'media-element',
                                                media_type: 'image',
                                                class: 'max-w-120 aspect-[1] flex h-fit flex mx-auto relative',
                                                media_class: 'w-full h-auto object-cover',
                                                pc_image: product.featured_image
                                              %}

                                              <div class="flex flex-col gap-8">
                                                {%- if product.metafields.custom.tag != blank -%}
                                                  <div class="flex h-22 w-fit items-center justify-center px-12 py-3 text-[12px] leading-[1.3] font-bold {% if card_product.metafields.custom.tag_style %} bg-[#FEDB1E] text-[#25282a] {% else %} bg-[#25282a] text-white {% endif %}">
                                                    {{ product.metafields.custom.tag }}
                                                  </div>
                                                {%- endif -%}
                                                <div class=" theme-title line-clamp-3 text-[16px]/[1.1] font-bold text-black uppercase">
                                                  {{ product.title }}
                                                </div>
                                              </div>
                                            </a>
                                          {% endfor %}
                                        </div>
                                      {% else -%}
                                        <div class="mt-12 grid  gap-12  grid-cols-{{ product_limit }}">
                                          {% for product in collection.products limit: product_limit %}
                                            <a
                                              href="{{ product.url }}"
                                              class="group flex flex-col gap-8 bg-[#f2f2f2] px-8 py-20"
                                            >
                                              {% render 'media-element',
                                                media_type: 'image',
                                                class: 'max-w-120 flex aspect-[1] h-fit flex mx-auto relative',
                                                media_class: 'w-full h-auto object-cover',
                                                pc_image: product.featured_image
                                              %}

                                              <div class=" theme-title line-clamp-3 text-center text-[16px]/[1.1] font-bold text-black uppercase">
                                                <span class="text-[#ddba00]">
                                                  {{- product.metafields.custom.nav_tag -}}
                                                </span>
                                                {{ product.title }}
                                              </div>
                                            </a>
                                          {% endfor %}
                                        </div>
                                      {% endif -%}
                                    {% endif %}
                                  {% endif -%}
                                {% endif %}
                              </div>
                            {% endfor %}
                          </div>
                        </div>
                      {% else %}
                        <div>
                          <!-- ✅ 没有三级 → 展示二级 -->
                          <div class="mb-8 flex items-center gap-8 text-[15px]">
                            <span class="font-bold text-[#515355]">
                              {{ sub_link.title }}
                            </span>
                            <a
                              href="{{ sub_link.url }}?p=t"
                              class="group flex items-center gap-7"
                            >
                              {{ 'button.view_all' | t }}
                              <svg
                                class="transition-transform duration-300 group-hover:translate-x-6"
                                width="9"
                                height="9"
                                viewBox="0 0 9 9"
                              >
                                <path d="M1.77014 0.657715L7.51885 0.725021M7.51885 0.725021L7.58528 6.39198M7.51885 0.725021L0.919189 7.32468"
                                  stroke="#25282A" stroke-width="1.3"/>
                              </svg>
                            </a>
                          </div>
                          {% if sub_link.url contains '/collections/' %}
                            {% assign handle = sub_link.url | split: '/collections/' | last | split: '/' | first %}

                            {% assign collection = collections[handle] %}
                            {% if collection and collection.products_count > 0 %}
                              <div class="mt-12 grid grid-cols-{{ product_limit }} gap-12">
                                {% for product in collection.products limit: product_limit %}
                                  <a
                                    href="{{ product.url }}"
                                    class="group flex flex-col gap-8 bg-[#f2f2f2] px-8 py-20"
                                  >
                                    {% render 'media-element',
                                      media_type: 'image',
                                      class: 'max-w-120 aspect-[1] flex h-fit flex mx-auto relative ',
                                      media_class: 'w-full h-auto object-cover',
                                      pc_image: product.featured_image
                                    %}

                                    <div class=" theme-title line-clamp-3 text-center text-[16px]/[1.1] font-bold text-black uppercase">
                                      <span class="text-[#ddba00]">
                                        {{- product.metafields.custom.nav_tag -}}
                                      </span>
                                      {{ product.title }}
                                    </div>
                                  </a>
                                {% endfor %}
                              </div>
                            {% endif %}
                          {% endif %}
                        </div>
                      {% endif %}
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {%- elsif link.links.size > 0 -%}
          <ul
            hidden
            id="desktop-menu-{{ forloop.index }}"
            class="nav-dropdown flex flex-col gap-12 p-24 font-medium {% if link.levels == 1 %}nav-dropdown--restrict{% endif %} list--unstyled"
            role="list"
          >
            {%- for sub_link in link.links -%}
              <li class="nav-dropdown__item {% if sub_link.links.size > 0 %}has-dropdown{% endif %}">
                <a
                  class="nav-dropdown__link link--faded"
                  href="{{ sub_link.url }}?p=t"
                  {% if sub_link.links.size > 0 %}
                    aria-controls="desktop-menu-{{ forloop.parentloop.index }}-{{ forloop.index }}"
                    aria-expanded="false"
                  {% endif %}
                >
                  {{- sub_link.title -}}

                  {%- if sub_link.links.size > 0 -%}
                    {% comment %}
                      {% render 'icon' with 'dropdown-arrow-right',
                        direction_aware: true
                      %}
                      >
                    {% endcomment %}
                  {%- endif -%}
                </a>

                {%- if sub_link.links.size > 0 -%}
                  <ul
                    hidden
                    id="desktop-menu-{{ forloop.parentloop.index }}-{{ forloop.index }}"
                    class="nav-dropdown list--unstyled p-24"
                    role="list"
                  >
                    {%- for sub_sub_link in sub_link.links -%}
                      <li class="nav-dropdown__item">
                        <a
                          class="nav-dropdown__link link--faded"
                          href="{{ sub_sub_link.url }}"
                        >
                          {{- sub_sub_link.title -}}
                        </a>
                      </li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </li>
    {%- endfor -%}

    {% if section.settings.show_live %}
      <li class="direct_seeding_img header__linklist-item mobile-nav__link">
        <a href="{{ section.settings.live_link }}">
          <span class="relative flex [&_path]:fill-[#fedb1e]!">
            <svg
              width="25"
              height="25"
              viewBox="0 0 25 25"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
            >
              <g clip-path="url(#clip0_13456_21043)">
              <circle cx="16.5" cy="7" r="1.5" fill="#FAFAFA"/>
              <path d="M22.8559 8.32707L20.4205 9.6224V6.34357C20.4205 5.19874 19.3153 4.27002 17.953 4.27002H2.4665C1.10415 4.27002 -0.00104523 5.19874 -0.00104523 6.34357V19.1965C-0.00104523 20.3413 1.10415 21.27 2.4665 21.27H17.953C19.3153 21.27 20.4205 20.3413 20.4205 19.1965V15.8302L22.8222 17.1937C23.7483 17.7198 24.999 17.1615 24.999 16.2225V9.31754C24.9974 8.39396 23.7851 7.83312 22.8559 8.32707ZM14.5103 13.7566L8.89713 16.7409C8.06594 17.1821 6.98371 16.6804 6.98371 15.8546V9.68414C6.98371 8.84417 8.10115 8.34508 8.92928 8.81587L14.5425 12.0021C15.288 12.4253 15.2711 13.3527 14.5103 13.7566ZM16.5416 8.31807C15.8268 8.31807 15.2466 7.83055 15.2466 7.22984C15.2466 6.62913 15.8268 6.14161 16.5416 6.14161C17.2565 6.14161 17.8366 6.62913 17.8366 7.22984C17.8366 7.83055 17.2565 8.31807 16.5416 8.31807Z" fill="#FF3045"/>
              <path d="M20.7716 9.6224V6.34357C20.7716 5.19874 19.6473 4.27002 18.263 4.27002H2.50756C1.12167 4.27002 -0.00104523 5.19874 -0.00104523 6.34357V19.1965C-0.00104523 20.3413 1.12323 21.27 2.50756 21.27H11.8537C16.8491 18.8157 20.359 14.5143 20.999 9.50405L20.7716 9.6224Z" fill="#FF4653"/>
              <path d="M-0.00104523 6.21821V17.27C2.56758 16.9786 4.96704 16.2844 7.08868 15.271C9.86744 14.1169 11.5186 12.4275 13.1137 10.6805C14.7092 8.75025 15.6977 6.55393 15.999 4.27002H2.49929C1.11953 4.27002 -0.00104523 5.14193 -0.00104523 6.21821Z" fill="#FF5C64"/>
              <path d="M-0.00104523 6.28737V11.27C3.88255 9.87127 7.0692 7.38433 8.99895 4.27002H2.42394C1.08576 4.27002 -0.00104523 5.17288 -0.00104523 6.28737Z" fill="#FF716E"/>
              </g>
              <defs>
              <clipPath id="clip0_13456_21043">
              <rect width="25" height="25" fill="white"/>
              </clipPath>
              </defs>
            </svg>
            <i class="Header_linePart__1tpw_ Header_line_1__TNAKB"></i>
            <i class="Header_linePart__1tpw_ Header_line_2___ZHFt"></i>
            <i class="Header_linePart__1tpw_ Header_line_3__5T_j9"></i>
          </span>
        </a>
      </li>
    {% endif %}
  </ul>
  <span
    class="header-nav-indicator"
    aria-hidden="true"
  ></span>
</desktop-navigation>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.querySelector('desktop-navigation');
    if (!nav) return;

    const indicator = nav.querySelector('.header-nav-indicator');
    if (!indicator) return;

    /* ===== Dynamic mega-menu top position ===== */
    const headerEl = document.querySelector('store-header');

    function updateMegaMenuTop() {
      if (!headerEl) return;
      const headerBottom = headerEl.getBoundingClientRect().bottom;
      nav.style.setProperty('--mega-menu-top', headerBottom + 'px');
    }

    // Update on scroll & resize (header is sticky, position changes)
    updateMegaMenuTop();
    window.addEventListener('scroll', updateMegaMenuTop, { passive: true });
    window.addEventListener('resize', updateMegaMenuTop, { passive: true });

    /* ===== Sliding indicator bar ===== */
    const menuItems = nav.querySelectorAll('.header__linklist > .header__linklist-item');

    menuItems.forEach((item) => {
      item.addEventListener('mouseenter', () => {
        updateMegaMenuTop();

        const textEl = item.querySelector('.header__linklist-link');
        if (!textEl) return;

        const navRect = nav.getBoundingClientRect();
        const textRect = textEl.getBoundingClientRect();

        const x = textRect.left - navRect.left;

        // Read the indicator's actual current opacity instead of using a
        // boolean "isFirstMove" flag. The boolean flag gets reset on
        // mouseleave immediately, but the fade-out transition still takes
        // 0.15s — if the user re-enters another item during that window,
        // the flag says "first move" and we'd snap the still-visible
        // indicator (transition:none) to a new position, producing the
        // visible white-bar flash when moving quickly.
        const currentOpacity = parseFloat(getComputedStyle(indicator).opacity) || 0;

        if (currentOpacity < 0.01) {
          // Indicator is effectively hidden — snap to target without
          // animation, then fade in. Synchronous reflow (void offsetWidth)
          // flushes transition:none before we re-enable transitions, so no
          // rAF race can sneak in another mouseenter while transition is
          // still 'none'.
          indicator.style.transition = 'none';
          indicator.style.transform = `translateX(${x}px)`;
          indicator.style.width = textRect.width + 'px';
          void indicator.offsetWidth;
          indicator.style.transition = '';
          indicator.style.opacity = '1';
        } else {
          // Indicator is visible (including mid fade-out) — keep smooth
          // transition so it slides to the new item without flashing.
          indicator.style.transition = '';
          indicator.style.transform = `translateX(${x}px)`;
          indicator.style.width = textRect.width + 'px';
          indicator.style.opacity = '1';
        }
      });
    });

    nav.addEventListener('mouseleave', () => {
      indicator.style.transition = '';
      indicator.style.opacity = '0';
    });
  });
</script>
