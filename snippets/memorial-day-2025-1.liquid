  <script>
      function copyActivityCouponCode(blockId) {
        const couponCode = document.getElementById('couponCode-' + blockId).innerText;
        const copyButton = document.querySelector(`button[onclick="copyActivityCouponCode('${blockId}')"]`);
        const icon = copyButton.querySelector('i');
  
        navigator.clipboard.writeText(couponCode).then(
          () => {
            icon.classList.remove('icon-copy');
            icon.classList.add('icon-true');
          },
          () => {
            console.log('Copy Fail!');
          }
        );
      }
      document.addEventListener('DOMContentLoaded', function () {
        // 图片翻转效果
        const flipCards = document.querySelectorAll('.flip-card');
        const cardTimers = new Map(); // 存储每个卡片的定时器
  
        // 重置卡片状态的函数
        function resetCard(card) {
          card.classList.remove('flipped');
          const copyButton = card.querySelector('.copy');
          if (copyButton) {
            const icon = copyButton.querySelector('i');
            icon.classList.remove('icon-true');
            icon.classList.add('icon-copy');
          }
          // 清除该卡片的定时器
          if (cardTimers.has(card)) {
            clearTimeout(cardTimers.get(card));
            cardTimers.delete(card);
          }
        }
  
        // 关闭所有其他卡片
        function closeOtherCards(currentCard) {
          flipCards.forEach((card) => {
            if (card !== currentCard && card.classList.contains('flipped')) {
              resetCard(card);
            }
          });
        }
  
        flipCards.forEach((card) => {
          // 检查卡片正面是否有图片
          const frontImages = card.querySelectorAll(
            '.flip-card-front .my-new-module__item-image, .flip-card-front .my-new-module__item-image-mobile'
          );
          const hasFrontImage = Array.from(frontImages).some((img) => {
            const imgElement = img.querySelector('img');
            return imgElement && imgElement.src && imgElement.src.trim() !== '';
          });
  
          // 如果没有正面图片，直接显示背面，不启用翻转功能
          if (!hasFrontImage) {
            card.classList.add('flipped', 'no-flip');
            return; // 跳过后续的点击事件绑定
          }
  
          // 有图片的卡片才启用翻转功能
          // 阻止复制按钮和加购按钮的点击事件冒泡
          const copyButtons = card.querySelectorAll('.copy');
          const addToCartButtons = card.querySelectorAll('add-to-cart');
  
          copyButtons.forEach((button) => {
            button.addEventListener('click', function (e) {
              e.stopPropagation();
            });
          });
  
          addToCartButtons.forEach((button) => {
            button.addEventListener('click', function (e) {
              e.stopPropagation();
            });
          });
  
          card.addEventListener('click', function () {
            if (this.classList.contains('flipped')) {
              // 如果已经翻转，则翻转回去
              resetCard(this);
            } else {
              // 关闭其他已翻转的卡片
              closeOtherCards(this);
  
              // 翻转当前卡片
              this.classList.add('flipped');
  
              // 设置12秒后自动翻转回去
              const timer = setTimeout(() => {
                resetCard(this);
              }, 12000);
  
              // 保存定时器引用
              cardTimers.set(this, timer);
            }
          });
        });
      });
    </script>
