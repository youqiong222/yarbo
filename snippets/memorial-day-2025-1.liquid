      // 锚点点击事件处理
      function initAnchorLinks() {
        document
          .querySelectorAll('#yb-banner-swiper__1747645463518bf6c3bb .yb-banner-swiper-anchor-link')
          .forEach((link) => {
            link.addEventListener('click', function (e) {
              e.preventDefault();
              const anchorId = this.getAttribute('data-anchor-id');
              if (!anchorId) return;
  
              const anchorElement = document.getElementById(`shopify-section-${anchorId}`);
              if (anchorElement) {
                window.scrollTo({
                  top: anchorElement.offsetTop - 120,
                  behavior: 'smooth',
                });
              } else {
                console.warn(`[yb-banner-swiper] 未找到对应的锚点元素: shopify-section-${anchorId}`);
              }
            });
          });
      }
  
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAnchorLinks);
      } else {
        initAnchorLinks();
