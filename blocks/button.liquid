      "default": "#25282A"
    },
    {
      "type": "color",
      "id": "hover_bg_color",
      "label": "Hover Background Color",
      "default": "#FEDB1E"
    },
    {
      "type": "color",
      "id": "hover_border_color",
      "label": "Hover Border Color",
      "default": "#FEDB1E"
    },
    {
      "type": "header",
      "content": "Spacing (PC)"
    },
    {
      "type": "range",
      "id": "pt_pc",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "pb_pc",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "pl_pc",
      "label": "Padding Left",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "pr_pc",
      "label": "Padding Right",
      "min": 0,
      "max": 120,
      "step": 2,
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing (Mobile)"
    },
    {
      "type": "range",
      "id": "pt_h5",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "pb_h5",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "pl_h5",
      "label": "Padding Left",
      "min": 0,
      "max": 100,
      "step": 2,
      "default": 0
    },
    {
      "type": "range",
      "id": "pr_h5",
